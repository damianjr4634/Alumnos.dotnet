@using Esba.Application.Abstractions
@using Esba.Application.DTOs.Carreras
@inject ICarrerasQuery CarrerasQuery

@* Menú por carrera: sucesor de Carreras.pas / dxNavBar de FrmEsba, generado
   desde la tabla CARRERA y filtrado por los permisos BARRA_SEGU del usuario
   (la UI oculta, el servidor deniega — migration_improvements.md §3.2). *@

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Inicio</MudNavLink>

    @foreach (var grupo in _carreras.GroupBy(c => c.Grupo))
    {
        @* TODO-migrar CARRE_GRP: mostrar la descripción del grupo, no el código. *@
        <MudNavGroup Title="@grupo.Key" Expanded="false" Icon="@Icons.Material.Filled.School">
            @foreach (var carrera in grupo)
            {
                <MudNavLink Href="@($"/alumnos/{carrera.Codigo}")">
                    @(string.IsNullOrWhiteSpace(carrera.NombreCorto) ? carrera.Nombre : carrera.NombreCorto)
                </MudNavLink>
            }
        </MudNavGroup>
    }
</MudNavMenu>

@code {
    private IReadOnlyList<CarreraListItemDto> _carreras = [];

    [CascadingParameter]
    private Task<AuthenticationState>? EstadoAutenticacion { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (EstadoAutenticacion is null)
        {
            return;
        }

        var usuario = (await EstadoAutenticacion).User;
        if (usuario.Identity?.IsAuthenticated != true)
        {
            return;
        }

        var permisos = usuario.EsSupervisor() ? null : usuario.Permisos();
        _carreras = await CarrerasQuery.ListarParaMenuAsync(permisos, CancellationToken.None);
    }
}
