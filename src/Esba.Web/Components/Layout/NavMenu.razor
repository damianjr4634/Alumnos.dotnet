@* Menú general por área funcional (espejo de Application/Features), sucesor
   del "Main Menu" dxBar de FrmEsba. El diseño por carrera fue descartado en el
   propio legacy: con muchas carreras era molesto buscarlas una por una. La
   carrera se elige al entrar a cada opción que la necesite (decisión
   2026-06-12, ver migration_improvements.md §3.2).
   Las opciones se habilitan a medida que se migran sus pantallas. *@

<MudNavMenu Rounded="true" Color="Color.Primary" Margin="Margin.Dense" Class="pa-2">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Search">Búsqueda de alumnos</MudNavLink>

    <MudDivider Class="my-2" />

    <MudNavGroup Title="Alumnos" Icon="@Icons.Material.Filled.People" Expanded="false">
        <MudNavLink Disabled="true">Inscripción de materias</MudNavLink>
        <MudNavLink Disabled="true">Regularización</MudNavLink>
        <MudNavLink Disabled="true">Permisos de exámenes</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Académica" Icon="@Icons.Material.Filled.MenuBook" Expanded="false">
        <MudNavLink Disabled="true">Materias</MudNavLink>
        <MudNavLink Disabled="true">Comisiones</MudNavLink>
        <MudNavLink Disabled="true">Cuatrimestres</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Asistencias" Icon="@Icons.Material.Filled.EventAvailable" Expanded="false">
        <MudNavLink Disabled="true">Carga de inasistencias</MudNavLink>
        <MudNavLink Disabled="true">Planillas de asistencia</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Exámenes" Icon="@Icons.Material.Filled.Grading" Expanded="false">
        <MudNavLink Disabled="true">Mesas de exámenes</MudNavLink>
        <MudNavLink Disabled="true">Notas de finales</MudNavLink>
        <MudNavLink Disabled="true">Actas</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Certificados" Icon="@Icons.Material.Filled.Description" Expanded="false">
        <MudNavLink Disabled="true">Constancias</MudNavLink>
        <MudNavLink Disabled="true">Equivalencias</MudNavLink>
    </MudNavGroup>

    <MudNavGroup Title="Administración" Icon="@Icons.Material.Filled.Settings" Expanded="false">
        <MudNavLink Disabled="true">Usuarios</MudNavLink>
        <MudNavLink Disabled="true">Profesores</MudNavLink>
        <MudNavLink Disabled="true">Configuración</MudNavLink>
    </MudNavGroup>
</MudNavMenu>
