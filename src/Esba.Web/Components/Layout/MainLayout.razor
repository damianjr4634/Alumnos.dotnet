@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="AlternarDrawer" aria-label="Abrir menú" />
        <MudText Typo="Typo.h6" Class="ml-2">ESBA — Gestión Académica</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-4">@context.User.FindFirst(EsbaClaims.NombreCompleto)?.Value</MudText>
                <form method="post" action="/auth/logout">
                    <AntiforgeryToken />
                    <MudButton ButtonType="ButtonType.Submit" Color="Color.Inherit" Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.Logout">Salir</MudButton>
                </form>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerAbierto" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerAbierto = true;

    private void AlternarDrawer() => _drawerAbierto = !_drawerAbierto;
}
