@page "/Error"
@attribute [AllowAnonymous]
@layout LoginLayout

<PageTitle>ESBA — Error</PageTitle>

@* Error genérico sin stack trace al usuario (migration_improvements.md §2.5). *@

<MudPaper Elevation="3" Class="pa-8 mx-auto" Style="width: 100%; max-width: 480px;">
    <MudText Typo="Typo.h5" Class="mb-2">Ocurrió un error</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary">
        Se produjo un error al procesar la solicitud. Si el problema persiste,
        comunicate con el administrador del sistema.
    </MudText>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6">Volver al inicio</MudButton>
</MudPaper>
