@using Esba.Application.DTOs.Academica
@using Esba.Application.Features.Academica
@using Esba.Domain.Common
@inject InscribirEnMateriaHandler Inscribir
@inject ModificarInscripcionHandler Modificar
@inject ISnackbar Snackbar

@* Alta/modificación de una inscripción (sucesor del panel inferior de
   InscripcionDeMaterias.pas). En modificación la materia no se cambia:
   se elimina la inscripción y se crea otra. *@

<MudDialog>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
        }
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudSelect T="string" @bind-Value="_codigoMateria" Label="Materia" Required="true"
                           Disabled="@EsModificacion" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var materia in Materias)
                    {
                        <MudSelectItem Value="@materia.Codigo">
                            @($"{materia.Codigo} — {materia.Nombre} (cuat. {materia.Cuatrimestre})")
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudNumericField T="int" @bind-Value="_turno" Label="Turno" Min="0" Max="9"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudNumericField T="int" @bind-Value="_comision" Label="Comisión" Min="0" Max="9"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect T="string" @bind-Value="_cuatrimestre" Label="Cuatrimestre"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("1")">1º</MudSelectItem>
                    <MudSelectItem Value="@("2")">2º</MudSelectItem>
                    <MudSelectItem Value="@("3")">3º</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudNumericField T="int" @bind-Value="_anio" Label="Año (2 díg.)" Min="0" Max="99"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="string" @bind-Value="_condicion" Label="Condición" Required="true"
                           RequiredError="Complete una condición." Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem Value="@("CURSANDO")">CURSANDO</MudSelectItem>
                    <MudSelectItem Value="@("P/EQUIVALEN")">P/EQUIVALEN</MudSelectItem>
                    <MudSelectItem Value="@("RECURSANDO")">RECURSANDO</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog?.Cancel())">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@_guardando" OnClick="Guardar">
            @(EsModificacion ? "Guardar cambios" : "Inscribir")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? EstadoAutenticacion { get; set; }

    [Parameter] public string Carre { get; set; } = string.Empty;

    [Parameter] public string CodigoAlumno { get; set; } = string.Empty;

    [Parameter] public IReadOnlyList<MateriaListItemDto> Materias { get; set; } = [];

    /// <summary>CUA_ANIO por defecto ("124"), del wrapper de XXX_NUMCUATANIO.</summary>
    [Parameter] public string? CuatrimestreAnioDefault { get; set; }

    [Parameter] public CursadaListItemDto? InscripcionAEditar { get; set; }

    private bool EsModificacion => InscripcionAEditar is not null;

    private string? _codigoMateria;
    private int _turno;
    private int _comision;
    private string _cuatrimestre = "1";
    private int _anio;
    private string? _condicion;
    private bool _guardando;
    private string? _error;

    protected override void OnParametersSet()
    {
        if (InscripcionAEditar is { } edicion)
        {
            _codigoMateria = edicion.CodigoMateria;
            _turno = edicion.Cutuco is { } cutuco ? (cutuco / 10) % 10 : 0;
            _comision = edicion.Cutuco is { } c ? c % 10 : 0;
            _condicion = edicion.Condicion.Trim();
            AplicarCuaAnio(edicion.CuatrimestreAnio);
        }
        else
        {
            AplicarCuaAnio(CuatrimestreAnioDefault);
        }
    }

    private void AplicarCuaAnio(string? cuaAnio)
    {
        if (cuaAnio is { Length: 3 })
        {
            _cuatrimestre = cuaAnio[..1];
            _anio = int.TryParse(cuaAnio[1..], out var anio) ? anio : 0;
        }
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(_codigoMateria) || string.IsNullOrWhiteSpace(_condicion))
        {
            _error = "Seleccione la materia y la condición.";
            return;
        }

        _guardando = true;
        _error = null;
        try
        {
            var usuario = (await EstadoAutenticacion!).User.Identity?.Name ?? "desconocido";
            var cuaAnio = $"{_cuatrimestre}{_anio:00}";

            Result<string> resultado = EsModificacion
                ? await Modificar.HandleAsync(new ModificarInscripcionCommand
                {
                    CodigoCarrera = Carre,
                    CodigoAlumno = CodigoAlumno,
                    CodigoMateria = _codigoMateria,
                    Turno = _turno,
                    NumeroComision = _comision,
                    CuatrimestreAnio = cuaAnio,
                    Condicion = _condicion,
                }, usuario, CancellationToken.None)
                : await Inscribir.HandleAsync(new InscribirEnMateriaCommand
                {
                    CodigoCarrera = Carre,
                    CodigoAlumno = CodigoAlumno,
                    CodigoMateria = _codigoMateria,
                    Turno = _turno,
                    NumeroComision = _comision,
                    CuatrimestreAnio = cuaAnio,
                    Condicion = _condicion,
                }, usuario, CancellationToken.None);

            if (resultado.IsSuccess)
            {
                Snackbar.Add(EsModificacion ? "Inscripción modificada." : "Alumno inscripto.", MudBlazor.Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _error = resultado.Message;
            }
        }
        finally
        {
            _guardando = false;
        }
    }
}
