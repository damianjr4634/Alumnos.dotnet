{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Esba.Web (http)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/Esba.Web/bin/Debug/net10.0/Esba.Web.dll",
            "cwd": "${workspaceFolder}/src/Esba.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5164"
            }
        },
        {
            "name": "Esba.Web (adjuntar a proceso)",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
