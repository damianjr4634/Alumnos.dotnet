procedure TAMAnalitico.EliminaClick(Sender: TObject);
begin
  if MessageDlg(Pchar(Vnombreusuario+', esta seguro de borrar el registro del analitico?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
     Begin
        With CustomerData Do
         Begin
           if TrDlVarios.Active then
               TRDlVarios.Rollback;
           TRDlVarios.Active:=False;
           IbDlVarios.Close;
           IBDlVarios.SQL.Clear;
           IbDlVarios.SQL.Text:='DELETE FROM ANALITIC WHERE COD_ALU=:CODALU AND COD_MAT=:CODMAT AND CARRE=:CARRE;';
           IBDlVarios.ParamByName('CODALU').Value:=VCodAlu;
           IBDlVarios.ParamByName('CODMAT').Value:=IBAnalitico.FieldByName('COD_MAT').Value;
           IBDlVarios.ParamByName('CARRE').Value:=VCarrera;
           TrDlVarios.Active:=True;
           IBDlVarios.ExecQuery;
           TRDlVarios.Commit;
           CustomerData.TrAnalitico.Active:=False;
           CustomerData.IbAnalitico.Active:=False;
           CustomerData.IbAnalitico.ParamByName('CODALU').Value:=Vcodalu;
           CustomerData.IbAnalitico.ParamByName('CARRE').Value:=VCarrera;
           CustomerData.IbAnalitico.Active:=True;
           CustomerData.Tranalitico.Active:=True;
         End
     End;
end;

procedure TAMAnalitico.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
  CustomerData.TrAnalitico.Rollback;
  CustomerData.TrAnalitico.Active:=False;
  CustomerData.IbAnalitico.Active:=False;
end;

procedure TAMAnalitico.ComboMateriasButtonClick(Sender: TObject);
Var b:Variant;
begin
  FuncionesDB.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS M WHERE M.CODCARRE='''+VCARRERA+''' AND M.ESTADO<>''B'' '+
                          ' AND NOT EXISTS(SELECT 1 FROM CURSADA C WHERE C.CARRE=M.CODCARRE AND C.COD_MAT=M.CODMATERI AND C.COD_ALU='''+Vcodalu+''') '+
                          ' ORDER BY CODMATERI',['Codigo','Nombre'],b,True);
  ComboMaterias.Text:=b[0];
  NombreMateria.Caption:=b[1];
end;

procedure TAMAnalitico.ComboMateriasExit(Sender: TObject);
Var b:Variant;
begin
  if (ComboMaterias.Text<>'') Then Begin
      ComBoMaterias.Text:=Lpad(ComboMaterias.Text,2,'0');
      FuncionesDB.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS M WHERE M.CODMATERI='''+ComboMaterias.Text+''' AND M.CODCARRE='''+VCARRERA+''' AND M.ESTADO<>''B'' '+
                              ' AND NOT EXISTS(SELECT 1 FROM CURSADA C WHERE C.CARRE=M.CODCARRE AND C.COD_MAT=M.CODMATERI AND C.COD_ALU='''+Vcodalu+''') '+
                              ' ORDER BY CODMATERI' ,['Codigo','Nombre'],b,False);
      If (vartostr(b[0])='') then begin
         MessageDlg('C鏚igo incorrecto',mtError,[mbok],0,mbok);
         ComboMaterias.SetFocus;
      end
      else if not (Modificacion) then begin
          With DataModule.CustomerData do
             Begin
              If TrQrVarios.Active Then
                 TRQrVarios.Rollback;
              TrQrVarios.Active:=False;
              IbQrVarios.SQL.Clear;
              IBQrVarios.SQL.Text:='SELECT FERRCOD, FERRMSG FROM XXX_INSC_VALMAT(:CODALU,:CARRE,:CODMAT,''A'');';
              IBQrVarios.ParamByName('CODALU').AsString:=VCODALU;
              IBQrVarios.ParamByName('CARRE').AsString:=VCarrera;
              IBQrVarios.ParamByName('CODMAT').AsString:=b[0];
              TrQrVarios.Active:=True;
              IBQrVarios.ExecQuery;
              If (IBQrVarios.FieldByName('FERRCOD').AsInteger=2) Then
                Begin
                 MessageDlg(PChar(VNombreUsuario + ', '+IBQrVarios.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
                 ComboMaterias.SetFocus;
                End
              Else
                Begin
                 Cuaanio.SetFocus;
                End;
              TRQrVarios.Rollback;
              TrQrVarios.Active:=False;
            End;
      end;
   ComboMaterias.Text:=b[0];
   NombreMateria.Caption:=b[1];
  end
end;

procedure TAMAnalitico.CmbPlanesButtonClick(Sender: TObject);
Var b:Variant;
begin
  FuncionesDB.combobusqueda('SELECT FCODIGO, FDESCRI FROM TBLPLANES',['Codigo','Nombre'],b,True);
  CmbPlanes.Text:=b[1];
end;

end.
