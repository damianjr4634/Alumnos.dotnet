procedure TAMAnalitico.GrabaClick(Sender: TObject);
begin
 if MessageDlg(Pchar(Vnombreusuario+', esta seguro de grabar la informaci鏮?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
  Begin
      If Modificacion Then
        Begin
          With CustomerData Do
            Begin
              iF (TRUpVarios.Active) then
                  TrUpVarios.Rollback;
              TrUpVarios.Active:=False;
              IbUpVarios.SQL.Clear;
              IbUpVarios.SQL.Text:='UPDATE ANALITIC A SET A.COD_MAT=:CODMAT, A.A_C=:AC, A.ACTDGE=:ACTDGE, A.ACTINT=:ACTINT, '+
                                   'A.ACTSNE=:ACTSNE, A.CARAC=:CARAC,A.COLEGIO=:COLEGIO, A.CONDICION=:CONDICION, '+
                                   'A.CUA_ANIO=:CUAANIO, A.FEC_FINAL=:FECFINAL,A.INSTITUT=:INSTITUT, A.NOTA_MAT=:NOTAMAT, '+
                                   'A.NREG=:NREG,A."PLAN"=:PLAN1, A.USUARIO=:USUARIO, FACTFIN=:FACTFIN, FEXDESCRI=:FEXDESCRI '+
                                   'WHERE A.COD_ALU=:CODALU AND A.CARRE=:CARRE AND A.COD_MAT=:W_CODMAT;';
              IbUpVarios.ParamByName('CODMAT').Value:=combomaterias.text;
              if Constanciacheck.Checked Then
                 IbUpVarios.ParamByName('AC').Value:='C';
              if analiticocheck.Checked Then
                 IbUpVarios.ParamByName('AC').Value:='A';
              IbUpVarios.ParamByName('ACTDGE').Value:=Actdgegp.Text;
              IbUpVarios.ParamByName('ACTINT').Value:=Actinterna.Text;
              IbUpVarios.ParamByName('CARAC').Value:=Caracteristica.Text;
              IbUpVarios.ParamByName('COLEGIO').Value:=Colegio.Text;
              IbUpVarios.ParamByName('CONDICION').Value:=ComboCondicion.Text;
              IbUpVarios.ParamByName('CUAANIO').Value:=Cuaanio.Text;
              IbUpVarios.ParamByName('FECFINAL').Value:=Fecha.Date;
              IbUpVarios.ParamByName('INSTITUT').Value:=Instituto.Text;
              IbUpVarios.ParamByName('NOTAMAT').Value:=Nota.Text;
              IbUpVarios.ParamByName('PLAN1').Value:=Cmbplanes.Text;
              IbUpVarios.ParamByName('USUARIO').Value:=funcionesConfiguracion.CodUsu;
              IbUpVarios.ParamByName('CODALU').Value:=VcodAlu;
              IbUpVarios.ParamByName('CARRE').Value:=VCarrera;
              IbUpVarios.ParamByName('FACTFIN').Value:=TxtLibroActa.Text;
              IbUpVarios.ParamByName('FEXDESCRI').Value:= TxtFEXDESCRI.Text;
              IbUpVarios.ParamByName('W_CODMAT').Value:=IBAnalitico.fieldByName('Cod_mat').Value;
            End
        End
      Else
        begin
           With CustomerData Do
            Begin
              If (trupvarios.Active) then
                  TrUpVarios.Rollback;
              TrUpVarios.Active:=False;
              IbUpVarios.SQL.Clear;
              IbUpVarios.SQL.Text:='INSERT INTO ANALITIC (COD_ALU, APELLIDO, COD_MAT, CUA_ANIO, NOTA_MAT, FEC_FINAL, MATRIZ, CONDICION, INSTITUT, '+
                                   'CARAC, ACTINT, ACTDGE, ACTSNE, CARRE, COLEGIO, "PLAN", A_C, NREG, USUARIO, FACTFIN, FEXDESCRI) '+
                                   'VALUES (:CODALU, :APELLIDO, :CODMAT, :CUAANIO, :NOTAMAT, :FECFINAL, :MATRIZ, :CONDICION, :INSTITUT, '+
                                   ':CARAC, :ACTINT, :ACTDGE, :ACTSNE, :CARRE, :COLEGIO, :PLAN1, :A_C, :NREG, :USUARIO, :FACTFIN, :FEXDESCRI);';
              IbUpVarios.ParamByName('CODALU').Value:=VcodAlu;
              IbUpVarios.ParamByName('APELLIDO').Value:=VApellido;
              IbUpVarios.ParamByName('CODMAT').Value:=combomaterias.text;
              IbUpVarios.ParamByName('CUAANIO').Value:=Cuaanio.Text;
              IbUpVarios.ParamByName('NOTAMAT').Value:=Nota.Text;
              IbUpVarios.ParamByName('FECFINAL').Value:=Fecha.Date;
              IbUpVarios.ParamByName('MATRIZ').Value:=VlibroMatriz;
              IbUpVarios.ParamByName('CONDICION').Value:=ComboCondicion.Text;
              IbUpVarios.ParamByName('INSTITUT').Value:=Instituto.Text;
              IbUpVarios.ParamByName('CARAC').Value:=Caracteristica.Text;
              IbUpVarios.ParamByName('ACTINT').Value:=Actinterna.Text;
              IbUpVarios.ParamByName('ACTDGE').Value:=Actdgegp.Text;
              IbUpVarios.ParamByName('CARRE').Value:=VCarrera;
              IbUpVarios.ParamByName('COLEGIO').Value:=Colegio.Text;
              IbUpVarios.ParamByName('PLAN1').Value:=CmbPlanes.Text;
              IbUpVarios.ParamByName('FACTFIN').Value:=TxtLibroActa.Text;
              IbUpVarios.ParamByName('FEXDESCRI').Value:= TxtFEXDESCRI.Text;
              if Constanciacheck.Checked Then
                 IbUpVarios.ParamByName('A_C').Value:='C';
              if analiticocheck.Checked Then
                 IbUpVarios.ParamByName('A_C').Value:='A';
              IbUpVarios.ParamByName('USUARIO').Value:=funcionesConfiguracion.codusu;
            End
        End;
      if (CustomerData.TRAnalitico.active) then
          CustomerData.TRAnalitico.Rollback;
      CustomerData.TrAnalitico.Active:=False;
      CustomerData.IbAnalitico.Active:=False;
      With Datamodule.CustomerData Do
       Begin
         try
            trupvarios.Active:=True;
            IBUpvarios.ExecQuery;
            TrUpvarios.Commit;
            TrUpVarios.Active:=False;
            CancelaGrabacionClick(Sender);
         except
            on E : Exception do begin
               TrUpvarios.Rollback;
               TrUpVarios.Active:=False;
               MessageDlg(PChar(VNombreUsuario+#13+#10+e.Message),mtError,[mbok],0,mbok);
            end
         end;
       End;
      CustomerData.IbAnalitico.ParamByName('CODALU').Value:=Vcodalu;
      CustomerData.IbAnalitico.ParamByName('CARRE').Value:=VCarrera;
      CustomerData.IbAnalitico.Active:=True;
      CustomerData.Tranalitico.Active:=True;
  End;
end;

procedure TAMAnalitico.ModificaClick(Sender: TObject);
begin
 Groupbox1.Enabled:=False;
 Groupbox2.Enabled:=False;
  With CustomerData do
    Begin
      Combomaterias.Text := IBAnalitico.fieldByName('Cod_mat').Value;
      CuaAnio.Text := IBAnalitico.fieldByName('Cua_Anio').Value;
      Nota.Text   := IBAnalitico.fieldByName('Nota_Mat').Value;
      Fecha.Date  := IBAnalitico.fieldByName('Fec_Final').Value;
      Matriz.Text := IBAnalitico.fieldByName('Matriz').Value;
      ComboCondicion.Text:=IBAnalitico.fieldByName('Condicion').Value;
      Instituto.Text :=  IBAnalitico.fieldByName('Institut').Value;
      Caracteristica.Text := IBAnalitico.fieldByName('Carac').Value;
      ActInterna.Text := IBAnalitico.fieldByName('ActInt').Value;
      ActDgegp.Text := IBAnalitico.fieldByName('ActDge').Value;
      Colegio.Text := IBAnalitico.fieldByName('Colegio').Value;
      CmbPlanes.Text := IBAnalitico.fieldByName('Plan').Value;
      TxtLibroActa.Text := IBAnalitico.fieldByName('FACTFIN').Value;
      TxtFEXDESCRI.Text := IBAnalitico.FieldByName('FEXDESCRI').AsString;
      If IBAnalitico.fieldByName('A_c').Value = 'A' Then
        Analiticocheck.Checked := True
      Else If IBAnalitico.fieldByName('A_c').Value = 'C' Then
        Constanciacheck.Checked := True;
     Modificacion := True;
     AMAnalitico.Height := 728;
     groupbox3.Visible:=true;
     ComboMaterias.SetFocus;
     Graba.Enabled := True;
     Nuevo.Enabled := False;
     Modifica.Enabled := False;
     Elimina.Enabled := False;
     Salir.Enabled := False;
  end;
end;

