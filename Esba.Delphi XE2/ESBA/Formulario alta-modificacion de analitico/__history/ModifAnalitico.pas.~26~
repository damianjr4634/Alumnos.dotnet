procedure TAMAnalitico.FormActivate(Sender: TObject);
begin
{
    PASAR ZLIB
  Modificacion := False;
  GroupBox3.Visible := false;
  AMAnalitico.Height := 345;
  MateriasCodigoAlumno.Text    := VCODALU;
  MateriasCarreraCursa.Text    := VCarrera;
  MateriasApellidoyNombre.Text := VApellido + ', ' + VNombre;
  MateriasLibroMatriz.Text     := Copy(VlibroMatriz,1,2) + '/' + copy(VlibroMatriz,3,3);
  If (VCarrera = 'BAC') or (VCarrera = '333') or (VCarrera = '750') Then
   Begin
     ComboCondicion.Items.Add('EQUIVALENCIA');
     ComboCondicion.Items.Add('REGULAR');
     ComboCondicion.Items.Add('LIBRES');
     ComboCondicion.Items.Add('EXIMIDO');
   End
  else
   Begin
     ComboCondicion.Items.Add('EQUIVALENCIA');
     ComboCondicion.Items.Add('FINAL');
     ComboCondicion.Items.Add('PASE/FINAL');
     ComboCondicion.Items.Add('EXIMIDO');
   End;
 CustomerData.TrAnalitico.Active:=False;
 CustomerData.IbAnalitico.Active:=False;
 CustomerData.IbAnalitico.ParamByName('CODALU').Value:=Vcodalu;
 CustomerData.IbAnalitico.ParamByName('CARRE').Value:=VCarrera;
 CustomerData.IbAnalitico.Active:=True;
 CustomerData.Tranalitico.Active:=True;
 }
end;

