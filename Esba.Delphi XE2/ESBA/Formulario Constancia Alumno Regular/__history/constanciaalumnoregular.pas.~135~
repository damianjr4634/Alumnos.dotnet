procedure TConstAlumnoRegular.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
{
    PASAR ZLIB
  if DataModule.CustomerData.TrQrVarios.Active then begin
    DataModule.CustomerData.IBQrVarios.Close;
    DataModule.CustomerData.TrQrVarios.Rollback;
  end;
  }
end;

procedure TConstAlumnoRegular.FormShow(Sender: TObject);
var
 Anio,Mes,Dia : Word;

begin
 Apenom.Text := Apellidonombre;
 Docum.Text  := PonePuntos(CodigoAlumno);
 Carre.Text  := Carreralarga;
 if DataModule.CustomerData.TrQrVarios.Active then begin
  DataModule.CustomerData.IBQrVarios.Close;
  DataModule.CustomerData.TrQrVarios.Rollback;
 end;
 DataModule.CustomerData.IBQrVarios.Sql.Clear;
 DataModule.CustomerData.IBQrVarios.Sql.Text:='SELECT C.COD_ALU, C.CUTUCO, C.CUA_ANIO, C.CONDICION, A.DISTANCIA, A.DICTAMEN '+
                                              'FROM CURSADA C '+
                                              'LEFT OUTER JOIN CARRERA A ON A.CARRE=C.CARRE '+
                                              'WHERE C.CARRE=:CARRE AND C.COD_ALU=:CODALU AND TRIM(C.CONDICION) IN (''CURSANDO'',''RECURSANDO'') AND C.CUA_ANIO=:CUAANIO '+
                                              'ORDER BY C.CUTUCO DESC, C.CONDICION;';
 DataModule.CustomerData.IBQrVarios.ParambyName('CODALU').AsString := CodigoAlumno;
 DataModule.CustomerData.IBQrVarios.ParambyName('CUAANIO').AsString := Cuatrimestre(CarreraActiva);
 DataModule.CustomerData.IBQrVarios.ParambyName('CARRE').AsString:= CarreraActiva;
 DataModule.CustomerData.TrQrVarios.Active:=True;
 DataModule.CustomerData.IBQrVarios.ExecQuery;

 If DataModule.CustomerData.IBQrVarios.RecordCount = 0 then
  Begin
   DataModule.CustomerData.TrQrVarios.Rollback;
   DataModule.CustomerData.TrQrVarios.Active:=False;
   MessageDlg(Pchar(Usuario+', EL ALUMNO NO SE ENCUENTRA CURSANDO ACTUALMENTE'),mtError,[mbok],0,mbok);
   BtnPdf.Enabled:=False;
   Imprimir.Enabled := False;
   Cancelar.SetFocus;
   ConstAlumnoRegular.Close;
  end
 Else
  Begin
    distancia:= DataModule.CustomerData.IBQrVarios.FieldByName('DISTANCIA').AsString;
    Dictamen:= DataModule.CustomerData.IBQrVarios.FieldByName('DICTAMEN').AsString;


    Try
     Comi.Text := InttoStr(DataModule.CustomerData.IBQrVarios.FieldByName('CUTUCO').AsInteger);
    Except
     Comi.text := '';
    End;
    DecodeDate(date,anio,mes,dia);
    dias.text := InttoStr(dia);
    meses.text  := MesALetras(mes);
    anios.text := InttoStr(anio);
    Memo.Enabled:=True;
    Label5.Caption:='y asiste a clase los días:';
    if (distancia<>'S') then begin
        if (CarreraActiva='BAC') then begin
          case StrToInt(Copy(Comi.Text,2,1)) of
             1: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 8:30 a 11:30 hs.';
             2: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 13:30 a 16:30 hs.';
             3: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 17:30 a 20:00 hs.';
             4: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 19:00 a 22:00 hs.';
          end
        end
        else if (CarreraActiva='333') or (CarreraActiva='650') then begin
           case StrToInt(Copy(Comi.Text,2,1)) of
             1: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 8:00 a 13:00 hs.';
             2: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 13:00 a 18:00 hs.';
             3: Memo.Lines.Text:= 'Sin horario definido';
             4: Memo.Lines.Text:= 'Sin horario definido';
           end
        end
        else begin
            case StrToInt(Copy(Comi.Text,2,1)) of
              1: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 8:30 a 11:45 hs.';
              2: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 13:30 a 16:45 hs.';
              3: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 17:15 a 20:00 hs.';
              4: Memo.Lines.Text:= 'Lunes a Viernes en el horario de 19:00 a 22:00 hs.';
            end
        end;
    end
    else begin
       Memo.Enabled:=False;
       Label5.Caption:='';
    end;
    antequien.SetFocus;
  End;
end;

procedure TConstAlumnoRegular.BitBtn1Click(Sender: TObject);
var
 opcion: integer;
begin
Case FuncionesSystem.CustomMessageDialog('Que desea hacer?', mtConfirmation,
          [mbNo, mbYes, mbCancel], ['Mail', 'Guardar', 'Cancelar']) of
       mrYes: opcion:=1;
       mrNo:  opcion:=2
       else exit;
End;

if opcion=1 then begin
  CreatePdf(UnidadPrograma+'pdfs\'+Apellidonombre+'.pdf');
  Frmenviomail := TFrmenviomail.Create(Self);
  EnvioCorreo.VUnidad := UnidadPrograma;
  EnvioCorreo.Vcarrera := CarreraActiva;
  EnvioCorreo.VUsuario := Usuario;
  FrmEnvioMail.DEPara.Text := MailAlumno;
  Frmenviomail.Asunto.Text := 'Constancia de Alumno regular';
  Frmenviomail.ArchAdj.Items.Add(UnidadPrograma+'pdfs\'+Apellidonombre+'.pdf');
  Frmenviomail.SetButtons;
  FrmEnvioMail.Position:=poScreenCenter;
  FrmEnvioMail.ShowModal;
  FrmEnvioMail.Free;
  Frmenviomail:=nil;
end
else If (opcion=2) and (SaveDialog1.Execute) then
    CreatePdf(SaveDialog1.FileName);
end;

procedure TConstAlumnoRegular.CancelarClick(Sender: TObject);
begin
 Close;
end;

