procedure TConstAlumnoRegular.CreatePDF(FileName:string);
const
 margen=40;
 sangria=20;
var
 fila: Single;
 Imagen : TMetaFile;
 sello, firmaSecre, FirmaRecto, FirmaDirectora:TPicture;
 texto : string;
 lPdf   : TPdfDocumentGDI;
 lPage  : TPdfPage;
 pdfr: TpdfRect;
begin
   lPdf := TPdfDocumentGDI.Create;
   Imagen := TMetaFile.Create;
   sello := TPicture.Create;
   firmaSecre := TPicture.Create;
   firmaRecto := TPicture.Create;
   FirmaDirectora := TPicture.Create;
   Imagen.LoadFromFile(UnidadPrograma+CARPETA_PLANTILLA+'\membrete_con_direccion.wmf');
   Sello.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\sello2.jpg');

   FirmaSecre.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_secre.jpg');
   FirmaRecto.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_recto.jpg');
   FirmaDirectora.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_direc.jpg');

   lPdf.Info.Author        := 'ESBA';
   lPdf.Info.CreationDate  := Now;
   lPdf.Info.Creator       := 'ESBA';
   lPdf.DefaultPaperSize   := psA4;

   lPage:= lPdf.AddPage;
   lPDF.Canvas.SetFont('Arial',14.0,[FsBold]);
   lPDF.Canvas.SetLeading(lPDF.Canvas.Page.FontSize);
   lPDF.Canvas.SetLineWidth(0.1);
   lPdf.Canvas.RenderMetaFile(imagen,0.18,0,0);
   lPdf.Canvas.BeginText;

   FILA:=700;
   //PDF.Canvas.TextOut(vertical,horizontal
   // vertical: 0 a partir del marguen izquierdo
   // horizontal: 0 a partir de abajo porque no se

   lPDF.Canvas.TextOut(200,fila,'CONSTANCIA DE ALUMNO REGULAR');
   //lPDF.Canvas.TextOut(strtofloat(edit1.text),strtofloat(edit2.text),'CONSTANCIA DE ALUMNO REGULAR');
   lPDF.Canvas.SetFont('Arial',11.0,[]);
   lPDF.Canvas.SetLeading(lPDF.Canvas.Page.FontSize);
   fila:=fila-70;

   if distancia='S' then begin
          texto := '      ' + Label2.Caption + ' ' + Apenom.Text + ' ' + Docum.Text + ', es alumno regular del '+LetrasCuat(StrtoInt(Copy(Comi.Text,1,1)))+
                   ' cuatrimestre de la carrera '+PasoAMayusculas(Carre.Text);
          texto:= texto + ' del Ministerio de Educación del Gobierno de la Ciudad Autónoma de Buenos Aires y Dictamen del Consejo Federal de Educación, del Ministerio de Educación de la Nación N° '+dictamen+'.'+
                  #13+#10+#13+#10+Label6.Caption + ' ' + PasoAMayusculas(Antequien.Text) + '.'+
                  #13+#10+#13+#10+Label9.Caption + ' ' + dias.Text + ' ' + Label10.caption + meses.text + ' ' + Label11.Caption + anios.Text + '.';
   end
   else begin
          texto := '      ' + Label2.Caption + ' ' + Apenom.Text + ' ' + Docum.Text + ', ' + Label3.Caption + ' ' +
                  PasoAMayusculas(Carre.Text) + ' - ' + LetrasCuat(StrtoInt(Copy(Comi.Text,1,1)));
          if (CarreraActiva='333') or (CarreraActiva='650') then
              texto:= texto + ' ańo.'
          else
              texto:= texto + ' cuatrimestre.';
          texto:= texto + #13+#10+#13+#10+'Asiste los dias: '+ memo.Lines.Text+
                #13+#10+#13+#10+Label6.Caption + ' ' + PasoAMayusculas(Antequien.Text) + '.'+
                #13+#10+#13+#10+Label9.Caption + ' ' + dias.Text + ' ' + Label10.caption + meses.text + ' ' + Label11.Caption + anios.Text + '.';
   end;

    pdfr.Left:=margen;
    pdfr.Top:=fila;
    pdfr.Right:=550;
    pdfr.bottom:=fila-200;
    lPdf.Canvas.MultilineTextRect(pdfr,texto,true);
    fila:=fila-200;
    //imagen,scala,horizontal,vertical


    lPdf.VCLCanvas.StretchDraw(rect(round(margen+130),round(fila-40),round(margen+230),round(fila+110)),sello.Graphic);

    lPdf.VCLCanvas.StretchDraw(rect(round(margen+405),round(fila-30),round(margen+600),round(fila)+80),firmaSecre.Graphic);
    lPdf.VCLCanvas.Draw(round(margen+355),round(fila),firmaRecto.Graphic);


    lPdf.Canvas.TextOut(margen+100,fila,'SELLO');

    lPdf.Canvas.TextOut(margen,fila,funcionesConfiguracion.Secretaria);
    lPdf.Canvas.TextOut(margen+335,fila,funcionesConfiguracion.Rector);

    fila:=fila-15;

    lPdf.Canvas.TextOut(margen,fila,'Secretaria');
    lPdf.Canvas.TextOut(margen+347,fila,'Rector/a');

    fila:=fila-50;

    lPdf.Canvas.TextOut(margen,fila,'NOTA: La presente certificación carecerá de valor si no estuviera firmada por la autoridad competente.-');

    If carreras.CarreIndexOf(CarreraActiva).tipo='TER' then Begin
        fila:=fila-15;
        if distancia='S' then
          lPdf.Canvas.TextOut(margen,fila,'La mencionada carrera cuenta con el 80% de la subvención del Estado');
    end
    else If carreras.CarreIndexOf(CarreraActiva).tipo='BAC' then Begin
        fila:=fila-15;
        if distancia='S' then
          lPdf.Canvas.TextOut(margen,fila,'La mencionada carrera cuenta con el 70% de la subvención del Estado');
    end;

    lPdf.Canvas.EndText;
    lPdf.SaveToFile(FileName);
    lPdf.Free;
    Imagen.Free;
    sello.Free;
    firmaSecre.Free;
    firmaRecto.Free;
end;

end.
