unit CambioPassword;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, Buttons, Datamodule, funciones;

type
  TFrmCambioPass = class(TForm)
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    RPassword: TEdit;
    PassNew: TEdit;
    RPassNew: TEdit;
    Graba: TBitBtn;
    Salir: TBitBtn;
    procedure SalirClick(Sender: TObject);
    procedure GrabaClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  FrmCambioPass: TFrmCambioPass;
  VCodUsu:Integer;

implementation

{$R *.dfm}

procedure TFrmCambioPass.SalirClick(Sender: TObject);
begin
 Close;
end;

procedure TFrmCambioPass.GrabaClick(Sender: TObject);
begin
  if (Rpassword.text='') or (PassNew.Text='') or (RPassNew.Text='') then
    exit;
  if CustomerData.TrDsVarios.Active then
      CustomerData.TrDsVarios.Rollback;
  CustomerData.IbDsVarios.Active:=False;
  CustomerData.IbDsVarios.SQLs.SelectSQL.Text:='SELECT PASSWD FROM USUARIOS WHERE CODUSU='+IntToStr(VCODUSU);
  CustomerData.TrDsVarios.Active:=True;
  CustomerData.IbDsVarios.Active:=True;
  If EncriptoCadena(CustomerData.IbDsVarios.FieldByName('PASSWD').AsString) <> Rpassword.Text Then  Begin
        MessageBox(FrmCambioPass.Handle,'Password anterior incorrecto','Error',MB_OK+MB_ICONERROR+MB_APPLMODAL);
  End Else begin
     if (PassNew.text<>RPassNew.Text) then
        MessageBox(FrmCambioPass.Handle,'Los password nuevos no coinciden','Error',MB_OK+MB_ICONERROR+MB_APPLMODAL)
     else begin
            if CustomerData.TrupVarios.Active then
               CustomerData.TrupVarios.Rollback;
            CustomerData.IbUpVarios.Sql.Clear;
            CustomerData.TrupVarios.Active:=False;
            CustomerData.IbUpVarios.SQL.Text:='UPDATE USUARIOS SET PASSWD='#39+encriptocadena(PassNew.Text)+#39+' WHERE CODUSU='+IntToStr(VCODUSU);
            CustomerData.TrupVarios.Active:=True;
            CustomerData.IbUpVarios.ExecQuery;
            CustomerData.TrUpVarios.Commit;
            CustomerData.TrupVarios.Active:=False;
            MessageBox(FrmCambioPass.Handle,'Password cambiado con exito','Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
            if CustomerData.TrDsVarios.Active then
               CustomerData.TrDsVarios.Rollback;
            CustomerData.IbDsVarios.Active:=False;
            close;
     end
  end;
if CustomerData.TrDsVarios.Active then
  CustomerData.TrDsVarios.Rollback;
CustomerData.IbDsVarios.Active:=False;
end;

end.
