procedure TFrmlstMesas.BtnExcelClick(Sender: TObject);
Var
  FrmProgress: TForm;
  FDir: string;
  Barra : TProgressBar;
  AppExcel: TExcelApplication;
  Libro : _WORKBOOK;
  Hoja  : _WORKSHEET;
  x, ContHojas, contalumnos : Integer;
  contareg:integer;
  sw : integer;
  tipoexamen:string;
  FormulTipoExamen:TFrmTipoExamen;
begin
  if (combomesa.Text='') then begin
    MessageDlg('El codigo de mesa es obligatorio',mtInformation, [mbok],0,mbok);
    exit;
  end;
  if not SelectDirectory('Seleccione Directorio para guardar los archivos', ExtractFileDrive(FDir), FDir,
             [sdNewUI, sdNewFolder]) then
    exit;

  If (ibtr.Active) then begin
    ibtr.Rollback;
    sqlcomi.Active:=false;
    sqldatos.Active:=False;
  end;
  SqlComi.SQLs.SelectSql.Text:='';
  SqlComi.SQLs.SelectSql.Text:= 'SELECT TRIM(T.DOCENTE)||'', ''||TRIM(V1.DOCENTE)||'', ''||TRIM(V2.DOCENTE) AS DOCENTE, M.COMI1 AS CUTUCO,MA.DESCRIPCI, '+
                               '       EXTRACT(DAY FROM M.FECH_EXA) AS DIA, EXTRACT(MONTH FROM M.FECH_EXA) AS MES, EXTRACT(YEAR FROM M.FECH_EXA) AS ANIO, '+
                               '       MA.CUATRIM AS CUATMAT '+
                               'FROM MESAS M '+
                               'LEFT OUTER JOIN DOCENTES T  ON M.TITULAR=T.CODPROFES '+
                               'LEFT OUTER JOIN DOCENTES V1  ON M.VOCAL1 =V1.CODPROFES '+
                               'LEFT OUTER JOIN DOCENTES V2 ON M.VOCAL2=V2.CODPROFES '+
                               'LEFT OUTER JOIN MATERIAS MA  ON MA.CODMATERI=M.COD_MAT AND MA.CODCARRE=M.CARRE '+
                               'WHERE M.MESA='+combomesa.Text+' AND M.CARRE='+#39+vcarrera+#39;

  sw := 0;
  contareg:=1;
  SqlComi.Active := True;
  SqlComi.FetchAll;
  IbTr.Active:=True;
  If SqlComi.RecordCount = 0 Then Begin
    MessageDlg(Pchar(VnombreUsuario+', no hay datos para mostrar'),mtError,[mbok],0,mbok);
    COMBOMESA.SetFocus;
    SqlComi.Active := False;
    IbTr.RollBack;
    IbTr.Active:=False;
  End
  Else begin
    tipoexamen:= 'FINAL';
    if (vcarrera='BAC') or (vcarrera='333') or (VCarrera = '650') then begin
      FormulTipoExamen:=TFrmTipoExamen.Create(nil);
      FormulTipoExamen.CbTipo.Items.Clear;
      FormulTipoExamen.CbTipo.Items.Add('LIBRES');
      FormulTipoExamen.CbTipo.Items.Add('PREVIOS');
      If (VCarrera = '333') or (VCarrera = '650') Then begin
        FormulTipoExamen.CbTipo.Items.Add('DICIEMBRE');
        FormulTipoExamen.CbTipo.Items.Add('MARZO');
        FormulTipoExamen.CbTipo.Items.Add('P/EQUIVALEN');
      end;
      FormulTipoExamen.CbTipo.ItemIndex:=0;

      if FormulTipoExamen.ShowModal<>mrOk then begin
         FormulTipoExamen.Free;
         FormulTipoExamen:=nil;
         exit;
      end;
      tipoexamen:=FormulTipoExamen.CbTipo.Text;
      FormulTipoExamen.Free;
      FormulTipoExamen:=nil;
    end;

    FrmProgress := TForm.Create(Application);
    Try
      FrmProgress.Caption := 'Exportando.....0%';
      FrmProgress.Position := poDesktopCenter;
      FrmProgress.Width := 400;
      FrmProgress.Height := 60;
      FrmProgress.BorderStyle := bsDialog;
      FrmProgress.Show;
      Barra := TProgressBar.Create(FrmProgress);
      Barra.Parent := FrmProgress;
      Barra.Visible := True;
      Barra.Align := AlClient;
      Barra.Max := SqlComi.RecordCount;
      Barra.Min := 0;
      Barra.Step := 1;
      Barra.Smooth := True;
    Finally

    End;

    While not SqlComi.eof do begin
      Try
        AppExcel:= TExcelApplication.Create(Nil);
      Except
        ShowMessage('Excel no se pudo iniciar.');
        Exit;
      End;
      Libro:=AppExcel.Workbooks.Open(vUnidad+CARPETA_PLANTILLA+'\Planilla_de_actas_volantes.xls',EmptyParam,true,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,EmptyParam,0);

      if not sqldatos.active then begin
        SqlDatos.SQLs.SelectSQL.Text:='SELECT PERM_EXA, COD_ALU, APELLIDO, NOM_APE '+
                                       'FROM XXX_MESAS_ALUMNOS('+COMBOMESA.Text+','+#39+vcarrera+#39+','+#39+tipoexamen+#39+')';

        SqlDatos.Active:=True;
        SqlDatos.FetchAll;
      end;


      ContHojas:=1;
      contalumnos:=0;
      while not sqlDatos.Eof do begin
        if (ContAlumnos=0) or (ContALumnos>24) then begin
          Hoja:=Libro.WorkSheets.Get_Item(ContHojas) as _WorkSheet;

          Hoja.Cells.Item[4,'C']:= VCarreraLarga;
          Hoja.Cells.Item[5,'E']:= 'ACTA DE EXAMEN '+UpperCase(tipoexamen);
          Hoja.Cells.Item[6,'E']:= 'Asignatura: '+SqlComi.FieldByName('DESCRIPCI').AsString;

          if not((SqlComi.FieldByName('CUTUCO').IsNull) or (SqlComi.FieldByName('CUTUCO').value<100)) then
           Hoja.Cells.Item[7,'E']:= 'Cuat.: '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'    Turno: '+Turnos(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),2,1)))+'     Divisi: '+Division(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),3,1)))+'      Mesa: '+ComboMesa.Text
          else
           Hoja.Cells.Item[7,'E']:='Mesa: '+ComboMesa.Text+' Cuat: '+IntToStr(SqlComi.FieldByName('CUATMAT').AsInteger);

          Hoja.Cells.Item[8,'D']:='Correspondiente al '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'ｺ CUATRIMESTRE de estudios';

          Hoja.Cells.Item[9,'A']:= 'A los '+SqlComi.FieldByName('DIA').AsString+' d僘s del mes '+funcionesText.MesALetras(sqlcomi.FieldByName('MES').value)+' de '+SqlComi.FieldByName('ANIO').AsString+' reunida la Comisi Examinadora de la asignatura mencionada, con asistencia de';
          Hoja.Cells.Item[10,'A']:= 'sus tres miembros seres '+SqlComi.FieldByName('DOCENTE').AsString;
          X:=14;
          contAlumnos:=1;
          ContHojas:=conthojas+1;
        end;

        Hoja.Cells.Item[x,'B']:=SqlDatos.FieldByName('PERM_EXA').AsInteger;
        Hoja.Cells.Item[x,'C']:=sqlDatos.FieldByName('COD_ALU').AsString;
        Hoja.Cells.Item[x,'D']:=SqlDatos.FieldByName('APELLIDO').AsString + ', ' + SqlDatos.FieldByName('NOM_APE').AsString;

        X:=X+1;
        SqlDatos.Next;
        contAlumnos:=contalumnos+1;
      end;
      SqlDatos.Close;
      Barra.StepIt;
      FrmProgress.Caption := 'Exportando.....'+FloatToStr(Int((SqlComi.RecNo/Barra.Max)*100))+'%';
      FrmProgress.Refresh;

      deletefile(FDir+'\MESA_'+ComboMesa.Text+'_'+SqlComi.FieldByName('DESCRIPCI').AsString+'.xls');

      AppExcel.ActiveWorkbook.Close(true,FDir+'\MESA_'+ComboMesa.Text+'_'+SqlComi.FieldByName('DESCRIPCI').AsString+'.xls',EmptyParam,0);

      AppExcel.Visible[0] := False;
      AppExcel.Disconnect;
      AppExcel.Free;
      SqlComi.Next;

    end;
    FrmProgress.Free;
 end;
 SqlComi.Active := False;
 IbTr.Rollback;
 IbTr.Active:=False;
end;

procedure TFrmlstMesas.CodigoMateriaKeyPress(Sender: TObject;
  var Key: Char);
begin
 if key=#13 then
    Imprimir.SetFocus;
end;

procedure TFrmlstMesas.ComboMesaButtonClick(Sender: TObject);
Var b:Variant;
begin
  FuncionesDB.combobusqueda('SELECT M.MESA, M.FECH_EXA,M.HORA, A.DESCRIPCI FROM MESAS M LEFT OUTER JOIN MATERIAS A ON M.COD_MAT=A.CODMATERI AND A.CODCARRE=M.CARRE WHERE M.CARRE='''+VCARRERA+''' ORDER BY M.MESA',['Mesa','Fecha','Hora','Materia'],b,True);
  ComboMesa.Text:=b[0];
  NombreMat.Caption:=b[1];
end;

procedure TFrmlstMesas.ComboMesaExit(Sender: TObject);
Var b:Variant;
begin
  if (Combomesa.Text<>'') Then Begin
      FuncionesDB.combobusqueda('SELECT M.MESA, M.FECH_EXA,M.HORA, A.DESCRIPCI FROM MESAS M LEFT OUTER JOIN MATERIAS A ON M.COD_MAT=A.CODMATERI AND A.CODCARRE=M.CARRE WHERE M.CARRE='+#39+VCARRERA+#39+'AND M.MESA='+Combomesa.Text+' ORDER BY M.MESA',['Mesa','Fecha','Hora','Materia'],b,False);
      If (vartostr(b[0])='') then begin
         MessageDlg('Cigo incorrecto',mtError,[mbok],0,mbok);
         Combomesa.SetFocus;
      end
      else begin
         Combomesa.Text:=b[0];
         NombreMat.Caption:=b[1];
      end
  end
end;

end.