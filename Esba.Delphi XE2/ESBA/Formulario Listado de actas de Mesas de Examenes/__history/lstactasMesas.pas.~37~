  FuncionesText,FuncionesDB, Printers,
  ComCtrls, DBCtrls, DataModuleZeosLib, Mask, RXToolEdit,
  strutils, Variants, TipodeExamen, Vcl.ExtCtrls, Vcl.FileCtrl, kbmMemTable;

type
  TFrmlstMesas= class(TForm)
    GroupBox1: TGroupBox;
    Label3: TLabel;
    Imprimir: TBitBtn;
    salir: TBitBtn;
    PrintDialog1: TPrintDialog;
    PrintSetup: TPrinterSetupDialog;
    ComboMesa: TComboEdit;
    NombreMat: TLabel;
    Panel1: TPanel;
