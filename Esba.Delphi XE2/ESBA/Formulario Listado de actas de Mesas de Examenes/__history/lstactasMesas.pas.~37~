begin
 COMBOMESA.SetFocus;
end;

procedure TFrmlstMesas.ImprimirClick(Sender: TObject);
var
  largopagina:real;
  contareg:integer;
  sw : integer;
  Cutuco_Aux : Integer;
  CodigoMateria_Aux : Integer;
  verti:real;
  x:integer;
  Imagen : TMetaFile;
  tipoexamen:string;
  FormulTipoExamen:TFrmTipoExamen;
begin
 if (combomesa.Text='') then begin
     MessageDlg('El codigo de mesa es obligatorio',mtInformation, [mbok],0,mbok);
     exit;
 end;
 If (ibtr.Active) then begin
    ibtr.Rollback;
    sqlcomi.Active:=false;
    sqldatos.Active:=False;
 end;
 SqlComi.SQLs.SelectSql.Text:='';
 SqlComi.SQLs.SelectSql.Text:= 'SELECT TRIM(T.DOCENTE)||'', ''||TRIM(V1.DOCENTE)||'', ''||TRIM(V2.DOCENTE) AS DOCENTE, M.COMI1 AS CUTUCO,MA.DESCRIPCI, '+
                               '       EXTRACT(DAY FROM M.FECH_EXA) AS DIA, EXTRACT(MONTH FROM M.FECH_EXA) AS MES, EXTRACT(YEAR FROM M.FECH_EXA) AS ANIO '+
                               'FROM MESAS M '+
                               'LEFT OUTER JOIN DOCENTES T  ON M.TITULAR=T.CODPROFES '+
                               'LEFT OUTER JOIN DOCENTES V1  ON M.VOCAL1 =V1.CODPROFES '+
                               'LEFT OUTER JOIN DOCENTES V2 ON M.VOCAL2=V2.CODPROFES '+
                               'LEFT OUTER JOIN MATERIAS MA  ON MA.CODMATERI=M.COD_MAT AND MA.CODCARRE=M.CARRE '+
                               'WHERE M.MESA='+combomesa.Text+' AND M.CARRE='+#39+vcarrera+#39;

 sw := 0;
 contareg:=1;
 SqlComi.Active := True;
 SqlComi.FetchAll;
 IbTr.Active:=True;
 If SqlComi.RecordCount = 0 Then
   Begin
    MessageDlg(Pchar(VnombreUsuario+', no hay datos para mostrar'),mtError,[mbok],0,mbok);
    COMBOMESA.SetFocus;
    SqlComi.Active := False;
    IbTr.RollBack;
    IbTr.Active:=False;
   End
 Else
  If PrintDialog1.execute then
   Begin
    FormPreview:=tFormPreview.create(self);
    largopagina:= 1.5;
    Imagen := TMetaFile.Create;
    Imagen.LoadFromFile(vUnidad+CARPETA_PLANTILLA+'\actas_volantes.wmf');
    FormPreview.VistaPrevia1.PaperSize:=Legal;
    FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21.54,35.56,Imagen,GmCentimeters);
    tipoexamen:= 'FINAL';
    if (vcarrera='BAC') or (vcarrera='333') or (VCarrera = '650') then begin
        FormulTipoExamen:=TFrmTipoExamen.Create(nil);
        FormulTipoExamen.CbTipo.Items.Clear;
        FormulTipoExamen.CbTipo.Items.Add('LIBRES');
        FormulTipoExamen.CbTipo.Items.Add('PREVIOS');
        If (VCarrera = '333') or (VCarrera = '650') Then begin
           FormulTipoExamen.CbTipo.Items.Add('DICIEMBRE');
           FormulTipoExamen.CbTipo.Items.Add('MARZO');
           FormulTipoExamen.CbTipo.Items.Add('P/EQUIVALEN');
        end;
        FormulTipoExamen.CbTipo.ItemIndex:=0;


        if FormulTipoExamen.ShowModal<>mrOk then begin
           FormulTipoExamen.Free;
           FormulTipoExamen:=nil;
           exit;
        end;
        tipoexamen:=FormulTipoExamen.CbTipo.Text;
        FormulTipoExamen.Free;
        FormulTipoExamen:=nil;
    end;
    While not SqlComi.eof do
     begin
      if not sqldatos.active then
        begin
         SqlDatos.SQLs.SelectSQL.Text:='SELECT PERM_EXA, COD_ALU, APELLIDO, NOM_APE '+
                                       'FROM XXX_MESAS_ALUMNOS('+COMBOMESA.Text+','+#39+vcarrera+#39+','+#39+tipoexamen+#39+')';

         SqlDatos.Active:=True;
         SqlDatos.FetchAll;
        end;
      FormPreview.VistaPrevia1.BeginUpdate;
      // **** INICIO DEL ENCABEZADO ***//
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 9;
      FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
      LargoPagina:=LargoPagina+0.7;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,VCarreraLarga,GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'ACTA DE EXAMEN '+UpperCase(tipoexamen),GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Asignatura: '+SqlComi.FieldByName('DESCRIPCI').AsString,GmCentimeters);
      LargoPagina:=LargoPagina+0.5;
      if not((SqlComi.FieldByName('CUTUCO').IsNull) or (SqlComi.FieldByName('CUTUCO').value<100)) then
         FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Cuat.: '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'    Turno: '+Turnos(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),2,1)))+'     Divisi: '+Division(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),3,1)))+'      Mesa: '+ComboMesa.Text,GmCentimeters)
      else
         FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'  Mesa: '+ComboMesa.Text,GmCentimeters);
      LargoPagina:=LargoPagina+0.5;
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 7;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Correspondiente al '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'ｺ CUATRIMESTRE de estudios',GmCentimeters);
      LargoPagina:=LargoPagina+0.55;
      FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(2.2,LargoPagina,SqlComi.FieldByName('DIA').value,GmCentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(5.2,LargoPagina,funcionesText.MesALetras(sqlcomi.FieldByName('MES').value),GmCentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(6.9,LargoPagina,SqlComi.FieldByName('ANIO').value,GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(11.5,LargoPagina,SqlComi.FieldByName('DOCENTE').AsString,GmCentimeters);
      // **** FIN DEL ENCABEZADO ***//
      // **** INICIO DEL DETALLE ***//
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
      FormPreview.VistaPrevia1.Canvas.Font.Style := [];
      LargoPagina := 7.8;
      //llenar los parametro de sqlcursada y ejecutarlo
      While (not SqlDatos.eof) and  (largopagina<=29)  do
       begin
           contareg:=contareg+1;
           //TOMA DATOS DE LA BD
           FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
           FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
           FormPreview.VistaPrevia1.Canvas.Font.Style := [];
           FormPreview.VistaPrevia1.Canvas.FloatOut(3.1,largopagina,SqlDatos.FieldByName('PERM_EXA').AsInteger,'0',gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.TextOut(3.4,largopagina,SqlDatos.FieldByName('COD_ALU').AsString,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.TextOut(5.9,largopagina,SqlDatos.FieldByName('APELLIDO').AsString + ', ' + SqlDatos.FieldByName('NOM_APE').AsString ,gmcentimeters);
           LargoPagina := LargoPagina + 0.9;
           SqlDatos.next;
       end;
        FormPreview.VistaPrevia1.EndUpdate;
        if SqlDatos.eof then
         Begin
           SqlDatos.Active:=False;
           SqlComi.Next;
           sw:=0;
           contareg:=1;
         end;
        if (not sqlcomi.Eof) or (largopagina>31) then begin
          FormPreview.VistaPrevia1.Newpage;
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21.54,35.56,Imagen,GmCentimeters);
        end;
        LargoPagina := 1.5;
     end; //end del while sqlcomi
     FormPreview.VistaPrevia1.CurrentPage := 1;
     FormPreview.ShowModal;
     FormPreview.Free;
     CoMBOMESA.SetFocus;
  end;
  SqlDatos.Active:=False;
  SqlComi.Active:=False;
  If IbTr.Active then
      IbTr.RollBack;
  IbTr.Active:=False;
end;

procedure TFrmlstMesas.salirClick(Sender: TObject);
begin
  Close
end;


