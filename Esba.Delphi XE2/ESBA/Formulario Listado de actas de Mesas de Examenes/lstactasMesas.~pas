unit lstactasMesas;

interface

uses
  Windows, Messages, SysUtils, Classes, Graphics, Controls, Forms, Dialogs,
  Db, StdCtrls, Buttons, Imprimir, GmTypes, GmPreview,gmprinter, Funciones, Printers,
  ComCtrls, DBCtrls, DataModule, Mask, ToolEdit, FIBDataSet, pFIBDataSet, FIBDatabase, pFIBDatabase,
  strutils;

type
  TFrmlstMesas= class(TForm)
    GroupBox1: TGroupBox;
    Label3: TLabel;
    Imprimir: TBitBtn;
    salir: TBitBtn;
    PrintDialog1: TPrintDialog;
    PrintSetup: TPrinterSetupDialog;
    ComboMesa: TComboEdit;
    NombreMat: TLabel;
    IbTr: TpFIBTransaction;
    SqlDatos: TpFIBDataSet;
    SqlComi: TpFIBDataSet;
    procedure FormActivate(Sender: TObject);
    procedure ImprimirClick(Sender: TObject);
    procedure salirClick(Sender: TObject);
    procedure OpcionesClick(Sender: TObject);
    procedure CodigoMateriaKeyPress(Sender: TObject; var Key: Char);
    procedure ComboMesaButtonClick(Sender: TObject);
    procedure ComboMesaExit(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  FrmlstMesas: TFrmlstMesas;
  VCarrera : String[6]; //sirve para saber la carrera activa
  VUnidad : String; //sirve para saber la unidad en la cual se corre el sistema
  VInstituto  : String[50]; //Pasa el nomnbre del instituto
  VCaracteristica : String[5]; //Pasa la caracteristica del colegio
  VCuatrimestreAnio : String[4]; //guarda el a cuatrimestre actual
  VNombreUsuario : String; //Trae el usuario que esta trabajando
  VCarreraLarga : String; //Trae el nombre completo de la carrera
implementation


{$R *.dfm}
procedure TFrmlstMesas.FormActivate(Sender: TObject);
begin
 COMBOMESA.SetFocus;
end;

procedure TFrmlstMesas.ImprimirClick(Sender: TObject);
var
  largopagina:real;
  contareg:integer;
  sw : integer;
  Cutuco_Aux : Integer;
  CodigoMateria_Aux : Integer;
  verti:real;
  x:integer;
  Imagen : TMetaFile;
  tipoexamen:string;
begin
 if (combomesa.Text='') then begin
     Application.MessageBox('El codigo de mesa es obligatorio','Aviso',MB_ICONINFORMATION+MB_APPLMODAL);
     exit;
 end;
 If (ibtr.Active) then begin
    ibtr.Rollback;
    sqlcomi.Active:=false;
    sqldatos.Active:=False;
 end;
 SqlComi.SQLs.SelectSql.Text:='';
 SqlComi.SQLs.SelectSql.Text:= 'SELECT TRIM(V1.DOCENTE)||'+#39', '+#39'||TRIM(T.DOCENTE)||'+#39', '+#39'||TRIM(V2.DOCENTE) AS DOCENTE, M.COMI1 AS CUTUCO,MA.DESCRIPCI, '+
                               '       EXTRACT(DAY FROM M.FECH_EXA) AS DIA, EXTRACT(MONTH FROM M.FECH_EXA) AS MES, EXTRACT(YEAR FROM M.FECH_EXA) AS ANIO '+
                               'FROM MESAS M '+
                               'LEFT OUTER JOIN DOCENTES T  ON M.TITULAR=T.CODPROFES '+
                               'LEFT OUTER JOIN DOCENTES V1  ON M.VOCAL1 =V1.CODPROFES '+
                               'LEFT OUTER JOIN DOCENTES V2 ON M.VOCAL2=V2.CODPROFES '+
                               'LEFT OUTER JOIN MATERIAS MA  ON MA.CODMATERI=M.COD_MAT AND MA.CODCARRE=M.CARRE '+
                               'WHERE M.MESA='+combomesa.Text+' AND M.CARRE='+#39+vcarrera+#39;

 sw := 0;
 contareg:=1;
 SqlComi.Active := True;
 SqlComi.FetchAll;
 IbTr.Active:=True;
 If SqlComi.RecordCount = 0 Then
   Begin
    MessageBox(FrmlstMesas.Handle,Pchar(VNombreUsuario+', no hay datos para mostrar'),'Aviso',MB_OK+MB_APPLMODAL+MB_ICONINFORMATION);
    COMBOMESA.SetFocus;
    SqlComi.Active := False;
    IbTr.RollBack;
    IbTr.Active:=False;
   End
 Else
  If PrintDialog1.execute then
   Begin
    FormPreview:=tFormPreview.create(self);
    largopagina:= 1.5;
    Imagen := TMetaFile.Create;
    Imagen.LoadFromFile(vUnidad+'\actas_volantes.wmf');
    FormPreview.VistaPrevia1.PaperSize:=Legal;
    FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21.54,35.56,Imagen,GmCentimeters);
    tipoexamen:= 'FINAL';
    if (vcarrera='BAC') or (vcarrera='333') then
       tipoexamen:=InputBox('Tipo de examen','Ingrese el tipo de examen de la mesa (LIBRES/PREVIOS)','LIBRES');
    While not SqlComi.eof do
     begin
      if not sqldatos.active then
        begin
         SqlDatos.SQLs.SelectSQL.Text:='SELECT PERM_EXA, COD_ALU, APELLIDO, NOM_APE '+
                                       'FROM XXX_MESAS_ALUMNOS('+COMBOMESA.Text+','+#39+vcarrera+#39+')';

         SqlDatos.Active:=True;
         SqlDatos.FetchAll;
        end;
      FormPreview.VistaPrevia1.BeginUpdate;
      // **** INICIO DEL ENCABEZADO ***//
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 9;
      FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
      LargoPagina:=LargoPagina+0.7;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,VCarreraLarga,GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'ACTA DE EXAMEN '+UpperCase(tipoexamen),GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Asignatura: '+SqlComi.FieldByName('DESCRIPCI').AsString,GmCentimeters);
      LargoPagina:=LargoPagina+0.5;
      if not((SqlComi.FieldByName('CUTUCO').IsNull) or (SqlComi.FieldByName('CUTUCO').value<100)) then
         FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Cuat.: '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'    Turno: '+Turnos(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),2,1)))+'     Divisi: '+Division(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),3,1)))+'      Mesa: '+ComboMesa.Text,GmCentimeters)
      else
         FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'  Mesa: '+ComboMesa.Text,GmCentimeters);
      LargoPagina:=LargoPagina+0.5;
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 7;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Correspondiente al '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'ｺ CUATRIMESTRE de estudios',GmCentimeters);
      LargoPagina:=LargoPagina+0.55;
      FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(2.2,LargoPagina,SqlComi.FieldByName('DIA').value,GmCentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(5.2,LargoPagina,funciones.MesALetras(sqlcomi.FieldByName('MES').value),GmCentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(6.9,LargoPagina,SqlComi.FieldByName('ANIO').value,GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(11.5,LargoPagina,SqlComi.FieldByName('DOCENTE').AsString,GmCentimeters);
      // **** FIN DEL ENCABEZADO ***//
      // **** INICIO DEL DETALLE ***//
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
      FormPreview.VistaPrevia1.Canvas.Font.Style := [];
      LargoPagina := 7.8;
      //llenar los parametro de sqlcursada y ejecutarlo
      While (not SqlDatos.eof) and  (largopagina<=28)  do
       begin
           contareg:=contareg+1;
           //TOMA DATOS DE LA BD
           FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
           FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
           FormPreview.VistaPrevia1.Canvas.Font.Style := [];
           FormPreview.VistaPrevia1.Canvas.FloatOut(3.1,largopagina,SqlDatos.FieldByName('PERM_EXA').AsInteger,'0',gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.TextOut(3.4,largopagina,SqlDatos.FieldByName('COD_ALU').AsString,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.TextOut(5.9,largopagina,SqlDatos.FieldByName('APELLIDO').AsString + ', ' + SqlDatos.FieldByName('NOM_APE').AsString ,gmcentimeters);
           LargoPagina := LargoPagina + 0.9;
           SqlDatos.next;
       end;
        FormPreview.VistaPrevia1.EndUpdate;
        if SqlDatos.eof then
         Begin
           SqlDatos.Active:=False;
           SqlComi.Next;
           sw:=0;
           contareg:=1;
         end;
        if (not sqlcomi.Eof) or (largopagina>28) then begin
          FormPreview.VistaPrevia1.Newpage;
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21.54,35.56,Imagen,GmCentimeters);
        end;
        LargoPagina := 1.5;
     end; //end del while sqlcomi
     FormPreview.VistaPrevia1.CurrentPage := 1;
     FormPreview.ShowModal;
     FormPreview.Free;
     CoMBOMESA.SetFocus;
  end;
  SqlDatos.Active:=False;
  SqlComi.Active:=False;
  If IbTr.Active then
      IbTr.RollBack;
  IbTr.Active:=False;
end;

procedure TFrmlstMesas.salirClick(Sender: TObject);
begin
  Close
end;


procedure TFrmlstMesas.OpcionesClick(Sender: TObject);
begin
  PrintSetup.Execute;
end;

procedure TFrmlstMesas.CodigoMateriaKeyPress(Sender: TObject;
  var Key: Char);
begin
 if key=#13 then
    Imprimir.SetFocus;
end;

procedure TFrmlstMesas.ComboMesaButtonClick(Sender: TObject);
Var Text1,Text2:String;
begin
  Funciones.combobusqueda('SELECT M.MESA, M.FECH_EXA,M.HORA, A.DESCRIPCI FROM MESAS M LEFT OUTER JOIN MATERIAS A ON M.COD_MAT=A.CODMATERI AND A.CODCARRE=M.CARRE WHERE M.CARRE='''+VCARRERA+''' ORDER BY M.MESA',['Mesa','Fecha','Hora','Materia'],Text1,Text2,0,1,True);
  ComboMesa.Text:=Text1;
  NombreMat.Caption:=Text2;
end;

procedure TFrmlstMesas.ComboMesaExit(Sender: TObject);
Var Text1,Text2:String;
begin
  Text1:='';
  if (Combomesa.Text<>'') Then Begin
      Funciones.combobusqueda('SELECT M.MESA, M.FECH_EXA,M.HORA, A.DESCRIPCI FROM MESAS M LEFT OUTER JOIN MATERIAS A ON M.COD_MAT=A.CODMATERI AND A.CODCARRE=M.CARRE WHERE M.CARRE='+#39+VCARRERA+#39+'AND M.MESA='+Combomesa.Text+' ORDER BY M.MESA',['Mesa','Fecha','Hora','Materia'],Text1,Text2,0,1,False);
      If (Text1='') then begin
         MessageBox(FrmlstMesas.Handle,'Codigo Incorrecto','Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
         Combomesa.SetFocus;
      end
      else begin
         Combomesa.Text:=Text1;
         NombreMat.Caption:=Text2;
      end
  end
end;

end.