procedure Tmesasexamenes.FormActivate(Sender: TObject);
begin

   MesasExamenes.Height := 405;
   With CustomerData Do
      Begin
         If (TrDsVarios.Active) then begin
             TrDsVarios.Rollback;
             IbdsVarios.Active:=False;
         end;
         IBdsVarios.SQLs.SelectSQL.Text:='';
         IBdsVarios.SQLs.SelectSQL.Text := 'SELECT M.COD_MAT, A.SIGLA, M.CARRE,M.MESA,M.LLAMADO,M.FECH_EXA,M.HORA,M.TITULAR,M.VOCAL1, '+
                                           '       M.VOCAL2,M.AULA,M.CUATRIM,M.COMI1,M.COMI2,M.COMI3,M.USUARIO,M.NREG, '+
                                           '       M.TIPMES, T.DESCRI '+
                                           'FROM MESAS M '+
                                           'LEFT OUTER JOIN MATERIAS A ON A.CODMATERI=M.COD_MAT AND A.CODCARRE=M.CARRE '+
                                           'LEFT OUTER JOIN MESA_TIPO T ON T.CODIGO=M.TIPMES '+
                                           'WHERE M.CARRE = '''+vcarrera+''' '+
                                           'ORDER BY M.MESA,M.COD_MAT ';
         IBDsvARIOS.Active:=tRUE;
         TrDsVarios.Active:=True;
          If IBDsVarios.RecordCount = 0 Then
           Begin
             ModificaMesa.Enabled := False;
             EliminaMesa.Enabled := False;
           End;
      End;
end;

