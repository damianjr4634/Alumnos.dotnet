procedure Tmesasexamenes.GrabamesaClick(Sender: TObject);
begin
{
    PASAR ZLIB
  if CbTipo.Text='' then begin
    ShowMessage('Falta tipo de mesa');
    exit;
  end;


  if MessageDlg(Pchar(VNombreUsuario + ', grabas la mesa de examen?'),mtConfirmation,[mbyes,mbno],0,mbno)=mryes Then
    Begin
      With CustomerData Do
        Begin
          IBUpVarios.SQL.Clear;
          If Modificacion Then Begin

              IBUpVarios.SQL.Text := 'UPDATE MESAS SET COD_MAT=:COD_MAT,CARRE=:CARRE,MESA=:MESA,LLAMADO=:LLAMADO, '+
                                     'FECH_EXA=:FECH_EXA,HORA=:HORA,                                              '+
                                     'TITULAR=:TITULAR,VOCAL1=:VOCAL1,VOCAL2=:VOCAL2,AULA=:AULA,CUATRIM=:CUATRIM, '+
                                     'COMI1=:COMI1,COMI2=:COMI2,COMI3=:COMI3,USUARIO=:USUARIO,NREG=:NREG, TIPMES=:TIPMES '+
                                     'WHERE CARRE = :FCARRE AND MESA = :FMESA;';
              IBUpVarios.ParamByName('FCARRE').AsString      := VCARRERA;
              IBUpVarios.ParamByName('FMESA').AsInteger      := IBDsVarios.FieldByName('MESA').AsInteger;
           End
          Else
              IBUpVarios.SQL.Text := 'INSERT INTO MESAS (COD_MAT,CARRE,MESA,LLAMADO,FECH_EXA,HORA, '+
                                     '                    TITULAR,VOCAL1,VOCAL2,AULA,CUATRIM, '+
                                     '                    COMI1,COMI2,COMI3,USUARIO,NREG,TIPMES) '+
                                     ' VALUES (:COD_MAT,:CARRE,:MESA,:LLAMADO,:FECH_EXA,:HORA, '+
                                     ' :TITULAR,:VOCAL1,:VOCAL2,:AULA,:CUATRIM, '+
                                     ' :COMI1,:COMI2,:COMI3,:USUARIO,:NREG, :TIPMES);';
          IBUpVarios.ParamByName('COD_MAT').AsString    := Combomaterias2.Text;
          IBUpVarios.ParamByName('CARRE').AsString      := VCARRERA;
          IBUpVarios.ParamByName('MESA').AsInteger      := StrToInt(Mesa.Text);
          IBUpVarios.ParamByName('LLAMADO').AsInteger   := StrToInt(Llamado.Text);
          IBUpVarios.ParamByName('FECH_EXA').AsDateTime := Fecha.Date;
          if (hora.Text <> '') then
             IBUpVarios.ParamByName('HORA').Asinteger      := strtoint(Hora.Text);
          IBUpVarios.ParamByName('TITULAR').AsString    := ComboTitular.Text;
          IBUpVarios.ParamByName('VOCAL1').AsString     := ComboVocal1.Text;
          IBUpVarios.ParamByName('VOCAL2').AsString     := ComboVocal2.Text;
          if (aula.text<>'') then
              IBUpVarios.ParamByName('AULA').AsInteger      := StrToInt(Aula.Text);
          if (trim(comision1.text)<>'') then
              IBUpVarios.ParamByName('COMI1').AsInteger     := StrToInt(Comision1.Text);
          if (trim(comision2.text)<>'') then
              IBUpVarios.ParamByName('COMI2').AsInteger     := StrToInt(Comision2.Text);
          if (trim(comision3.text)<>'') then
              IBUpVarios.ParamByName('COMI3').AsInteger     := StrToInt(Comision3.Text);
          IBUpVarios.ParamByName('USUARIO').AsInteger     := FuncionesConfiguracion.CodUsu;
          IBUpVarios.ParamByName('TIPMES').AsString     := CbTipo.Text;
          Try
             TRUpVarios.Active := True;
             IbUpVarios.ExecQuery;
             TRUpVarios.Commit;
          Finally
             If TRUpVarios.Active Then TrUpVarios.Rollback;
             TRUpVarios.Active := False;
             IF (TRQrVarios.Active) Then TrQrVarios.RollBack;
             TRQrVarios.Active := False;
             IBDsVarios.Active := False;
             TRQrVarios.Active := True;
             IBDsVarios.Active := True;
             CancelaGrabacionClick(Sender);
           End;
        End; // With
   End;
   }
end;

procedure Tmesasexamenes.modificaMesaClick(Sender: TObject);
begin
{
    PASAR ZLIB
  NuevaMesaClick(Sender);
  With CustomerData Do
    Begin
      ComboMaterias2.Text := IBDsVarios.FieldByName('COD_MAT').AsString;
      Mesa.Text           := IntToStr(IBDsVarios.FieldByName('MESA').AsInteger);
      Llamado.Text        := IntToStr(IBDSVarios.FieldByName('LLAMADO').AsInteger);
      Fecha.Date          := IBDSVarios.FieldByName('FECH_EXA').AsDateTime;
      Hora.Text           := IntToStr(IBDSVarios.FieldByName('HORA').AsInteger);
      comboTitular.Text   := IBDSVarios.FieldByName('TITULAR').AsString;
      comboVocal1.Text    := IBDSVarios.FieldByName('VOCAL1').AsString;
      comboVocal2.Text    := IBDSVarios.FieldByName('VOCAl2').AsString;
      Aula.Text           := IntToStr(IBDsVarios.FieldByName('AULA').AsInteger);
      Comision1.Text      := IntToStr(IBDSVarios.FieldByName('COMI1').AsInteger);
      Comision2.Text      := IntToStr(IBDSVarios.FieldByName('COMI2').AsInteger);
      Comision3.Text      := IntToStr(IBDsVarios.FieldByName('COMI3').AsInteger);
      CbTipo.Text         := IBDSVarios.FieldByName('TIPMES').AsString;
      CbTipo.OnExit(self);
      ComboMaterias2.OnExit(sender);
      Combotitular.OnExit(sender);
      Combovocal1.OnExit(sender);
      Combovocal2.OnExit(sender);
      Modificacion := True;
   End;
   }
End;

