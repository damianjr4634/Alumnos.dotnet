Function VerificoSiEsta(Combo:TComboBox;Codigo:AnsiString;princi, cont:Integer):Boolean;
Var
  x : Integer;
Begin
  VerificoSiEsta := False;
  For x:=0 To (Combo.Items.Count - 1) Do
   Begin
     If Princi = 0 Then
       Begin
         If codigo = Copy(Combo.Items.Strings[x],Length(Combo.Items.Strings[x])-2,cont) Then
           Begin
             VerificoSiEsta := True;
             Combo.ItemIndex := x;
           End
       End
     Else
       Begin
         If codigo = Copy(Combo.Items.Strings[x],1,cont) Then
          Begin
            VerificoSiEsta := True;
            Combo.ItemIndex := x;
          End
       End;
   End;
End;

