procedure Tmesasexamenes.FormKeyPress(Sender: TObject; var Key: Char);
begin
  If Key=#13 Then
     If not (ActiveControl is TDBGrid) then begin
        Key:=#0;
        Perform(WM_NEXTDLGCTL,0,0);
     end
     else if (activecontrol is TDbgrid) then
            With TDBGRID(ActiveControl) do
               If Selectedindex < (Fieldcount-1) then
                  SelectedIndex := SelectedIndex+1
               else
                  SelectedIndex :=0;
end;

procedure Tmesasexamenes.MesaExit(Sender: TObject);
begin
{
    PASAR ZLIB
   If Mesa.Text = '' Then begin
      MessageDlg(Pchar(VNombreUsuario + ', ingrese un número de mesa!'),mtError,[mbok],0,mbok);
      Mesa.SetFocus;
   end
   Else
      Begin
        If ((Modificacion) And (StrToInt(Mesa.Text) <> CustomerData.IBdsVarios.FieldByName('MESA').AsInteger)) Or
           (Not Modificacion) Then
          Begin
               CustomerData.IBValidacion.Sql.Clear;
               CustomerData.IBValidacion.SQL.Text := 'SELECT ERRCOD, ERRMSG FROM XXX_VALIDO_MESA(:MESA,:CARRE);';
               CustomerData.IBValidacion.ParamByName('MESA').Value := Mesa.Text;
               CustomerData.IBValidacion.ParamByName('CARRE').Value := VCarrera ;
               CustomerData.TRValidacion.Active := True;
               CustomerData.IBValidacion.Execquery;
               If (CustomerData.IBValidacion.FieldByName('ERRCOD').Value <> 0) Then
                    MessageDlg(Pchar(VNombreUsuario+', '+CustomerData.IBValidacion.FieldByName('ERRMSG').AsString),mtError,[mbok],0,mbok);
               CustomerData.TRValidacion.Rollback;
          End
      End;
      }
end;

