procedure TFrmModiInaComi.GrillaColExit(Sender: TObject);
Var b:Variant;
begin
 IF (grilla.SelectedField.FullName='CODFAL') and not (MtFaltas.FieldByName('CODFAL').Isnull) then begin
     FuncionesDB.combobusqueda('SELECT FCODIGO, FDESCRI, FCANTID FROM TBL_FALTAS WHERE FCODIGO='+#39+MtFaltas.FieldByName('CODFAL').value+#39+' AND (CARRE IS NULL OR CARRE CONTAINING '''+VCarrera+''')',['Codigo','Descripcion','Cantidad'],b,False);
     If (vartostr(b[0])='') then begin
         MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
     end
     else begin
         if Not (mtFaltas.State=dsedit) then
             MtFaltas.edit;
         MtFaltas.FieldByName('CODFAL').AsString:=b[0];
         MtFaltas.FieldByName('DESFAL').AsString:=b[1];
         MtFaltas.FieldByName('CANTID').AsFloat:=b[2];//StrToFloat(text2);
     end
 end
 else IF (grilla.SelectedField.FullName='CUTUCO') and not (MtFaltas.FieldByName('CUTUCO').Isnull) then begin
     if (Vcarrera='333') or (Vcarrera='650') then
         FuncionesDB.combobusqueda('SELECT DISTINCT CUTUCO FROM COMARM WHERE CARRE='''+Vcarrera+''' AND CUA_ANIO='+FuncionesText.Cuatrimestre(vcarrera)+' AND CUTUCO='+IntToStr(MtFaltas.FieldByName('CUTUCO').Value),['Comision'],b,False)
     else
         FuncionesDB.combobusqueda('SELECT DISTINCT CUTUCO FROM COMARM WHERE COD_MAT='''+materia+''' AND CARRE='''+Vcarrera+''' AND CUA_ANIO='+FuncionesText.Cuatrimestre(vcarrera)+' AND CUTUCO='+IntToStr(MtFaltas.FieldByName('CUTUCO').Value),['Comision'],b,False);
     If (vartostr(b[0])='') then begin
         MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
     end
     else begin
         if Not (mtFaltas.State=dsedit) then
             MtFaltas.edit;
         MtFaltas.FieldByName('CUTUCO').AsInteger:=b[0];//StrToFloat(text2);
     end
 end
end;

procedure TFrmModiInaComi.MtFaltasCODFALSetText(Sender: TField;
  const Text: String);
var b:Variant;
begin
  if (text<>'') then begin
       sender.AsString:=UpperCase(text);
       FuncionesDB.combobusqueda('SELECT FCODIGO, FDESCRI, FCANTID FROM TBL_FALTAS WHERE FCODIGO='+#39+Sender.AsString+#39+' AND (CARRE IS NULL OR CARRE CONTAINING '''+VCarrera+''')',['Codigo','Descripcion','Cantidad'],b,False);
       If vartostr(b[0])='' Then begin
          if (MtFaltas.State in [DsInsert,DsEdit]) then begin
              MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
              Sender.AsString:='';
              abort;
          end
       end
       else begin
          Sender.AsString:=b[0];
          MtFaltas.FieldByName('DESFAL').AsString:=b[1];
          MtFaltasCantid.value:=b[2];//StrToFloat(Text2);
       end
  end
  else begin
        Sender.AsString:='';
        Abort;
  end
end;

procedure TFrmModiInaComi.MtFaltasCUTUCOSetText(Sender: TField;
  const Text: string);
var b:Variant;
begin
  if (text<>'') then begin
       sender.AsInteger:=StrToint(text);
       FuncionesDB.combobusqueda('SELECT DISTINCT CUTUCO FROM COMARM WHERE COD_MAT='''+materia+''' AND CARRE='''+Vcarrera+''' AND CUA_ANIO='+FuncionesText.Cuatrimestre(vcarrera)+' AND CUTUCO='+text,['Comision'],b,False);
       If vartostr(b[0])='' Then begin
          if (MtFaltas.State in [DsInsert,DsEdit]) then begin
              MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
              Sender.Value:=null;
              abort;
          end
       end
       else begin
          Sender.Value:=b[0];
       end
  end
  else begin
        Sender.Value:=null;
        Abort;
  end
end;

procedure TFrmModiInaComi.GrillaDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn;
  State: TGridDrawState);
begin
  with TDBGrid(Sender) do begin
      if SelectedRows.IndexOf(DataSource.Dataset.Bookmark) >= 0 then
        Canvas.Brush.Color := clPurple
      else if gdSelected in State then begin
        Canvas.Brush.Color := clHighlight;
        Canvas.Font.Color:=ClWhite;
      end
      else if (DataSource.Dataset.FieldByName('CANTID').Value <> 0) and not(DataSource.Dataset.FieldByName('CANTID').Isnull) then begin
          Canvas.Brush.Color := clYellow;
      end;
      DefaultDrawColumnCell(Rect,DataCol,Column,State);
    end;
end;

