procedure TFrmModiInaComi.FormActivate(Sender: TObject);
begin
  if (VCarrera = '333') or (VCarrera='650') then begin
    DsFaltas.SQLs.SelectSQL.Text:= 'SELECT F.CUTUCO, F.FECHA, F.CODFAL, T.FDESCRI, F.CANFAL '+
                                   'FROM FALTAS F '+
                                   'LEFT OUTER JOIN TBL_FALTAS T ON T.FCODIGO=F.CODFAL '+
                                   'WHERE F.CARRERA='''+vCARRERA+''' AND F.CODALU='''+CODALU+''' AND F.FECHA BETWEEN '''+DDE+''' AND '''+HTA+''' AND COD_MAT IS NULL ORDER BY 2,1'
  end
  else
    DsFaltas.SQLs.SelectSQL.Text:= 'SELECT F.CUTUCO, F.FECHA, F.CODFAL, T.FDESCRI, F.CANFAL '+
                                   'FROM FALTAS F '+
                                   'LEFT OUTER JOIN TBL_FALTAS T ON T.FCODIGO=F.CODFAL '+
                                   'WHERE F.CARRERA='''+vCARRERA+''' AND F.CODALU='''+CODALU+''' AND F.FECHA BETWEEN '''+DDE+''' AND '''+HTA+''' AND COD_MAT='''+materia+''' ORDER BY 2,1';
  if trfaltas.Active then
     TrFaltas.Rollback;
  trfaltas.Active:=true;
  DsFaltas.Active:=true;
  dsFaltas.First;
  mtfaltas.Active:=True;
  while not (dsfaltas.Eof) do begin
      MtFaltas.Append;
      MtFaltasFECHA.value:=DsFaltas.FieldByName('FECHA').Value;
      MtFaltasCUTUCO.value:=DsFaltas.FieldByName('CUTUCO').Value;
      MtFaltasDESFAL.value:=DsFaltas.FieldByName('FDESCRI').Value;
      MtFaltasCODFAL.Value:=DsFaltas.FieldByName('CODFAL').Value;
      MtFaltasCANTID.Value:=DsFaltas.FieldByName('CANFAL').Value;
      MtFaltas.Post;
      DsFaltas.Next;
  end;
  BtnEliminar.Enabled := DsFaltas.RecordCount<>0;
  TrFaltas.Rollback;
  trfaltas.Active:=False;
  DsFaltas.Active:=False;
  MtFaltas.First;
  grilla.Repaint;
end;
procedure TFrmModiInaComi.GrillaEditButtonClick(Sender: TObject);
Var b:variant;
begin
 IF (grilla.SelectedField.FullName='CODFAL')  then begin
     FuncionesDB.combobusqueda('SELECT FCODIGO, FDESCRI, FCANTID FROM TBL_FALTAS WHERE CARRE IS NULL OR CARRE CONTAINING '''+VCarrera+'''',['Codigo','Apellido','Cantidad'],b,True);
     if Not (mtFaltas.State=dsedit) then
        MtFaltas.edit;
     if (vartostr(b[0])<>'') then begin
        MtFaltas.FieldByName('CODFAL').AsString:=b[0];
        MtFaltas.FieldByName('DESFAL').AsString:=b[1];
        MtFaltas.FieldByName('CANTID').AsFloat:=b[2];//StrToFloat(text2);
     end;
 end
 else IF (grilla.SelectedField.FullName='CUTUCO')  then begin
     if (Vcarrera='333') or (Vcarrera='650') then
        FuncionesDB.combobusqueda('SELECT DISTINCT CUTUCO FROM COMARM WHERE CARRE='''+Vcarrera+''' AND CUA_ANIO='+FuncionesText.Cuatrimestre(vcarrera),['Comision'],b,True)
     else
        FuncionesDB.combobusqueda('SELECT DISTINCT CUTUCO FROM COMARM WHERE COD_MAT='''+materia+''' AND CARRE='''+Vcarrera+''' AND CUA_ANIO='+FuncionesText.Cuatrimestre(vcarrera),['Comision'],b,True);
     if Not (mtFaltas.State=dsedit) then
        MtFaltas.edit;
     if (vartostr(b[0])<>'') then begin
        MtFaltas.FieldByName('CUTUCO').AsInteger:=b[0];
     end;
 end;
end;

