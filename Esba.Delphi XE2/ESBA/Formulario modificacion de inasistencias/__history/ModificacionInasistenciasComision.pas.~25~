procedure TFrmModiInaComi.GrabamesaClick(Sender: TObject);
begin
  MtFaltas.First;
  if trfaltas.Active then
      TrFaltas.Rollback;

  trfaltas.Active:=false;
  if (Vcarrera='333') or (Vcarrera='650') then
    IbUpins.SQL.Text:=' DELETE FROM FALTAS WHERE COD_MAT IS NULL AND CARRERA='''+vCARRERA+''' AND CODALU='''+CODALU+''' AND FECHA BETWEEN '''+DDE+''' AND '''+HTA+''''
  else
    IbUpins.SQL.Text:=' DELETE FROM FALTAS WHERE COD_MAT='''+materia+''' AND CARRERA='''+vCARRERA+''' AND CODALU='''+CODALU+''' AND FECHA BETWEEN '''+DDE+''' AND '''+HTA+'''';
  trfaltas.Active:=True;
  ibupins.ExecQuery;
  //TRFALTAS.Commit;

  //trfaltas.Active:=false;
  IbUpins.SQL.Text:=' INSERT INTO FALTAS (CARRERA, CODALU, CUTUCO, FECHA, CODFAL, CANFAL,COD_MAT) '+
                    ' VALUES (:CARRERA, :CODALU, :CUTUCO, :FECHA, :CODFAL, :CANFAL, :COD_MAT) ';
  //trfaltas.Active:=True;
  while not mtfaltas.Eof do begin
     ibupins.ParamByName('CARRERA').Value:=vCARRERA;
     ibupins.ParamByName('CUTUCO').Value:=MtFaltasCutuco.value;
     ibupins.ParamByName('FECHA').Value:=MtFaltasFECHA.Value;
     ibupins.ParamByName('CODALU').Value:=CodAlu;
     ibupins.ParamByName('CODFAL').Value:=MtFaltasCODFAL.Value;
     ibupins.ParamByName('CANFAL').Value:=MtFaltasCANTID.Value;
     ibupins.ParamByName('COD_MAT').Value:=funcionesVariant.TextToNull(materia);

     ibupins.ExecQuery;
     mtfaltas.Next;
  end;
  trfaltas.Commit;
  trfaltas.Active:=false;
  MessageDlg(Pchar(VNombreUsuario + ', faltas grabadas'),mtInformation, [mbok],0,mbok);
  close;
end;

