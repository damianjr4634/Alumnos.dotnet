procedure TFrmImpresionEqTerc.ComboDocenteButtonClick(Sender: TObject);
Var b:Variant;
begin
  FuncionesDB.combobusqueda('SELECT CODPROFES, DOCENTE FROM DOCENTES WHERE FECHA_BAJ IS NULL ORDER BY 1',['Codigo','Nombre'],b,True);
  Combodocente.Text:=b[0];
  label2.Caption:=b[1];
end;

procedure TFrmImpresionEqTerc.ComboDocenteExit(Sender: TObject);
Var b:Variant;
begin
  if (Combodocente.Text<>'') Then Begin
      ComBodocente.Text:=Lpad(Combodocente.Text,3,'0');
      FuncionesDB.combobusqueda('SELECT CODPROFES, DOCENTE FROM DOCENTES WHERE FECHA_BAJ IS NULL AND CODPROFES='''+combodocente.Text+''' ORDER BY 1',['Codigo','Nombre'],b,False);
      If (vartostr(b[0])='') then begin
         MessageDlg('Cigo incorrecto',mtError,[mbok],0,mbok);
         Combodocente.SetFocus;
      end
      else begin
         Combodocente.Text:=b[0];
         label2.Caption:=b[1];
      end
  end
end;

