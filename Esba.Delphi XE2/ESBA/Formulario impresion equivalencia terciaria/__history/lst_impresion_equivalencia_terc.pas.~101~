begin
  QR:='SELECT A.COD_MAT, M.DESCRIPCI, A.FEQDOCE,A.FEQMATE,A.FEQCARRE,A.FEQINST FROM ANALITIC A LEFT OUTER JOIN MATERIAS M ON A.COD_MAT=M.CODMATERI AND M.CODCARRE=A.CARRE WHERE A.COD_ALU='#39+vcodalu+#39+' AND A.CARRE='#39+vcarrera+#39+' AND A.CONDICION='+#39'EQUIVALENCIA'+#39;
