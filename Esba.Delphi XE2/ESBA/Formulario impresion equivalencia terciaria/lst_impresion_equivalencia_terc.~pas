     FormPreview.VistaPrevia1.Canvas.TextOut(1.8,7.8,ds.fieldbyname('ALU').AsString,GmCentimeters);
     FormPreview.VistaPrevia1.Canvas.TextOut(1.8,8.3,VCarreraLarga,GmCentimeters);
     FormPreview.VistaPrevia1.Canvas.TextOut(1.8,9.3,ds.fieldbyname('DESCRIPCI').AsString,GmCentimeters);

     FormPreview.VistaPrevia1.EndUpdate;
     FormPreview.VistaPrevia1.Newpage;
     if (chb.Checked) then
        Imagen.LoadFromFile(vUnidad+'\Equivalencia_terciaria_cm_h2.wmf')
     else
        Imagen.LoadFromFile(vUnidad+'\Equivalencia_terciaria_h2.wmf');
     FormPreview.VistaPrevia1.PaperSize:=A4;
     FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21,29.5,Imagen,GmCentimeters);
     FormPreview.VistaPrevia1.BeginUpdate;
      // **** INICIO DEL ENCABEZADO ***//

    // esto lo hago proque si no me cambia la fuente y me cagaba la impresion //
     FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
     FormPreview.VistaPrevia1.Canvas.Font.Size := 6;
     FormPreview.VistaPrevia1.Canvas.Font.Style := [];
     FormPreview.VistaPrevia1.Canvas.TextOut(1,1,'.',GmCentimeters);
    // esto lo hago proque si no me cambia la fuente y me cagaba la impresion //

     FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
