     FormPreview.VistaPrevia1.Canvas.TextOut(3.1,13.8,txtmateriacursada.text,GmCentimeters);
     FormPreview.VistaPrevia1.Canvas.TextOut(3.1,14.4,'en '+txtcarreracursada.text,GmCentimeters);
