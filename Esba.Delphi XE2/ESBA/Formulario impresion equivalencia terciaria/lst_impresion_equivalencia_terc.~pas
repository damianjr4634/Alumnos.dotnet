     FormPreview.VistaPrevia1.Canvas.TextOut(13.0,4.5,'Buenos Aires, '+FormatDateTime('dd "de" MMMM "de" yyyy',date),GmCentimeters);
     FormPreview.VistaPrevia1.Canvas.TextOut(8.5,9.3,ds.fieldbyname('ALU').AsString,GmCentimeters);
     FormPreview.VistaPrevia1.Canvas.TextOut(12.8,9.8,ds.fieldbyname('DESCRIPCI').AsString,GmCentimeters);
