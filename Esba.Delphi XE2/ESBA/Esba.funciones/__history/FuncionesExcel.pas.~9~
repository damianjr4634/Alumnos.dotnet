     Barra.Step := 1;
     Barra.Smooth := True;
  Finally

  End;
  Try
    AppExcel:= TExcelApplication.Create(Nil);
  Except
    ShowMessage('Excel no se pudo iniciar.');
    Exit;
  End;
  Libro := AppExcel.Workbooks.Add('',0);
  TotalHojas:=Libro.Worksheets.Count;
  ContHojas:=1;
  While Not Sql.Eof Do
    Begin
      if VarIsEmpty(DatoCorte) or (Sql.FieldByName(FieldCorte).Value<>DatoCorte) then begin
          if totalhojas<conthojas then
             Libro.Sheets.Add(EmptyParam,Libro.Sheets[Libro.Sheets.Count],1,xlWorksheet,0);
