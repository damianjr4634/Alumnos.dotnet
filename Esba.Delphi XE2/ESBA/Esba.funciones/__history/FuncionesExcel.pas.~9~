unit FuncionesExcel;

interface

Uses
  SysUtils, Printers, Windows, GmTypes, GmPreview, Messages, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, Db, Grids, DBGrids, OleServer, ExcelXP, ComCtrls,
  busqueda,FIBDatabase, pFIBDatabase, FIBQuery,
  pFIBQuery, FIBDataSet, pFIBDataSet, Variants, kbmMemTable;


Procedure Exportar_Excel_DS(Sql:TpFIBDataSet); overload;
Procedure Exportar_Excel_DS(Sql:TpFIBDataSet;Fields:Array Of String; Titles: Array of String); overload;
Procedure Exportar_Excel_MT(MT:TKbmMemtable);
Procedure Exportar_Excel_DS_Hojas(Sql:TpFIBDataSet; Const FieldCorte, FieldNombreHoja:String; Fields:Array Of String; Titles: Array of String);

implementation

Procedure Exportar_Excel_MT(MT:TKbmMemtable);
Var
  FrmProgress: TForm;
  Barra : TProgressBar;
  AppExcel: TExcelApplication;
  Libro : _WORKBOOK;
  Hoja  : _WORKSHEET;
  x : Integer;
Begin
  Try
     Mt.First;
     FrmProgress := TForm.Create(Application);
     FrmProgress.Caption := 'Exportando.....0%';
     FrmProgress.Position := poDesktopCenter;
     FrmProgress.Width := 400;
     FrmProgress.Height := 60;
     FrmProgress.BorderStyle := bsDialog;
     FrmProgress.Show;
     Barra := TProgressBar.Create(FrmProgress);
     Barra.Parent := FrmProgress;
     Barra.Visible := True;
     Barra.Align := AlClient;
     Barra.Max := Mt.RecordCount;
     Barra.Min := 0;
     Barra.Step := 1;
     Barra.Smooth := True;
  Finally

  End;
  Try
    AppExcel:= TExcelApplication.Create(Nil);
  Except
    ShowMessage('Excel no se pudo iniciar.');
    Exit;
  End;
  Libro := AppExcel.Workbooks.Add('',0);
  Hoja  := Libro.Sheets[1] as _WORKSHEET;
  For x:= 0 to Mt.FieldCount-1 Do
    AppExcel.Cells.Item[1,Chr(X+65)] :=  Mt.Fields.Fields[x].DisplayLabel;
  While Not Mt.Eof Do
    Begin
      For x:= 0 to Mt.FieldCount-1 Do begin
        case Mt.Fields[x].DataType of
          ftString:
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  Mt.Fields[x].AsString;
          ftInteger, ftWord, ftSmallint, ftLargeint:
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  IntToStr(Mt.Fields[x].value);
          ftFloat, ftCurrency, ftBCD, ftSingle:
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  FloatToStr(Mt.Fields[x].value);
          ftDate:
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  FormatDateTime('mm/dd/yyyy', Mt.Fields[x].value);
          ftTime:
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  FormatDateTime('hh:nn:ss',Mt.Fields[x].value);
          ftDateTime:
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  FormatDateTime('dd/mm/yyyy hh:nn:ss',Mt.Fields[x].value);
          else
            AppExcel.Cells.Item[(Mt.RecNo+1),Chr(X+65)] :=  Mt.Fields[x].value;
        end;
      end;
      Mt.Next;
      Barra.StepIt;
      FrmProgress.Caption := 'Exportando.....'+FloatToStr(Int((Mt.RecNo/Barra.Max)*100))+'%';
      FrmProgress.Refresh;
    End;
  AppExcel.Visible[0] := True;
  AppExcel.Free;
  FrmProgress.Free;
End;

