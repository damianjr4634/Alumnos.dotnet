Function EditoNumero(Numero:String):String;
 Begin
  EditoNumero := Numero;
  Case Length(Numero) Of
   1..2: EditoNumero := Numero + ',00';
   3: EditoNumero := Numero + '0';
   4: EditoNumero := Numero;
  End;
 End;


Function Pos(Str1, Str2 :String):Integer;
var x,i:integer;
    sw:boolean;
    str3:string;
begin
   Sw:=False;
   Pos:=0;
   str3:='';
   For i:=1 to Length(str1)-Length(str2) do
    begin
     for x:=0 to Length(str2)-1 do
