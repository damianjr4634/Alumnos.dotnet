Function Corto(Texto:string;pos:Integer):Integer;
Var
     x : Integer;
Begin
    corto := 0;
    For x:= pos Downto 1 do
     If  texto[x] in [' ',',',';'] Then
       Begin
         Corto:=x;
         Break;
       End;
End;

Procedure Corto_en_espacio(Texto:string;inic,pos:Integer; Var texto2:String; Var y:Integer);
Var
    x : Integer;
Begin
    if inic>pos then begin
       texto2:='';
       y:=-1;
       exit;
    end;
    For x:=pos Downto inic do
     If  (texto[x]='') or (texto[x]=' ') Then
       Begin
         y:=x;
         Break;
       End;
    texto2:=copy(texto,inic,y);
End;

Function position(Texto:string;pos:integer;char:String):Integer;
Var
    x : Integer;
Begin
    position:=pos;
    For x:=pos downto 1  do
     If  (texto[x]=char) Then
       Begin
         position:=x;
         Break;
       End;
End;


Function EncriptoCadena2(Texto : String; signo:integer):String;
var
  Cont, x :Integer;
  Resultado : AnsiString;
begin
  Result := '';
  Cont:=1;
  For x:=1 To Length(Texto) Do
   Begin
     If (Cont Mod 3) = 0 Then
        Resultado := Resultado + chr(ord(texto[x])+ (5*signo));
     If (Cont Mod 3) = 1 Then
        Resultado := Resultado + chr(ord(texto[x])+ (1*signo));
     If (Cont Mod 3) = 2 Then
        Resultado := Resultado + chr(ord(texto[x])+ (3*signo));
     Cont := Cont + 1;
     If Cont = 15 Then
       Cont := 1;
   End;
  EncriptoCadena2:=Resultado;
End;

function MBoolToStr(const valor:boolean):string;
begin
  if valor then
    result:='S'
  else
    result:='N';
end;

Function LPad(cadena : string;numero : integer; caracter : Char) : string;
begin
  while Length(cadena) < numero do
      cadena := caracter + cadena;
  LPad := cadena;
end;

Function CampoenLista(campo, Lista : string):Boolean;
Var y:Integer;
    Strings: TStringList;
    Pasa:Boolean;
begin
   if lista='' then begin
      campoenlista:=true;
      exit;
   end;
   Pasa:=False;
   Strings := TStringList.Create;
   Assert(Assigned(Strings)) ;
   Strings.Clear;
   Strings.Delimiter := ';';
   Strings.DelimitedText := Lista;
   for y:=0 to strings.Count-1 do
       if campo=strings[y] then begin
          pasa:=true;
          break;
       end;
   Campoenlista:=Pasa;
end;

end.
