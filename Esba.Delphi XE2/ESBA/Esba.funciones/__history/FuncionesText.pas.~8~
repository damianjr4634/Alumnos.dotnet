function TextToArray(const s: string):TToArray;
var
  SLista: TStringList;
  Arreglo: array of String;
  Indice: Integer;
begin
  SLista := TStringList.Create;
  SLista.Delimiter := ','; // el separador que uses
  SLista.DelimitedText := s;  // la cadena a partir

  SetLength(Result, SLista.Count);
  for Indice := 0 to Pred(SLista.Count) do
    Result[Indice] := SLista[Indice];

  SLista.Free;
end;

Function PasoAMayusculas(Texto : String): String;
Var
  X:Integer;
  Letra:String[1];
  Texto2:String;
Begin
 Texto2 := '';
 For x:= 1 To Length(Texto) Do
  Begin
    Letra := UpperCase(Copy(Texto,x,1));
    If Letra = 'į' Then
      Letra := 'Į';
    If Letra = 'é' Then
      Letra := 'É';
    If Letra = 'ķ' Then
      Letra := 'Ķ';
    If Letra = 'ó' Then
      Letra := 'Ó';
    If Letra = 'ś' Then
      Letra := 'Ś';
    Texto2 := Texto2 + Letra;
  End;
  PasoAMayusculas := Texto2;
End;

