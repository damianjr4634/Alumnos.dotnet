procedure TFrmCargaPermisosWeb.MtPermisosSetText(Sender: TField;
  const Text: String);
var b:Variant;
begin
  if (text<>'') then begin
       sender.AsString:=UpperCase(text);
       if (Sender.FullName='COD_ALU') then begin
            mtPermisos.FieldByName('NOMBRE').AsString:=null;
            FuncionesDB.combobusqueda('SELECT COD_ALU, TRIM(NOM_APE)||'+#39+', '+#39'||TRIM(APELLIDO) AS NOMBRE FROM ALUMNOS WHERE CARRE='#39+VCARRERA+#39+' AND BAJA='#39+'N'+#39+' AND COD_ALU='+#39+text+#39+' ORDER BY 2',['Codigo','Apellido y Nombre'],b,False);
            mtPermisos.FieldByName('NOMBRE').AsString:=b[1];
       end else if (Sender.FullName='COD_MAT') then begin
            mtPermisos.FieldByName('CUTUCO').AsInteger:=null;//strToInt(text2);
            mtPermisos.FieldByName('MATERIA').Value:=null;
            FuncionesDB.combobusqueda('SELECT CODMAT, MATERIA, CUTUCO, FERRCOD, FERRMSG FROM XXX_MATERIAS_FINALES('+#39+MtPermisos.FieldByName('COD_ALU').AsString+#39','+#39+VCARRERA+#39+') WHERE CODMAT='+#39+text+#39,['Codigo','Nombre'],b,False);
       end else if (Sender.FullName='MESA') then begin
            MtPermisos.FieldByName('FECHA').AsDateTime:=null;
            FuncionesDB.combobusqueda('SELECT M.MESA, M.LLAMADO, M.FECH_EXA, M.HORA FROM MESAS M WHERE M.CARRE='+#39+VCARRERA+#39+'AND M.COD_MAT='+#39+MtPermisos.FieldByName('COD_MAT').Asstring+#39+' AND MESA='+#39+text+#39,['Mesa','Llamado','Fecha Exa.','Hora'],b,False);
            MtPermisos.FieldByName('FECHA').AsDateTime:=b[2];
       end;
       If vartostr(b[0])='' Then begin
          if (MtPermisos.State=DsInsert) then begin
              MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
              Sender.AsString:='';
              abort;
          end
       end
       else if (Sender.FullName='COD_MAT') then begin
            if (b[3]=2) then begin
                MessageDlg(Pchar(VNombreUsuario + vartostr(b[4])),mtInformation, [mbok],0,mbok);
                Sender.AsString:='';
                abort;
            end
            else if (b[3]=1) then begin
              if MessageDlg(Pchar(VNombreUsuario + vartostr(b[4])),mtConfirmation,[mbyes,mbno],0,mbyes)=mrno  Then begin
                  Sender.AsString:='';
                  abort;
              end
              else begin
                  Sender.AsString:=b[0];
                  mtPermisos.FieldByName('CUTUCO').AsInteger:=b[2];//strToInt(text2);
                  mtPermisos.FieldByName('MATERIA').Value:=b[1];
              end;
            end
            else if (b[3]=0) then begin
               Sender.AsString:=b[0];
               mtPermisos.FieldByName('CUTUCO').AsInteger:=b[2];//strToInt(text2);
               mtPermisos.FieldByName('MATERIA').Value:=b[1];
            end
       end
  end
  else begin
        case Sender.DataType of
          ftInteger:
              Sender.AsInteger:=0;
          else
              Sender.AsString:='';
        end;

        Abort;
  end
end;

procedure TFrmCargaPermisosWeb.GrabamesaClick(Sender: TObject);
var
  indice, i: integer;
begin
if (mtpermisos.State in [Dsinsert,DsEdit]) then
   MtPermisos.Post;
if (mtpermisos.RecordCount=0) then
  exit;
if MessageDlg(Pchar(VNombreUsuario + ', graba los permisos seleccionados?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then begin
    mtpermisos.First;
    trpermisos.Active:=True;
    for i:=0 to Grilla.SelectedRows.Count-1 do begin
        mtpermisos.GotoBookmark(Pointer(grilla.SelectedRows.Items[i]));
         IbupIns.SQL.Text:='INSERT INTO PERMEXA(PERM_EXA,MESA,LLAMADO,COD_ALU,APELLIDO,CUTUCO,' +
                             'CARRE,COD_MAT,FECH_EXA,FECH_EMI, NREG,USUARIO) '+
                             '             VALUES(:PERM_EXA,:MESA,:LLAMADO,:COD_ALU,:APELLIDO,' +
                             ':CUTUCO,:CARRE,:COD_MAT,:FECH_EXA,:FECH_EMI,:NREG,:USUARIO) returning indice; ';
         IbupIns.ParamByName('PERM_EXA').AsInteger  := MtPermisos.Fieldbyname('NUMPER').AsInteger;
         IbupIns.ParamByName('MESA').AsInteger      := MtPermisos.Fieldbyname('MESA').AsInteger;
         IbupIns.ParamByName('COD_ALU').AsString    := MtPermisos.Fieldbyname('COD_ALU').AsString;
         IbupIns.ParamByName('CUTUCO').AsInteger    := MtPermisos.FieldByName('CUTUCO').AsInteger;
         IbupIns.ParamByName('CARRE').AsString      := VCarrera;
         IbupIns.ParamByName('COD_MAT').AsString    := MtPermisos.Fieldbyname('COD_MAT').AsString;
         IbupIns.ParamByName('FECH_EMI').AsDateTime := Date();
         IbupIns.ParamByName('USUARIO').Value := funcionesConfiguracion.CodUsu;
         //IbUpIns.ExecQuery;
         //indice := IbUpIns.FieldByName('INDICE').AsInteger;
         IbupIns.SQL.Text:='UPDATE web_permexa wp SET wp.permexa_id=:indice WHERE wp.indice=:PERM_EXA; ';
         IbupIns.ParamByName('PERM_EXA').AsInteger:= MtPermisos.Fieldbyname('NUMPER').AsInteger;
         IbupIns.ParamByName('INDICE').AsInteger:= indice;

         //IbUpIns.ExecQuery;
    end;
    TrPermisos.Commit;
    TrPermisos.Active:=False;
    MessageDlg(Pchar(VNombreUsuario + ', permisos grabados'),mtInformation, [mbok],0,mbok);
    close;
end;
end;

procedure TFrmCargaPermisosWeb.CargaGrilla;
var
  query: string;
begin
  MTPermisos.Active:=false;
  MTPermisos.Active:=True;
  query:= 'select a.cod_alu, a.nom_ape as nombre, wp.cod_mat, m.descripci as materia, '+
          '       wp.cutuco, wp.fech_emi as fecha, wp.indice as numper, wp.mesa,  '+
          ' case when coalesce(trim(x.FERRMSG),'''') <> '''' then x.ferrmsg  '+
          ' when (exists(select 1 from analitic an where an.carre=wp.carre and an.cod_alu=a.cod_alu and an.cod_mat=wp.cod_mat)) then ''La meteria esta en el analitico'' '+
          ' when ca.TIPO = ''TER'' and (not exists(select 1 from cursada c where c.cod_alu=a.cod_alu and c.cod_mat=wp.cod_mat and trim(c.condicion)=''REGULAR'')) THEN ''La meteria no esta en condicion de regular'' '+
          ' end as ferrmsg '+
          ' from web_permexa wp '+
          ' left outer join carrera ca on ca.carre=wp.carre '+
          ' left outer join alumnos a on a.indice = wp.alumno_id '+
          ' left outer join materias m on m.codmateri=wp.cod_mat and m.codcarre = wp.carre '+
          ' left outer join XXX_MATERIAS_FINALES(A.cod_alu,wp.carre) x on x.CODMAT=wp.cod_mat '+
          'where wp.permexa_id is null and wp.carre = '''+VCarrera+'''';
  FuncionesDB.Carga_MemTable(query,MTPermisos,false);

end;

end.
