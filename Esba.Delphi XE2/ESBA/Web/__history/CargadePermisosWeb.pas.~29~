procedure TFrmCargaPermisosWeb.GrillaKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
Var b:Variant;
    x:integer;
begin
   IF (grilla.SelectedField.FullName='COD_ALU') and (key=VK_F1) then begin
       if Not (mtPermisos.State=dsInsert) then
          MtPermisos.Append;
       FuncionesDB.combobusqueda('SELECT COD_ALU, TRIM(APELLIDO)||'+#39+', '+#39'||TRIM(NOM_APE) AS NOMBRE FROM ALUMNOS WHERE CARRE='#39+VCARRERA+#39+' AND BAJA='#39+'N'+#39+' ORDER BY 2',['Codigo','Apellido y Nombre'],b,True);
       MtPermisos.FieldByName('COD_ALU').AsString:=b[0];
       MtPermisos.FieldByName('NOMBRE').AsString:=b[1];
   end
   else IF (grilla.SelectedField.FullName='COD_MAT') and (key=VK_F1) then begin
       if Not (mtPermisos.State=dsInsert) then
          MtPermisos.Append;
       FuncionesDB.combobusqueda('SELECT CODMAT, MATERIA, CONDICION, CUTUCO, FERRCOD, FERRMSG FROM XXX_MATERIAS_FINALES('+#39+MtPermisos.FieldByName('COD_ALU').AsString+#39','+#39+VCARRERA+#39+')',['Codigo','Nombre','Condicion'],b,True);
       if (b[4]=2) then begin
             MessageDlg( Pchar(VNombreUsuario + vartostr(b[5])),mtInformation, [mbok],0,mbok);
       end else if (b[4]=1) then begin
              if MessageDlg(Pchar(VNombreUsuario + vartostr(b[5])),mtConfirmation,[mbyes,mbno],0,mbyes)=mrno  Then
                  grilla.SelectedField.FieldName:='COD_MAT'
              else begin
                 MtPermisos.FieldByName('COD_MAT').AsString:=b[0];
                 MtPermisos.FieldByName('MATERIA').AsString:=b[1];
                 MtPermisos.FieldByName('CUTUCO').AsInteger:=b[3];
              end;
       end else if (b[4]=0) then begin
             MtPermisos.FieldByName('COD_MAT').AsString:=b[0];
             MtPermisos.FieldByName('CUTUCO').AsInteger:=b[3];
             MtPermisos.FieldByName('MATERIA').AsString:=b[1];
       end
   end
   else IF (grilla.SelectedField.FullName='MESA') and (key=VK_F1) then begin
       if Not (mtPermisos.State=dsInsert) then
          MtPermisos.Append;
       FuncionesDB.combobusqueda('SELECT M.MESA, M.LLAMADO, M.FECH_EXA, M.HORA, T.DESCRI FROM MESAS M LEFT OUTER JOIN MESA_TIPO T ON T.CODIGO=M.TIPMES WHERE M.CARRE='+#39+VCARRERA+#39+'AND M.COD_MAT='+#39+MtPermisos.FieldByName('COD_MAT').Asstring+#39,['Mesa','Llamado','Fecha Exa.','Hora', 'Tipo'],b,True);
       IF (vartostr(b[0])<>'') then begin
          MtPermisos.FieldByName('MESA').AsInteger:=b[0];
          MtPermisos.FieldByName('FECHA').AsDateTime:=b[2];
       end
   end
   else if (key=VK_RETURN) and ((vartostr(mtpermisos.FieldByName(grilla.SelectedField.FullName).value)<>'') or not (mtpermisos.FieldByName(grilla.SelectedField.FullName).Required)) then begin
      for x:=mtpermisos.Fields.IndexOf(Grilla.SelectedField)+1 to mtpermisos.FieldCount-1 do begin
        if not (Grilla.Columns.Items[x].ReadOnly) then begin
          Grilla.SelectedField:=MtPermisos.Fields.Fields[x];
          break;
        end
      end
   end
   else if key=VK_DELETE	then begin
      if MessageDlg(Pchar(VNombreUsuario + ', borra el permiso?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
         MtPermisos.Delete;
   end
end;

procedure TFrmCargaPermisosWeb.GrillaTitleClick(Column: TColumn);
begin
  if MtPermisos.IndexName = Column.FieldName then
    MtPermisos.IndexName:= Column.FieldName+'_DESC'
  else
    MtPermisos.IndexName:= Column.FieldName;
end;

