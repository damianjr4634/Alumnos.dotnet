procedure TConstanciadelAlumno2.LoadPlantilla(const FileName:String; aPaper : TGmPaperSize);
var
  Picture: TPicture;
begin
  if (CBmembrete.Checked) then begin
    Picture:= TPicture.Create;
    try
      if FileExists(UnidadPrograma+CARPETA_PLANTILLA+'\'+FileName+'.jpg') then begin
        picture.LoadFromFile(UnidadPrograma+CARPETA_PLANTILLA+'\'+FileName+'.jpg');
        if (aPaper = A4) then
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21,31.5,Picture.Graphic,GmCentimeters)
        else
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21,35,Picture.Graphic,GmCentimeters)
      end
      else if FileExists(UnidadPrograma+CARPETA_PLANTILLA+'\'+FileName+'.wmf') then begin
        picture.LoadFromFile(UnidadPrograma+CARPETA_PLANTILLA+'\'+FileName+'.wmf');
        if (aPaper = A4) then
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21,31.5,picture.Graphic,GmCentimeters)
        else
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21,35,picture.Graphic,GmCentimeters)
      end;
    finally
      Picture.Free;
    end;
  end;
end;

procedure TConstanciadelAlumno2.LoadPlantilla(const FileName:String);
begin
  LoadPlantilla(FileName,TGmPaperSize.A4);
end;

