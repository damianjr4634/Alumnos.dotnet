Procedure TConstanciadelAlumno2.Constancia;
var
  i, recno:integer;
begin
  DbMaterias.DataSource:=nil;
  DbResto.DataSource:=nil;
  recno:=0;
  Mt.Active:=False;
  Mt.Active:=true;
  DataModule.CustomerData.TRConstancia.Active:=True;
  DataModule.CustomerData.IBConstancia.Active:=True;
  DataModule.CustomerData.IBConstancia.FetchAll;
  While Not DataModule.CustomerData.IBConstancia.Eof Do
     Begin
        recno:=recno+1;
        With Datamodule.CustomerData.IBConstancia do
         Begin
           mt.Append;
           for I := 0 to FieldCount-1 do
              mt.FieldByName(Fields.Fields[i].FullName).Value:=Fields.Fields[i].Value;
           mt.Post;
           Next;
         End
  End;
  DbMaterias.DataSource:=Ds;
  DbResto.DataSource:=Ds;
  DataModule.CustomerData.TRConstancia.Rollback;
  DataModule.CustomerData.TRConstancia.Active:=False;
  DataModule.CustomerData.IBConstancia.Active:=False;
End;

