procedure TConstanciadelAlumno2.BitBtn1Click(Sender: TObject);
Const
 margen=1.80;
 sangria=1.80;
var
   x,cuatAct : Integer;
   Fila, FilaAnterior, largopagina : Real;
   Anio, Mes, Dia : Word;
   Nota: String;
   TextoSalida:WideString;
   sello, firmasecre,firmaRecto:TPicture;
   aPaper : TGmPaperSize;
begin
 if (CBmembrete.Checked) then
     ShowMessage('Las firmas de las autoridades solo salen con hoja oficio');

 Case FuncionesSystem.CustomMessageDialog('Tipo de papel?', mtConfirmation,
          [mbNo, mbYes], ['A4', 'Oficio']) of
       mrYes: aPaper := A4;
       mrNo:  aPaper := Legal;
       else exit;
  End;
  if (aPaper=A4) then
    largopagina:=26
  else
    largopagina:=28;

 If Dialogo.Execute Then Begin
  FormPreview := TFormPreview.Create(Self);
  sello:= TPicture.Create;

  firmasecre := TPicture.Create;
  firmaRecto := TPicture.Create;
  sello := TPicture.Create;

  FirmaSecre.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_secre.jpg');
  FirmaRecto.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_recto.jpg');
  Sello.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\sello2.jpg');
  try
    FormPreview.falumno:= CodigoAlumno;
    FormPreview.fcarre:=CarreraActiva;
    FormPreview.Ftitle:= 'ConstanciaMateriasAprobadas';
    if (aPaper = A4) then
      LoadPlantilla('membrete_con_direccion',aPaper)
    else
      LoadPlantilla('membrete_con_direccion_oficio',aPaper);

    With FormPreview.VistaPrevia1 Do Begin
  //    Title := 'Constancia de Materias Aprobadas';
      BeginUpdate;

      PaperSize := aPaper;

      Canvas.Pen.Width:=1;
      Canvas.Pen.Color:=ClWhite;
      With Canvas Do Begin
        Fila := 4.6;
        Font.Name := 'Arial';
        Font.Size := 12;
        Font.Style := [FsBold];
        TextOutCenter(11,fila,'CONSTANCIA DE MATERIAS APROBADAS',GmCentimeters);
        Fila  := Fila + 1;
        Font.Size := 1;
        Font.Style := [];
        DecodeDate(Date,Anio,Mes,Dia);
        TextOut(1,1,'.',gmcentimeters);
        Font.Size := 9;
        Font.Style := [];
        textosalida:= '    En Buenos Aires a los '+ IntToStr(Dia) +' días del mes de '+ Trim(MesALetras(Mes)) +' de '+IntToStr(Anio) +' se extiende la presente perteneciente al alumno/a '+
                      PasoAMayusculas(ApellidoNombre) +' - '+ PonePuntos(CodigoAlumno)+' correspondiente a la carrera '+ PasoAMayusculas(NombreCarrera)+'.';


        TextBox(2,fila,19,fila+2,textosalida,taLeftJustify,GmCentimeters);
        Canvas.Pen.Width:=8;
        Canvas.Pen.Color:=Clblack;
        Font.Size := 8;
        Fila := Fila + 2;
        FilaAnterior := Fila - 0.0;
        Rectangle(1.80,FilaAnterior ,20.00,Fila + 0.50, GmCentimeters);
        TextOut(2,fila,'Materia',gmcentimeters);
        TextOut(9,fila,'Condición',gmcentimeters);
        TextOut(11.30,fila,'Nota',gmcentimeters);
        TextOut(12.50,fila,'Fecha',gmcentimeters);
        TextOut(14.70,fila,'Instituto / Característica',gmcentimeters);
        Fila := Fila + 0.9;
        Mt.First;
        CuatAct := Mt.FieldByName('CUATRIM').Asinteger;
        MoveTo(1.80,fila,gmcentimeters);
        LineTo(2.30,fila,gmcentimeters);
        TextOut(2.50,Fila-0.2,LetrasCuat(CuatAct)+' Cuatrimestre/Año',gmcentimeters);
        MoveTo(6.40,fila,gmcentimeters);
        LineTo(20.00,fila,gmcentimeters);
        Fila := Fila + 0.20;
        While Not Mt.Eof Do Begin
               If Mt.FieldByName('CUATRIM').Asinteger <> CuatAct Then  Begin
                    Fila := Fila + 0.20;
                    CuatAct := Mt.FieldByName('CUATRIM').Asinteger;
                    MoveTo(1.80,fila,gmcentimeters);
                    LineTo(2.30,fila,gmcentimeters);
                    TextOut(2.50,Fila-0.2,LetrasCuat(CuatAct)+' Cuatrimestre/Año',gmcentimeters);
                    MoveTo(6.40,fila,gmcentimeters);
                    LineTo(20.00,fila,gmcentimeters);
                    Fila := Fila + 0.20;
               End;
               TextOut(2,fila,Mt.FieldByName('DESCRIPCI').AsString,gmcentimeters); //Nombre Materia
               If Mt.FieldByName('ANUAL').AsString = '*' Then
                    TextOut(9.00,fila,'---------- M A T E R I A  A N U A L ----------',GmCentimeters)
               else begin
                    If ((Mt.FieldByName('CONDICION').AsString <> 'EQUIVALENCIA') and  (Mt.FieldByName('CONDICION').AsString <> 'EXIMIDO')) Then  Begin
                        If Mt.FieldByName('CONDICION').AsString = '* ADEUDA *' Then //Condicion Alumno
                             TextOut(9.00,fila,'ADEUDA',gmcentimeters)
                        Else
                             TextOut(9.00,fila,Mt.FieldByName('CONDICION').AsString,gmcentimeters);
                        If Mt.FieldByName('NOTA').AsFloat <> 0 Then  Begin// nota
                             If Mt.FieldByName('NOTA').AsFloat=10 Then
                                 TextOut(11.30,fila,FormatFloat('0.00',Mt.FieldByName('NOTA').AsFloat),gmcentimeters)
                             Else
                                 TextOut(11.50,fila,FormatFloat('0.00',Mt.FieldByName('NOTA').AsFloat),gmcentimeters);
                        End Else
                             TextOut(11.20,fila,'------',gmcentimeters);
                        If Not VarIsNull(Mt.FieldByName('FECHA').value) Then
                             TextOut(12.50,fila,DateToStr(Mt.FieldByName('FECHA').AsDateTime),gmcentimeters)  //Fecha
                        Else
                             TextOut(12.50,fila,'--------------',gmcentimeters);
                        If Mt.FieldByName('INSTITUTO').AsString<> '' Then
                             TextOut(14.70,fila,Mt.FieldByName('INSTITUTO').AsString+' '+Mt.FieldByName('CARACT').AsString,gmcentimeters)  //Instituto
                        Else
                             TextOut(14.70,fila,'-------------------------------------------------',gmcentimeters);
                    End Else begin// else de aprobada por equivalencia
                         if (Mt.FieldByName('CONDICION').AsString = 'EXIMIDO') Then  Begin
                            TextOut(9.00,fila,Mt.FieldByName('EXIMDESC').AsString,gmcentimeters)

                         End
                         else if Not (VarIsNull(Mt.FieldByName('ACTINT').Value)) then
                             TextOut(9.00,fila,'APROBADA POR EQUIVALENCIA - Act. Interna N° '+Mt.FieldByName('ACTINT').AsString,gmcentimeters)
                         else if Not (VarIsNull(Mt.FieldByName('ACTDEGP').value)) then
                             TextOut(9.00,fila,'APROBADA POR EQUIVALENCIA - Act. D.G.E.G.P. N° '+ Mt.FieldByName('ACTDEGP').AsString,gmcentimeters);
                    end;
               end;
              Fila := Fila + 0.45;
              if (fila>=largopagina) then begin // por corte de hoja
                 Caja(1.80,FilaAnterior,20.00,Fila+0.20,formpreview.VistaPrevia1);
                 NewPage;
                 fila:=4.6;
                 filaanterior:=fila;
                 Font.Size := 1;
                 Font.Style := [];
                 TextOut(1,1,'.',gmcentimeters);
                 Font.Size := 8;
                 Font.Style := [];
                 if (aPaper = A4) then
                    LoadPlantilla('membrete_con_direccion',aPaper)
                else
                    LoadPlantilla('membrete_con_direccion_oficio',aPaper);
              end;
              Mt.Next;
        End; //end del while
        Canvas.Pen.Width:=8;
        Canvas.Pen.Color:=Clblack;
        Caja(1.80,FilaAnterior,20.00,Fila+0.20,formpreview.VistaPrevia1);
        TextOut(3.00,Fila+0.70,'Para ser presentada ante '+Antequien.text,gmcentimeters);

        fila:=fila+3.5;
        if (CBmembrete.Checked) and (aPaper=legal) then begin

           //x,y,x2,y2
            {  firma realcion de aspecto
               x - x2 = 4.5
               y - y2 = 2.5
            }
            Canvas.StretchDraw(2.5,fila,7,fila+2.5,firmaSecre.Graphic, GmCentimeters);

            Canvas.StretchDraw(14.5,fila,19,fila+2.5,firmaRecto.Graphic, GmCentimeters);

            {  sello realcion de aspecto
               x - x2 = 4.5
               y - y2 = 5.5
            }
            Canvas.StretchDraw(8,fila,12.5,fila+5.5,sello.Graphic, GmCentimeters);

            //fila:=fila+1.5;
            TextOut(margen+sangria-1.00,fila+1,FuncionesConfiguracion.Secretaria,GmCentimeters);
            TextOut(15,fila+1,FuncionesConfiguracion.Rector,GmCentimeters);
            fila:=fila+0.40;
            TextOut(margen+sangria,fila+1,'Secretaria',GmCentimeters);
            TextOut(16.40,fila+1,'Rectora',GmCentimeters);
            fila:=fila+0.20;
            TextOut(margen+8.00,(fila+3.2),'SELLO',GmCentimeters);

        end;
       End; // end del if que pregunta si es ADM
     EndUpdate;
   End;
 finally
  formpreview.VistaPrevia1.Repaint;
  FormPreview.ShowModal;
  FormPreview.Free;
  sello.Free;
  firmasecre.Free;
  firmarecto.Free;
 end;
End;

end;

Procedure TConstanciadelAlumno2.Impresion_Constancia_Examen(const Titu, Query, Tipo:String; confirma: boolean);
Const
 margen=1.80;
 sangria=1.80;
Var
 Cuat,Cont,x, largo, DondeCorto, VuelvoACortar, MaxCuat: Integer;
 fila : Real;
 Anio,Mes,Dia:Word;
 Acusigla, Todas, STRCuatAnio:String;
 textosalida:WideString;
 sw:Boolean;
 aIdioma: variant;
 sello, FirmaSecre, FirmaRecto:TPicture;
begin

if (MtCONDICION.AsString = '* ADEUDA *') or (MtCONDICION.AsString = 'CURSANDO') or (MtCONDICION.AsString = 'RECURSANDO') or (MtCONDICION.AsString = 'EQUIVALENCIA') or (MtCONDICION.AsString = 'PREVIA') then begin
  ShowMessage('en esta condicion no se puede imprimir la constancia');
  exit;

end;

if (CarreraActiva='333') or (CarreraActiva='650') then
  STRCuatAnio:=' AñO; '
else
  STRCuatAnio:= ' CUAT.; ';

if Query <> '' then begin

  With Datamodule.CustomerData do begin
       TrQrVarios.Active:=False;
       IbQrVarios.SQL.Text:=query;
       TrQrVarios.Active:=True;
       Ibqrvarios.ExecQuery;
       sw:=False;
       if (ibQrVarios.FieldByName('FERRCOD').AsInteger=1) then
          sw:=MessageDlg(pchar(ibQrVarios.FieldByName('FERRMSG').AsString),MtConfirmation,[mbyes,mbno],0,mbyes)=MrYES
       else if (ibQrVarios.FieldByName('FERRCOD').AsInteger=2) then
               MessageDlg(pchar(ibQrVarios.FieldByName('FERRMSG').AsString),MtError,[mbok],0,mbok)
       else if (ibQrVarios.FieldByName('FERRCOD').AsInteger=0) then
               sw:=True;
       maxcuat:=ibQrVarios.FieldByName('FCUATRI').AsInteger;
       TrqrVarios.Rollback;
       TrQrVarios.Active:=False;
   end;
  if not sw then
     exit;
end;

If Dialogo.Execute then Begin

   firmasecre := TPicture.Create;
   firmaRecto := TPicture.Create;
   sello := TPicture.Create;

   FirmaSecre.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_secre.jpg');
   FirmaRecto.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_recto.jpg');
   Sello.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\sello2.jpg');

   FormPreview := TFormPreview.Create(Self);
   FormPreview.falumno:= CodigoAlumno;
   try
     FormPreview.fcarre:=CarreraActiva;
     FormPreview.Ftitle:= Tipo;
     LoadPlantilla('membrete_con_direccion');
     With Imprimir.FormPreview.VistaPrevia1 Do Begin
       BeginUpdate;
        With Canvas Do Begin
          Pen.Width:=1;
          Pen.Color:=ClWhite;
          Font.Name := 'Arial';
          Font.Size := 12;
          Font.Style := [FsBold];
          fila:=5.00;
          DecodeDate(Date,Anio,Mes,Dia);
          TextOutCenter(11,Fila,titu,GmCentimeters);
          fila:=fila+2.00;
          Font.Size:= 11;
          Font.Style:=[];
          TextOut(margen,fila,'La Dirección del Instituto:',GmCentimeters);
          fila:=fila+1.00;
          With Datamodule.CustomerData do begin
             TrQrVarios.Active:=False;
             IbQrVarios.SQL.Text:='SELECT FPARRAFO FROM XXX_PARRAFO_CONSTANCIA('+#39+CODIGOALUMNO+#39+','+#39+CARRERAACTIVA+#39+','+#39+tipo+'-'+MtCODMAT.AsString+#39+')';
             TrQrVarios.Active:=True;
             Ibqrvarios.ExecQuery;
             textosalida:=ibQrVarios.FieldByName('FPARRAFO').AsString;
             textosalida:= textosalida + #13+#13+'Para ser presentada ante '+Antequien.text;
             TrqrVarios.Rollback;
             TrQrVarios.Active:=False;
          end;
          TextBox(margen,fila,19,fila+4,textosalida,taLeftJustify,GmCentimeters);
          fila:=fila+TextBoxHeight(19-margen,textosalida,GmCentimeters).AsCentimeters+1;

          fila:=fila+0.50;
          TextOut(margen,fila,'La presente certificación carecerá de valor si no estuviera firmada por las autoridades competentes.',GmCentimeters);
          fila:=fila+4.00;
          Font.Style := [FsBold];

          TextOut(margen+sangria-2.00,fila+0.5,FuncionesConfiguracion.Secretaria,GmCentimeters);

          TextOut(13,fila+0.5,FuncionesConfiguracion.Rector,GmCentimeters);

          fila:=fila+0.40;

          TextOut(margen+sangria,fila+0.5,'Secretaria',GmCentimeters);
          TextOut(16.40,fila+0.5,'Rectora',GmCentimeters);
          fila:=fila+0.20;

          if (confirma) then begin
            //x,y,x2,y2
            {  firma realcion de aspecto
               x - x2 = 4.5
               y - y2 = 2.5
            }


            Canvas.StretchDraw(2.5,(fila-3),7,(fila-3)+2.5,firmaSecre.Graphic, GmCentimeters);

            Canvas.StretchDraw(14.5,(fila-3),19,(fila-3)+2.5,firmaRecto.Graphic, GmCentimeters);

            {  sello realcion de aspecto
               x - x2 = 4.5
               y - y2 = 5.5
            }

            Canvas.StretchDraw(8,(fila-3),12.5,(fila-3)+5.5,sello.Graphic, GmCentimeters);
          end;

          TextOut(margen+8.00,(fila+2.5),'SELLO',GmCentimeters);

          fila:=fila+1;

        End;
       EndUpdate;
      End;
   finally
    formpreview.VistaPrevia1.Repaint;
    FormPreview.ShowModal;
    FormPreview.Free;
    firmasecre.free;
    firmaRecto.free;
    sello.free;
   end;
End;
end;


