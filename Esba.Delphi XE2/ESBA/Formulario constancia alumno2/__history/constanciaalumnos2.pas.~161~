Procedure TConstanciadelAlumno2.Impresion_Analitico_Pase(const Titu, Query, Tipo:String; confirma: boolean);
Const
 margen=1.80;
 sangria=1.80;
Var
 Cuat,Cont,x, largo, DondeCorto, VuelvoACortar, MaxCuat: Integer;
 fila : Real;
 Anio,Mes,Dia:Word;
 Acusigla, Todas, STRCuatAnio:String;
 textosalida:WideString;
 sw:Boolean;
 aIdioma: variant;
 sello, FirmaSecre, FirmaRecto:TPicture;
begin

if (CarreraActiva='333') or (CarreraActiva='650') then
  STRCuatAnio:=' AÑO; '
else
  STRCuatAnio:= ' CUAT.; ';

With Datamodule.CustomerData do begin
     TrQrVarios.Active:=False;
     IbQrVarios.SQL.Text:=query;
     TrQrVarios.Active:=True;
     Ibqrvarios.ExecQuery;
     sw:=False;
     if (ibQrVarios.FieldByName('FERRCOD').AsInteger=1) then
        sw:=MessageDlg(pchar(ibQrVarios.FieldByName('FERRMSG').AsString),MtConfirmation,[mbyes,mbno],0,mbyes)=MrYES
     else if (ibQrVarios.FieldByName('FERRCOD').AsInteger=2) then
             MessageDlg(pchar(ibQrVarios.FieldByName('FERRMSG').AsString),MtError,[mbok],0,mbok)
     else if (ibQrVarios.FieldByName('FERRCOD').AsInteger=0) then
             sw:=True;
     maxcuat:=ibQrVarios.FieldByName('FCUATRI').AsInteger;
     TrqrVarios.Rollback;
     TrQrVarios.Active:=False;
 end;
if not sw then
   exit;
If Dialogo.Execute then Begin

   firmasecre := TPicture.Create;
   firmaRecto := TPicture.Create;
   sello := TPicture.Create;

   FirmaSecre.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_secre.jpg');
   FirmaRecto.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\firma_recto.jpg');
   Sello.LoadFromFile(UnidadPrograma+CARPETA_FIRMAS+'\sello2.jpg');

   FormPreview := TFormPreview.Create(Self);
   FormPreview.falumno:= CodigoAlumno;
   try
     FormPreview.fcarre:=CarreraActiva;
     FormPreview.Ftitle:= Tipo;
     LoadPlantilla('membrete_con_direccion');
     With Imprimir.FormPreview.VistaPrevia1 Do Begin
       BeginUpdate;
        With Canvas Do Begin
          Pen.Width:=1;
          Pen.Color:=ClWhite;
          Font.Name := 'Arial';
          Font.Size := 12;
          Font.Style := [FsBold];
          fila:=5.00;
          DecodeDate(Date,Anio,Mes,Dia);
          TextOutCenter(11,Fila,titu,GmCentimeters);
          fila:=fila+2.00;
          Font.Size:= 11;
          Font.Style:=[];
          TextOut(margen,fila,'La Dirección del Instituto:',GmCentimeters);
          fila:=fila+1.00;
          With Datamodule.CustomerData do begin
             TrQrVarios.Active:=False;
             IbQrVarios.SQL.Text:='SELECT FPARRAFO FROM XXX_PARRAFO_CONSTANCIA('+#39+CODIGOALUMNO+#39+','+#39+CARRERAACTIVA+#39+','+#39+tipo+#39+')';
             TrQrVarios.Active:=True;
             Ibqrvarios.ExecQuery;
             textosalida:=ibQrVarios.FieldByName('FPARRAFO').AsString;
             TrqrVarios.Rollback;
             TrQrVarios.Active:=False;
          end;
          TextBox(margen,fila,19,fila+3,textosalida,taLeftJustify,GmCentimeters);
          fila:=fila+TextBoxHeight(19-margen,textosalida,GmCentimeters).AsCentimeters+1;
          Font.Style:=[FsUnderline,FsBold];
          TextOut(margen,fila,'DATOS CORRESPONDIENTES:',GmCentimeters);
          fila:=fila+1;
          Cuat:=1;
          Cont:=0;
          Acusigla:='';
          Todas:='';
          mt.First;
          while not Mt.Eof do Begin
              If (Mt.FieldByName('CUATRIM').Asinteger>MaxCuat) and (MaxCuat<>0) then
                 Break;
              If (Mt.FieldByName('CUATRIM').Asinteger<>Cuat) then Begin
                If Acusigla <> '' Then Begin
                   Acusigla := Copy(Acusigla,1,Length(Acusigla)-2);
                   If (Cont=5) AND (Cuat=1) then
                      Acusigla:='TODAS LAS ';
                   If (Cont=6) AND (Cuat<>1) then
                      Acusigla:='TODAS LAS ';
                   Todas:=Todas + Acusigla + ' DEL ' + UpperCase(LetrasCuat(Cuat)) + STRCuatAnio;
                End;
                Cont:=0;
                Cuat:=Mt.FieldByName('CUATRIM').Asinteger;
                Acusigla:='';
              End;
              If (Mt.FieldByName('CONDICION').AsString<>'EQUIVALENCIA') and  (Mt.FieldByName('CONDICION').AsString <> 'EXIMIDO') and ((Mt.FieldByName('CONDICION').AsString='* ADEUDA *') or (Mt.FieldByName('CONDICION').AsString='CURSANDO') OR (Mt.FieldByName('CONDICION').AsString='RECURSANDO') or (Mt.FieldByName('NOTA').AsFloat=0)) then Begin
                 Cont:=Cont + 1;
                 AcuSigla:=AcuSigla + Mt.FieldByName('SIGLA').AsString + ', ';
              End;
          Mt.Next;
          End;
          If Acusigla <> '' Then Begin
               Acusigla := Copy(Acusigla,1,Length(Acusigla)-2);
               If (Cont=5) AND (Cuat=1) then //
                 Acusigla:='TODAS LAS ';
               If (Cont=6) AND (Cuat<>1) then
                 Acusigla:='TODAS LAS ';
               Todas:=Todas + Acusigla + ' DEL ' + UpperCase(LetrasCuat(Cuat)) + STRCuatAnio
          End;
          Todas := Copy(Todas,1,Length(Todas)-2);
          Font.Size:=9;
          font.Style:=[];
          If Todas='' then
                textosalida:= '* Materias que adeuda: NINGUNA'
          Else
                textosalida:= '* Materias que adeuda: '+todas;
          TextBox(margen+1.00,fila,19,fila+4,textosalida,taLeftJustify,GmCentimeters);
          fila:=fila+TextBoxHeight(19-(margen+1),textosalida,GmCentimeters).AsCentimeters;
          Font.Size:=10;
          FuncionesDB.consulta('select idioma from carrera where carre='''+CarreraActiva+'''',aIdioma);
          if (VarToStr(aIdioma[0]) <> '')  then
             TextBox(margen+1.00,fila,19,fila+4,'* Idioma extranjero cursado: '+VarToStr(aIdioma[0]),taLeftJustify,GmCentimeters);

          fila:=fila+2.00;
          textosalida:='      A pedido del interesado se extiende la presente constancia, sin raspadura ni enmiendas, en Buenos Aires, '+
                       'a los ' + IntToStr(Dia) + ' días del mes de ' + MesALetras(Mes) + ' de ' + IntToStr(Anio)+', para ser presentado ante: '+Antequien.Text;
          TextBox(margen,fila,19,fila+2,textosalida,taLeftJustify,GmCentimeters);
          fila:=fila+TextBoxHeight(19-margen,textosalida,GmCentimeters).AsCentimeters+1;
          Font.Style := [];
          Font.Size:=8;
          TextOut(margen,fila,'La presente Resolución Ministerial permite el ingreso a Universidades a Nivel Nacional.-',GmCentimeters);
          fila:=fila+0.40;
          TextOut(margen,fila,'La presente constancia tiene validez por 90 días.-',GmCentimeters);
          fila:=fila+0.40;
          TextOut(margen,fila,'La presente certificación carecerá de valor si no estuviera firmada por las autoridades competentes.',GmCentimeters);
          fila:=fila+3.00;
          Font.Style := [FsBold];

          TextOut(margen+sangria-1.00,fila+0.5,FuncionesConfiguracion.Secretaria,GmCentimeters);
          TextOut(15,fila+0.5,FuncionesConfiguracion.Rector,GmCentimeters);
          fila:=fila+0.40;
          TextOut(margen+sangria,fila+0.5,'Secretaria',GmCentimeters);
          TextOut(16.40,fila+0.5,'Rectora',GmCentimeters);
          fila:=fila+0.20;

          if (confirma) then begin
            //x,y,x2,y2
            {  firma realcion de aspecto
               x - x2 = 4.5
               y - y2 = 2.5
            }


            Canvas.StretchDraw(2.5,(fila-3),7,(fila-3)+2.5,firmaSecre.Graphic, GmCentimeters);

            Canvas.StretchDraw(14.5,(fila-3),19,(fila-3)+2.5,firmaRecto.Graphic, GmCentimeters);

            {  sello realcion de aspecto
               x - x2 = 4.5
               y - y2 = 5.5
            }

            Canvas.StretchDraw(8,(fila-3),12.5,(fila-3)+5.5,sello.Graphic, GmCentimeters);
          end;

          TextOut(margen+8.00,(fila+2.5),'SELLO',GmCentimeters);

          fila:=fila+1;

        End;
       EndUpdate;
      End;
   finally
    formpreview.VistaPrevia1.Repaint;
    FormPreview.ShowModal;
    FormPreview.Free;
    firmasecre.free;
    firmaRecto.free;
    sello.free;
   end;
End;
end;


