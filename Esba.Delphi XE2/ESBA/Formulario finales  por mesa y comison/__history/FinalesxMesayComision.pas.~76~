                 Fecha2.Date := 0;
                 if (not mt.FieldByName('FECHA2').IsNull) then
                    Fecha2.Date := mt.FieldByName('FECHA2').AsDateTime;
                 IF (mt.FieldByName('FACTFIN2').IsNull) THEN
                   TxtLibroActa2.Text:=TxtLibroActa.Text
                 else
                   TxtLibroActa2.Text:= mt.FieldByName('FACTFIN2').Value;
                 TxtLibroActa2.Enabled:=True;
                 Nota2.Enabled := True;
                 Nota2.SetFocus;
              End
            Else If (mt.FieldByName('NUMFIN').AsFloat = 3) Then
              Begin
                 Nota1.Text := FloatToStr(mts.FieldByName('FINAL1').AsFloat);
                 Fecha1.Date := mt.FieldByName('FECHA1').AsDateTime;
                 TxtLibroActa1.Text:= mt.FieldByName('FACTFIN1').Value;
                 Nota2.Text := FloatToStr(mt.FieldByName('FINAL2').AsFloat);
                 Fecha2.Date := mt.FieldByName('FECHA2').AsDateTime;
                 TxtLibroActa2.Text:= mt.FieldByName('FACTFIN2').Value;

                 Nota3.Text := FloatToStr(mt.FieldByName('FINAL3').AsFloat);
                 Fecha3.Date := 0;
                 if (not mt.FieldByName('FECHA3').IsNull) then
                     Fecha3.Date := mt.FieldByName('FECHA3').AsDateTime;
