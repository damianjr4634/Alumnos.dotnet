       label7.Visible := False;
       label12.Visible := False;
       label13.Visible := False;
       TxtLibroActa2.Visible := False;
       TxtLibroActa3.Visible := False;
       Label4.Visible := False;
       label8.Visible := False;
  end;
  If (Carreras.CarreIndexOf(VCarrera).tipo='TER') Then begin

       If (mt.FieldByName('NUMFIN').value = 1) Then
          Begin
            Nota1.Text := FloatToStr(mt.FieldByName('FINAL1').AsFloat);
            Fecha1.Date := 0;
            if (not mt.FieldByName('FECHA1').IsNull) then
              Fecha1.Date :=mt.FieldByName('FECHA1').AsDateTime;

            IF (mt.FieldByName('FACTFIN1').IsNull) THEN
               TxtLibroActa1.Text:=TxtLibroActa.Text
            else
               TxtLibroActa1.Text:= mt.FieldByName('FACTFIN1').Value;
            TxtLibroActa1.Enabled:=True;
            Nota1.Enabled := True;
            Nota1.SetFocus;
          End
       Else
          Begin
            If (mt.FieldByName('NUMFIN').AsFloat = 2) Then
              Begin
                 Nota1.Text := FloatToStr(mt.FieldByName('FINAL1').AsFloat);
                 Fecha1.Date := mt.FieldByName('FECHA1').AsDateTime;
                 TxtLibroActa1.Text:= mt.FieldByName('FACTFIN1').Value;

