procedure TFinalesmesacom.FormClose(Sender: TObject;
  var Action: TCloseAction);
Var
  NotaAna : Real;
  FechaAna:TDate;
var
  ZConn: TZConnection;
  ZQuery: TZQuery;
begin
  ZQuery:= TZQuery.Create(nil);
  try
    zconn:= DataModuleZlib.GetConnection();
    ZQuery.Connection:= zconn;
     if  (mt.RecordCount<>0) and (MessageDlg(Pchar(VNombreUsuario + ', pasa todas notas introducidas a los archivos correspondiantes?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes)  Then
      Begin
          ZQuery.SQL.Text:='SELECT FERRCOD, FERRMSG FROM XXX_MESAS(:USUARIO) ';
          ZQuery.ParamByName('USUARIO').AsInteger:=FuncionesConfiguracion.Codusu;
          zconn.StartTransaction;
          ZQuery.Open;
          IF ZQuery.FieldByName('FERRCOD').AsInteger=1 Then Begin
              if MessageDlg(Pchar(ZQuery.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
                zconn.Commit
              else
                zconn.Rollback;
          End;
          IF ZQuery.FieldByName('FERRCOD').AsInteger=2 Then Begin
             MessageDlg(Pchar(ZQuery.FieldByName('FERRMSG').AsString),mtInformation, [mbok],0,mbok);
             zconn.Rollback;
          End;
          IF ZQuery.FieldByName('FERRCOD').AsInteger=0 Then Begin
             zconn.Commit;
          End;
          zQuery.Close;
          zConn.Disconnect;
      End;
  finally
    if zConn.Connected then begin
      zQuery.Close;
      zconn.Rollback;
      zConn.Disconnect;
    end;
    ZQuery.Free;
    zconn.Free;
  end;
end;

