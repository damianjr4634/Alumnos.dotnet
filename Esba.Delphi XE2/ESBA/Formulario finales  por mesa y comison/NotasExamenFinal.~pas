   VCodAlu := 'DNI25829686';//'DNI25682464'; //'DNI24997773'; //'DNI23453509';//'DNI22493865'; //'DNI24999589'; //'DNI33333333'
   VApellido := 'GUSTAVO MARCELO';
   VNombre := 'ERNESTO';
   VLibroMatriz := '12176';
   VInstituto := 'I. Estudios Superiores Bs. As.';
   VCaracteristica := 'A-781';
   VNombreUsuario := 'Damian';}
   //Hasta Aca
   MateriasCodigoAlumno.Text    := VCODALU;
   MateriasCarreraCursa.Text    := VCarrera;
