procedure TFinalesmesacom.GrabaNotaFinalClick(Sender: TObject);
Var codalu:String;
Begin
 codalu:=DataModule.CustomerData.IBdsVarios.FieldByName('COD_ALU').AsString;
 If (VCarrera = 'ASC') Or (VCarrera = 'RRP') Or (VCarrera = 'RRH') Or (VCarrera = 'ADM') Or (VCarrera = 'TAE') Or (VCarrera = 'TRH') Then
   GraboNotaASC(FinalesMesaCom);
 If (VCarrera = 'BAC') Or (Vcarrera = 'CNA') or (VCarrera = '333')  Then
   GraboNotaBAC(FinalesMesaCom);
 CancelaGrabacionClick(Sender);
 DataModule.CustomerData.IBdsVarios.Locate('COD_ALU',codalu,[]);
end;


