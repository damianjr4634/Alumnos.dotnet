  FechaAna:TDate;
begin
 If MessageBox(FinalesMesaCom.Handle, Pchar(VNombreUsuario + ', pasa todas notas introducidas a los archivos correspondiantes?'),'Aviso', MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)
     = IDYES Then
  Begin
   WITH DataModule.CustomerData do
    begin
      TRQrVarios.Active:=False;
      IBQrVarios.SQL.Clear;
      IBQrVarios.SQL.Text:='SELECT FERRCOD, FERRMSG FROM XXX_MESAS(:USUARIO) ';
      IBQrVarios.ParamByName('USUARIO').AsInteger:=Funciones.Codusu;
      TRQrVarios.Active:=True;
      IBQrVarios.ExecQuery;
      IF IBQrVarios.FieldByName('FERRCOD').AsInteger=1 Then
        Begin
          If MessageBox(FinalesMesaCom.Handle, Pchar(IBQrVarios.FieldByName('FERRMSG').AsString),'Aviso', MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)
                = IDYES Then
            TRQrVarios.Commit
          else
            TRQrVarios.Rollback;
        End;
      IF IBQrVarios.FieldByName('FERRCOD').AsInteger=2 Then
        Begin
         MessageBox(FinalesMesaCom.Handle, Pchar(IBQrVarios.FieldByName('FERRMSG').AsString),'Aviso', MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
         TRQrVarios.Rollback;
        End;
      IF IBQrVarios.FieldByName('FERRCOD').AsInteger=0 Then
        Begin
         TRQrVarios.Commit;
        End;
      TRQrVarios.Active:=False;
      IBQrVarios.SQL.Clear;
    end
  End;
  if CustomerData.TrDsVarios.Active then
         CustomerData.TrDsVarios.Rollback;
  CustomerData.IbDsVarios.Active:=False;
  CustomerData.IbDsVarios.SQLs.SelectSQL.Text:='';
end;

procedure TFinalesmesacom.NumMesaButtonClick(Sender: TObject);
Var b:Variant;
begin
  Funciones.combobusqueda('SELECT M.MESA,A.DESCRIPCI, M.FECH_EXA FROM MESAS M LEFT OUTER JOIN MATERIAS A ON A.CODMATERI=M.COD_MAT AND M.CARRE=A.CODCARRE WHERE M.CARRE='+#39+vcarrera+#39+' ORDER BY M.MESA',['Mesa','Materia','Fecha'],b,True);
  NumMesa.Text:=b[0];
  lblMesa.Caption:=b[1];
end;

procedure TFinalesmesacom.NumMesaExit(Sender: TObject);
Var b:Variant;
begin
  if (NumMesa.Text<>'') Then Begin
        Funciones.combobusqueda('SELECT M.MESA,A.DESCRIPCI FROM MESAS M LEFT OUTER JOIN MATERIAS A ON A.CODMATERI=M.COD_MAT AND M.CARRE=A.CODCARRE WHERE M.CARRE='+#39+vcarrera+#39+'AND M.MESA='+NumMesa.Text+'  ORDER BY M.MESA',['Mesa','Materia'],b,False);
      If (vartostr(b[0])='') then begin
         MessageBox(Finalesmesacom.Handle,'Codigo Incorrecto','Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
         NumMesa.SetFocus;
      end
      else begin
         NumMesa.Text:=b[0];
         LblMesa.Caption:=b[1];
      end
  end
end;



