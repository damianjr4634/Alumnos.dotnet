function TregularizacionMateriasXComision_nuevo.PostVal(const ZConn: TZConnection; const ZQuery: TZQuery):boolean;
var
  a: TToArray;
  paso: string;
begin

  try
    ZQuery.Sql.Text:='SELECT FERRCOD, FERRMSG, FBUTTONS FROM XXX_REGULARIZACION_MAT_POSTVAL('+#39+
                                       VCARRERA+#39+','+#39+
                                       mt.FieldByName('COD_ALU').Value+#39+','+
                                       #39+mt.FieldByName('COD_MAT').Value+#39+','+
                                       VarTosTr(FuncionesConfiguracion.CodUsu)+','''')';

    ZQuery.Open;
    If (ZQuery.FieldByName('FERRCOD').AsInteger=2) Then begin
      MessageDlg(PChar(VNombreUsuario + ', '+ZQuery.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
      zconn.Rollback;
    end
    else If (ZQuery.FieldByName('FERRCOD').AsInteger=1) Then begin
      if (MessageDlg(PChar(VNombreUsuario + ', '+ZQuery.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes) then
        zconn.Commit
      else
        zconn.Rollback;
    end
    else If (ZQuery.FieldByName('FERRCOD').AsInteger=0) Then begin
      if (ZQuery.FieldByName('FERRMSG').AsString<>'') then
        ShowMessage(ZQuery.FieldByName('FERRMSG').AsString);
      zconn.Commit;
    end
    else If (ZQuery.FieldByName('FERRCOD').AsInteger=3) Then begin
      a:= FuncionesText.TextToArray(ZQuery.FieldByName('FBUTTONS').AsString);

      if Length(a)=1 then
        Case FuncionesSystem.CustomMessageDialog(ZQuery.FieldByName('FERRMSG').AsString, mtConfirmation,
            [mbNo], a) of
          mrNo:     paso:=a[0];
          else begin result:=false; exit; end;
        end
      else  if Length(a)=2 then
        Case FuncionesSystem.CustomMessageDialog(ZQuery.FieldByName('FERRMSG').AsString, mtConfirmation,
            [mbYes, mbNo], a) of
          mrYes:    paso := a[0];
          mrNo:     paso := a[1];
          else begin result:=false; exit; end;
        end
      else  if Length(a)=3 then
        Case FuncionesSystem.CustomMessageDialog(ZQuery.FieldByName('FERRMSG').AsString, mtConfirmation,
            [mbYes, mbNo, mbCancel], a) of
          mrCancel: paso := a[2];
          mrYes:    paso := a[0];
          mrNo:     paso := a[1];
          else begin result:=false; exit; end;
        end;
      if FuncionesDB.ExecScriptMsg('SELECT FERRCOD AS ERRCOD, FERRMSG AS ERRMSG FROM XXX_REGULARIZACION_MAT_POSTVAL('+#39+
                                  VCARRERA+#39+','+#39+
                                  mt.FieldByName('COD_ALU').Value+#39+','+
                                  #39+mt.FieldByName('COD_MAT').Value+#39+','+
                                  VarTosTr(FuncionesConfiguracion.CodUsu)+','''+paso+''')') then
        zconn.Commit
      else
        zconn.Rollback;
    end;
  except
    on e:exception do begin
      zconn.Rollback;
      zquery.Close;
      ShowMessage(e.Message);
    end;
  end;

end;

Procedure TregularizacionMateriasXComision_nuevo.ValidoGrabaciondeMateria(const ZConn: TZConnection);
var
   codalu :String;
   ZQuery: TZQuery;
begin
  ZQuery:= TZQuery.Create(nil);
  try
    ZQuery.Connection:= zconn;
    codalu:=Mt.FieldByName('COD_ALU').Value;
    ZQuery.Sql.Text:='SELECT FERRCOD, FERRMSG FROM XXX_REGULARIZACION_MAT('+#39+VCARRERA+#39+','+#39+mt.FieldByName('COD_ALU').Value+#39+','+#39+mt.FieldByName('COD_MAT').Value+#39+','+#39+mt.FieldbyName('CONDICION').Value+#39+','+VarTosTr(FuncionesConfiguracion.CodUsu)+')';
    ZQuery.Open;
    If (ZQuery.FieldByName('FERRCOD').AsInteger=2) Then Begin
      MessageDlg(PChar(VNombreUsuario + ', '+ZQuery.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
      zconn.Rollback;
      LoadTable();
      Mt.Locate('COD_ALU',codalu,[loPartialKey]);
    End
    ELSE If (ZQuery.FieldByName('FERRCOD').AsInteger=1) and
           (MessageDlg(PChar(VNombreUsuario + ', '+ZQuery.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes) then begin

      Zconn.Commit;
      PostVal(zconn, zquery);
      LoadTable();
      Mt.Locate('COD_ALU',codalu,[loPartialKey]);
      CancelaGrabacionBACClick(nil);
    End
    else If (ZQuery.FieldByName('FERRCOD').AsInteger=0) then begin
      if (ZQuery.FieldByName('FERRMSG').AsString<>'') then
        ShowMessage(ZQuery.FieldByName('FERRMSG').AsString);
      zconn.Commit;
      PostVal(zconn, zquery);
      LoadTable;
      Mt.Locate('COD_ALU',codalu,[loPartialKey]);
      CancelaGrabacionBACClick(nil);
    end
    else begin
      zconn.Rollback;
      LoadTable();
      Mt.Locate('COD_ALU',codalu,[loPartialKey]);
    end;
  finally
    zquery.Close;
    ZQuery.Free;
  end;
end;

