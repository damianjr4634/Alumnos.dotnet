procedure TregularizacionMateriasXComision_nuevo.FormClose(Sender: TObject;
  var Action: TCloseAction);
Var
 Cod_Mat : String;
 ZConn: TZConnection;
  ZQuery: TZQuery;
begin
  ZQuery:= TZQuery.Create(nil);
  try
    zconn:= DataModuleZlib.GetConnection();
    ZQuery.Connection:= zconn;

     if MessageDlg(Pchar(VNombreUsuario + ', pasa todas notas introducidas a los archivos correspondiantes?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
      Begin
        ZQuery.SQL.Text := 'SELECT FERRCOD, FERRMSG FROM XXX_REGULARIZACION(:CARRE,:USUARIO)';
        ZQuery.ParamByName('CARRE').Value := Vcarrera;
        ZQuery.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
        zconn.StartTransaction;
        zquery.Open;
        If (zquery.FieldByName('FERRCOD').Value=0) then
             zconn.Commit
        Else If (zquery.FieldByName('FERRCOD').Value=1) then
               begin
                  if MessageDlg(Pchar(VNombreUsuario + zquery.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbno)=mryes Then
                    zconn.Commit
                  Else
                    zconn.Rollback;
               end
        Else If (zquery.FieldByName('FERRCOD').Value=2) then
               begin
                  MessageDlg(Pchar(VNombreUsuario + zquery.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
                  zconn.Rollback;
               end;
      End;
      zconn.StartTransaction;
      zquery.Sql.Text := 'DELETE FROM "$$$CURSADA" WHERE USUARIO = :USUARIO;';
      zquery.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
      zquery.Execsql;
      zconn.Commit;
      zconn.Disconnect;
  finally
    if zConn.Connected then begin
      zQuery.Close;
      zConn.Rollback;
      zConn.Disconnect;
    end;
    ZQuery.Free;
    zconn.Free;
  end;
end;

procedure TregularizacionMateriasXComision_nuevo.Graba333Click(Sender: TObject);
Var
  Nota1, Nota2, Nota3, Dic, Mar, Prom: Real;
  ZConn: TZConnection;
  ZQuery: TZQuery;
begin
  ZQuery:= TZQuery.Create(nil);
  try
    zconn:= DataModuleZlib.GetConnection();
    ZQuery.Connection:= zconn;
    If (NotaPrimerTri.Text = '') Then
         NotaPrimerTri.Text := '0';
    If (NotaSegundoTri.Text = '') Then
         NotaSegundoTri.Text := '0';
    If (NotaTercerTri.Text = '') Then
         NotaTercerTri.Text := '0';
    If (NotaDic.Text = '') Then
         NotaDic.Text := '0';
    If (NotaMar.Text = '') Then
         NotaMar.Text := '0';
    Prom := RoundTo(CalculaPromedio,-2);
    Promedio.Text := FloatTostr(RoundTo(Prom,-2));
    Nota1 := RoundTo(NotaPrimerTri.value,-2);
    Nota2 := RoundTo(NotaSegundoTri.value,-2);
    Nota3 := RoundTo(NotaTercerTri.value,-2);
    Dic   := RoundTo(NotaDic.value,-2);
    Mar   := RoundTo(NotaMar.value,-2);
    ZQuery.SQL.Text := 'UPDATE "$$$CURSADA" SET TP_EVA=:TP_EVA, TP_EVA2=:TP_EVA2, TP_EVA3=:TP_EVA3, CONDICION=:CONDICION, '+
                                        'FINAL1=:FINAL1, FINAL2=:FINAL2, PROM=:PROM , FEC_EVA1=:FEC_EVA1, FEC_EVA2=:FEC_EVA2, FEC_EVA3=:FEC_EVA3, '+
                                        'FAL_EVA1=:FAL_EVA1,FAL_EVA2=:FAL_EVA2,FAL_EVA3=:FAL_EVA3, FECHA1=:FECHA1, FECHA2=:FECHA2, NOTADIC=:NOTADIC, NOTAMAR=:NOTAMAR, FECHDIC=:FECHDIC, FECHMAR=:FECHMAR ' +
                                        'WHERE COD_ALU = :COD_ALU AND USUARIO = :USUARIO; ';
    ZQuery.ParamByName('TP_EVA').Value := Nota1;
    ZQuery.ParamByName('FAL_EVA1').Value := FaltasPrimerTri.Value;
    if (FechaPrimerTri.date<>0) then
       ZQuery.ParamByName('FEC_EVA1').Value := FechaPrimerTri.Date
    else
       ZQuery.ParamByName('FEC_EVA1').Clear;

    ZQuery.ParamByName('TP_EVA2').Value := Nota2;
    ZQuery.ParamByName('FAL_EVA2').Value := FaltasSegundoTri.Value;
    if (FechaSegundoTri.date<>0) then
        ZQuery.ParamByName('FEC_EVA2').Value := FechaSegundoTri.Date
    else
        ZQuery.ParamByName('FEC_EVA2').clear;


    ZQuery.ParamByName('TP_EVA3').Value := Nota3;
    ZQuery.ParamByName('FAL_EVA3').Value := FaltasTercerTri.Value;
    if (FechaTercerTri.date<>0) then
        ZQuery.ParamByName('FEC_EVA3').Value := FechaTercerTri.Date
    else
        ZQuery.ParamByName('FEC_EVA3').clear;

    ZQuery.ParamByName('NOTADIC').Value := Dic;
    if (FechaDic.date<>0) then
       ZQuery.ParamByName('FECHDIC').Value := FechaDic.Date
    else
       ZQuery.ParamByName('FECHDIC').clear;

    ZQuery.ParamByName('NOTAMAR').Value := Mar;
    if (FechaMar.date<>0) then
       ZQuery.ParamByName('FECHMAR').Value := FechaMar.Date
    else
       ZQuery.ParamByName('FECHMAR').clear;

    ZQuery.ParamByName('PROM').Value := Prom;
    ZQuery.ParamByName('COD_ALU').Value :=Mt.FieldByName('COD_ALU').Value;
    ZQuery.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;

    Zconn.StartTransaction;
    ZQuery.ExecSql;


    ValidoGrabaciondeMateria(zconn);
    loadTable;
  finally
    if zConn.Connected then begin
      zQuery.Close;
      zConn.Rollback;
      zConn.Disconnect;
    end;
    ZQuery.Free;
    zconn.Free;
  end;
end;

procedure TregularizacionMateriasXComision_nuevo.NotaSegundoParcialASCKeyPress(
  Sender: TObject; var Key: Char);
begin
  Valid(Key,NotaSegundoParcialASC.Text);
  If Key = #13 Then
   Begin
    If NotaPrimerParcialASC.Text = '' Then
       NotaPrimerParcialASC.Text :='0';
    If (NotaSegundoParcialASC.Text = '') or (NotaSegundoParcialASC.Text = '0') Then
       NotaSegundoParcialASC.Text := '0'
    Else begin
      If (((StrToFloat(NotaSegundoParcialASC.Text) >= 1) And (StrToFloat(NotaSegundoParcialASC.Text) <= 10)) or (StrToFloat(NotaSegundoParcialASC.Text) = 99))  Then
       Begin
        If (((StrToFloat(NotaPrimerParcialASC.Text) >= 1) And (StrToFloat(NotaPrimerParcialASC.Text) < 4)) or
           ((StrToFloat(NotaSegundoParcialASC.Text) >= 1) And (StrToFloat(NotaSegundoParcialASC.Text) < 4))) Or
           ((StrToFloat(NotaPrimerParcialASC.Text) = 99) Or (StrToFloat(NotaSegundoParcialASC.Text) = 99)) Then
          Begin
//           RecuperatorioASC.Enabled := True;
           RecuperatorioASC.SetFocus;
          End
        Else
          Begin
//            TotalHorasASC.Enabled := True;
            TotalHorasASC.SetFocus;
          End;
       End
    Else
      MessageDlg(Pchar(Vnombreusuario+', la nota tiene que estar comprendida entre 1 y 10.'),mtInformation, [mbok],0,mbok);
   end
  end
end;

