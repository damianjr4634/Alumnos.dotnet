Function TregularizacionMateriasXComision_nuevo.CalculaPromedio:Real;
Var Prom:Real;
begin
     Prom:=0;
     If ((NotaPrimerTri.Value = 99) and (NotaSegundoTri.value = 99) and (NotaTercerTri.Value = 99)) then
        Prom := 0;
     If ((NotaPrimerTri.value = 99) and (NotaSegundoTri.value<>99) and (NotaSegundoTri.value<>0) and (NotaTercerTri.value<>99) and (NotaTercerTri.value<>0)) then
        Prom := (NotaSegundoTri.value+NotaTercerTri.value)/2;
     If ((NotaPrimerTri.value<>99) and (NotaPrimerTri.value<>0) and (NotaSegundoTri.value=99) and (NotaTercerTri.value<>99) and (NotaTercerTri.value<>0)) then
        Prom := (NotaTercerTri.value+NotaPrimerTri.value)/2;
     If ((NotaPrimerTri.value<>99) and (NotaPrimerTri.value<>0) and (NotaSegundoTri.value<>99) and (NotaSegundoTri.value<>0) and (NotaTercerTri.value<>99) and (NotaTercerTri.value<>0)) then
        Prom := (NotaSegundoTri.value+NotaPrimerTri.value)/2;
     If ((NotaPrimerTri.value=99) and (NotaSegundoTri.value<>99) and (NotaSegundoTri.value<>0) and (NotaTercerTri.value=99)) then
        Prom := 0; //StrToFloat(NotaSegundoTri.Text);
     If ((NotaPrimerTri.value=99) and (NotaTercerTri.value<>99) and (NotaTercerTri.value<>0) and (NotaSegundoTri.value=99)) then
        Prom := 0; //StrToFloat(NotaTercerTri.Text);
     If ((NotaPrimerTri.value<>99) and (NotaPrimerTri.value<>0) and (NotaSegundoTri.value=99) and (NotaTercerTri.value=99)) then
        Prom := 0; //StrToFloat(NotaPrimerTri.Text);
     If ((NotaPrimerTri.value <> 99) and (NotaPrimerTri.value <> 0) and (NotaSegundoTri.value <> 99) and (NotaSegundoTri.value <> 0) and (NotaTercerTri.value <> 99) and (NotaTercerTri.value <> 0)) then
        Prom := (NotaPrimerTri.value+NotaSegundoTri.value+NotaTercerTri.value)/3;
     If ((NotaPrimerTri.value = 0) or (NotaSegundoTri.value = 0) or (NotaTercerTri.value = 0)) then
        Prom := -1;
     Result:=Prom;
end;



Procedure CambioSolapa(Carreras : TPageControl;ASC,ADM,RRP,RRH,BAC,CNA,T333: TTabSheet);
Begin
 If CarreIndexOf(VCarrera).regsolapa=0 Then Begin
   Carreras.ActivePageIndex := 0;
   Asc.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=1 Then Begin
   Carreras.ActivePageIndex := 1;
   ADM.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=2 Then Begin
   Carreras.ActivePageIndex := 2;
   Bac.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=3 Then Begin
   Carreras.ActivePageIndex := 3;
   RRP.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=4 Then Begin
   Carreras.ActivePageIndex := 4;
   RRH.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=5 Then Begin
   Carreras.ActivePageIndex := 5;
   CNA.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=6 Then Begin
   Carreras.ActivePageIndex := 6;
   T333.Enabled := True;
 End
End;

Procedure Valid(Var Key : Char; Texto:String);
Begin
 If Not (charinset(key,['0'..'9',Chr(8), Chr(7), Chr(13), chr(9),',','.'])) Then
    Key := #0;
 If (Key = '.') And (Length(Texto) = 0)Then
    Key := #0;
End;

Function BuscoMateria(CodigoMateria : String) : String;
Var x:Integer;
Begin
 For x:=1 to 50 Do
  If LMaterias[x].Codigo = CodigoMateria Then
     BuscoMateria := LMaterias[x].Nombre;
End;

