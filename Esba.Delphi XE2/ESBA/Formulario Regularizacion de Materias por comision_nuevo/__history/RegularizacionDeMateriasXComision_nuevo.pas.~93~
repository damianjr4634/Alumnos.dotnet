  nota1, nota2, recuperatorio : Real;
  mcondicion,codalu: String;
  ZConn: TZConnection;
  ZQuery: TZQuery;
begin
  ZQuery:= TZQuery.Create(nil);
  try
    zconn:= DataModuleZlib.GetConnection();
    ZQuery.Connection:= zconn;
     If NotaSegundoParcialRRP.Text = '' Then
         NotaSegundoParcialRRP.Text := '0';
     If NotaPrimerParcialRRP.Text = '' Then
         NotaPrimerParcialRRP.Text :='0';
     If RecuperatorioRRP.Text = '' Then
         RecuperatorioRRP.Text :='0';
     If TotalHorasRRP.Text = '' Then
         TotalHorasRRP.Text := '0';
     If SinJustificarRRP.Text = '' Then
         SinJustificarRRP.Text :='0';
     If JustificadasRRP.Text = '' Then
         JustificadasRRP.Text :='0';
     nota1  := StrToFloat(NotaPrimerParcialRRP.Text);
     nota2 := StrToFloat(NotaSegundoParcialRRP.Text);
     recuperatorio   := StrToFloat(RecuperatorioRRP.Text);

    //** GRABACION **//
    zquery.SQL.Text := 'UPDATE "$$$CURSADA" SET TP_EVA=:TP_EVA, TP_EVA2=:TP_EVA2, RECUP=:RECUP, CONDICION=:CONDICION, '+
                                        'TOT_HORAS=:TOT_HORAS, INASIST=:INASIST, JUSTIF=:JUSTIF                                        '+
                                        'WHERE COD_ALU = :COD_ALU AND USUARIO = :USUARIO; ';
    zquery.ParamByName('TP_EVA').Value := Nota1;
    zquery.ParamByName('TP_EVA2').Value := Nota2;
    zquery.ParamByName('RECUP').Value := Recuperatorio;
    zquery.ParamByName('TOT_HORAS').Value := StrToInt(TotalHorasRRP.Text);
    zquery.ParamByName('INASIST').Value :=  StrToInt(SinJustificarRRP.Text);
    zquery.ParamByName('JUSTIF').Value := StrToInt(JustificadasRRP.Text);

    zquery.ParamByName('COD_ALU').Value := mt.FieldByName('COD_ALU').Value;
    zquery.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
    Zconn.StartTransaction;
    ZQuery.ExecSql;


    ValidoGrabaciondeMateria(zconn);
    loadTable;
  finally
    if zConn.Connected then begin
      zQuery.Close;
      zConn.Rollback;
      zConn.Disconnect;
    end;
    ZQuery.Free;
    zconn.Free;
  end;
end;

