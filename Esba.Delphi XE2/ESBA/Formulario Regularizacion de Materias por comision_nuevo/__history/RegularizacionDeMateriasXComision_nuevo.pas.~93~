begin
  if (ComboMaterias.Text<>'') Then Begin
      ComBoMaterias.Text:=Lpad(ComboMaterias.Text,2,'0');
      FuncionesDB.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='+#39+VCARRERA+#39+' AND CODMATERI='+#39+ComboMaterias.Text+#39+' AND ESTADO<>'+#39+'B'+#39+' ORDER BY CODMATERI',['Codigo','Nombre'],b,False);
      If (vartostr(b[0])='') then begin
         MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
         BuscarComision.Enabled:=False;
         ComboMaterias.SetFocus;
      end
      else begin
         ComboMaterias.Text:=b[0];
         NombreMat.Caption:=b[1];
      end
  end
end;

