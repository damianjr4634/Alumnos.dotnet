procedure TregularizacionMateriasXComision_nuevo.modificacursadaClick(Sender: TObject);
Var
   Datos, totfaltas:Variant;
begin
 GroupBox3.Visible := True;
 regularizacionMateriasXComision_nuevo.Height := 630;
 ModificaCursada.Enabled := False;
 Salir.Enabled := False;
 GbAlumnos.Enabled := False;
 If CarreIndexOf(VCarrera).regsolapa=0 Then
  Begin
   totfaltas:=null;
   funcionesDB.Consulta('SELECT FALTAS, JUSTI FROM XXX_CONT_FALTAS('''+CustomerData.IBdsVarios.FieldByName('COD_ALU').Value+''', '''+Vcarrera+''', '''+ComboMaterias.Text+''', '+Cuatrimestre.text+')',totfaltas);
   NotaPrimerParcialASC.Text := FloatToStr(DataModule.CustomerData.IBDsVarios.FieldbyName('TP_EVA').AsFloat);
   NotaSegundoParcialASC.Text := FloatToStr(DataModule.CustomerData.IBDsVarios.FieldbyName('TP_EVA2').AsFloat);
   RecuperatorioASC.Text := FloatToStr(DataModule.CustomerData.IBDsVarios.FieldbyName('RECUP').Value);
   if DataModule.CustomerData.IBDsVarios.FieldbyName('TOT_HORAS').AsInteger=0 then
      TotalHorasASC.Text := TotalHoras.Text
   else
      TotalHorasASC.Text := IntToStr(DataModule.CustomerData.IBDsVarios.FieldbyName('TOT_HORAS').Value);

   if not VarIsNull(totfaltas)  then begin
      if DataModule.CustomerData.IBDsVarios.FieldbyName('INASIST').Value=0 then
        SinJustificarASC.Text := VarToStr(totfaltas[0])
      else
        SinJustificarASC.Text := IntToStr(DataModule.CustomerData.IBDsVarios.FieldbyName('INASIST').Value);
      if DataModule.CustomerData.IBDsVarios.FieldbyName('JUSTIF').Value=0 then
        JustificadasASC.Text := VarToStr(totfaltas[1])
