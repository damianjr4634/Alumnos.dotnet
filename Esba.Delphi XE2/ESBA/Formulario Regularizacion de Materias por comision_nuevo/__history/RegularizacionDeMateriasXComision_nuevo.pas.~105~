Function TregularizacionMateriasXComision_nuevo.CalculaPromedio:Real;
Var Prom:Real;
begin
     Prom:=0;
     If ((NotaPrimerTri.Value = 99) and (NotaSegundoTri.value = 99)) then
        Prom := 0;
     If ((NotaSegundoTri.value>6) and (NotaSegundoTri.value<>99)) then
        Prom := NotaSegundoTri.value;
     Result:=Prom;
end;

Procedure TregularizacionMateriasXComision_nuevo.ValidoGrabaciondeMateria;
var
   codalu :String;

  function PostVal:boolean;
  var
    a: TToArray;
    paso: string;
  begin
    try
      CustomerData.IBUpVarios.Sql.Text:='SELECT FERRCOD, FERRMSG, FBUTTONS FROM XXX_REGULARIZACION_MAT_POSTVAL('+#39+
                                         VCARRERA+#39+','+#39+
                                         CustomerData.IBdsVarios.FieldByName('COD_ALU').Value+#39+','+
                                         #39+CustomerData.IBdsVarios.FieldByName('COD_MAT').Value+#39+','+
                                         VarTosTr(FuncionesConfiguracion.CodUsu)+','''')';
      CustomerData.TRUpVarios.Active:=true;
      CustomerData.IBUpVarios.ExecQuery;
      If (CustomerData.IBupVarios.FieldByName('FERRCOD').AsInteger=2) Then begin
        MessageDlg(PChar(VNombreUsuario + ', '+CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
        CustomerData.TRUpVarios.Rollback;
      end
      else If (CustomerData.IBupVarios.FieldByName('FERRCOD').AsInteger=1) Then begin
        if (MessageDlg(PChar(VNombreUsuario + ', '+CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes) then
          CustomerData.TRUpVarios.Commit
        else
          CustomerData.TRUpVarios.Rollback;
      end
      else If (CustomerData.IBupVarios.FieldByName('FERRCOD').AsInteger=0) Then begin
        if (CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString<>'') then
          ShowMessage(CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString);
        CustomerData.TRUpVarios.Commit;
      end
      else If (CustomerData.IBupVarios.FieldByName('FERRCOD').AsInteger=3) Then begin
        a:= FuncionesText.TextToArray(CustomerData.IBUpVarios.FieldByName('FBUTTONS').AsString);
        {
        TMsgDlgBtn = (mbYes, mbNo, mbOK, mbCancel, mbAbort, mbRetry, mbIgnore,
      mbAll, mbNoToAll, mbYesToAll, mbHelp, mbClose);
       }
        if Length(a)=1 then
          Case FuncionesSystem.CustomMessageDialog(CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString, mtConfirmation,
              [mbNo], a) of
            mrNo:     paso:=a[0];
            else begin result:=false; exit; end;
          end
        else  if Length(a)=2 then
          Case FuncionesSystem.CustomMessageDialog(CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString, mtConfirmation,
              [mbYes, mbNo], a) of
            mrYes:    paso := a[0];
            mrNo:     paso := a[1];
            else begin result:=false; exit; end;
          end
        else  if Length(a)=3 then
          Case FuncionesSystem.CustomMessageDialog(CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString, mtConfirmation,
              [mbYes, mbNo, mbCancel], a) of
            mrCancel: paso := a[2];
            mrYes:    paso := a[0];
            mrNo:     paso := a[1];
            else begin result:=false; exit; end;
          end;
        if FuncionesDB.ExecScriptMsg('SELECT FERRCOD AS ERRCOD, FERRMSG AS ERRMSG FROM XXX_REGULARIZACION_MAT_POSTVAL('+#39+
                                    VCARRERA+#39+','+#39+
                                    CustomerData.IBdsVarios.FieldByName('COD_ALU').Value+#39+','+
                                    #39+CustomerData.IBdsVarios.FieldByName('COD_MAT').Value+#39+','+
                                    VarTosTr(FuncionesConfiguracion.CodUsu)+','''+paso+''')') then
          CustomerData.TRUpVarios.Commit
        else
          CustomerData.TRUpVarios.Rollback;
      end;
    except
      on e:exception do begin
        CustomerData.TRUpVarios.Rollback;
        CustomerData.IbupVarios.Close;
        ShowMessage(e.Message);
      end;
    end;
  end;

begin
  codalu:=CustomerData.IBdsVarios.FieldByName('COD_ALU').Value;
  CustomerData.IBUpVarios.Sql.Text:='SELECT FERRCOD, FERRMSG FROM XXX_REGULARIZACION_MAT('+#39+VCARRERA+#39+','+#39+CustomerData.IBdsVarios.FieldByName('COD_ALU').Value+#39+','+#39+CustomerData.IBdsVarios.FieldByName('COD_MAT').Value+#39+','+#39+Datamodule.CustomerData.IBdsVarios.FieldbyName('CONDICION').Value+#39+','+VarTosTr(FuncionesConfiguracion.CodUsu)+')';
  CustomerData.IBUpVarios.ExecQuery;
  If (CustomerData.IBupVarios.FieldByName('FERRCOD').AsInteger=2) Then Begin
    MessageDlg(PChar(VNombreUsuario + ', '+CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
    CustomerData.TRUpVarios.Rollback;
    CustomerData.TRUpVarios.Active := False;
    CustomerData.TRdsVarios.RollBack;
    CustomerData.TRdsVarios.Active := False;
    CustomerData.IBdsVarios.Active := False;
    CustomerData.IBdsVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
    CustomerData.TRdsVarios.Active := True;
    CustomerData.IBdsVarios.Active := True;
    CustomerData.IbDsVarios.LocateNext('COD_ALU',codalu,[loPartialKey]);
  End
  ELSE If (CustomerData.IBUpVarios.FieldByName('FERRCOD').AsInteger=1) and
         (MessageDlg(PChar(VNombreUsuario + ', '+CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes) then begin

    CustomerData.TRUpVarios.Commit;
    PostVal;
    CustomerData.TRUpVarios.Active := False;
    CustomerData.TRdsVarios.RollBack;
    CustomerData.TRdsVarios.Active := False;
    CustomerData.IBdsVarios.Active := False;
    CustomerData.IBdsVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
    CustomerData.TRdsVarios.Active := True;
    CustomerData.IBdsVarios.Active := True;
    CustomerData.IbDsVarios.LocateNext('COD_ALU',codalu,[loPartialKey]);
    CancelaGrabacionBACClick(nil);
  End
  else If (CustomerData.IBUpVarios.FieldByName('FERRCOD').AsInteger=0) then begin
    if (CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString<>'') then
      ShowMessage(CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString);
    CustomerData.TRUpVarios.Commit;
    PostVal;
    CustomerData.TRUpVarios.Active := False;
    CustomerData.TRdsVarios.RollBack;
    CustomerData.TRdsVarios.Active := False;
    CustomerData.IBdsVarios.Active := False;
    CustomerData.IBdsVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
    CustomerData.TRdsVarios.Active := True;
    CustomerData.IBdsVarios.Active := True;
    CustomerData.IbDsVarios.LocateNext('COD_ALU',codalu,[loPartialKey]);
    CancelaGrabacionBACClick(nil);
  end
  else begin
    CustomerData.TRUpVarios.Rollback;
    CustomerData.TRUpVarios.Active := False;
    CustomerData.TRdsVarios.RollBack;
    CustomerData.TRdsVarios.Active := False;
    CustomerData.IBdsVarios.Active := False;
    CustomerData.IBdsVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
    CustomerData.TRdsVarios.Active := True;
    CustomerData.IBdsVarios.Active := True;
    CustomerData.IbDsVarios.LocateNext('COD_ALU',codalu,[loPartialKey]);
  end;
end;

Procedure CambioSolapa(Carreras : TPageControl;ASC,ADM,RRP,RRH,BAC,CNA,T333: TTabSheet);
Begin
 If CarreIndexOf(VCarrera).regsolapa=0 Then Begin
   Carreras.ActivePageIndex := 0;
   Asc.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=1 Then Begin
   Carreras.ActivePageIndex := 1;
   ADM.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=2 Then Begin
   Carreras.ActivePageIndex := 2;
   Bac.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=3 Then Begin
   Carreras.ActivePageIndex := 3;
   RRP.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=4 Then Begin
   Carreras.ActivePageIndex := 4;
   RRH.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=5 Then Begin
   Carreras.ActivePageIndex := 5;
   CNA.Enabled := True;
 End
 else If CarreIndexOf(VCarrera).regsolapa=6 Then Begin
   Carreras.ActivePageIndex := 6;
   T333.Enabled := True;
 End
End;

Procedure Valid(Var Key : Char; Texto:String);
Begin
 If Not (charinset(key,['0'..'9',Chr(8), Chr(7), Chr(13), chr(9),',','.'])) Then
    Key := #0;
 If (Key = '.') And (Length(Texto) = 0)Then
    Key := #0;
End;

Function BuscoMateria(CodigoMateria : String) : String;
Var x:Integer;
Begin
 For x:=1 to 50 Do
  If LMaterias[x].Codigo = CodigoMateria Then
     BuscoMateria := LMaterias[x].Nombre;
End;

