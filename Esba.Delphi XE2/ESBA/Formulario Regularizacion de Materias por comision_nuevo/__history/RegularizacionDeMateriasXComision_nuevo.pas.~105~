procedure TregularizacionMateriasXComision_nuevo.NotaPrimerParcialASCKeyPress(
  Sender: TObject; var Key: Char);
begin
  Valid(Key,NotaPrimerParcialASC.Text);
  If Key = #13 Then
   Begin
     If (NotaPrimerParcialASC.Text = '') or ((NotaPrimerParcialASC.Text = '0')) Then
        NotaPrimerParcialASC.Text :='0'
     Else If ( (StrToFloat(NotaPrimerParcialASC.Text) >= 1) And (StrToFloat(NotaPrimerParcialASC.Text) <= 10) ) or (StrToFloat(NotaPrimerParcialASC.Text)=99) Then
       Begin
//        NotaSegundoParcialASC.Enabled := True;
        NotaSegundoParcialASC.SetFocus;
       End
     Else
       MessageDlg(Pchar(Vnombreusuario+', la nota tiene que estar comprendida entre 1 y 10.'),mtInformation, [mbok],0,mbok);
   End;
end;

