           If  (Bimestre1.Text <> '99') And  (Bimestre1.Text <> '99') Then
              Prom := (StrToInt(Bimestre1.Text)+StrToInt(Bimestre2.Text)) / 2;
           NotadefinitivaBAC.Text := FloatToStr((Prom + StrToInt(RecuperatorioBAC.Text)) / 2);
       End
       Else
          NotadefinitivaBAC.Text := FloatToStr(Prom);
   end;
end;

