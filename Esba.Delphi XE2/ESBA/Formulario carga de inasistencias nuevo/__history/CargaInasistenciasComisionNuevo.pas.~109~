procedure TFrmCargaInaComiNuevo.MemoClick(Sender: TObject);
var
  fil, col, dia: integer;
  b: Variant;
begin
  fil:=StrToInt(Copy(TMemo(Sender).Name,2,1));
  col:=StrToInt(Copy(TMemo(Sender).Name,3,1));
  if (FdayHabilita[fil,col]=1) then begin
    if FuncionesDB.combobusqueda('SELECT FCODIGO, FDESCRI, FCANTID FROM TBL_FALTAS WHERE CARRE IS NULL OR CARRE CONTAINING '''+VCarrera+'''',['Codigo','Descripcion','Cantidad'],b,True) then begin
      dia:=TMemo(Sender).Tag;
      if MtFaltas.Locate('FECHA',EncodeDate(FAnio,FMes,Dia),[]) then begin
        MtFaltas.Edit;
        MtFaltasCODFAL.Value:=b[0];
        MtFaltasCANTID.Value:=b[2];
        MtFaltasDESCRI.Value:=b[1];
        MtFaltas.Post;
      end
      else begin
        MtFaltas.Append;
        MtFaltasCODALU.Value:=MtAlumnosCODALU.Value;
        MtFaltasFECHA.Value:=EncodeDate(FAnio,FMes,Dia);
        MtFaltasCODFAL.Value:=b[0];
        MtFaltasCANTID.Value:=b[2];
        MtFaltasDESCRI.Value:=b[1];
        MtFaltas.Post;
      end;
      DrawPanel(fil,col,dia,b[1]);
    end;
    TMemo(Sender).SetFocus;
    TMemo(Sender).Color:= clWhite;
  end;
end;

procedure TFrmCargaInaComiNuevo.BitBtn1Click(Sender: TObject);
begin
  if (FMes<12) and (FMes+1<=FMaxMes) then begin
