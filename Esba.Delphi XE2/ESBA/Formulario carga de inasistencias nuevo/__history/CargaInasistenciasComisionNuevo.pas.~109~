procedure TFrmCargaInaComiNuevo.DrawPanel(const fil, col, dia: integer; const text:string);
var
  i: integer;
begin
  for I := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do begin
    if (FrmCargaInaComiNuevo.Components[i] is TMemo) and (FrmCargaInaComiNuevo.Components[i].Name='M'+IntToStr(fil)+IntToStr(col)) then begin
      TMemo(FrmCargaInaComiNuevo.Components[i]).Lines.clear;
      TMemo(FrmCargaInaComiNuevo.Components[i]).Lines.Add(text);
      TMemo(FrmCargaInaComiNuevo.Components[i]).SelStart:=0;
      TMemo(FrmCargaInaComiNuevo.Components[i]).SelLength:=0;
      if (FColHabilita[col]=1) then
        TMemo(FrmCargaInaComiNuevo.Components[i]).Color:=clGreen
      else
        TMemo(FrmCargaInaComiNuevo.Components[i]).Color:=clGray;
      TMemo(FrmCargaInaComiNuevo.Components[i]).Tag:=dia;
    end
    else if (FrmCargaInaComiNuevo.Components[i] is TStaticText) and (FrmCargaInaComiNuevo.Components[i].Name='ST'+IntToStr(fil)+IntToStr(col)) then begin
      TStaticText(FrmCargaInaComiNuevo.Components[i]).Caption:=IntToStr(dia);
    end;
  end;
end;

procedure TFrmCargaInaComiNuevo.ResetDefaultPanels;
var
  i: integer;
begin
  for I := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do begin
    if (FrmCargaInaComiNuevo.Components[i] is TMemo) and (Copy(FrmCargaInaComiNuevo.Components[i].Name,1,1)='M') then begin
      TMemo(FrmCargaInaComiNuevo.Components[i]).Lines.Clear;
      TMemo(FrmCargaInaComiNuevo.Components[i]).Color:=clBtnFace;
      TMemo(FrmCargaInaComiNuevo.Components[i]).Font.Size:=11;
      TMemo(FrmCargaInaComiNuevo.Components[i]).Font.Style:=[fsBold];
      TMemo(FrmCargaInaComiNuevo.Components[i]).Cursor:= crArrow;
      TMemo(FrmCargaInaComiNuevo.Components[i]).ReadOnly:=True;
    end
    else if (FrmCargaInaComiNuevo.Components[i] is TStaticText) and (Copy(FrmCargaInaComiNuevo.Components[i].Name,1,2)='ST') then begin
      TStaticText(FrmCargaInaComiNuevo.Components[i]).Caption:='';
      TStaticText(FrmCargaInaComiNuevo.Components[i]).Color:=clBtnFace;
    end;
  end;
end;

procedure TFrmCargaInaComiNuevo.MKeyUp(Sender: TObject; var Key: Word; Shift: TShiftState);
var
  i, fil, col, dia: integer;
  sw: boolean;
begin
  if key in [38,40] then begin
    fil:=StrToInt(Copy(TMemo(Sender).Name,2,1));
    col:=StrToInt(Copy(TMemo(Sender).Name,3,1));
    if (Key=40) and (fil<5) then //bajar
      fil:=fil+1
    else if (Key=38) and (fil>0) then //subir
      fil:=fil-1;
    if not (FDayHabilita[fil,col]=1) then
      exit;
    TMemo(sender).Color:=clGreen;
    for I := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do
      if (FrmCargaInaComiNuevo.Components[i] is TMemo) and (FrmCargaInaComiNuevo.Components[i].Name='M'+IntToStr(fil)+IntToStr(col)) then begin
        TMemo(FrmCargaInaComiNuevo.Components[i]).SetFocus;
        TMemo(FrmCargaInaComiNuevo.Components[i]).color:=clWhite;
      end;
  end
  else if key in [37,39] then begin
    fil:=StrToInt(Copy(TMemo(Sender).Name,2,1));
    col:=StrToInt(Copy(TMemo(Sender).Name,3,1));
    sw:=true;
    while sw do begin
      if (Key=39) then //izq
        col:=col+1
      else if (Key=37) then //dere
        col:=col-1;

      if (col>4) or (col<0) then
        break;
      if (FDayHabilita[fil,col]=1) then begin
        TMemo(sender).Color:=clGreen;
        for I := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do
          if (FrmCargaInaComiNuevo.Components[i] is TMemo) and (FrmCargaInaComiNuevo.Components[i].Name='M'+IntToStr(fil)+IntToStr(col)) then begin
            TMemo(FrmCargaInaComiNuevo.Components[i]).SetFocus;
            TMemo(FrmCargaInaComiNuevo.Components[i]).color:=clWhite;
            sw:=false;
          end;
      end;
    end;
    if sw then begin
      TMemo(sender).SetFocus;
      TMemo(sender).color:=clWhite;
    end;
  end
  else if key in [VK_F1,VK_CONTROL] then
    MemoClick(Sender)
  else if key in [VK_TAB] then
    Grilla.SetFocus
  else if key = VK_DELETE then
    BorraFalta(sender);
end;

procedure TFrmCargaInaComiNuevo.DrawDayInPanels(const mes, anio: integer);
Var
  fil,col,day, dayweek, daymonth :integer;
  dia:TDateTime;
begin
  ResetDefaultPanels;
  daymonth:=DaysInAMonth(anio,mes);
  for fil := 0 to 5 do
    for col := 0 to 4 do
      FdayHabilita[fil,col]:=0;

  for day := 1 to daymonth do begin
    dia:=EncodeDate(anio,mes,day);
    dayweek:=DayOfWeek(dia);
    if not (dayweek in [1,7]) then begin
      col:=dayweek-2;
      if (WeekOfTheYear(EncodeDate(anio,mes,day))>50) and (mes=1) then
        fil:= 0 //WeekOfTheMonth(EncodeDate(anio,mes,day))-1;
      else if (WeekOfTheYear(EncodeDate(anio,mes,day))=1) and (mes=12) then
        fil:= 5 //WeekOfTheMonth(EncodeDate(anio,mes,day))-1;
      else if (WeekOfTheYear(EncodeDate(anio,mes,daymonth))=1) and (mes=12) then
        fil:= WeekOfTheYear(EncodeDate(anio,mes,day))-52+4
      else
        fil:= WeekOfTheYear(EncodeDate(anio,mes,day))-WeekOfTheYear(EncodeDate(anio,mes,daymonth))+4; //WeekOfTheMonth(EncodeDate(anio,mes,day))-1;
      if MTFaltas.Locate('FECHA',DIA,[]) then begin
         DrawPanel(fil,col,day,MtFaltasDESCRI.Value);
      end
      else begin
         DrawPanel(fil,col,day,'');
      end;
      if FColHabilita[col]=1 then
        FdayHabilita[fil,col]:=1;
    end;
  end;
  XPanelMes.Caption:=UpperCase(FuncionesText.MesALetras(mes));
end;

function TFrmCargaInaComiNuevo.ValidateDatosParametros:string;
var
  query:string;
  datos: variant;
begin
  result:='';
  if (vcarrera<>'333') and (vcarrera<>'650') then begin
    query:='SELECT DIA1, DIA2, DIA3 FROM COMARM C WHERE C.CARRE='''+VCarrera+''' AND C.CUTUCO='''+Comi+''' AND C.COD_MAT='''+materia+''' AND C.CUA_ANIO='''+cuaanio+'''';
    datos:=null;
    funcionesDB.Consulta(query,datos);

    FColHabilita[0]:=0;
    FColHabilita[1]:=0;
    FColHabilita[2]:=0;
    FColHabilita[3]:=0;
    FColHabilita[4]:=0;

    if not VarIsNull(datos) then begin
      if (datos[0]='BLANCO') and (datos[1]='BLANCO') and (datos[2]='BLANCO') then begin
        result:='En la comision no esta cargada los dias de que se cursa';
      end;
      if ((datos[0]='LUNES') or (datos[1]='LUNES') or (datos[2]='LUNES')) then
        FColHabilita[0]:=1;
      if ((datos[0]='MARTES') or (datos[1]='MARTES') or (datos[2]='MARTES')) then
        FColHabilita[1]:=1;
      if ((datos[0]='MIERCOLES') or (datos[1]='MIERCOLES') or (datos[2]='MIERCOLES')) then
        FColHabilita[2]:=1;
      if ((datos[0]='JUEVES') or (datos[1]='JUEVES') or (datos[2]='JUEVES')) then
        FColHabilita[3]:=1;
      if ((datos[0]='VIERNES') or (datos[1]='VIERNES') or (datos[2]='VIERNES')) then
        FColHabilita[4]:=1;
    end
    else
      result:='No hay comision cargada para los datos ingresados';
  end
  else begin
    FColHabilita[0]:=1;
    FColHabilita[1]:=1;
    FColHabilita[2]:=1;
    FColHabilita[3]:=1;
    FColHabilita[4]:=1;

  end;
end;

