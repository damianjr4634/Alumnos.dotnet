procedure TFrmCargaInaComiNuevo.GrillaKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
var
  i,fil, col:integer;
begin
  if key=vk_f2 then
    dbgrid1.Visible:=not dbgrid1.Visible
  else if (key=13) then begin
    for fil := 0 to 5 do
      for col := 0 to 4 do
        if FDayHabilita[fil,col]=1 then begin
          for i := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do begin
            if (FrmCargaInaComiNuevo.Components[i] is TMemo) and (FrmCargaInaComiNuevo.Components[i].Name='M'+IntToStr(fil)+IntToStr(col)) then begin
              TMemo(FrmCargaInaComiNuevo.Components[i]).SetFocus;
              key:=0;
              exit;
            end;
          end;
        end;
  end;
end;

