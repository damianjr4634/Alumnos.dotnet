procedure TFrmCargaInaComiNuevo.DrawPanel(const fil, col, dia: integer; const text:string);
var
  i: integer;
begin
  for I := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do begin
    if (FrmCargaInaComiNuevo.Components[i] is TStaticText) and (FrmCargaInaComiNuevo.Components[i].Name='P'+IntToStr(fil)+IntToStr(col)) then begin
      TStaticText(FrmCargaInaComiNuevo.Components[i]).Caption:=IntToStr(dia)+#13#10+text;
      TStaticText(FrmCargaInaComiNuevo.Components[i]).BevelOuter:=bvRaised;
      TStaticText(FrmCargaInaComiNuevo.Components[i]).BorderStyle:=sbsSunken;
      if (FHabilita[col]=1) then
        TStaticText(FrmCargaInaComiNuevo.Components[i]).Color:=clGreen
      else
        TStaticText(FrmCargaInaComiNuevo.Components[i]).Color:=clWhite;
      TStaticText(FrmCargaInaComiNuevo.Components[i]).Tag:=dia;
      break;
    end;
  end;
end;

procedure TFrmCargaInaComiNuevo.ResetDefaultPanels;
var
  i: integer;
begin
  for I := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do begin
    if (FrmCargaInaComiNuevo.Components[i] is TStaticText) and (Copy(FrmCargaInaComiNuevo.Components[i].Name,1,1)='P') then begin
