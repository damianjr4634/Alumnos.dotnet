procedure TFrmCargaInaComiNuevo.PanelMouseUp(Sender: TObject;
  Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
var
  fil, col, dia: integer;
begin
  if Button=mbRight then begin
    fil:=StrToInt(Copy(TStaticText(Sender).Name,2,1));
    col:=StrToInt(Copy(TStaticText(Sender).Name,3,1));
    dia:=TStaticText(Sender).Tag;
    if MtFaltas.Locate('FECHA',EncodeDate(FAnio,FMes,Dia),[]) then begin
      MtFaltas.Delete;
    end;
    DrawPanel(fil,col,dia,'');
  end;
end;

procedure TFrmCargaInaComiNuevo.PanelClick(Sender: TObject);
var
  fil, col, dia: integer;
  b: Variant;
begin
  fil:=StrToInt(Copy(TStaticText(Sender).Name,2,1));
  col:=StrToInt(Copy(TStaticText(Sender).Name,3,1));
  if (FHabilita[col]=1) then begin
    if Funciones.combobusqueda('SELECT FCODIGO, FDESCRI, FCANTID FROM TBL_FALTAS WHERE CARRE IS NULL OR CARRE CONTAINING '''+VCarrera+'''',['Codigo','Descripcion','Cantidad'],b,True) then begin
      dia:=TStaticText(Sender).Tag;
      if MtFaltas.Locate('FECHA',EncodeDate(FAnio,FMes,Dia),[]) then begin
        MtFaltas.Edit;
        MtFaltasCODFAL.Value:=b[0];
        MtFaltasCANTID.Value:=b[2];
        MtFaltasDESCRI.Value:=b[1];
        MtFaltas.Post;
      end
      else begin
        MtFaltas.Append;
        MtFaltasCODALU.Value:=MtAlumnosCODALU.Value;
        MtFaltasFECHA.Value:=EncodeDate(FAnio,FMes,Dia);
        MtFaltasCODFAL.Value:=b[0];
        MtFaltasCANTID.Value:=b[2];
        MtFaltasDESCRI.Value:=b[1];
        MtFaltas.Post;
      end;
      DrawPanel(fil,col,dia,b[1]);
    end;
  end;
end;

procedure TFrmCargaInaComiNuevo.BitBtn1Click(Sender: TObject);
begin
  if (FMes<12) and (FMes+1<=FMaxMes) then begin
    FMes:=FMes+1;
    DrawDayInPanels(FMes, FAnio);
  end;
end;

procedure TFrmCargaInaComiNuevo.BitBtn2Click(Sender: TObject);
begin
  if (FMes>1) and (FMes-1>=FMinMes) then begin
    FMes:=FMes-1;
    DrawDayInPanels(FMes, FAnio);
  end;
end;

