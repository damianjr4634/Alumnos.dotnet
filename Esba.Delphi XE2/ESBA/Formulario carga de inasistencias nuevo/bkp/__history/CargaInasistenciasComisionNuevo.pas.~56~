procedure TFrmCargaInaComiNuevo.FormShow(Sender: TObject);
var
  dia, mes, year: word;
  x: integer;
  mt: TKbmMemTable;
  q:String;
  b: Variant;
begin
  mt:= TKbmMemTable.Create(Self);
  try
    Memo1.Lines.Clear;
    Memo1.Lines.Add('Comision: '+comi);
    Memo1.Lines.Add('Cuatrimestre/a隳: '+ cuaanio+' materia: '+materia);
    Memo1.Lines.Add('Carrera:'+Vcarrera);

    for x := 0 to FrmCargaInaComiNuevo.ComponentCount-1 do
      if (FrmCargaInaComiNuevo.Components[x] is TStaticText) and (Copy(FrmCargaInaComiNuevo.Components[x].Name,1,1)='P') then begin
        TStaticText(FrmCargaInaComiNuevo.Components[x]).OnClick := PanelClick;
        TStaticText(FrmCargaInaComiNuevo.Components[x]).OnMouseUp := PanelMouseUp;
      end;

    DsFaltas.SQLs.SelectSQL.Text:='SELECT CODALU, NOMBRE, CANANT, CODFAL, CANTID FROM XXX_FALTAS_COMISION('+#39+vCARRERA+#39+','+COMI+',null,'+cuaanio+','''+materia+''')';
    if trfaltas.Active then
       TrFaltas.Rollback;
    trfaltas.Active:=true;
    DsFaltas.Active:=true;
    dsFaltas.First;
    MtAlumnos.Active:=True;
    MtFaltas.Active:=True;
    while not (dsfaltas.Eof) do begin
        MtAlumnos.Append;
        MtAlumnosCODALU.Value:=DsFaltas.FieldByName('CODALU').Value;
        MtAlumnosCANTOT.Value:=DsFaltas.FieldByName('CANANT').Value;
        MtAlumnosNOMBRE.Value:=DsFaltas.FieldByName('NOMBRE').Value;
        MtAlumnosCANTOT.Value:=DsFaltas.FieldByName('CANTID').Value+DsFaltas.FieldByName('CANANT').Value;;
        MtAlumnos.Post;
        Q:='SELECT FECHA, CODFAL, CANTID, DESCRI FROM XXX_FALTAS_FALTAS('''+VCarrera+''', '+comi+', '+CUAANIO+','''+DsFaltas.FieldByName('CODALU').Value+''', '''+materia+''') ORDER BY FECHA';
        Funciones.Carga_MemTable(Q,Mt,true);
        while Not Mt.Eof do begin
          MtFaltas.Append;
          MtFaltasCODALU.Value:= MtAlumnosCODALU.Value;
          MtFaltasFECHA.Value:= Mt.FieldByName('FECHA').Value;
          MtFaltasCODFAL.Value:= Mt.FieldByName('CODFAL').Value;
          MtFaltasCANTID.Value:= Mt.FieldByName('CANTID').Value;
          MtFaltasDESCRI.Value:= Mt.FieldByName('DESCRI').Value;
          MtFaltas.Post;
          Mt.Next;
        end;
        Mt.Active:=False;
        DsFaltas.Next;
    end;
  finally
    mt.Free;
    mt:=nil;
  end;
  TrFaltas.Rollback;
  trfaltas.Active:=False;
  DsFaltas.Active:=False;
  DecodeDate(date,FAnio,FMes,dia); //dia de hoy
  MtAlumnos.First;
  DrawDayInPanels(FMes, FAnio);
  grilla.Repaint;
  if (VCarrera='333') or (VCarrera='650') then begin
    Funciones.Consulta('SELECT EXTRACT(MONTH FROM FDDEPRI), EXTRACT(MONTH FROM FHTATER) FROM TBL_TRIM WHERE FANIO='+IntToStr(FAnio),b);
    if (Not VarIsNull(b)) or (not VarIsNull(b[0])) then begin
      FMinMes:=b[0];
      FMaxMes:=b[1];
    end
    else
      raise Exception.Create('No hay cuatrimestre cargado');
  end
  else begin
    Funciones.Consulta('SELECT EXTRACT(MONTH FROM FDDEPRI), EXTRACT(MONTH FROM FHTAPRI),EXTRACT(MONTH FROM FDDESEG), EXTRACT(MONTH FROM FHTASEG) FROM TBL_CUAT WHERE FANIO='+IntToStr(FAnio),b);
    if (Not VarIsNull(b)) or (not VarIsNull(b[0])) then begin
      if Copy(cuaanio,1,1)='1' then begin
        FMinMes:=b[0];
        FMaxMes:=b[1];
      end
      else begin
        FMinMes:=b[2];
        FMaxMes:=b[3];
      end;
    end
    else
      raise Exception.Create('No hay cuatrimestre cargado');
  end;
end;

procedure TFrmCargaInaComiNuevo.GrabamesaClick(Sender: TObject);
begin
  MtAlumnos.First;
  if trfaltas.Active then
      TrFaltas.Rollback;
  trfaltas.Active:=false;

  try
    if (VCarrera='333') or (VCarrera='650') then
      IbUpins.SQL.Text:=' DELETE FROM FALTAS WHERE CARRERA=:CARRERA AND CUTUCO=:CUTUCO AND COD_MAT IS NULL AND EXTRACT(YEAR FROM FECHA)='+IntToStr(FAnio)+' AND EXTRACT(MONTH FROM FECHA) BETWEEN '+IntToStr(FMinMes)+' AND '+IntToStr(FMaxMes)
    else
      IbUpins.SQL.Text:=' DELETE FROM FALTAS WHERE CARRERA=:CARRERA AND CUTUCO=:CUTUCO AND COD_MAT='''+materia+''' AND EXTRACT(YEAR FROM FECHA)='+IntToStr(FAnio)+' AND EXTRACT(MONTH FROM FECHA) BETWEEN '+IntToStr(FMinMes)+' AND '+IntToStr(FMaxMes);
    while not MTAlumnos.Eof do begin
      ibupins.ParamByName('CARRERA').Value:=vCARRERA;
      ibupins.ParamByName('CUTUCO').Value:=COMI;
      trfaltas.Active:=True;

      ibupins.ExecQuery;

      while not MtFaltas.Eof do begin

        IbUpins.SQL.Text:=' INSERT INTO FALTAS (CARRERA, CODALU, CUTUCO, FECHA, CODFAL, CANFAL,COD_MAT, USUARIO) '+
                          ' VALUES (:CARRERA, :CODALU, :CUTUCO, :FECHA, :CODFAL, :CANFAL,:COD_MAT, :USUARIO) ';
        ibupins.ParamByName('CARRERA').Value:=vCARRERA;
        ibupins.ParamByName('CODALU').Value:=MtAlumnosCODALU.Value;
        ibupins.ParamByName('CUTUCO').Value:=COMI;
        ibupins.ParamByName('FECHA').Value:=MtFaltasFECHA.Value;
        ibupins.ParamByName('CODFAL').Value:=MtFaltasCODFAL.Value;
        ibupins.ParamByName('CANFAL').Value:=MtFaltasCANTID.Value;
        if (VCarrera='333') or (VCarrera='650') then
           ibupins.ParamByName('COD_MAT').Value:=null
        else
           ibupins.ParamByName('COD_MAT').Value:=materia;
        ibupins.ParamByName('USUARIO').Value:=FUNCIONES.CodUsu;
        ibupins.ExecQuery;
        MtFaltas.Next;
      end;
      MtAlumnos.Next;
    end;
    trfaltas.Commit;
    trfaltas.Active:=false;
    MessageDlg(Pchar(VNombreUsuario + ', faltas grabadas'),mtInformation, [mbok],0,mbok);
    close;
  except
    on e: exception do begin
        ShowMessage(e.Message);
        TrFaltas.Rollback;
        ibupins.Close;
    end;
  end;
end;

