      TStaticText(FrmCargaInaComiNuevo.Components[i]).Font.Size:=12;
      TStaticText(FrmCargaInaComiNuevo.Components[i]).Font.Style:=[fsBold];
    end;
  end;
end;

procedure TFrmCargaInaComiNuevo.DrawDayInPanels(const mes, anio: integer);
Var
  fil,col,day, dayweek, daymonth :integer;
  dia:TDateTime;
begin
  ResetDefaultPanels;
  daymonth:=DaysInAMonth(anio,mes);
  for day := 1 to daymonth do begin
    dia:=EncodeDate(anio,mes,day);
    dayweek:=DayOfWeek(dia);
    if not (dayweek in [1,7]) then begin
      col:=dayweek-2;
      if (WeekOfTheYear(EncodeDate(anio,mes,day))>50) and (mes=1) then
        fil:= 0 //WeekOfTheMonth(EncodeDate(anio,mes,day))-1;
      else if (WeekOfTheYear(EncodeDate(anio,mes,day))=1) and (mes=12) then
        fil:= 5 //WeekOfTheMonth(EncodeDate(anio,mes,day))-1;
      else if (WeekOfTheYear(EncodeDate(anio,mes,daymonth))=1) and (mes=12) then
        fil:= WeekOfTheYear(EncodeDate(anio,mes,day))-52+4
      else
        fil:= WeekOfTheYear(EncodeDate(anio,mes,day))-WeekOfTheYear(EncodeDate(anio,mes,daymonth))+4; //WeekOfTheMonth(EncodeDate(anio,mes,day))-1;
      if MTFaltas.Locate('FECHA',DIA,[]) then
         DrawPanel(fil,col,day,MtFaltasDESCRI.Value)
      else
         DrawPanel(fil,col,day,'');
    end;
  end;
  XPanelMes.Caption:=UpperCase(Funciones.MesALetras(mes));
end;

function TFrmCargaInaComiNuevo.ValidateDatosParametros:string;
var
  query:string;
  datos: variant;
begin
  result:='';
  if (vcarrera<>'333') and (vcarrera<>'650') then begin
    query:='SELECT DIA1, DIA2, DIA3 FROM COMARM C WHERE C.CARRE='''+VCarrera+''' AND C.CUTUCO='''+Comi+''' AND C.COD_MAT='''+materia+''' AND C.CUA_ANIO='''+cuaanio+'''';
    datos:=null;
    funciones.Consulta(query,datos);

    FHabilita[0]:=0;
    FHabilita[1]:=0;
    FHabilita[2]:=0;
    FHabilita[3]:=0;
    FHabilita[4]:=0;

    if not VarIsNull(datos) then begin
      if (datos[0]='BLANCO') and (datos[1]='BLANCO') and (datos[2]='BLANCO') then begin
        result:='En la comision no esta cargada los dias de que se cursa';
      end;
      if ((datos[0]='LUNES') or (datos[1]='LUNES') or (datos[2]='LUNES')) then
        FHabilita[0]:=1;
      if ((datos[0]='MARTES') or (datos[1]='MARTES') or (datos[2]='MARTES')) then
        FHabilita[1]:=1;
      if ((datos[0]='MIERCOLES') or (datos[1]='MIERCOLES') or (datos[2]='MIERCOLES')) then
        FHabilita[2]:=1;
      if ((datos[0]='JUEVES') or (datos[1]='JUEVES') or (datos[2]='JUEVES')) then
        FHabilita[3]:=1;
      if ((datos[0]='VIERNES') or (datos[1]='VIERNES') or (datos[2]='VIERNES')) then
        FHabilita[4]:=1;
    end
    else
      result:='No hay comision cargada para los datos ingresados';
  end;
end;

