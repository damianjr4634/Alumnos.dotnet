{$R *.dfm}

procedure TFrmCargaPermisos.GrillaKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
Var b:Variant;
    x:integer;
begin
   IF (grilla.SelectedField.FullName='COD_ALU') and (key=VK_F1) then begin
       if Not (mtPermisos.State=dsInsert) then
          MtPermisos.Append;
       Funciones.combobusqueda('SELECT COD_ALU, TRIM(NOM_APE)||'+#39+', '+#39'||TRIM(APELLIDO) AS NOMBRE FROM ALUMNOS WHERE CARRE='#39+VCARRERA+#39+' AND BAJA='#39+'N'+#39+' ORDER BY 2',['Codigo','Apellido y Nombre'],b,True);
       MtPermisos.FieldByName('COD_ALU').AsString:=b[0];
       MtPermisos.FieldByName('NOMBRE').AsString:=b[1];
   end
   else IF (grilla.SelectedField.FullName='COD_MAT') and (key=VK_F1) then begin
       if Not (mtPermisos.State=dsInsert) then
          MtPermisos.Append;
       Funciones.combobusqueda('SELECT CODMAT, MATERIA, CUTUCO, FERRCOD, FERRMSG FROM XXX_MATERIAS_FINALES('+#39+MtPermisos.FieldByName('COD_ALU').AsString+#39','+#39+VCARRERA+#39+')',['Codigo','Nombre'],b,True);
       if (b[3]=2) then begin
             MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + vartostr(b[4])),'Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
       end else if (b[3]=1) then begin
              if (MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + vartostr(b[4])),'Aviso',MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)=ID_NO) then
                  grilla.SelectedField.FieldName:='COD_MAT'
              else begin
                 MtPermisos.FieldByName('COD_MAT').AsString:=b[0];
                 MtPermisos.FieldByName('MATERIA').AsString:=b[1];
                 MtPermisos.FieldByName('CUTUCO').AsInteger:=b[2];
              end;
       end else if (b[3]=0) then begin
             MtPermisos.FieldByName('COD_MAT').AsString:=b[0];
             MtPermisos.FieldByName('CUTUCO').AsInteger:=b[2];
             MtPermisos.FieldByName('MATERIA').AsString:=b[1];
       end
   end
   else IF (grilla.SelectedField.FullName='MESA') and (key=VK_F1) then begin
       if Not (mtPermisos.State=dsInsert) then
          MtPermisos.Append;
       Funciones.combobusqueda('SELECT M.MESA, M.LLAMADO, M.FECH_EXA, M.HORA FROM MESAS M WHERE M.CARRE='+#39+VCARRERA+#39+'AND M.COD_MAT='+#39+MtPermisos.FieldByName('COD_MAT').Asstring+#39,['Mesa','Llamado','Fecha Exa.','Hora'],b,True);
       IF (vartostr(b[0])<>'') then begin
          MtPermisos.FieldByName('MESA').AsString:=b[0];
          MtPermisos.FieldByName('FECHA').AsDateTime:=b[2];
       end
   end
   else if key=VK_RETURN	 then begin
      for x:=mtpermisos.Fields.IndexOf(Grilla.SelectedField)+1 to mtpermisos.FieldCount-1 do begin
        if not (Grilla.Columns.Items[x].ReadOnly) then begin
          Grilla.SelectedField:=MtPermisos.Fields.Fields[x];
          break;
        end
      end
   end
   else if key=VK_DELETE	then begin
      if (MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + ', borra el permiso?'),'Aviso',MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)=IDYES) then
         MtPermisos.Delete;
   end
end;

