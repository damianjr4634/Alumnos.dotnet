procedure TFrmCargaPermisos.MtPermisosSetText(Sender: TField;
  const Text: String);
var b:Variant;
begin
  if (text<>'') then begin
       sender.AsString:=UpperCase(text);
       if (Sender.FullName='COD_ALU') then begin
            Funciones.combobusqueda('SELECT COD_ALU, TRIM(NOM_APE)||'+#39+', '+#39'||TRIM(APELLIDO) AS NOMBRE FROM ALUMNOS WHERE CARRE='#39+VCARRERA+#39+' AND BAJA='#39+'N'+#39+' AND COD_ALU='+#39+text+#39+' ORDER BY 2',['Codigo','Apellido y Nombre'],b,False);
            mtPermisos.FieldByName('NOMBRE').AsString:=b[1];
       end else if (Sender.FullName='COD_MAT') then begin
            Funciones.combobusqueda('SELECT CODMAT, CUTUCO, FERRCOD, FERRMSG FROM XXX_MATERIAS_FINALES('+#39+MtPermisos.FieldByName('COD_ALU').AsString+#39','+#39+VCARRERA+#39+') WHERE CODMAT='+#39+text+#39,['Codigo','Nombre'],b,False);
            mtPermisos.FieldByName('CUTUCO').AsInteger:=b[1];//strToInt(text2);
       end else if (Sender.FullName='MESA') then begin
            Funciones.combobusqueda('SELECT M.MESA, M.LLAMADO, M.FECH_EXA, M.HORA FROM MESAS M WHERE M.CARRE='+#39+VCARRERA+#39+'AND M.COD_MAT='+#39+MtPermisos.FieldByName('COD_MAT').Asstring+#39+' AND MESA='+#39+text+#39,['Mesa','Llamado','Fecha Exa.','Hora'],b,False);
       end;
       If vartostr(b[0])='' Then begin
          if (MtPermisos.State=DsInsert) then begin
              MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + ', código incorrecto'),'Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
              Sender.AsString:='';
              abort;
          end
       end
       else if (Sender.FullName='COD_MAT') then begin
            if (b[2]=2) then begin
                MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + vartostr(b[3])),'Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
                mtPermisos.FieldByName('CUTUCO').AsInteger:=null;
                Sender.AsString:='';
                abort;
            end
            else if (b[2]=1) then begin
              if (MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + vartostr(b[3])),'Aviso',MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)=ID_NO) then begin
                  mtPermisos.FieldByName('CUTUCO').AsInteger:=null;
                  Sender.AsString:='';
                  abort;
              end
              else begin
                  Sender.AsString:=b[0];
              end;
            end
            else if (b[2]=0) then begin
               Sender.AsString:=b[0];
            end
       end
  end
  else begin
        Sender.AsString:='';
        Abort;
  end
end;

procedure TFrmCargaPermisos.GrabamesaClick(Sender: TObject);
begin
if (mtpermisos.State in [Dsinsert,DsEdit]) then
   MtPermisos.Post;
if (mtpermisos.RecordCount=0) then exit;
if (MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + ', graba los permisos?'),'Aviso',MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)=IDYES) then begin
    mtpermisos.First;
    IbupIns.SQL.Text:='INSERT INTO PERMEXA(PERM_EXA,MESA,LLAMADO,COD_ALU,APELLIDO,CUTUCO,' +
                             'CARRE,COD_MAT,FECH_EXA,FECH_EMI, NREG,USUARIO) '+
                             '             VALUES(:PERM_EXA,:MESA,:LLAMADO,:COD_ALU,:APELLIDO,' +
                             ':CUTUCO,:CARRE,:COD_MAT,:FECH_EXA,:FECH_EMI,:NREG,:USUARIO)';
    trpermisos.Active:=True;
    while not mtpermisos.Eof do begin
       IbupIns.ParamByName('PERM_EXA').AsInteger  := MtPermisos.Fieldbyname('NUMPER').AsInteger;
       IbupIns.ParamByName('MESA').AsInteger      := MtPermisos.Fieldbyname('MESA').AsInteger;
       IbupIns.ParamByName('COD_ALU').AsString    := MtPermisos.Fieldbyname('COD_ALU').AsString;
       IbupIns.ParamByName('CUTUCO').AsInteger    := MtPermisos.FieldByName('CUTUCO').AsInteger;
       IbupIns.ParamByName('CARRE').AsString      := VCarrera;
       IbupIns.ParamByName('COD_MAT').AsString    := MtPermisos.Fieldbyname('COD_MAT').AsString;
       IbupIns.ParamByName('FECH_EMI').AsDateTime := Date();
       IbupIns.ParamByName('USUARIO').Value := funciones.CodUsu;
       IbUpIns.ExecQuery;
       mtpermisos.Next;
    end;
    TrPermisos.Commit;
    TrPermisos.Active:=False;
    MessageBox(FrmCargaPermisos.Handle, Pchar(VNombreUsuario + ', permisos grabados'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
    close;    
end;
end;

end.
