unit modulovariable_grf;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, VCLTee.TeEngine, VCLTee.TeeProcs,
  VCLTee.Chart, VCLTee.DBChart, Data.DB, kbmMemTable, Vcl.StdCtrls, Vcl.ExtCtrls,
  Vcl.Grids, Vcl.DBGrids, Funciones, VCLTee.Series, VCLTee.TeeDBCrossTab;

type
  TFrmModVar_grf = class(TForm)
    Panel1: TPanel;
    Panel2: TPanel;
    Label1: TLabel;
    CbTipGrf: TComboBox;
    Button1: TButton;
    Button2: TButton;
    DataSource1: TDataSource;
    Mt: TkbmMemTable;
    TcGrf: TDBChart;
    DBGrid1: TDBGrid;
    procedure FormKeyUp(Sender: TObject; var Key: Word; Shift: TShiftState);
    procedure FormCreate(Sender: TObject);
    procedure FormActivate(Sender: TObject);
    procedure Button2Click(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure CbTipGrfChange(Sender: TObject);
    procedure Button1Click(Sender: TObject);
  private
    { Private declarations }
    DBCrossTabSeries1: TDBCrossTabSource;
    DBCrossTabSeries2: TDBCrossTabSource;
    DBCrossTabSeries3: TDBCrossTabSource;
    Series1: TLineSeries;
    Series2: TBarSeries;
    Series3: TPieSeries;
    Procedure Carga_series(series:integer);
  public
    { Public declarations }
    Sql:String;
  end;

var
  FrmModVar_grf: TFrmModVar_grf;
  cnf: TMemo;

implementation

{$R *.dfm}

procedure TFrmModVar_grf.Carga_series(series:integer);
var x:integer;
    tipo,fldlabel,fldcantid,fldgroup:string;
begin
   if assigned(series1) then begin
      series1.Free;
      series1:=nil;
      DBCrossTabSeries1.Free;
      DBCrossTabSeries1:=nil;
   end;
   if assigned(series2) then begin
      series2.Free;
      series2:=nil;
      DBCrossTabSeries2.Free;
      DBCrossTabSeries2:=nil;
   end;
   if assigned(series3) then begin
      series3.Free;
      series3:=nil;
      DBCrossTabSeries3.Free;
      DBCrossTabSeries3:=nil;
   end;
   if series=1 then begin
       Series1:= TLineSeries.Create(nil);
       DBCrossTabSeries1:=TDBCrossTabSource.Create(nil);
       Series1.ParentChart:=TcGrf;
   end;
   if series=2 then begin
       Series2:= TBarSeries.Create(nil);
       DBCrossTabSeries2:=TDBCrossTabSource.Create(nil);
       Series2.ParentChart:=TcGrf;
   end;
   if series=3 then begin
       Series3:= TpieSeries.Create(nil);
       DBCrossTabSeries3:=TDBCrossTabSource.Create(nil);
       Series3.ParentChart:=TcGrf;
   end;

   for x := 0 to Cnf.Lines.Count-1 do begin
      if AnsiPos('TIPO',cnf.Lines.Strings[x])<>0 Then
          tipo:=Copy(cnf.Lines.Strings[x],AnsiPos('=',cnf.Lines.Strings[x])+1,Length(cnf.Lines.Strings[x]));
      if AnsiPos('FLDLABEL',cnf.Lines.Strings[x])<>0 Then
          fldlabel:=Copy(cnf.Lines.Strings[x],AnsiPos('=',cnf.Lines.Strings[x])+1,Length(cnf.Lines.Strings[x]));
      if AnsiPos('FLDCANTID',cnf.Lines.Strings[x])<>0 Then
          fldCantid:=Copy(cnf.Lines.Strings[x],AnsiPos('=',cnf.Lines.Strings[x])+1,Length(cnf.Lines.Strings[x]));
      if AnsiPos('FLDGROUP',cnf.Lines.Strings[x])<>0 Then
          fldgroup:=Copy(cnf.Lines.Strings[x],AnsiPos('=',cnf.Lines.Strings[x])+1,Length(cnf.Lines.Strings[x]));
   end;

   if tipo='TABLE' then begin
     if series=1 then begin
       with series1 do begin
           Marks.Style := smsLabelPercent;
           XLabelsSource := fldlabel;
           Pointer.InflateMargins := True;
           Pointer.Style := psRectangle;
           Pointer.Visible := False;
           XValues.Name := 'X';
           XValues.Order := loAscending;
           YValues.Name := 'Y';
           YValues.Order := loNone;
           YValues.ValueSource := fldcantid;
           DataSource := Mt;
       end;
     end;
     if series=2 then begin
       with series2 do begin
           Marks.Arrow.Visible := True;
           Marks.Callout.Brush.Color := clBlack;
           Marks.Callout.Arrow.Visible := True;
           Marks.Style := smsLabelPercent;
           Marks.Visible := True;
           XLabelsSource := fldlabel;
           Emboss.Color := 8750469;
           Shadow.Color := 8750469;
           XValues.Name := 'X';
           XValues.Order := loAscending;
           YValues.Name := 'Bar';
           YValues.Order := loNone;
           YValues.ValueSource := fldcantid;
           DataSource := Mt;
       end;
     end;
     if series=3 then begin
       with series3 do begin
           Marks.Arrow.Visible := True;
           Marks.Callout.Brush.Color := clBlack;
           Marks.Callout.Arrow.Visible := True;
           Marks.Style := smsLabelPercent;
           Marks.Visible := True;
           XLabelsSource := fldlabel;
           XValues.Order := loAscending;
           YValues.Name := 'Pie';
           YValues.Order := loNone;
           YValues.ValueSource := fldcantid;
           Frame.InnerBrush.BackColor := clRed;
           Frame.InnerBrush.Gradient.EndColor := clGray;
           Frame.InnerBrush.Gradient.MidColor := clWhite;
           Frame.InnerBrush.Gradient.StartColor := 4210752;
           Frame.InnerBrush.Gradient.Visible := True;
           Frame.MiddleBrush.BackColor := clYellow;
           Frame.MiddleBrush.Gradient.EndColor := 8553090;
           Frame.MiddleBrush.Gradient.MidColor := clWhite;
           Frame.MiddleBrush.Gradient.StartColor := clGray;
           Frame.MiddleBrush.Gradient.Visible := True;
           Frame.OuterBrush.BackColor := clGreen;
           Frame.OuterBrush.Gradient.EndColor := 4210752;
           Frame.OuterBrush.Gradient.MidColor := clWhite;
           Frame.OuterBrush.Gradient.StartColor := clSilver;
           Frame.OuterBrush.Gradient.Visible := True;
           Frame.Visible := False;
           Frame.Width := 4;
           OtherSlice.Legend.Visible := False;
           DataSource := Mt;
       end;
     end;
   end
   else if tipo='CROSS' then begin
      if series=1 then begin
        with  DBCrossTabSeries1 do begin
           DataSet := Mt;
           GroupField := fldgroup;
           LabelField := fldlabel;
           Series := Series1;
           ValueField := fldcantid;
           Active := True;
        end;
        with Series1 do begin
           Marks.Arrow.Visible := True;
           Marks.Callout.Brush.Color := clBlack;
           Marks.Callout.Arrow.Visible := True;
           Marks.Style := smsLabelPercent;
           Marks.Visible := True;
           DataSource := DBCrossTabSeries1;
           XLabelsSource := fldlabel;
           Pointer.InflateMargins := True;
           Pointer.Style := psRectangle;
           Pointer.Visible := False;
           XValues.Name := 'X';
           XValues.Order := loAscending;
           YValues.Name := 'Y';
           YValues.Order := loNone;
           YValues.ValueSource := fldcantid;
        end;

      end;
      if series=2 then begin
        with  DBCrossTabSeries2 do begin
           DataSet := Mt;
           GroupField := fldgroup;
           LabelField := fldlabel;
           Series := Series2;
           ValueField := fldcantid;
           Active := True;
        end;
        with Series2 do begin
           Marks.Arrow.Visible := True;
           Marks.Callout.Brush.Color := clBlack;
           Marks.Callout.Arrow.Visible := True;
           Marks.Visible := True;
           Marks.Style := smsLabelPercent;
           DataSource := DBCrossTabSeries2;
           XLabelsSource := fldLabel;
           Emboss.Color := 8947848;
           Shadow.Color := 8947848;
           XValues.Name := 'X';
           XValues.Order := loAscending;
           YValues.Name := 'Bar';
           YValues.Order := loNone;
           YValues.ValueSource := fldCantid;
        end;
      end;
      if series=3 then begin
         with  DBCrossTabSeries3 do begin
           DataSet := Mt;
           GroupField := fldgroup;
           LabelField := fldlabel;
           Series := Series3;
           ValueField := fldcantid;
           Active := True;
        end;
         with Series3 do begin
           Marks.Arrow.Visible := True;
           Marks.Callout.Brush.Color := clBlack;
           Marks.Callout.Arrow.Visible := True;
           Marks.Style := smsLabelPercent;
           Marks.Visible := True;
           DataSource := DBCrossTabSeries3;
           XLabelsSource := fldlabel;
           XValues.Order := loAscending;
           YValues.Name := 'Pie';
           YValues.Order := loNone;
           YValues.ValueSource := fldcantid;
           Frame.InnerBrush.BackColor := clRed;
           Frame.InnerBrush.Gradient.EndColor := clGray;
           Frame.InnerBrush.Gradient.MidColor := clWhite;
           Frame.InnerBrush.Gradient.StartColor := 4210752;
           Frame.InnerBrush.Gradient.Visible := True;
           Frame.MiddleBrush.BackColor := clYellow;
           Frame.MiddleBrush.Gradient.EndColor := 8553090;
           Frame.MiddleBrush.Gradient.MidColor := clWhite;
           Frame.MiddleBrush.Gradient.StartColor := clGray;
           Frame.MiddleBrush.Gradient.Visible := True;
           Frame.OuterBrush.BackColor := clGreen;
           Frame.OuterBrush.Gradient.EndColor := 4210752;
           Frame.OuterBrush.Gradient.MidColor := clWhite;
           Frame.OuterBrush.Gradient.StartColor := clSilver;
           Frame.OuterBrush.Gradient.Visible := True;
           Frame.Visible := False;
           Frame.Width := 4;
           OtherSlice.Legend.Visible := False;
        end;
      end;
   end;
   if series=1 then
     Series1.Active:=True;
   if series=2 then
     Series2.Active:=True;
   if series=3 then
     Series3.Active:=True;
end;


procedure TFrmModVar_grf.CbTipGrfChange(Sender: TObject);
begin
   Carga_series(CbTipGrf.itemindex+1);
end;

procedure TFrmModVar_grf.Button1Click(Sender: TObject);
begin
   tcgrf.PrintLandscape;
end;

procedure TFrmModVar_grf.Button2Click(Sender: TObject);
begin
  Close;
end;

procedure TFrmModVar_grf.FormActivate(Sender: TObject);
begin
  if NOT mt.Active then begin
     Carga_series(CbTipGrf.itemindex+1);
     DataSource1.DataSet:=nil;
     funciones.Carga_MemTable(sql,mt,True);
     DataSource1.DataSet:=Mt;
  end;
end;

procedure TFrmModVar_grf.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  Mt.Active:=False;
  Cnf.Destroy;
  Cnf:=nil;
end;

procedure TFrmModVar_grf.FormCreate(Sender: TObject);
begin
   dbgrid1.Visible:=false;
   cnf:=Tmemo.Create(nil);
   cnf.Parent := Self;
   cnf.Visible:=False;
   cnf.ScrollBars:= ssBoth;
   cnf.Lines.Clear;
end;


procedure TFrmModVar_grf.FormKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if (key=vk_f1) and (not dbgrid1.Visible) then
    dbgrid1.Visible:=True
  else
    dbgrid1.Visible:=false;
end;

end.
