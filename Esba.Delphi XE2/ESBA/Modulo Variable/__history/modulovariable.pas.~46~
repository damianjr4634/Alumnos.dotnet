    sql:=AnsireplaceText(sql,':CODUSU',IntToStr(Funciones.CodUsu));
    sql_Grf:=AnsireplaceText(sql_grf,'&CODUSU',IntToStr(Funciones.CodUsu));
    sql_grf:=AnsireplaceText(sql_grf,':CODUSU',IntToStr(Funciones.CodUsu));
