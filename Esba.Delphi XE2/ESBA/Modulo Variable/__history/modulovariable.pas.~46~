procedure TFrmModVariable.BtnGraficoClick(Sender: TObject);
var
   Formulario:TFrmModVar_grf;
   i:integer;
begin
  try
     formulario:=TFrmModVar_grf.Create(nil);
     Formulario.Caption:='Grafico '+FrmModVariable.Caption;
     formulario.Sql:=Sql_grf;
     formulario.cnf.lines.Text:=BuscoenMemo('[GRAFICO_CNF]');
     Formulario.TcGrf.Title.Clear;
     for I := 0 to encabezado.Lines.Count-1 do
        Formulario.TcGrf.Title.Text.Add(Encabezado.Lines.Strings[I]+'<br>');
     Formulario.ShowModal;
  finally
     Formulario.Free;
     Formulario:=Nil;
  end;
end;

procedure TFrmModVariable.BtnImprimirClick(Sender: TObject);

Procedure Imprime_encabezado();
begin
    Hoja:=Hoja+1;
    FormPreview.VistaPrevia1.NewPage;
    FormPreview.VistaPrevia1.BeginUpdate;
    If Plantilla <> '' Then Begin
          Imagen := TMetaFile.Create;
          Imagen.LoadFromFile(Unidad+Plantilla);
          c := TStringList.Create;
          Split_2(';',area,c);
          FormPreview.VistaPrevia1.Canvas.StretchDraw(VerificaNumero(c[0],'[DIBIJA_AREA]'),VerificaNumero(c[1],'[DIBIJA_AREA]'),VerificaNumero(c[2],'[DIBIJA_AREA]'),VerificaNumero(c[3],'[DIBIJA_AREA]'),Imagen,GmCentimeters);
    end;
  //  FormPreview.VistaPrevia1.Canvas.StretchDraw(StrToFloat(c[0]),StrToFloat(c[1]),StrToFloat(c[2]),StrToFloat(c[3]),Imagen,GmCentimeters);
    FormPreview.VistaPrevia1.Canvas.Font.Name := Fuente_Enca;
    FormPreview.VistaPrevia1.Canvas.Font.Size := StrToInt(Size_Enca);
    FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
    For x:=0 to Encabezado.Lines.Count-1 Do
           FormPreview.VistaPrevia1.Canvas.TextOut(Margen_enc,Margen_sup+x,Encabezado.Lines.Strings[x],GmCentimeters);
    IF Papel='LEGAL' then  begin
          If (Orientacion='H') Then
              FormPreview.VistaPrevia1.Canvas.TextOut(32,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters)
          else
              FormPreview.VistaPrevia1.Canvas.TextOut(18,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters);
    end else  begin
         If (Orientacion='H') Then
               FormPreview.VistaPrevia1.Canvas.TextOut(27,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters)
         else
               FormPreview.VistaPrevia1.Canvas.TextOut(18,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters);
    end;
    Columna:=Margen;
   //titulos
    y:=0;
    for x:=0 to MtPrn.FieldCount-1 do begin
          if funciones.campoenlista(MtPrn.Fields.Fields[x].FullName,Campos) then begin
               if y=0 then
                   Columna:=Margen
               else if b[y-1]<>'0' Then
                     Columna:=columna+VerificaNumero(b[y-1],'Anchos de impresion');
               if b[y]<>'0' Then
                     FormPreview.VistaPrevia1.Canvas.TextOut(Columna,largopagina,a[x],GmCentimeters);
               y:=y+1;
          end;
    end;
    LargoPagina:=LargoPagina+espaciado+0.3;
    FormPreview.VistaPrevia1.Canvas.Font.Name := Fuente_Deta;
    FormPreview.VistaPrevia1.Canvas.Font.Size := StrToInt(Size_Deta);
    FormPreview.VistaPrevia1.Canvas.Font.Style := [];
    FormPreview.VistaPrevia1.Canvas.Pen.Width:=EspesorLinea;
end;


