Function TFrmModVariable.VerificaNumero(Valor:String; Lugar:String):Real;
var
   numero:Real;
begin
  numero:=0;
  try
     numero:=StrToFloat(Valor);
  except
     numero:=0;
     if (strpos(pchar(valor),'.') <> nil) then
        valor:=AnsireplaceText(valor,'.',',')
     else if (strpos(pchar(valor),',') <> nil) then
        valor:=AnsireplaceText(valor,',','.');
  end;
  try
     numero:=StrToFloat(Valor);
  except
     MessageDlg(pchar(lugar+'. Error al comvertir el numero '+valor+' a punto flotante. Se usara valor 0'),mtInformation, [mbok],0,mbok);
     numero:=0;
  end;
  result:=numero;
end;

procedure Split_2 (const Delimiter: Char; Input: string;  Const Strings: TStrings) ;
begin
   Assert(Assigned(Strings)) ;
   Strings.Clear;
   Strings.Delimiter := Delimiter;
   Strings.DelimitedText := Input;
end;

Function TFrmModVariable.BuscoEnMemo(Texto:String):String;
Var x:Integer;
Begin
  Result:='';
  if (Memo.Lines.IndexOf(Texto)=-1) then
    exit;
  For x:=Memo.Lines.IndexOf(Texto)+1 To Memo.Lines.Count Do
    Begin
      if (Memo.Lines.Strings[x]='[]') then
        break;
      Result:=Result+Memo.Lines.Strings[x];
      Result:=Result+#13;
    End
End;

