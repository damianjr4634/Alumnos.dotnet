          sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+TEdit(FrmParametros.LstParam[x].control).Text+'''');
          sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,TEdit(FrmParametros.LstParam[x].control).Text);
       end
       else If (FrmParametros.LstParam[x].Tipo='K') Then begin
          if (TComboEdit(FrmParametros.LstParam[x].control).Text='') then begin
             sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,'0');
             sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,'');
             sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,'0');
             sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,'')
          end
          else begin
             if (FrmParametros.LstParam[x].CampoValDevol<>'') then begin
                sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,FrmParametros.LstParam[x].CampoValDevol);
                sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+FrmParametros.LstParam[x].CampoValDevol+'''');
                sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,FrmParametros.LstParam[x].CampoValDevol);
                sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+FrmParametros.LstParam[x].CampoValDevol+'''');
             end
             else begin
                sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+TComboEdit(FrmParametros.LstParam[x].control).Text+'''');
                sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,TComboEdit(FrmParametros.LstParam[x].control).Text);
                sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+TComboEdit(FrmParametros.LstParam[x].control).Text+'''');
                sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,TComboEdit(FrmParametros.LstParam[x].control).Text);
             end
          end
       end
       else If (FrmParametros.LstParam[x].Tipo='D') Then begin
          fecha:=FormatDateTime('mm/dd/yyyy',TDateEdit(FrmParametros.LstParam[x].control).Date);
          sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,''''+fecha+'''');
          sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+fecha+'''');
          sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,''''+fecha+'''');
          sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+fecha+'''');
       end
       else If (FrmParametros.LstParam[x].Tipo='N') Then
        Begin
          If (TCurrencyEdit(FrmParametros.LstParam[x].control).Text='') Then begin
            sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,'0');
            sql:=AnsireplaceText(sql,'&'+''''+FrmParametros.LstParam[x].Variable+'''','0');
            sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,'0');
            sql_grf:=AnsireplaceText(sql_grf,'&'+''''+FrmParametros.LstParam[x].Variable+'''','0');
          end
          Else begin
            sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+TCurrencyEdit(FrmParametros.LstParam[x].control).Text+'''');
            sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,TCurrencyEdit(FrmParametros.LstParam[x].control).Text);
            sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+TCurrencyEdit(FrmParametros.LstParam[x].control).Text+'''');
            sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,TCurrencyEdit(FrmParametros.LstParam[x].control).Text);
          end
        End
       else If (FrmParametros.LstParam[x].Tipo='X') Then
         Begin
          For y:=0 to TRxCheckListBox(FrmParametros.LstParam[x].control).Items.Count-1 do
            Begin
              If TRxCheckListBox(FrmParametros.LstParam[x].control).Checked[y] then
                  Lista:=Lista+TRxCheckListBox(FrmParametros.LstParam[x].control).Items.Strings[y]+',';
            End;
            Lista:=Copy(Lista,1,Length(Lista)-1);
            sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+Lista+'''');
            sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,Lista);
            sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+Lista+'''');
            sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,Lista);
         End
       else If (FrmParametros.LstParam[x].Tipo='L') Then begin
         sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+FrmParametros.LstParam[X].Valores_lista[TComboBox(FrmParametros.LstParam[x].control).ItemIndex]+'''');
         sql:=AnsireplaceText(sql,':'+FrmParametros.LstParam[x].Variable,FrmParametros.LstParam[X].Valores_lista[TComboBox(FrmParametros.LstParam[x].control).ItemIndex]);
         sql_grf:=AnsireplaceText(sql_grf,'&'+FrmParametros.LstParam[x].Variable,''''+FrmParametros.LstParam[X].Valores_lista[TComboBox(FrmParametros.LstParam[x].control).ItemIndex]+'''');
         sql_grf:=AnsireplaceText(sql_grf,':'+FrmParametros.LstParam[x].Variable,FrmParametros.LstParam[X].Valores_lista[TComboBox(FrmParametros.LstParam[x].control).ItemIndex]);
       end;
       Encabezado.Lines.Text:=AnsireplaceText(Encabezado.Lines.Text,'&'+FrmParametros.LstParam[x].Variable,''''+TEdit(FrmParametros.LstParam[x].control).Text+'''');
       Encabezado.Lines.Text:=AnsireplaceText(Encabezado.Lines.Text,':'+FrmParametros.LstParam[x].Variable,TEdit(FrmParametros.LstParam[x].control).Text);
     End;
     DataSet.SQLs.SelectSql.Text:=Sql;
     Try
       DataSet.Active:=True;
       Tr.Active:=True;
       Lista:=BuscoEnMemo('[TITULOS]');
       Titulos := TStringList.Create;
       Split_2(';',Lista, Titulos);
       Lista:=BuscoEnMemo('[ANCHOS]');
       Anchos := TStringList.Create;
       Split_2(';',Lista, Anchos);
       Lista:=BuscoEnMemo('[MASCARAS]');
       Mascaras := TStringList.Create;
       Split_2(';',Lista, Mascaras);
       For x:=0 to Dataset.FieldCount-1 Do
        Begin
         Mt.FieldDefs.Add(DataSet.Fields.Fields[x].FullName,DataSet.Fields.Fields[x].DataType,DataSet.Fields.Fields[x].Size,False);
         MtPrn.FieldDefs.Add(DataSet.Fields.Fields[x].FullName,DataSet.Fields.Fields[x].DataType,DataSet.Fields.Fields[x].Size,False);
        end;
       Mt.CreateTable;
       MtPrn.CreateTable;
       For x:=0 to Titulos.Count-1 Do
        Begin
         Grilla.Columns.Add;
         Grilla.Columns.Items[x].Field:=Mt.Fields.Fields[x];
         Grilla.Columns.Items[x].Field.DisplayLabel:=Titulos[x];
         Grilla.Columns.Items[x].Field.DisplayWidth:=StrToInt(Anchos[x]);
         if StrToInt(Anchos[x])=0 Then
            Grilla.Columns.Items[x].Visible:=False;
         Mt.Fields.Fields[x].DisplayLabel:=Titulos[x];
         if (Mascaras.Count>x) and (Mascaras[x]<>'') then
             TFloatField(Mt.Fields.Fields[x]).DisplayFormat:=Mascaras[x];
        End;
       mt.Active:=true;
       mtPrn.Active:=true;
       Mt.First;
       MtPrn.First;
       Dataset.First;
       while Not dataset.eof do begin
          mt.Append;
          mtPrn.Append;
          for x := 0 to dataset.FieldCount-1 do begin
             mt.Fields.fields[x].Value:=dataset.FieldByName(mt.Fields.fields[x].fullname).Value;
             mtPrn.Fields.fields[x].Value:=dataset.FieldByName(mtPrn.Fields.fields[x].fullname).Value;
          end;
          mt.Post;
          mtPrn.Post;
          dataset.Next;
       end;
       Lista:=BuscoEnMemo('[FORMULARIO]');
       Formulario := TStringList.Create;
       if (lista<>'') then begin
          Split_2(';',Lista, Formulario);
          Ancho:=StrToInt(formulario[0]);
          Alto:=StrToInt(Formulario[1]);
       end;
       Lista:=BuscoEnMemo('[VISOR]');
       Visor := TStringList.Create;
       if (lista<>'') then begin
          Split_2(';',Lista, Visor);
          Modulo_form:=Visor[0];
          Modulo_clave:=Visor[1];
       end Else
         BtnViewer.Visible:=False;
       Lista:=BuscoEnMemo('[GRAFICO]');
       BtnGrafico.Visible:=False;
       if Lista<>'' then
         BtnGrafico.Visible:=True;
     Except
       on E: Exception do
       begin
           DataSet.Active:=False;
           Tr.RollBack;
           mensaje:=TFrmmensaje.Create(self);
           mensaje.Memo1.Lines.Text:='Error en query'+#13+#13+E.Message+#13+#13+SQL;
//           ShowMessage(Format(errConnectBD, [E.Message]));
           mensaje.ShowModal;
           mensaje.Free;
       end;
  //     MessageBox(Application.Handle,PCHAR(DataSet.SQL.Text),'Error en query',MB_OK+MB_ICONERROR+MB_APPLMODAL);
//       Parametros.Pasa:=False;
     End;
//     FrmParametros.Memo.Destroy;
  End;
  if Tr.Active then
     Tr.Rollback;
  DataSet.Active:=False;
  Tr.Active:=False;
  FrmParametros.DestroyComponents;
  FrmParametros.Free;
  Cerrar:=Parametros.Pasa;
end;

procedure TFrmModVariable.MtFilterRecord(DataSet: TDataSet;
  var Accept: Boolean);
Var x:Integer;
begin
 If (TxtBusqueda.Text='') Then
      Accept:=True
   Else begin
      Accept:=False;
      For x:=0 to  Mt.FieldCount-1 Do begin
         if PosEx(uppercase(TxtBusqueda.Text),uppercase(DataSet.Fields.Fields[x].AsString),1)>0 Then
             Accept:=True
      end;
   end;
end;

