      if AnsiPos('PAPEL',Memo1.Lines.Strings[x])<>0 Then
          Papel:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('SIZE_DETALLE',Memo1.Lines.Strings[x])<>0 Then
          Size_Deta:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('FUENTE_DETALLE',Memo1.Lines.Strings[x])<>0 Then
          Fuente_Deta:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('SIZE_ENCABEZADO',Memo1.Lines.Strings[x])<>0 Then
          Size_Enca:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('FUENTE_ENCABEZADO',Memo1.Lines.Strings[x])<>0 Then
         Fuente_Enca:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('ORIENTACION',Memo1.Lines.Strings[x])<>0 Then
          Orientacion:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('ANCHOS',Memo1.Lines.Strings[x])<>0 Then
          Anchos:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('PLANTILLA',Memo1.Lines.Strings[x])<>0 Then
          Plantilla:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('AREA',Memo1.Lines.Strings[x])<>0 Then
          area:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('INICIO',Memo1.Lines.Strings[x])<>0 Then
          Inicio:=VerificaNumero(Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x])),'INICIO');
      if AnsiPos('MARGEN_IZQUIERDO',Memo1.Lines.Strings[x])<>0 Then
          Margen:=VerificaNumero(Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x])),'MARGEN_IZQUIERDO');
      if AnsiPos('ESPACIADO',Memo1.Lines.Strings[x])<>0 Then
          Espaciado:=VerificaNumero(Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x])),'ESPACIADO');
      if AnsiPos('CORTE_PAGINA',Memo1.Lines.Strings[x])<>0 Then
          Corte:=VerificaNumero(Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x])),'CORTE_PAGINA');
      if AnsiPos('NUMERO_PAGINA',Memo1.Lines.Strings[x])<>0 Then
          Pagina:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('ESPESOR_LINEA',Memo1.Lines.Strings[x])<>0 Then
          EspesorLinea:=StrToInt(Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x])));
      if AnsiPos('CAMPOS',Memo1.Lines.Strings[x])<>0 Then
          Campos:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('GRUPOS',Memo1.Lines.Strings[x])<>0 Then
          Grupos:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
      if AnsiPos('MASCARAS',Memo1.Lines.Strings[x])<>0 Then
          Mascaras_prn:=Copy(Memo1.Lines.Strings[x],AnsiPos('=',Memo1.Lines.Strings[x])+1,Length(Memo1.Lines.Strings[x]));
    End;
  if (Plantilla<>'') and (area='') then begin
      MessageDlg('Si define plantilla defina el area de la misma con el tag AREA. La plantilla no se tomara en cuenta',mtInformation, [mbok],0,mbok);
      Plantilla:='';
  end;
  With FormPreview do
    Begin
      FormPreview.VistaPrevia1.Canvas.Pen.Width:=EspesorLinea;
       If Plantilla <> '' Then
         Begin
          Imagen := TMetaFile.Create;
          Imagen.LoadFromFile(Unidad+Plantilla);
          c := TStringList.Create;
          Split_2(';',area,c);
          VistaPrevia1.Canvas.StretchDraw(VerificaNumero(c[0],'[DIBIJA_AREA]'),VerificaNumero(c[1],'[DIBIJA_AREA]'),VerificaNumero(c[2],'[DIBIJA_AREA]'),VerificaNumero(c[3],'[DIBIJA_AREA]'),Imagen,GmCentimeters);
         end;
      FormPreview.VistaPrevia1.Canvas.Font.Name := Fuente_Enca;
      FormPreview.VistaPrevia1.Canvas.Font.Size := StrToInt(Size_Enca);
      FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
       For x:=0 to Encabezado.Lines.Count-1 Do
          VistaPrevia1.Canvas.TextOut(Margen_enc,Margen_sup+x,Encabezado.Lines.Strings[x],GmCentimeters);
       If (Orientacion='H') Then
          VistaPrevia1.Orientation:=gmLandscape
       Else
          VistaPrevia1.Orientation:=gmPortrait;
       VistaPrevia1.PaperSize:=A4;
       If Papel='A4' Then
         VistaPrevia1.PaperSize:=A4;
       If Papel='LEGAL' Then
         VistaPrevia1.PaperSize:=Legal;
      FormPreview.VistaPrevia1.BeginUpdate;
      IF Papel='LEGAL' then
        begin
          If (Orientacion='H') Then
            VistaPrevia1.Canvas.TextOut(32,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters)
          else
            VistaPrevia1.Canvas.TextOut(18,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters);
        end
      else
        begin
          If (Orientacion='H') Then
            VistaPrevia1.Canvas.TextOut(27,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters)
          else
            VistaPrevia1.Canvas.TextOut(18,0.5,'Pagina: '+IntToStr(Hoja),GmCentimeters);
        end;
      Lista:=BuscoEnMemo('[TITULOS]');
      A := TStringList.Create;
      B := TStringList.Create;
      d := TStringList.Create;
      if Grupos<>'' then begin
         Split_2(';',Grupos,A);
         Campo_grupo:=a[0];
         try
            Texto_grupo:=a[1];
            Grupo_Corte:=a[2];
         except
            Texto_grupo:='';
            Grupo_Corte:='N';
         end;
      end;
      Split_2(';',Lista,A);
      Split_2(';',Anchos,b);
      Split_2(';',Mascaras_prn,d);
      LargoPagina := inicio;
       //titulos
      y:=0;
      for x:=0 to MtPrn.FieldCount-1 do begin
           if funciones.campoenlista(MtPrn.Fields.Fields[x].FullName,Campos) then begin
               if y=0 then
                    Columna:=Margen
               else if b[y-1]<>'0' Then
                   Columna:=columna+VerificaNumero(b[y-1],'Anchos de impresion');
               if b[y]<>'0' Then
                  VistaPrevia1.Canvas.TextOut(Columna,largopagina,a[x],GmCentimeters);
               y:=y+1;
           end;
      end;
      LargoPagina:=LargoPagina+espaciado+0.3;
      //Datos
      MtPrn.First;
      FormPreview.VistaPrevia1.Canvas.Font.Name := Fuente_Deta;
      FormPreview.VistaPrevia1.Canvas.Font.Size := StrToInt(Size_Deta);
      FormPreview.VistaPrevia1.Canvas.Font.Style := [];
      Grupo_ValAnterior:='';
      While Not MtPrn.Eof Do Begin
          While (LargoPagina<=Corte) and (Not MtPrn.Eof) Do Begin
                if grupos<>'' then begin
                    if (MtPrn.FieldByName(Campo_grupo).AsString<>Grupo_ValAnterior) then begin
                         if Grupo_Valanterior<>'' then begin
                             Grupo_ValAnterior:=MtPrn.FieldByName(Campo_Grupo).AsString;
                             if grupo_corte='S' then begin
                                 LargoPagina:=Inicio;
                                 VistaPrevia1.EndUpdate;
                                 Imprime_encabezado;
                             end;
                         end else
                             Grupo_ValAnterior:=MtPrn.FieldByName(Campo_Grupo).AsString;
                         FormPreview.VistaPrevia1.Canvas.Font.Name := Fuente_Enca;
                         FormPreview.VistaPrevia1.Canvas.Font.Size := StrToInt(Size_Enca);
                         FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
                         Largopagina:=Largopagina+0.8;
                         VistaPrevia1.Canvas.TextOut(Margen,largopagina,Texto_Grupo+' '+MtPrn.FieldByName(Campo_Grupo).AsString,GmCentimeters);
                         Largopagina:=Largopagina+0.8;
                         FormPreview.VistaPrevia1.Canvas.Font.Name := Fuente_Deta;
                         FormPreview.VistaPrevia1.Canvas.Font.Size := StrToInt(Size_Deta);
                         FormPreview.VistaPrevia1.Canvas.Font.Style := [];
                    end;
                end;
                y:=0;
                for x:=0 to MtPrn.FieldCount-1 do begin
                    if funciones.campoenlista(MtPrn.Fields.Fields[x].FullName,Campos) then begin
                        if y=0 then
                            Columna:=Margen
                        else
                            If VerificaNumero(b[y-1],'Anchos de impresion')<>0 Then
                                Columna:=columna+VerificaNumero(b[y-1],'Anchos de impresion');
                        If (VerificaNumero(b[y],'Anchos de impresion')<>0) and not varisnull(mtPrn.Fields.Fields[x].Value) and not varisfloat(mtPrn.Fields.Fields[x].Value) Then
                             VistaPrevia1.Canvas.TextOut(Columna,largopagina,mtPrn.Fields.Fields[x].Value,GmCentimeters)
                        else if (b[y]<>'0') and not varisnull(mtPrn.Fields.Fields[x].Value) and varisfloat(mtPrn.Fields.Fields[x].Value) Then begin
                             if (d.Count>0) and (d[y]<>'') then begin
                                  //VistaPrevia1.Canvas.TextOut(Columna,largopagina,'#',GmCentimeters);
                                  VistaPrevia1.Canvas.FloatOut(Columna+(VerificaNumero(b[y],'Anchos de impresion')/2),largopagina,mtPrn.Fields.Fields[x].Value,d[y],GmCentimeters)
                             end
                             else
                                  VistaPrevia1.Canvas.TextOut(Columna,largopagina,formatfloat(',0.00',mtPrn.Fields.Fields[x].Value),GmCentimeters);
                        end;
                        y:=y+1;
                    end;
                end;
                If DibLineas='S' Then Begin
                    If Anchotot=0 Then
                         For x:=0 to b.Count-1 do
                            AnchoTot:=AnchoTot+VerificaNumero(b[x],'Anchos de impresion');
                    VistaPrevia1.Canvas.Line(Margen,LargoPagina+Espaciado-0.1,Margen+Anchotot,LargoPagina+Espaciado-0.1,GmCentimeters);
                End;
                LargoPagina:=LargoPagina+espaciado;
                mtPrn.Next;
          end;
          LargoPagina:=Inicio;
          VistaPrevia1.EndUpdate;
          if not mtPrn.eof then
            Begin
               Imprime_encabezado;
            End;
        End;
      ShowModal;
      Free;
    End;
END
end;

