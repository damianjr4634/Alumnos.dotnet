     Begin
       If (FrmParametros.LstParam[x].Tipo='C') Then begin
          sql:=AnsireplaceText(sql,'&'+FrmParametros.LstParam[x].Variable,''''+TEdit(FrmParametros.LstParam[x].control).Text+'''');
