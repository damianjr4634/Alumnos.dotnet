  end
end;

procedure TFrmBusqueda.FormActivate(Sender: TObject);
begin
  TxtBsq.SetFocus;
end;

procedure TFrmBusqueda.TxtBsqKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  If Key=40 Then
    Query.Next;
  If Key=38 Then
    Query.Prior;
  If (Key=34) And Not (Query.Eof) Then
    Query.RecNo:=Query.RecNo+10;
  If (Key=33) And Not(Query.Bof) Then
    Query.RecNo:=Query.RecNo-10;
end;

