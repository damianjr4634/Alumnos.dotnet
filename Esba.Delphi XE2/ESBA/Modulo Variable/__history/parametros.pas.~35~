unit parametros;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs,StdCtrls, StrUtils, Mask, RXToolEdit, RXCurrEdit, RXCtrls, Busqueda, DataModule,DB,
  FuncionesText, FuncionesConfiguracion;

Type Param=Record
  Labels:TLabel;
  control:Tcontrol;
  Etiqueta:String;
  Variable:String;
  Tipo:String;
  KMultiselect: boolean;
  Obligatorio:String;
  SQL:String;
  Lista:Array of String;
  Titulos:Array of String;
  Valores_Lista:Array of String;
  ValorDefecto:String;
  CharFill:String[1];
  CampoDevol:String;
  CampoValDevol:String;
end;

type
  TFrmParametros = class(TForm)
    BtnAceptar: TButton;
    BtnCancelar: TButton;
    procedure FormCreate(Sender: TObject);
    procedure FormActivate(Sender: TObject);
    procedure BtnAceptarClick(Sender: TObject);
    procedure BtnCancelarClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    Memo:Tmemo;
    LstParam: Array Of Param;
    Procedure CargoRegistro;
    procedure ComboEditButtonClick(Sender: TObject);
    procedure ComboEditExit(Sender: TObject);
    Procedure TransformaArray(x:Integer;texto:string);
    procedure KeyPress(Sender: TObject; var Key: Char);
  end;



var
  FrmParametros: TFrmParametros;
  Pasa:Boolean;
  Carrera_activa:String;
  UltParam:Variant;
  procedure Split (const Delimiter: Char; Input: string;  Const Strings: TStrings) ;

implementation

{$R *.dfm}

Procedure TFrmParametros.KeyPress(Sender: TObject; var Key: Char);
begin
   if (Key=#13) then
      BtnAceptarClick(BtnAceptar);
end;


procedure Split (const Delimiter: Char; Input: string;  Const Strings: TStrings) ;
begin
   Assert(Assigned(Strings)) ;
   Strings.Clear;
   Strings.Delimiter := Delimiter;
   Strings.DelimitedText := Input;
end;

Procedure TFrmParametros.TransformaArray(x:Integer;texto:string);
Var y:Integer;
    A,B: TStringList;
Begin
  A := TStringList.Create;
  Split(';',Texto, A);
  LstParam[x].Etiqueta:=a[0];
  LstParam[x].Variable:=a[1];
  LstParam[x].Tipo:=a[2];
  LstParam[x].KMultiselect:= false;

  if (StrPos(Pchar(a[3]),'S')<>nil) then
    LstParam[x].Obligatorio:='S'
  else if (StrPos(Pchar(a[3]),'N')<>nil) then
    LstParam[x].Obligatorio:='N';

  if (LstParam[x].Tipo='C') or (LstParam[x].Tipo='N') Then begin
     try
         if (a[4]='&CUA_ACT') then
             LstParam[x].ValorDefecto:=FuncionesText.Cuatrimestre(carrera_activa);
         if (a[4]='&CAR_ACT') then
             LstParam[x].ValorDefecto:=Carrera_activa;
     except
         LstParam[x].ValorDefecto:='';
     end;
  end;
  if (LstParam[x].Tipo='K') Then
   Begin
      LstParam[x].SQL:=a[4];
      LstParam[x].SQL:=AnsireplaceText(LstParam[x].SQL,'&CODUSU',IntToStr(FuncionesConfiguracion.CodUsu));
      LstParam[x].SQL:=AnsireplaceText(LstParam[x].SQL,':CODUSU',IntToStr(FuncionesConfiguracion.CodUsu));

      LstParam[x].KMultiselect:= (StrPos(PChar(a[3]),'M')<>nil);
      B := TStringList.Create;
      Split(',',a[5],B);
      SetLength(LstParam[x].Titulos,B.Count);
      For y:=0 to High(LstParam[x].Titulos) do
          LstParam[x].Titulos[y]:=b[y];
      LstParam[x].CharFill:=a[6];
      LstParam[x].CampoDevol:=a[7];
      try
         if (a[8]='&CUA_ACT') then
             LstParam[x].ValorDefecto:=FuncionesText.Cuatrimestre(carrera_activa);
         if (a[8]='&CAR_ACT') then
             LstParam[x].ValorDefecto:=Carrera_activa;
      except
         LstParam[x].ValorDefecto:='';
      end;
      B.Free;
  end
  else if (LstParam[x].Tipo='X') Then
   Begin
      B := TStringList.Create;
      Split(',',a[4],B);
      SetLength(LstParam[x].Lista,B.Count);
      For y:=0 to High(LstParam[x].Lista) do
          LstParam[x].Lista[y]:=b[y];
      B.Free;
   End
  else if (LstParam[x].Tipo='L') Then
   Begin
      B := TStringList.Create;
      Split(',',a[4],B);
      SetLength(LstParam[x].Lista,B.Count);
      For y:=0 to High(LstParam[x].Lista) do
          LstParam[x].Lista[y]:=b[y];
      Split(',',a[5],B);
      SetLength(LstParam[x].Valores_lista,B.Count);
      For y:=0 to High(LstParam[x].Valores_Lista) do
          LstParam[x].Valores_Lista[y]:=b[y];
      LstParam[x].ValorDefecto:=a[6];
      B.Free;
   End;
  A.Free;
End;

Procedure TFrmParametros.CargoRegistro;
Var x,y:integer;
    Linea:string;
    Top:integer;
Begin
  FrmParametros.Width:=285;
  FrmParametros.Position:=poScreenCenter;
  //Width:=235;
  //Position:=poScreenCenter;
  SetLength(LstParam,(Memo.Lines.Count));
  Top:=10;
  For x:=0 to Memo.Lines.Count-1 do
    begin
     Linea:=Memo.Lines.Strings[x];
     transformaarray(x,Linea);
     LstParam[x].Labels:=TLabel.Create(FrmParametros);
     LstParam[x].Labels.Parent:=FrmParametros;
     TLabel(LstParam[x].Labels).Caption:=LstParam[x].Etiqueta;
     TLabel(LstParam[x].Labels).Left:=8;
     TLabel(LstParam[x].Labels).Top:=Top;
     TLabel(LstParam[x].Labels).Visible:=True;
     If (LstParam[x].Tipo='C') Then
      Begin
        LstParam[x].Control:=TEdit.Create(FrmParametros);
        LstParam[x].Control.Parent:=FrmParametros;
        TEdit(LstParam[x].Control).Text:='';
        TEdit(LstParam[x].Control).Top:=Top-6;
        TEdit(LstParam[x].Control).Width:=121;
        TEdit(LstParam[x].Control).Left:=150;
        TEdit(LstParam[x].Control).Width:=100;
        TEdit(LstParam[x].Control).Visible:=True;
        TEdit(LstParam[x].Control).Tag:=x;
        TEdit(LstParam[x].Control).text:=LstParam[x].ValorDefecto;
        TEdit(LstParam[x].Control).OnKeyPress:=KeyPress;
      End
     else If (LstParam[x].Tipo='N') Then
      Begin
        LstParam[x].Control:=TCurrencyEdit.Create(FrmParametros);
        LstParam[x].Control.Parent:=FrmParametros;
        TCurrencyEdit(LstParam[x].Control).Text:='';
        TCurrencyEdit(LstParam[x].Control).Top:=Top-6;
        TCurrencyEdit(LstParam[x].Control).Left:=150;
        TCurrencyEdit(LstParam[x].Control).Width:=100;
        TCurrencyEdit(LstParam[x].Control).Width:=121;
        TCurrencyEdit(LstParam[x].Control).Visible:=True;
        TCurrencyEdit(LstParam[x].Control).DecimalPlaces:=0;
        TCurrencyEdit(LstParam[x].Control).DisplayFormat:='';
        TCurrencyEdit(LstParam[x].Control).Value:=0;
        TCurrencyEdit(LstParam[x].Control).Alignment:=taRightJustify;
        TCurrencyEdit(LstParam[x].Control).Tag:=x;
        TCurrencyEdit(LstParam[x].Control).text:=LstParam[x].ValorDefecto;
        TCurrencyEdit(LstParam[x].Control).OnKeyPress:=KeyPress;
      End
     else If (LstParam[x].Tipo='K') Then
      Begin
        LstParam[x].Control:=TComboEdit.Create(FrmParametros);
        LstParam[x].Control.Parent:=FrmParametros;
        TComboEdit(LstParam[x].Control).Top:=Top-6;
        TComboEdit(LstParam[x].Control).Left:=150;
        TComboEdit(LstParam[x].Control).Width:=121;
        TComboEdit(LstParam[x].Control).Visible:=True;
        TComboEdit(LstParam[x].Control).GlyphKind:=gkEllipsis;
        TComboEdit(LstParam[x].Control).OnButtonClick:=ComboEditButtonClick;
        TComboEdit(LstParam[x].Control).OnExit:=ComboEditExit;
        TComboEdit(LstParam[x].Control).Tag:=x;
        TComboEdit(LstParam[x].Control).ClickKey:=VK_F1;
        TComboEdit(LstParam[x].Control).text:=LstParam[x].ValorDefecto;
        TComboEdit(LstParam[x].Control).OnKeyPress:=KeyPress;
      End
     else If (LstParam[x].Tipo='X') Then
      Begin
        LstParam[x].Control:=TRxCheckListBox.Create(FrmParametros);
        LstParam[x].Control.Parent:=FrmParametros;
        TRxCheckListBox(LstParam[x].Control).Top:=Top-6;
        TRxCheckListBox(LstParam[x].Control).Left:=150;
        TRxCheckListBox(LstParam[x].Control).Width:=121;
        TRxCheckListBox(LstParam[x].Control).Height:=100;
        TRxCheckListBox(LstParam[x].Control).Visible:=True;
        top:=top+80;
        for y:=0 to High(LstParam[x].Lista) do
           TRxCheckListBox(LstParam[x].Control).Items.Add(LstParam[x].Lista[y]);
        TRxCheckListBox(LstParam[x].Control).Tag:=x;
        TRxCheckListBox(LstParam[x].Control).OnKeyPress:=KeyPress;
      End
    else If (LstParam[x].Tipo='D') Then
      Begin
        LstParam[x].Control:= TDateEdit.Create(FrmParametros);
        LstParam[x].Control.Parent:=FrmParametros;
        TDateEdit(LstParam[x].Control).Top:=Top-6;
        TDateEdit(LstParam[x].Control).Left:=150;
        TDateEdit(LstParam[x].Control).Width:=121;
        TDateEdit(LstParam[x].Control).Visible:=True;
        TDateEdit(LstParam[x].Control).Tag:=x;
        TDateEdit(LstParam[x].Control).Date:=Date;
        TDateEdit(LstParam[x].Control).OnKeyPress:=KeyPress;
      End
     else If (LstParam[x].Tipo='L') Then
      Begin
        LstParam[x].Control:= TComboBox.Create(FrmParametros);
        LstParam[x].Control.Parent:=FrmParametros;
        For y:=0 to high(LstParam[x].Lista) do
          TComboBox(LstParam[x].control).Items.Add(LstParam[x].lista[y]);
        TComboBox(LstParam[x].Control).Top:=Top-6;
        TComboBox(LstParam[x].Control).Left:=150;
        TComboBox(LstParam[x].Control).Width:=121;
        TComboBox(LstParam[x].Control).Visible:=True;
        TComboBox(LstParam[x].Control).Tag:=x;
        TComboBox(LstParam[x].Control).Style:=csDropDownList;
        TcomboBox(LstParam[x].control).ItemIndex:=StrToInt(LstParam[x].ValorDefecto);
        TcomboBox(LstParam[x].Control).OnKeyPress:=KeyPress;
      End;
     Top:=Top+30;
    End;
  try
    if not VarIsnull(UltParam) then begin
       for x := 0 to High(LstParam) do begin
           If (LstParam[X].Tipo='D') Then
              TDateEdit(LstParam[X].Control).Date:=UltParam[x]
           else If (LstParam[X].Tipo='C') Then
              TEdit(LstParam[X].Control).Text:=UltParam[x]
           else If (LstParam[X].Tipo='N') Then
              TCurrencyEdit(LstParam[X].Control).Value:=UltParam[x]
           else If (LstParam[X].Tipo='K') Then
              TComboEdit(LstParam[X].Control).Text:=UltParam[x]
           //else If (LstParam[X].Tipo='X') Then
             // UltParam[x]:=UltParam[x]
           else If (LstParam[X].Tipo='L') Then
              TComboBox(LstParam[X].Control).ItemIndex:=UltParam[x];

      end
    end;
  except
       for x := 0 to High(LstParam) do begin
           If (LstParam[X].Tipo='D') Then
              TDateEdit(LstParam[X].Control).Date:=date
           else If (LstParam[X].Tipo='C') Then
              TEdit(LstParam[X].Control).Text:=''
           else If (LstParam[X].Tipo='N') Then
              TCurrencyEdit(LstParam[X].Control).Value:=0
           else If (LstParam[X].Tipo='K') Then
              TComboEdit(LstParam[X].Control).Text:=''
           else If (LstParam[X].Tipo='X') Then
              UltParam[x]:=UltParam[x]
           else If (LstParam[X].Tipo='L') Then
              TComboBox(LstParam[X].Control).ItemIndex:=StrToInt(LstParam[x].ValorDefecto);
      end
  end;
  //FrmParametros.ClientHeight:=Top+35;
  ClientHeight:=Top+35;
  BtnAceptar.Top:=Top;
  BtnCancelar.Top:=Top;
End;


