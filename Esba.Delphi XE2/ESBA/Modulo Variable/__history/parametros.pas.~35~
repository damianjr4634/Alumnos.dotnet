procedure TFrmParametros.ComboEditButtonClick(Sender: TObject);
Var
   x,y:Integer;
   sql,Lista, aText:string;
   I: integer;

begin
  //setLength(Field,2);
  FrmBusqueda := TFrmBusqueda.Create(FrmParametros);
  sql:=LstParam[TComponent(Sender).Tag].SQL;
  lista:='';
  FrmBusqueda.DBGrid1.MultiSelect:= LstParam[TComponent(Sender).Tag].KMultiselect;

  With FrmBusqueda Do
    Begin
       Query.SQLs.SelectSql.Clear;
       For x:=0 to High(LstParam) Do
         Begin
            If (LstParam[x].Tipo='C') Then begin
              sql:=AnsireplaceText(sql,'&'+LstParam[x].Variable,''''+TEdit(LstParam[x].control).Text+'''');
              sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,TEdit(LstParam[x].control).Text)
            end
            else If (LstParam[x].Tipo='K') Then begin
              if (LstParam[x].CampoValDevol='') Then begin
                 sql:=AnsireplaceText(sql,'&'+LstParam[x].Variable,''''+TComboEdit(LstParam[x].control).Text+'''');
                 sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,TComboEdit(LstParam[x].control).Text);
              end
              else begin
                 sql:=AnsireplaceText(sql,'&'+LstParam[x].Variable,''''+LstParam[x].CampoValDevol+'''');
                 sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,LstParam[x].CampoValDevol);
              end
            end
            else If (LstParam[x].Tipo='D') Then begin
              sql:=AnsireplaceText(sql,'&'+LstParam[x].Variable,''''+FormatDateTime('mm/dd/yyyy',TDateEdit(LstParam[x].control).Date)+'''');
              sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,''''+FormatDateTime('mm/dd/yyyy',TDateEdit(LstParam[x].control).Date)+'''');
            end
            else If (LstParam[x].Tipo='N') Then begin
              sql:=AnsireplaceText(sql,'&'+LstParam[x].Variable,''''+TCurrencyEdit(LstParam[x].control).Text+'''');
              sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,TCurrencyEdit(LstParam[x].control).Text);
            end
            else If (LstParam[x].Tipo='X') Then
              Begin
                For y:=0 to TRxCheckListBox(LstParam[x].control).Items.Count-1 do
                  Begin
                    If TRxCheckListBox(LstParam[x].control).Checked[y] then
                       Lista:=Lista+TRxCheckListBox(LstParam[x].control).Items.Strings[y]+',';
                  End;
                Lista:=Copy(Lista,1,Length(Lista)-1);
                sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,''''+Lista+'''');
              end
            else If (LstParam[x].Tipo='L') Then begin
              sql:=AnsireplaceText(sql,'&'+LstParam[x].Variable,''''+LstParam[x].Valores_lista[TComboBox(LstParam[x].control).ItemIndex]+'''');
              sql:=AnsireplaceText(sql,':'+LstParam[x].Variable,LstParam[x].Valores_lista[TComboBox(LstParam[x].control).ItemIndex]);
            end
         End;
       Query.SQLs.SelectSql.Text:=sql;//LstParam[TComponent(Sender).Tag].SQL;
       pFIBTransaction1.Active:=True;
       Query.Active:=True;
       SetLength(Busqueda.Titulos,High(LstParam[TComponent(Sender).Tag].Titulos)+1);
       For x:=0 to Query.FieldCount-1 do
        Begin
              Dbgrid1.Columns.Add;
   {          Dbgrid1.Columns.Items[x].FieldName:=Query.Fields.Fields[x].FieldName;
              DbGrid1.Columns.Items[x].Title.Caption:=LstParam[TComponent(Sender).Tag].Titulos[x];
              DbGrid1.Columns.Items[x].Width:=Query.Fields.Fields[x].DisplayWidth;
   }          DbGrid1.Columns.Items[x].Field:=Query.Fields.Fields[x];
              DbGrid1.Columns.Items[x].Field.DisplayLabel:=LstParam[TComponent(Sender).Tag].Titulos[x];
              DbGrid1.Columns.Items[x].Field.DisplayWidth:=Query.Fields.Fields[x].DisplayWidth;
              Busqueda.Titulos[x]:=LstParam[TComponent(Sender).Tag].Titulos[x];
              IF (LstParam[TComponent(Sender).Tag].Titulos[x]='') Then
                  DbGrid1.Columns.Items[x].Visible:=False;
        End;
       Width:=120;
       For x:=0 to High(LstParam[TComponent(Sender).Tag].Titulos) Do
         Width:=Width+dbgrid1.Columns.Items[x].Width;

       if Width<200 then
          Width:=200;

       TxtBsq.Width:=Width-30;
       Button1.Left:=Width-Button1.Width-10;
       Button2.Left:=Width-Button2.Width-Button1.Width-20;
       ShowModal;
       If Query.Active Then
         Begin
           if LstParam[TComponent(Sender).Tag].KMultiselect then begin
              aText:='';
              for I := 0 to DbGrid1.SelectedRows.Count-1 do begin
                Query.GotoBookmark(Pointer(DBGrid1.SelectedRows.Items[i]));
                if i<>DbGrid1.SelectedRows.Count-1 then
                  atext:= atext+ Query.Fields.Fields[0].Value+','
                else
                  atext:= atext+ Query.Fields.Fields[0].Value;
              end;
              TComboEdit(Sender).Text:= aText;
           end
           else
             TComboEdit(Sender).Text:=Query.Fields.Fields[0].Value;
           LstParam[TComponent(Sender).Tag].CampoValDevol:=Query.FieldByName(LstParam[TComponent(Sender).Tag].CampoDevol).Value;
           Query.Active:=False;
           pFIBTransaction1.Rollback;
           pFIBTransaction1.Active:=False;
         End;
       Free;
    End;
end;

