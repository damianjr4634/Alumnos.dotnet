              for I := 0 to DbGrid1.SelectedRows.Count-1 do begin
                Query.GotoBookmark(Pointer(DBGrid1.SelectedRows.Items[i]));
                if i<>DbGrid1.SelectedRows.Count-1 then
                  atext:= atext+ Query.Fields.Fields[0].Value+','
                else
                  atext:= atext+ Query.Fields.Fields[0].Value;
              end;
              TComboEdit(Sender).Text:= aText;
           end
           else
             TComboEdit(Sender).Text:=Query.Fields.Fields[0].Value;

           LstParam[TComponent(Sender).Tag].CampoValDevol:=Query.FieldByName(LstParam[TComponent(Sender).Tag].CampoDevol).Value;
         End
       else begin
           MessageDlg('Parametro incorrecto',mtError,[mbok],0,mbok);
           TComboEdit(Sender).SetFocus;
       end;
       If (Query.Active) then begin
           Query.Active:=False;
           pFIBTransaction1.Rollback;
           pFIBTransaction1.Active:=False;
       end;    
       Free;
    End;
end;


procedure TFrmParametros.FormActivate(Sender: TObject);
begin
  If (LstParam[0].Tipo='C') Then
       TEdit(LstParam[0].Control).SetFocus
  else If (LstParam[0].Tipo='N') Then
       TCurrencyEdit(LstParam[0].Control).SetFocus
  else If (LstParam[0].Tipo='K') Then
       TComboEdit(LstParam[0].Control).SetFocus
  else If (LstParam[0].Tipo='X') Then
       TRxCheckListBox(LstParam[0].Control).SetFocus
  else If (LstParam[0].Tipo='D') Then
      TDateEdit(LstParam[0].Control).SetFocus
  else If (LstParam[0].Tipo='L') Then
      TcomboBox(LstParam[0].Control).SetFocus
end;

procedure TFrmParametros.BtnAceptarClick(Sender: TObject);
Var x,y:Integer;
    Sw1,Sw:Boolean;
begin
  Sw:=True;
  For x:=0 to High(LstParam) Do
    Begin
      If (LstParam[X].Obligatorio='S') Then
        Begin
          If (LstParam[X].Tipo='D') Then
             Begin
               If (TDateEdit(LstParam[X].Control).Text='  /  /    ') Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TDateEdit(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
             End
           else If (LstParam[X].Tipo='C') Then
             Begin
               If (TEdit(LstParam[X].Control).Text='') Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TEdit(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
             End
           else If (LstParam[X].Tipo='N') Then
              Begin
               If (TCurrencyEdit(LstParam[X].Control).Value=0) Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TCurrencyEdit(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
              End
           else If (LstParam[X].Tipo='K') Then
             Begin
               If (TComboEdit(LstParam[X].Control).Text='') Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TComboEdit(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
              End
           else If (LstParam[X].Tipo='X') Then
             Begin
               Sw1:=False;
               For y:=0 to TRxCheckListBox(LstParam[X].Control).Items.Count-1 Do
                Begin
                  If (TRxCheckListBox(LstParam[X].Control).Checked[y]) Then
                     Sw1:=True;
                End;
               If (Not Sw1) Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TRxCheckListBox(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
             End
           else If (LstParam[X].Tipo='D') Then
            Begin
               If (TDateEdit(LstParam[X].Control).Text='') Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TDateEdit(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
            End
           else If (LstParam[X].Tipo='L') Then
            Begin
               If (TComboBox(LstParam[X].Control).ItemIndex=-1) Then
                 Begin
                   MessageDlg('Parametro Obligatorio',mtError,[mbok],0,mbok);
                   TComboBox(LstParam[X].Control).SetFocus;
                   Sw:=False;
                   break;
                 End
            End
        End
    End;
  If (Sw) Then
   Begin
    Pasa:=True;
    UltParam:=null;
    UltParam := VarArrayCreate([0, High(LstParam)], varVariant);
    for x := 0 to High(LstParam) do begin
         If (LstParam[X].Tipo='D') Then
            UltParam[x]:=TDateEdit(LstParam[X].Control).Date
         else If (LstParam[X].Tipo='C') Then
            UltParam[x]:=TEdit(LstParam[X].Control).Text
         else If (LstParam[X].Tipo='N') Then
            UltParam[x]:=TCurrencyEdit(LstParam[X].Control).Value
         else If (LstParam[X].Tipo='K') Then
            UltParam[x]:=TComboEdit(LstParam[X].Control).Text
         else If (LstParam[X].Tipo='X') Then
            UltParam[x]:=''
         else If (LstParam[X].Tipo='L') Then
            UltParam[x]:=TComboBox(LstParam[X].Control).ItemIndex;
    end;
    Close;
   End;
end;

procedure TFrmParametros.BtnCancelarClick(Sender: TObject);
begin
  pasa:=False; 
  Close;
end;

end.
