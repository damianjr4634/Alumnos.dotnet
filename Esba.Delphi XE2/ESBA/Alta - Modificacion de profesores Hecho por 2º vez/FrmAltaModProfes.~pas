Procedure TFrmAltaModifProf.CreaCertServ(Codigo : String);
Var
  Copiar : Boolean;
  Origen, Destino : String;
Begin
  Copiar := True;
  //Origen := Vunidad+':\new pailot\dbfgral\CertServ.dbf';
  //Destino :=Vunidad+':\new pailot\dbfgral\certserv\CertServ.dbf';
  CopyFile(Pchar(Origen),Pchar(Destino),Copiar);
  If Copiar Then
      Begin
  //     Origen  := Vunidad+':\new pailot\dbfgral\certserv\CertServ.dbf';
  //     Destino :=Vunidad+':\new pailot\dbfgral\CertServ\'+Codigo+'.dbf';
         RenameFile(Pchar(Origen),Pchar(Destino));
         MessageBox(frmAltaModifProf.Handle,Pchar(VUsuario+', se creo la base correspodiente al docente para su certificacion de servisios'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
      End
   Else
      MessageBox(frmAltaModifProf.Handle,Pchar(VUsuario+', hubo un error al crear el archivo para la certificacion de servicios. Llame al administrador o hagalo manualmente'),'Error',MB_OK+MB_ICONERROR+MB_APPLMODAL);
End;

Procedure TFrmAltaModifProf.PasoCampos;
Begin
 With  CustomerData do Begin
   IBUpdateProf.ParamByName('CODPROFES').AsString   := Codigo.Text;
//   fechaingreso.GetDateMask;
   IBUpdateProf.ParamByName('DOCENTE').AsString     := Nombre.Text;
   if (fechaIngreso.date<>0) then
      IBUpdateProf.ParamByName('FECHA_ING').AsDatetime := strtodate(fechaIngreso.text);
   if (fechaegreso.date<>0) then
      IBUpdateProf.ParamByName('FECHA_BAJ').AsDatetime := strtodate(FechaEgreso.text);
   IBUpdateProf.ParamByName('DI_ECCION').AsString   := Direccion.Text;
   IBUpdateProf.ParamByName('PISO').AsString        := Piso.Text;
   IBUpdateProf.ParamByName('DEPTO').AsString       := Depto.Text;
   IBUpdateProf.ParamByName('TELEFONO_P').AsString  := TelefonoParti.Text;
   IBUpdateProf.ParamByName('TELEFONO_M').AsString  := TelefonoMensa.Text;
   IBUpdateProf.ParamByName('INTERNO').AsString     := Interno.Text;
   IBUpdateProf.ParamByName('LOCALIDAD').AsString   := Localidad.Text;
   IBUpdateProf.ParamByName('TITULO').AsString      := Titulo.Text;
   IBUpdateProf.ParamByName('UNIVERDID').AsString   := universidad.Text;
   IBUpdateProf.ParamByName('CODPROFES').AsString   := Codigo.Text;
   IBUpdateProf.ParamByName('NRODOCUM').AsString    := NumeroDocumento.Text;
   IBUpdateProf.ParamByName('TIPODOC').AsString     := ComboDocumento.Text;
   if (fechanacimiento.date<>0) then
      IBUpdateProf.ParamByName('FEC_NAC').AsDateTime   := strtodate(FechaNacimiento.text);
   IBUpdateProf.ParamByName('COD_POST').AsString    := CodigoPostal.Text;
   IBUpdateProf.ParamByName('NACIONALI').AsString   := Copy(ComboNacionalidad.Text,1,1);
   if (antiguedaddocente.date<>0) then
      IBUpdateProf.ParamByName('ANTDOCENT').AsDateTime :=  strtodate(AntiguedadDocente.text);
   if (antiguedaddocsup.date<>0) then
      IBUpdateProf.ParamByName('ANTDOCSUP').AsDateTime :=  strtodate(AntiguedadDocSup.text);
   if (antiguedadcatedra.date<>0) then
      IBUpdateProf.ParamByName('ANTCATEDR').AsDateTime :=  strtodate(AntiguedadCatedra.text);
   if (fechalicencia.date<>0) then
       IBUpdateProf.ParamByName('LICENFECH').AsDateTime :=  strtodate(FechaLicencia.text);
   if Licencia.Checked then
     IBUpdateProf.ParamByName('LICENCIA').AsString :=  'S'
   else
     IBUpdateProf.ParamByName('LICENCIA').AsString :=  'N';
 end
End;

