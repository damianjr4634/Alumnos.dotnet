procedure TFrmAltaModifProf.ModificarClick(Sender: TObject);
begin
 Codigo.Enabled := False;
 Modificacion := True;
 FrmAltaModifProf.Height := 579;
 ResetearControles(False);
 With CustomerData do Begin
   Nombre.SetFocus;
   Nombre.Text := IBProfesores.FieldByName('DOCENTE').AsString;
   Try
     fechaIngreso.Date := IBProfesores.FieldByName('FECHA_ING').AsDateTime;
   Except
     fechaIngreso.Date := StrToDate('01/01/1900');
   End;
   Try
    FechaEgreso.Date := IBProfesores.FieldByName('FECHA_BAJ').AsDateTime;
   Except
    FechaEgreso.Date := StrToDate('01/01/1900');
   End;
   Direccion.Text := IBProfesores.FieldByName('DI_ECCION').AsString;
   Piso.Text := IBProfesores.FieldByName('PISO').AsString;
   Depto.Text := IBProfesores.FieldByName('DEPTO').AsString;
   TelefonoParti.Text := IBProfesores.FieldByName('TELEFONO_P').AsString;
   TelefonoMensa.Text := IBProfesores.FieldByName('TELEFONO_M').AsString;
   Interno.Text := IBProfesores.FieldByName('INTERNO').AsString;
   Localidad.Text := IBProfesores.FieldByName('LOCALIDAD').AsString;
   Titulo.Text := IBProfesores.FieldByName('TITULO').AsString;
   universidad.Text := IBProfesores.FieldByName('UNIVERDID').AsString;
   Codigo.Text := IBProfesores.FieldByName('CODPROFES').AsString;
   NumeroDocumento.Text := IBProfesores.FieldByName('NRODOCUM').AsString;
   ComboDocumento.Text := IBProfesores.FieldByName('TIPODOC').AsString;
   Try
     FechaNacimiento.Date := IBProfesores.FieldByName('FEC_NAC').AsDateTime;
   Except
     FechaNacimiento.Date := StrToDate('01/01/1900');
   End;
   CodigoPostal.Text := IBProfesores.FieldByName('COD_POST').AsString;
   if (IBProfesores.FieldByName('NACIONALI').AsString='A') then
       ComboNacionalidad.ItemIndex:=0
   Else
       ComboNacionalidad.ItemIndex:=1;
   try
     AntiguedadDocSup.Date := IBProfesores.FieldByName('ANTDOCSUP').AsDateTime;
   except
     AntiguedadDocSup.Date := StrToDate('01/01/1900');
   end;
   try
     AntiguedadDocente.Date := IBProfesores.FieldByName('ANTDOCENT').AsDateTime;
   except
     AntiguedadDocente.Date := StrToDate('01/01/1900');
   end;
   try
     AntiguedadCatedra.Date := IBProfesores.FieldByName('ANTCATEDR').AsDateTime;
   except
     AntiguedadCatedra.Date := StrToDate('01/01/1900');
   end;
   if (IbProfesores.FieldByName('LICENCIA').AsString='S') Then
       Licencia.Checked:=True
   else
       Licencia.Checked:=False;
   try
     FechaLicencia.Date := IBProfesores.FieldByName('LICENFECH').AsDateTime;
   except
     FechaLicencia.Date := StrToDate('01/01/1900');
   end;
   label23.Caption:='Antigüedad en ańos: '+IntToStr(IBProfesores.FieldByName('ANIOS').asinteger);
 end;
end;


