procedure TFrmAltaModifProf.GrabarClick(Sender: TObject);
begin

{ if MessageDlg(Pchar(VUsuario+', estas seguro de grabar la información?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
  Begin
   CustomerData.IBUpdateProf.SQL.Clear;
   If Modificacion Then
       CustomerData.IBUpdateProf.SQL.Text := 'UPDATE DOCENTES SET DOCENTE=:DOCENTE,FECHA_ING=:FECHA_ING,FECHA_BAJ=:FECHA_BAJ,'+
                                             'DI_ECCION=:DI_ECCION,PISO=:PISO, DEPTO=:DEPTO,TELEFONO_P=:TELEFONO_P,'+
                                             'TELEFONO_M=:TELEFONO_M,INTERNO=:INTERNO,LOCALIDAD=:LOCALIDAD,TITULO=:TITULO,'+
                                             'UNIVERDID=:UNIVERDID,NROREGIST=:NROREGIST,ANTDOCENT=:ANTDOCENT,ANTDOCSUP=:ANTDOCSUP,'+
                                             'ANTCATEDR=:ANTCATEDR,CODPROFES=:CODPROFES,NRODOCUM=:NRODOCUM,TIPODOC=:TIPODOC,'+
                                             'FEC_NAC=:FEC_NAC,COD_POST=:COD_POST, NACIONALI=:NACIONALI, LICENCIA=:LICENCIA, LICENFECH=:LICENFECH, SEXO=:SEXO, GENERO=:GENERO '+
                                             'WHERE CODPROFES=:CODPROFES;'
   Else
      CustomerData.IBUpdateProf.SQL.Text := 'INSERT INTO DOCENTES (CODPROFES,DOCENTE,FECHA_ING,FECHA_BAJ,DI_ECCION,PISO, DEPTO, TELEFONO_P,  TELEFONO_M,'+
                                            '  INTERNO,LOCALIDAD,    TITULO,    UNIVERDID,    NROREGIST,'+
                                            '  ANTDOCENT,    ANTDOCSUP,    ANTCATEDR, NRODOCUM,'+
                                            '  TIPODOC,    FEC_NAC,    COD_POST, NACIONALI, LICENCIA, LICENFECH, SEXO, GENERO)'+
                                            '  VALUES (:CODPROFES,:DOCENTE,:FECHA_ING,:FECHA_BAJ,:DI_ECCION,:PISO,:DEPTO,:TELEFONO_P,:TELEFONO_M,'+
                                            '  :INTERNO,:LOCALIDAD,:TITULO,:UNIVERDID,:NROREGIST,'+
                                            '  :ANTDOCENT,:ANTDOCSUP,:ANTCATEDR,:NRODOCUM,'+
                                            '  :TIPODOC,:FEC_NAC,:COD_POST,:NACIONALI,:LICENCIA,:LICENFECH, :SEXO, :GENERO );';
   PasoCampos;

   Try
     CustomerData.TRUpdateProf.Active := True;
     CustomerData.IBUpdateProf.ExecQuery;
     ExecQuery_Params('DELETE FROM DOC_TITULOS WHERE CODPROF= :CODPROF',['CODPROF'],[Codigo.Text],CustomerData.TRUpdateProf);
     if mtTitulos.State in [dsInsert,dsEdit] then
        MtTitulos.Post;
     mttitulos.First;
     while not MtTitulos.Eof do begin
        ExecQuery_Params('INSERT INTO DOC_TITULOS (CODPROF, TITULO, NIVEL, OTORGADO, FECHA) VALUES (:CODPROF, :TITULO, :NIVEL, :OTORGADO, :FECHA)',['CODPROF', 'TITULO', 'NIVEL', 'OTORGADO', 'FECHA'],[Codigo.Text,MtTitulosTITULO.value,MtTitulosNIVEL.value,MtTitulosOTORGADO.value, MtTitulosFECHA.value],CustomerData.TRUpdateProf);
        MtTitulos.Next;
     end;
     CustomerData.TRUpdateProf.Commit;
   Except
     CustomerData.TRUpdateProf.Rollback;
   end;
   CustomerData.TRUpdateProf.Active := False;
  End;
 ResetearControles(True);
 FrmAltaModifProf.Height := 276;
 Modificacion := False;
 CargaMt;
     }
end;

