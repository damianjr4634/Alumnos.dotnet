procedure TFrmAltaModifProf.ModificarClick(Sender: TObject);
begin


 Codigo.Enabled := False;
 Modificacion := True;
 FrmAltaModifProf.Height := 579;
 ResetearControles(False);

   Nombre.SetFocus;
   Nombre.Text := Mt.FieldByName('DOCENTE').AsString;
   Try
     fechaIngreso.Date := Mt.FieldByName('FECHA_ING').AsDateTime;
   Except
     fechaIngreso.Date := StrToDate('01/01/1900');
   End;
   Try
    FechaEgreso.Date := Mt.FieldByName('FECHA_BAJ').AsDateTime;
   Except
    FechaEgreso.Date := StrToDate('01/01/1900');
   End;
   Direccion.Text := Mt.FieldByName('DI_ECCION').AsString;
   Piso.Text := Mt.FieldByName('PISO').AsString;
   Depto.Text := Mt.FieldByName('DEPTO').AsString;
   TelefonoParti.Text := Mt.FieldByName('TELEFONO_P').AsString;
   TelefonoMensa.Text := Mt.FieldByName('TELEFONO_M').AsString;
   Interno.Text := Mt.FieldByName('INTERNO').AsString;
   Localidad.Text := Mt.FieldByName('LOCALIDAD').AsString;
   Codigo.Text := Mt.FieldByName('CODPROFES').AsString;
   NumeroDocumento.Text := Mt.FieldByName('NRODOCUM').AsString;
   ComboDocumento.Text := Mt.FieldByName('TIPODOC').AsString;
   Try
     FechaNacimiento.Date := Mt.FieldByName('FEC_NAC').AsDateTime;
   Except
     FechaNacimiento.Text:='';
   End;
   CodigoPostal.Text := Mt.FieldByName('COD_POST').AsString;
   if not (Mt.FieldByName('NACIONALI').IsNull) then
       ComboNacionalidad.ItemIndex:=-1
   Else
       ComboNacionalidad.ItemIndex:=Mt.FieldByName('NACIONALI').value;
   if (Mt.FieldByName('LICENCIA').AsString='S') Then
       Licencia.Checked:=True
   else
       Licencia.Checked:=False;
   try
     FechaLicencia.Date := Mt.FieldByName('LICENFECH').AsDateTime;
   except
     FechaLicencia.Text:='';
   end;
   if Mt.FieldByName('SEXO').AsString='M' then
      CbSexo.ItemIndex:=0
   else if Mt.FieldByName('SEXO').AsString='F' then
      CbSexo.ItemIndex:=1;
   if not Mt.FieldByName('GENERO').IsNull then
      CbGenero.ItemIndex:=Mt.FieldByName('GENERO').AsInteger
   else
      CbGenero.ItemIndex:=-1;

   FuncionesDB.Carga_MemTable(' SELECT TITULO, NIVEL, OTORGADO, FECHA FROM DOC_TITULOS WHERE CODPROF='''+MtCodprofes.Value+'''',MtTitulos, false);

end;


