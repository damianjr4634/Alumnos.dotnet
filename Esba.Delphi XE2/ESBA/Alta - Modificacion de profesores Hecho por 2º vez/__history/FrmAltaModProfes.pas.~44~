   Localidad.Text := '';
   Codigo.Text := '';
   NumeroDocumento.Text := '';
   ComboDocumento.Text := '';
  FechaNacimiento.Date := 0;
   CodigoPostal.Text := '';
   ComboNacionalidad.Text := '';
   Grilla.Enabled := Seteo;
   Nuevo.Enabled := Seteo;
   Modificar.Enabled := Seteo;
   Salir.Enabled := Seteo;
   TxtBusqueda.Enabled:=Seteo;
   CbSexo.ItemIndex:=-1;
   CbGenero.ItemIndex:=-1;
End;


