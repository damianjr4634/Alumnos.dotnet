 If (ComboMateria.Text <> '') and (Comision.Text<>'') then
   Begin
     SqlComi.SQLs.SelectSQL.Text:= 'SELECT TRIM(D.DOCENTE) AS DOCENTE, TRIM(M.DESCRIPCI) AS DESCRIPCI, C.CUTUCO, C.COD_MAT, C.TIT_SUP '+
