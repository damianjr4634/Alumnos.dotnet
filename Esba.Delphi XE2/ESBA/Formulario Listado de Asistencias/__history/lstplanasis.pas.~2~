           //TOMA DATOS DE LA BD
           FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
           FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
           FormPreview.VistaPrevia1.Canvas.Font.Style := [];
           FormPreview.VistaPrevia1.Canvas.TextOut(1.40,largopagina,SqlDatos.FieldByName('APELLIDO').AsString + ', ' + SqlDatos.FieldByName('NOM_APE').AsString ,gmcentimeters);
