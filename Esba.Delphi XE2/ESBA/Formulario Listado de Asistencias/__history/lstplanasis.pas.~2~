      FormPreview.VistaPrevia1.Canvas.MoveTo(7,largopagina-0.35,gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.LineTo(18.30,largopagina-0.35,gmcentimeters);

      LargoPagina := LargoPagina + 0.25;

      FormPreview.VistaPrevia1.Canvas.SetPenValues(4,clblack,psSolid);
      FormPreview.VistaPrevia1.Canvas.MoveTo(0.5,largopagina,gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.LineTo(20.4,largopagina,gmcentimeters);
