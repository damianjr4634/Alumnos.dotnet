      FormPreview.VistaPrevia1.Canvas.TextOut(18.25,largopagina,'  A ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(19,largopagina,'  T ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(19.75,largopagina,'  T ',gmcentimeters);
      largopagina:=largopagina+0.25;           //8.75
      FormPreview.VistaPrevia1.Canvas.TextOut(7,largopagina-0.25,' H ',gmcentimeters);

