      LargoPagina:=LargoPagina+0.5;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Cuat.: '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'    Turno: '+Turnos(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),2,1)))+'     Divisi¾n: '+Division(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),3,1))),GmCentimeters);
      LargoPagina:=LargoPagina+1;
      IF (SqlComi.FieldByName('TIT_SUP').AsString='T') THEN
         FormPreview.VistaPrevia1.Canvas.TextOut(1,LargoPagina,'Profesor: '+(SqlComi.FieldByName('DOCENTE').AsString+'(Tit.)'),GmCentimeters)
      ELSE
         FormPreview.VistaPrevia1.Canvas.TextOut(1,LargoPagina,'Profesor: '+(SqlComi.FieldByName('DOCENTE').AsString+'(Sup.)'),GmCentimeters);
      LargoPagina:=LargoPagina+1;
      FormPreview.VistaPrevia1.Canvas.TextOut(1,LargoPagina,'Mes: .......................'+'                    Ciclo Lectivo: '+Copy(DatetoStr(Date),7,4),GmCentimeters);
      LargoPagina:=LargoPagina+1;
      FormPreview.VistaPrevia1.Canvas.TextOut(1,LargoPagina,'Horas dictadas del mes anterior: ....................                   Total: ....................',GmCentimeters);
      LargoPagina:=LargoPagina+1;

      FormPreview.VistaPrevia1.Canvas.Font.Size := 9;
      FormPreview.VistaPrevia1.Canvas.TextOut(0.75,largopagina+0.25,' N░ ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(1.50,largopagina+0.25,' APELLIDO Y NOMBRE ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(7,largopagina-0.25,' D ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(18.25,largopagina-0.25,'   I ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(19,largopagina-0.25,'  A ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(19.75,largopagina-0.25,'  T ',gmcentimeters);
