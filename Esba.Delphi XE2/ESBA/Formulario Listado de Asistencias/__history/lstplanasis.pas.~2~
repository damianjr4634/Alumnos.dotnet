procedure TFrmlstplanasis.ComboMateriaButtonClick(Sender: TObject);
Var b:Variant;
begin
  Funciones.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='+#39+VCARRERA+#39+' AND ESTADO<>'+#39+'B'+#39,['Codigo','Nombre'],b,True);
  ComboMateria.Text:=b[0];
  NombreMat.Caption:=b[1];
end;

procedure TFrmlstplanasis.ComboMateriaExit(Sender: TObject);
Var b:Variant;
begin
  if (ComboMateria.Text<>'') Then Begin
      ComBoMateria.Text:=Lpad(ComboMateria.Text,2,'0');
      Funciones.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='+#39+VCARRERA+#39+' AND CODMATERI='+#39+ComboMateria.Text+#39+' AND ESTADO<>'+#39+'B'+#39,['Codigo','Nombre'],b,False);
      If (vartostr(b[0])='') then begin
         MessageDlg('C¾digo incorrecto',mtError,[mbok],0,mbok);
         ComboMateria.SetFocus;
      end
      else begin
          ComboMateria.Text:=b[0];
          NombreMat.Caption:=b[1];
      end
  end
end;

