      FormPreview.VistaPrevia1.Canvas.TextOut(18.25,largopagina-0.125,'  N ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(19,largopagina-0.125,'  N ',gmcentimeters);
      FormPreview.VistaPrevia1.Canvas.TextOut(19.75,largopagina-0.125,'  O ',gmcentimeters);
