     SqlComi.ParamByName('CUTUCO').AsInteger := StrToint(Comision.Text);
  end;
 If (ComboMateria.Text = '') and (Comision.Text='') then
   SqlComi.SQLs.SelectSQL.Text:= 'SELECT TRIM(D.DOCENTE) AS DOCENTE, TRIM(M.DESCRIPCI) AS DESCRIPCI, C.CUTUCO, C.COD_MAT, C.TIT_SUP '+
                        'FROM COMARM C '+
                        'LEFT OUTER JOIN DOCENTES D  ON C.CODPROFES = D.CODPROFES '+
                        'LEFT OUTER JOIN MATERIAS M  ON C.COD_MAT = M.CODMATERI AND C.CARRE = M.CODCARRE '+
                        'WHERE C.CARRE = :CARRERA AND C.CUA_ANIO = :CUA_ANIO '+
