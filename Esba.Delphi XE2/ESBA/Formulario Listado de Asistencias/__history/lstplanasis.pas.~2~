           FormPreview.VistaPrevia1.Canvas.SetPenValues(2,clblack,psSolid);
           FormPreview.VistaPrevia1.Canvas.MoveTo(0.5,largopagina,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.LineTo(20.4,largopagina,gmcentimeters);
           //LargoPagina := LargoPagina + 1;
           SqlDatos.next;
           if (SqlDatos.FieldByName('CONDICION').AsString = 'RECURSANDO') and (sw=0) then
              begin
                 sw := 1;
                 //FORMATO DEL ENCABEZADO DE RECURSANTES
                 FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
                 FormPreview.VistaPrevia1.Canvas.Font.Size := 10;
                 FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
                 FormPreview.VistaPrevia1.Canvas.TextOut(1.4,largopagina+0.25,'RECURSANTES',GmCentimeters);
                 FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
                 FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
                 FormPreview.VistaPrevia1.Canvas.Font.Style := [];
                 // FIN FORMATO ENCABEZADO DE RECURSANTES
                 LargoPagina := LargoPagina + 1;
                 FormPreview.VistaPrevia1.Canvas.SetPenValues(4,clblack,psSolid);
                 FormPreview.VistaPrevia1.Canvas.MoveTo(0.5,largopagina,gmcentimeters);
                 FormPreview.VistaPrevia1.Canvas.LineTo(20.4,largopagina,gmcentimeters);
                 LargoPagina := LargoPagina;
                 contareg:=1;
               end;
       end;
        FormPreview.VistaPrevia1.Canvas.SetPenValues(4,clblack,psSolid);
         // ***** RAYAS VERTICALES DEL NUMERO *****//
        FormPreview.VistaPrevia1.Canvas.MoveTo(1.25,7.75,gmcentimeters);
        FormPreview.VistaPrevia1.Canvas.LineTo(1.25,largopagina,gmcentimeters);
       // ***** RAYAS VERTICALES DEL APELLIDO Y NOMBRE *****//
        FormPreview.VistaPrevia1.Canvas.MoveTo(7,7.75,gmcentimeters);
        FormPreview.VistaPrevia1.Canvas.LineTo(7,largopagina,gmcentimeters);
        // ***** RAYAS VERTICALES DE LOS HORARIOS *****//
        FormPreview.VistaPrevia1.Canvas.MoveTo(7.45,7.75,gmcentimeters);
        FormPreview.VistaPrevia1.Canvas.LineTo(7.45,largopagina,gmcentimeters);
        FormPreview.VistaPrevia1.Canvas.MoveTo(7.5,7.75,gmcentimeters);
        FormPreview.VistaPrevia1.Canvas.LineTo(7.5,largopagina,gmcentimeters);

        FormPreview.VistaPrevia1.Canvas.MoveTo(18.30,7.75,gmcentimeters);
        FormPreview.VistaPrevia1.Canvas.LineTo(18.30,largopagina,gmcentimeters);
        // ***** RAYAS VERTICALES VARIAS PARA ASISTENCIA *****//
        verti:=7.5;
        FOR x:=1 to 25 do
          begin
           FormPreview.VistaPrevia1.Canvas.MoveTo(verti+0.415,7.75,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.LineTo(verti+0.415,largopagina,gmcentimeters);
           verti:=verti+0.415;
          end;
        verti:=verti+0.35;
        FOR x:=1 to 2 do
          begin
           FormPreview.VistaPrevia1.Canvas.MoveTo(verti+0.65,7.75,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.LineTo(verti+0.65,largopagina,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.MoveTo(verti+0.70,7.75,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.LineTo(verti+0.70,largopagina,gmcentimeters);
           verti:=verti+0.65
          end;

        Caja(0.5,7.75,20.4,largopagina,FormPreview.VistaPrevia1);
        FormPreview.VistaPrevia1.EndUpdate;
        if SqlDatos.eof then
         Begin
           SqlDatos.Active:=False;
           SqlComi.Next;
           sw:=0;
           contareg:=1;
         end;
        if (not sqlcomi.Eof) or (largopagina>28) then
          FormPreview.VistaPrevia1.Newpage;
        LargoPagina := 1.5;
     end; //end del while sqlcomi
     FormPreview.VistaPrevia1.CurrentPage := 1;
     FormPreview.ShowModal;
     FormPreview.Free;
     Comision.SetFocus;
  end;
  SqlDatos.Active:=False;
  SqlComi.Active:=False;
  If IbTr.Active then
      IbTr.RollBack;
  IbTr.Active:=False;
end;

