procedure TFrmComArmadas.ModificarClick(Sender: TObject);
 Function BuscoColumna(Dia : String):Integer;
  Begin
    BuscoColumna := 0;
    If Dia = 'BLANCO' Then BuscoColumna := 0;
    If Dia = 'LUNES' Then BuscoColumna := 1;
    If Dia = 'MARTES' Then BuscoColumna := 2;
    If Dia = 'MIERCOLES' Then BuscoColumna := 3;
    If Dia = 'JUEVES' Then BuscoColumna := 4;
    If Dia = 'VIERNES' Then BuscoColumna := 5;
  End;
 Function BuscoFila(Bloque : String):Integer;
  Begin
    BuscoFila := 0;
    If Bloque = 'BLANCO' Then BuscoFila := 0;
    If Bloque = 'PRIMERO' Then BuscoFila := 1;
    If Bloque = 'SEGUNDO' Then BuscoFila := 2;
    If Bloque = 'TERCERO' Then BuscoFila := 3;
    If Bloque = 'PRISEG' Then BuscoFila := 4;
    If Bloque = 'PRITER' Then BuscoFila := 5;
    If Bloque = 'SEGTER' Then BuscoFila := 6;
    If Bloque = 'UNICO' Then BuscoFila := 7;
  End;
 Procedure PasoAGrillaLosDias(Poscol, PosRow : Integer);
  Var x:integer;
  Begin
    If PosCol In [1..5] Then
     Begin
       If PosRow In [1..3] Then
           Grilla[PosCol,PosRow].Dibujo := True;
       If PosRow=4 Then
         Begin
           Grilla[PosCol,1].Dibujo := True;
           Grilla[PosCol,2].Dibujo := True;
         End;
       If PosRow=5 Then
         Begin
           Grilla[PosCol,1].Dibujo := True;
           Grilla[PosCol,3].Dibujo := True;
         End;
       If PosRow=6 Then
         Begin
           Grilla[PosCol,3].Dibujo := True;
           Grilla[PosCol,2].Dibujo := True;
         End;
       If PosRow = 7 Then
         For x:=1 to filas do
           Grilla[PosCol,x].Dibujo := True;
     End;
  End;
Var
  Key : Char;
begin
 FrmComArmadas.Height := 380+((Filas+1)*28);
 Horario.Height := 27 * (filas+1);
 GroupBox2.Height := 134 +(filas+1)*27;
 Timer1.Enabled := True;
 Nueva.Enabled := False;
 Modificar.Enabled := False;
 Eliminar.Enabled := False;
 Salir.Enabled := False;
 comboMaterias.Enabled := True;
 GrillaComi.Enabled := False;
 Comision.Enabled := True;
 Cuatrimestre.Enabled := True;
 ComboDocente.Enabled := True;
 ComboDocente.SetFocus;
 Modificacion := True;
 CertServ.Enabled := False;
 ComboMaterias.Text := CustomerData.IBDsVarios.FieldByName('COD_MAT').AsString;
 Comision.Text :=  IntToStr(CustomerData.IBDsVarios.FieldByName('CUTUCO').AsInteger);
 Cuatrimestre.Text := CustomerData.IBDsVarios.FieldByName('CUA_ANIO').AsString;
 combodocente.Text := CustomerData.IBDsVarios.FieldByName('CODPROFES').AsString;
 If Trim(CustomerData.IBDsVarios.FieldByName('TIT_SUP').AsString) = 'T' Then
   Titular.Checked := True;
 If Trim(CustomerData.IBDsVarios.FieldByName('TIT_SUP').AsString) = 'S' Then
   Suplente.Checked := True;
 Key := #13;
 PasoAGrillaLosDias(BuscoColumna(TRIM(CustomerData.IBDsVarios.FieldByName('DIA1').AsString)),
                    BuscoFila(TRIM(CustomerData.IBDsVarios.FieldByName('BLOQUE1').AsString)));
 PasoAGrillaLosDias(BuscoColumna(TRIM(CustomerData.IBDsVarios.FieldByName('DIA2').AsString)),
                    BuscoFila(TRIM(CustomerData.IBDsVarios.FieldByName('BLOQUE2').AsString)));
 PasoAGrillaLosDias(BuscoColumna(TRIM(CustomerData.IBDsVarios.FieldByName('DIA3').AsString)),
                    BuscoFila(TRIM(CustomerData.IBDsVarios.FieldByName('BLOQUE3').AsString)));
 CargoDibujos(Sender);
end;

