procedure TFrmComArmadas.ComisionKeyPress(Sender: TObject; var Key: Char);
Var
  sw : Boolean;
begin
 If (Key = #13) And (Not Modificacion) Then
   Begin
     Sw := True;
     CustomerData.IBValidacion.Sql.Clear;
     CustomerData.IBValidacion.SQL.Text := 'SELECT ERRCOD, ERRMSG FROM XXX_VALIDO_COMISION(:CUAANIO,:CODMAT,:CUTUCO,:CARRE);';
     CustomerData.IBValidacion.ParamByName('CUAANIO').Value := Funciones.Cuatrimestre;
     CustomerData.IBValidacion.ParamByName('CODMAT').Value := ComboMaterias.Text;
     CustomerData.IBValidacion.ParamByName('CUTUCO').Value := Comision.Text;
     CustomerData.IBValidacion.ParamByName('CARRE').Value := VCarrera ;
     CustomerData.TRValidacion.Active := True;
     CustomerData.IBValidacion.ExecQuery;
     If (CustomerData.IBValidacion.FieldByName('ERRCOD').Value <> 0) Then
        Begin
           MessageDlg(Pchar(VNombreUsuario+', '+CustomerData.IBValidacion.FieldByName('ERRMSG').AsString),mtInformation, [mbok],0,mbok);
           Sw := False;
        End;
     CustomerData.TRValidacion.Rollback;
    If Sw Then
       Begin
         Cuatrimestre.Enabled := True;
         Cuatrimestre.SetFocus;
         Cuatrimestre.Text := Funciones.Cuatrimestre();
       End;
   End;
   If (Key = #13) And (Modificacion) Then
     Begin
        Cuatrimestre.Enabled := True;
        Cuatrimestre.SetFocus;
        Cuatrimestre.Text := Funciones.Cuatrimestre();
     End;
end;

procedure TFrmComArmadas.GrabaMateriaClick(Sender: TObject);
Var
  i,  Cont : Integer;
  Sw : Boolean;
begin
 if MessageDlg(Pchar(VNombreUsuario + ', grabás la comisión?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
   Begin
     Cont := 1;
     CustomerData.IBUpVarios.SQL.Clear;
     If Modificacion Then Begin
           CustomerData.IBUpVarios.SQL.Text := 'UPDATE COMARM SET CARRE=:CARRE,CUTUCO=:CUTUCO,COD_MAT=:COD_MAT,CUA_ANIO=:CUA_ANIO, '+
                                               'CODPROFES=:CODPROFES,DIA1=:DIA1,BLOQUE1=:BLOQUE1, '+
                                               'DIA2=:DIA2,BLOQUE2=:BLOQUE2,DIA3=:DIA3,BLOQUE3=:BLOQUE3, '+
                                               'USUARIO=:USUARIO,TIT_SUP=:TIT_SUP '+
                                               'WHERE CARRE=:FCARRE AND CUTUCO=:FCUTUCO AND COD_MAT=:FCOD_MAT AND CUA_ANIO=:FCUA_ANIO;';
           CustomerData.IBUpVarios.ParamByName('FCARRE').Value := VCarrera;
           CustomerData.IBUpVarios.ParamByName('FCUTUCO').Value := CustomerData.IBDsVarios.FieldByName('CUTUCO').Value;
           CustomerData.IBUpVarios.ParamByName('FCOD_MAT').Value := CustomerData.IBDsVarios.FieldByName('COD_MAT').Value;
           CustomerData.IBUpVarios.ParamByName('FCUA_ANIO').Value := CustomerData.IBDsVarios.FieldByName('CUA_ANIO').Value;
        End
     Else
        CustomerData.IBUpVarios.SQL.Text := 'INSERT INTO COMARM (CARRE,CUTUCO,COD_MAT,CUA_ANIO,CODPROFES,DIA1,BLOQUE1, '+
                                            '                    DIA2,BLOQUE2,DIA3,BLOQUE3,USUARIO,TIT_SUP) '+
                                            'VALUES(:CARRE,:CUTUCO,:COD_MAT,:CUA_ANIO,:CODPROFES,:DIA1,:BLOQUE1,:DIA2,:BLOQUE2,:DIA3, '+
                                            ':BLOQUE3,:USUARIO,:TIT_SUP);';
     With CustomerData do
        Begin
           IBUpVarios.ParamByName('CARRE').Value := VCarrera;
           IBUpVarios.ParamByName('CUTUCO').Value := StrToInt(Comision.Text);
           IBUpVarios.ParamByName('COD_MAT').Value := ComboMaterias.Text;
           IBUpVarios.ParamByName('CUA_ANIO').Value := Cuatrimestre.Text;
           IBUpVarios.ParamByName('CODPROFES').Value := ComboDocente.Text;
           IBUpVarios.ParamByName('USUARIO').Value := Funciones.CodUsu;
           If titular.Checked Then
              IBUpVarios.ParamByName('TIT_SUP').Value := 'T';
           If Suplente.Checked Then
              IBUpVarios.ParamByName('TIT_SUP').Value := 'S';
           For i := 1 To 5 do
            Begin
              If Cont <= 3 Then
                Begin
                   If Grilla[i,1].Dibujo Then
                     Begin
                       If Grilla[i,2].Dibujo Then
                         Begin
                           If Grilla[i,3].Dibujo Then
                            Begin
                              IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                              IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'UNICO';
                              Cont := Cont + 1;
                            End
                           Else
                            Begin
                              IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                              IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'PRISEG';
                              Cont := Cont + 1;
                            End
                         End
                       Else
                         Begin
                           If Grilla[i,3].Dibujo Then
                            Begin
                              IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                              IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'PRITER';
                              Cont := Cont + 1;
                            End
                           Else
                            Begin
                              IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                              IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'PRIMERO';
                              Cont := Cont + 1;
                            End
                         End
                     End
                   Else
                      Begin
                        If Grilla[i,2].Dibujo Then
                          Begin
                            If Grilla[i,3].Dibujo Then
                              Begin
                                IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                                IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'SEGTER';
                                Cont := Cont + 1;
                              End
                            Else
                              Begin
                                IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                                IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'SEGUNDO';
                                Cont := Cont + 1;
                              End
                          End
                        Else
                          Begin
                            If Grilla[i,3].Dibujo Then
                              Begin
                                IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                                IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'TERCERO';
                                Cont := Cont + 1;
                              End
                          End
                      End
                End;
            End;
            While Cont <= 3 Do
              Begin
                IBUpVarios.ParamByName('DIA'+IntToStr(Cont)).Value := 'BLANCO';
                IBUpVarios.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'BLANCO';
                Cont := Cont + 1;
              End;
            Try
              TrUpVarios.Active := True;
              IBUpVarios.ExecQuery;
              QrPosval.Transaction:=IbUpVarios.Transaction;
              Qrposval.SQL.Text:='SELECT FERRCOD,FERRMSG FROM XXX_VAL_COMISION(:FCARRE,:FCUTUCO,:FCOD_MAT,:FCUA_ANIO)';
              QrPosval.ParamByName('FCARRE').Value := VCarrera;
              QrPosval.ParamByName('FCUTUCO').Value := StrToInt(Comision.Text);
              QrPosval.ParamByName('FCOD_MAT').Value := ComboMaterias.Text;
              QrPosval.ParamByName('FCUA_ANIO').Value := Cuatrimestre.Text;
              QrPosval.ExecQuery;
              If (QrPosval.FieldByName('FERRCOD').Value=0) then begin
                   TRUpVarios.Commit;
                   CancelaGrabacionClick(Sender);
              end
              Else If (QrPosval.FieldByName('FERRCOD').Value=1) then
                    begin
                         if MessageDlg(Pchar(QrPosval.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then begin
                             TRUpVarios.Commit;
                             CancelaGrabacionClick(Sender);
                         end
                         Else
                             TRUpVarios.Rollback;
                    end
              Else If (QrPosval.FieldByName('FERRCOD').Value=2) then
                    begin
                        MessageDlg(Pchar(QrPosval.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
                        TRUpVarios.Rollback;
                    end;
            Finally
               If (TRUpVarios.Active) Then  TrUpVarios.Rollback;
            End;
            TrUpVarios.Active := False;
            IBDsVarios.Active := False;
            TRDsVarios.Active := False;
            TRDSVarios.Active := True;
            IBDSVarios.Active := True;
        End; //End With
  End;
end;

procedure TFrmComArmadas.EliminarClick(Sender: TObject);
Var
 SW:Boolean;
begin
  if MessageDlg(Pchar(VNombreUsuario + ', estas seguro de borrar la comisión?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
   Begin
     With CustomerData Do
       Begin
          IBDlVarios.SQL.Clear;
          IBDlVarios.SQL.Text := 'DELETE FROM COMARM WHERE CARRE=:FCARRE AND CUTUCO=:FCUTUCO AND COD_MAT=:FCOD_MAT AND CUA_ANIO=:FCUA_ANIO;';
          IBDlVarios.ParamByName('FCARRE').Value := VCarrera;
          IBDlVarios.ParamByName('FCUTUCO').Value := CustomerData.IBdsVarios.FieldByName('CUTUCO').Value;
          IBDlVarios.ParamByName('FCOD_MAT').Value := CustomerData.IBdsVarios.FieldByName('COD_MAT').Value;
          IBDlVarios.ParamByName('FCUA_ANIO').Value := CustomerData.IBdsVarios.FieldByName('CUA_ANIO').Value;
          TRDlVarios.Active := True;
          IBDlVarios.ExecQuery;
          TRDlVarios.Commit;
          TRDlVarios.Active := False;
          IBdsVarios.Active := False;
          TRdsVarios.Active := False;
          TRdsVarios.Active := True;
          IBdsVarios.Active := True;
       End
   End;

end;

procedure TFrmComArmadas.CertServClick(Sender: TObject);
 Function CuentoHoras( Bloque : String) : Integer;
  Begin
    CuentoHoras := 0;
    If (Bloque = 'PRIMERO') Or (Bloque = 'SEGUNDO') Then CuentoHoras := 2;
    If Bloque = 'UNICO' Then CuentoHoras := 4;
    If Bloque = 'BLANCO' Then CuentoHoras := 0;
  End;

Var
  Copiar : Boolean;
  Origen, Destino : String;
  Cont : Integer;
  IniFile : TiniFile;
begin
 {If MessageBox(FrmComArmadas.Handle, Pchar(VNombreUsuario+', estas por pasar al historial de cada docente '+
               'toda la información de las comisiones que anteriormente cargaste. Si por casualidad la '+
               'información es incorrecta, tendrás que modificar o borrar a mano '+
               'la información que se grabó de cada docente. Después de todo esto estas realmente segura/o de hacerlo?'),
               'Aviso sin vuelta atrás hasta el próximo cuatrimestre',MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)
              = IDYES Then
  Begin
    VideoEspera := TVideoEspera.Create(Self);
    VideoEspera.Caption := VNombreUsuario + ', ' + VideoEspera.Caption;
    VideoEspera.Show;
    SQLComisiones.First;
    Cont := 0;
    While Not SQLComisiones.Eof Do
       Begin
         Copiar := True;
         If Not (FileExists(VUnidad + ':\new Pailot\Dbfgral\CertServ\'+
                 SQLComisiones.FieldByName('CODPROFES').AsString +'.Dbf')) Then
             Begin
                Origen := Vunidad+':\new pailot\dbfgral\CertServ.dbf';
                Destino :=Vunidad+':\new pailot\dbfgral\certserv\CertServ.dbf';
                CopyFile(Pchar(Origen),Pchar(Destino),Copiar);
                If Copiar Then
                   Begin
                     Origen  := Vunidad+':\new pailot\dbfgral\certserv\CertServ.dbf';
                     Destino :=Vunidad+':\new pailot\dbfgral\CertServ\' + SQLComisiones.FieldByName('CODPROFES').AsString + '.dbf';
                     RenameFile(Pchar(Origen),Pchar(Destino));
                     //MessageBox(FrmComArmadas.Handle,Pchar(VNombreUsuario+', se creo la base correspodiente al docente, '+ SQLComisiones.FieldByName('DOCENTE').AsString +', para su certificacion de servisios'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                     VideoEspera.Show;
                   End
               Else
                  Begin
                    MessageBox(FrmComArmadas.Handle,Pchar(VNombreUsuario+', hubo un error al crear el archivo de , '+ SQLComisiones.FieldByName('DOCENTE').AsString + ', para su certificacion de servicios. Llame al administrador o hagalo manualmente'),'Error',MB_OK+MB_ICONERROR+MB_APPLMODAL);
                    VideoEspera.Show;
                  End;
             End;
         If Copiar Then
           Begin
             TablaCertServ.TableName := SQLComisiones.FieldByName('CODPROFES').AsString +'.Dbf';
             TablaCertServ.Active := True;
             TablaCertServ.Append;
             TablaCertServ.FieldByName('COD_PROFES').AsString := SQLComisiones.FieldByName('CODPROFES').AsString;
             TablaCertServ.FieldByName('COD_CARRE').AsString  := SQLComisiones.FieldByName('CARRE').AsString;
             TablaCertServ.FieldByName('COD_MAT').AsString    := SQLComisiones.FieldByName('COD_MAT').AsString;
             If SQLComisiones.FieldByName('DIA1').AsString <> 'BLANCO' Then
                Cont := Cont + CuentoHoras(SQLComisiones.FieldByName('BLOQUE1').AsString);
             If SQLComisiones.FieldByName('DIA2').AsString <> 'BLANCO' Then
                Cont := Cont + CuentoHoras(SQLComisiones.FieldByName('BLOQUE2').AsString);
             If SQLComisiones.FieldByName('DIA3').AsString <> 'BLANCO' Then
                Cont := Cont + CuentoHoras(SQLComisiones.FieldByName('BLOQUE3').AsString);
             TablaCertServ.FieldByName('HORAS').AsInteger     := Cont;
             TablaCertServ.FieldByName('COMISION').AsInteger     := SQLComisiones.FieldByName('CUTUCO').AsInteger;
             TablaCertServ.FieldByName('CUA_ANIO').AsString      := SQLComisiones.FieldByName('CUA_ANIO').AsString;
             TablaCertServ.FieldByName('TIT_SUP').AsString       := SQLComisiones.FieldByName('TIT_SUP').AsString;
             TablaCertServ.Post;
             TablaCertServ.Active := False;
             Cont := 0;
           End;
         SQLComisiones.Next;
       End;
    IniFile := TIniFile.Create(Vunidad+':\New pailot\dbfgral\Esba.ini');
    CertServ.Enabled := False;
    IniFile.WriteBool('configuracion','CertServ'+VCarrera,False);
    IniFile.Free;
    VideoEspera.Close;
    VideoEspera.Free;
  End;}
end;

