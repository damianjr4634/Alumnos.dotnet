implementation
uses IBExternals, uMensajesError;
{$R *.DFM}


Function VerificoSiEsta(Combo:TComboBox;Codigo:String;princi, cont:Integer):Boolean;
Var
  x : Integer;
Begin
  VerificoSiEsta := False;
  For x:=0 To (Combo.Items.Count - 1) Do
   Begin
     If Princi = 0 Then
       Begin
         If codigo = Copy(Combo.Items.Strings[x],Length(Combo.Items.Strings[x])-2,cont) Then
           Begin
             VerificoSiEsta := True;
             Combo.ItemIndex := x;
           End
       End
     Else
       Begin
         If codigo = Copy(Combo.Items.Strings[x],1,cont) Then
          Begin
            VerificoSiEsta := True;
            Combo.ItemIndex := x;
          End
       End;
   End;
End;

procedure TFrmComArmadas.FormActivate(Sender: TObject);
Var
  i, x : Integer;
  IniFile : TiniFile;
  Codigo : String;
begin
   IniFile := TIniFile.Create(Vunidad+'\Esba.ini');
   CertServ.Enabled := IniFile.ReadBool('configuracion','CertServ'+VCarrera,False);
   EnabledCertServ := CertServ.Enabled;
   IniFile.Free;
   FrmComArmadas.Height := 245;
   Horario.RowCount := Filas+1;
   For x := 1 to Filas Do
     horario.Cells[0,X] :=  UpperCase(Funciones.LetrasCuat(X))+' BLOQUE';
   horario.Cells[1,0] := 'LUNES';
   horario.Cells[2,0] := 'MARTES';
   horario.Cells[3,0] := 'MIERCOLES';
   horario.Cells[4,0] := 'JUEVES';
   horario.Cells[5,0] := 'VIERNES';
   For i := 0 to 5 do
     horario.ColWidths[i] := 130;
   For i := 1 to 5 do
     For x:= 1 to filas do
         Grilla[i,x].dibujo := False;
   With CustomerData Do
     Begin
       if (trdsVarios.Active) then begin
           trdsvarios.Rollback;
           ibdsvarios.Active:=False;
       end;
       IBdsVarios.SQLs.SelectSQL.Clear;
       IBdsVarios.SQLs.SelectSQL.Text := 'SELECT C.CUTUCO, C.COD_MAT,C.CUA_ANIO,C.CODPROFES,D.DOCENTE,C.TIT_SUP,C.DIA1, '+
                              ' C.BLOQUE1,C.DIA2,C.BLOQUE2,C.DIA3,C.BLOQUE3 '+
                              'FROM COMARM C                               '+
                              'LEFT OUTER JOIN DOCENTES D ON C.CODPROFES=D.CODPROFES  '+
                              'LEFT OUTER JOIN MATERIAS M ON M.CODMATERI=C.COD_MAT AND M.CODCARRE=C.CARRE '+
                              'WHERE C.CARRE = :CARRE AND C.CUA_ANIO=:CUA_ANIO';
       IBdsVarios.ParamByName('CARRE').Value := VCarrera;
       IBdsVarios.ParamByName('CUA_ANIO').Value := Funciones.Cuatrimestre;
       TrdsVarios.Active := True;
       IBdsVarios.Active := True;
       Timer1.Enabled := False;
     End
   //TablaCertServ.DatabaseName := VUnidad + ':\new Pailot\Dbfgral\CertServ\';
end;

Procedure TFrmComArmadas.CargoDibujos(Sender : TObject);
Var
  ii, xx : Integer;
  Rect : TRect;
Begin
 For ii := 1 to 5 do
   For xx:= 1 to Filas do
     If Grilla[ii,xx].Dibujo Then
       Begin
         Rect := Horario.CellRect(ii,xx);
         horario.Canvas.Draw(((Rect.Left + Rect.Right) - 16) Div 2 ,
                             ((Rect.Top + Rect.Bottom) - 16) Div 2 ,
                             Image1.Picture.Graphic);
       End;
End;

