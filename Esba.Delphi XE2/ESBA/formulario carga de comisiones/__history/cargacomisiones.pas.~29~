procedure TFrmComArmadas.ComisionKeyPress(Sender: TObject; var Key: Char);
Var
  sw : Boolean;
  datos: variant;
begin

 If (Key = #13) And (Not Modificacion) Then
   Begin
     Sw := True;

     funcionesDb.Consulta('SELECT ERRCOD, ERRMSG FROM XXX_VALIDO_COMISION('#39+FuncionesText.Cuatrimestre(vcarrera)+#39','#39+
                                                                               ComboMaterias.Text+#39','#39+
                                                                               Comision.Text+#39','#39+
                                                                               vCarrera+#39')',datos);

     If (datos[0] <> 0) Then
        Begin
           MessageDlg(Pchar(VNombreUsuario+', '+VarToStr(datos[1])),mtInformation, [mbok],0,mbok);
           Sw := False;
        End;
    If Sw Then
       Begin
         Cuatrimestre.Enabled := True;
         Cuatrimestre.SetFocus;
         Cuatrimestre.Text := FuncionesText.Cuatrimestre(vcarrera);
       End;
   End;
   If (Key = #13) And (Modificacion) Then
     Begin
        Cuatrimestre.Enabled := True;
        Cuatrimestre.SetFocus;
        Cuatrimestre.Text := FuncionesText.Cuatrimestre(vcarrera);
     End;
end;

procedure TFrmComArmadas.GrabaMateriaClick(Sender: TObject);
Var
  i,  Cont : Integer;
  Sw : Boolean;
  ZConn: TZConnection;
  ZQuery: TZQuery;
begin

 ZQuery:= TZQuery.Create(nil);
 try
    zconn:= DataModuleZlib.GetConnection();
    ZQuery.Connection:= zconn;

   if MessageDlg(Pchar(VNombreUsuario + ', grabás la comisión?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
     Begin
      Cont := 1;

      If Modificacion Then Begin
        ZQuery.Sql.Text := 'UPDATE COMARM SET CARRE=:CARRE,CUTUCO=:CUTUCO,COD_MAT=:COD_MAT,CUA_ANIO=:CUA_ANIO, '+
                                           'CODPROFES=:CODPROFES,DIA1=:DIA1,BLOQUE1=:BLOQUE1, '+
                                           'DIA2=:DIA2,BLOQUE2=:BLOQUE2,DIA3=:DIA3,BLOQUE3=:BLOQUE3, '+
                                           'USUARIO=:USUARIO,TIT_SUP=:TIT_SUP '+
                                           'WHERE CARRE=:FCARRE AND CUTUCO=:FCUTUCO AND COD_MAT=:FCOD_MAT AND CUA_ANIO=:FCUA_ANIO;';
        ZQuery.ParamByName('FCARRE').Value := VCarrera;
        ZQuery.ParamByName('FCUTUCO').Value := mt.FieldByName('CUTUCO').Value;
        ZQuery.ParamByName('FCOD_MAT').Value := mt.FieldByName('COD_MAT').Value;
        ZQuery.ParamByName('FCUA_ANIO').Value := mt.FieldByName('CUA_ANIO').Value;
      End
      Else
          ZQuery.Sql.Text:= 'INSERT INTO COMARM (CARRE,CUTUCO,COD_MAT,CUA_ANIO,CODPROFES,DIA1,BLOQUE1, '+
                                              '                    DIA2,BLOQUE2,DIA3,BLOQUE3,USUARIO,TIT_SUP) '+
                                              'VALUES(:CARRE,:CUTUCO,:COD_MAT,:CUA_ANIO,:CODPROFES,:DIA1,:BLOQUE1,:DIA2,:BLOQUE2,:DIA3, '+
                                              ':BLOQUE3,:USUARIO,:TIT_SUP);';

      ZQuery.ParamByName('CARRE').Value := VCarrera;
      ZQuery.ParamByName('CUTUCO').Value := StrToInt(Comision.Text);
      ZQuery.ParamByName('COD_MAT').Value := ComboMaterias.Text;
      ZQuery.ParamByName('CUA_ANIO').Value := Cuatrimestre.Text;
      ZQuery.ParamByName('CODPROFES').Value := ComboDocente.Text;
      ZQuery.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
      If titular.Checked Then
        ZQuery.ParamByName('TIT_SUP').Value := 'T';
      If Suplente.Checked Then
        ZQuery.ParamByName('TIT_SUP').Value := 'S';

      For i := 1 To 5 do Begin
        If Cont <= 3 Then
          Begin
             If Grilla[i,1].Dibujo Then
               Begin
                 If Grilla[i,2].Dibujo Then
                   Begin
                     If Grilla[i,3].Dibujo Then
                      Begin
                        ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                        ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'UNICO';
                        Cont := Cont + 1;
                      End
                     Else
                      Begin
                        ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                        ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'PRISEG';
                        Cont := Cont + 1;
                      End
                   End
                 Else
                   Begin
                     If Grilla[i,3].Dibujo Then
                      Begin
                        ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                        ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'PRITER';
                        Cont := Cont + 1;
                      End
                     Else
                      Begin
                        ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                        ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'PRIMERO';
                        Cont := Cont + 1;
                      End
                   End
               End
             Else
                Begin
                  If Grilla[i,2].Dibujo Then
                    Begin
                      If Grilla[i,3].Dibujo Then
                        Begin
                          ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                          ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'SEGTER';
                          Cont := Cont + 1;
                        End
                      Else
                        Begin
                          ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                          ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'SEGUNDO';
                          Cont := Cont + 1;
                        End
                    End
                  Else
                    Begin
                      If Grilla[i,3].Dibujo Then
                        Begin
                          ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := Horario.Cells[i,0];
                          ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'TERCERO';
                          Cont := Cont + 1;
                        End
                    End
                End
          End;
      End;
      While Cont <= 3 Do Begin
          ZQuery.ParamByName('DIA'+IntToStr(Cont)).Value := 'BLANCO';
          ZQuery.ParamByName('BLOQUE'+IntToStr(Cont)).AsString := 'BLANCO';
          Cont := Cont + 1;
      End;

      zconn.StartTransaction;
      ZQuery.ExecSql;

      ZQuery.SQL.Text:='SELECT FERRCOD,FERRMSG FROM XXX_VAL_COMISION(:FCARRE,:FCUTUCO,:FCOD_MAT,:FCUA_ANIO)';
      ZQuery.ParamByName('FCARRE').Value := VCarrera;
      ZQuery.ParamByName('FCUTUCO').Value := StrToInt(Comision.Text);
      ZQuery.ParamByName('FCOD_MAT').Value := ComboMaterias.Text;
      ZQuery.ParamByName('FCUA_ANIO').Value := Cuatrimestre.Text;
      ZQuery.ExecSql;
      If (ZQuery.FieldByName('FERRCOD').Value=0) then begin
        Zconn.Commit;
        CancelaGrabacionClick(Sender);
      end
      Else If (ZQuery.FieldByName('FERRCOD').Value=1) then begin
        if MessageDlg(Pchar(ZQuery.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then begin
           zconn.Commit;
           CancelaGrabacionClick(Sender);
        end
        Else
           zconn.Rollback;
      end
      Else If (ZQuery.FieldByName('FERRCOD').Value=2) then
      begin
          MessageDlg(Pchar(ZQuery.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
          zconn.Rollback;
      end;
    End;
  finally
    if zConn.Connected then begin
      zconn.rollback;
      zQuery.Close;
      zConn.Disconnect;
    end;
    ZQuery.Free;
    zconn.Free;
 end;
end;

