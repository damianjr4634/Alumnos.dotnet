procedure TAlMoMaterias.BotonGrabarClick(Sender: TObject);
var Lst:String; x:Integer;
    b:Variant;
begin

if customerdata.TrUpVarios.Active then
   customerdata.TrUpVarios.Rollback;
CustomerData.IBUpVarios.SQL.Clear;
If Dondeestoy = 'Nuevo' then
    CustomerData.IBUpVarios.SQL.Text := 'INSERT INTO MATERIAS(CODCARRE,CODMATERI,CUATRIM,DESCRIPCI,CORRELATIV, '+
                                        ' SIGLA,ANUAL,EQUIVALE, ORDEN, USUARIO, ESTADO, CORREFINAL, PROMOCION) '+
                                        'VALUES (:CODCARRE,:CODMATERI,:CUATRIM,:DESCRIPCI,:CORRELATIV, '+
                                        ' :SIGLA,:ANUAL,:EQUIVALE, :ORDEN, :USUARIO, :ESTADO, :CORREFINAL, :PROMOCION);'
else
    CustomerData.IBUpVarios.SQL.Text := 'UPDATE MATERIAS SET CUATRIM=:CUATRIM, DESCRIPCI=:DESCRIPCI, CORRELATIV=:CORRELATIV, '+
                                        ' SIGLA=:SIGLA, ANUAL=:ANUAL, EQUIVALE=:EQUIVALE, ORDEN= :ORDEN, USUARIO= :USUARIO, ESTADO=:ESTADO, CORREFINAL= :CORREFINAL, PROMOCION=:PROMOCION WHERE CODCARRE=:CODCARRE AND CODMATERI=:CODMATERI;';


With CustomerData Do Begin
  IBUpVarios.ParamByName('Codmateri').Value:=Edit1.text;
  IBUpVarios.ParamByName('Equivale').Value:=CmbEquivale.text;
  IBUpVarios.ParamByName('Cuatrim').Value:=StrToInt(Edit3.text);
  IBUpVarios.ParamByName('Descripci').Value:=Edit4.text;
  IBUpVarios.ParamByName('orden').Value:=ceorden.value;

  if promo.Checked then
    IBUpVarios.ParamByName('PROMOCION').Value:='S'
  else
    IBUpVarios.ParamByName('PROMOCION').Value:='N';

  if LstCorrelaCursar.Count<>0 then begin
    lst:='';
    for x := 0 to LstCorrelaCursar.Count-1 do
      Lst:=Lst+#39+LstCorrelaCursar.Items.Strings[x]+#39;
    lst:=ansiReplaceText(lst,#39+#39,#39+','+#39);
    FuncionesDB.Consulta('SELECT LIST(M.CODMATERI,'+#39+'-'+#39+') FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' and m.sigla in ('+lst+')',b);
    IBUpVarios.ParamByName('Correlativ').Value:=b[0];
  end
  else
    IBUpVarios.ParamByName('Correlativ').Value:=Null;

  if LstCorrelaRendir.Count<>0 then begin
    lst:='';
    for x := 0 to LstCorrelaRendir.Count-1 do
      Lst:=Lst+#39+LstCorrelaRendir.Items.Strings[x]+#39;
    lst:=ansiReplaceText(lst,#39+#39,#39+','+#39);
    FuncionesDB.Consulta('SELECT LIST(M.CODMATERI,'+#39+'-'+#39+') FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' and m.sigla in ('+lst+')',b);
    IBUpVarios.ParamByName('CORREFINAL').Value:=b[0];
  end
  else
    IBUpVarios.ParamByName('CORREFINAL').Value:=Null;

  IBUpVarios.ParamByName('Sigla').Value:=Edit6.text;
  if Anual.Checked then
      IBUpVarios.ParamByName('Anual').Value:='S'
  else
      IBUpVarios.ParamByName('Anual').Value:='N';
  IBUpVarios.ParamByName('Codcarre').Value:=CarreraActiva;
  IBUpVarios.ParamByName('USUARIO').Value:=FuncionesConfiguracion.CodUsu;
  if baja.Checked then
      IBUpVarios.ParamByName('ESTADO').Value:='B'
  Else
      IBUpVarios.ParamByName('ESTADO').Value:='Y';

  Try
    TRUpVarios.Active := True;
    IBUpVarios.ExecQuery;
    TRUpVarios.Commit;
  Finally
    If (TRUpVarios.Active) Then TRUpVarios.Rollback;
    TRUpVarios.Active := False;
  End;
  BotonCancelarClick(sender);
  If (TRUpVarios.Active) Then
      TRUpVarios.Rollback;
  TRUpVarios.Active := False;

  if TRdsVarios.Active then
      TRDSVarios.Rollback;
  TRdsVarios.Active := False;
  TRDsVarios.Active := True;
  IBDsVarios.active:=True;
End;

End;

procedure TAlMoMaterias.BitBtn2Click(Sender: TObject);
var
 Fila : Real;
begin
 If Dialogo.Execute Then
 Begin
  FormPreview := TFormPreview.Create(Self);
  With FormPreview.VistaPrevia1 Do
  Begin
//    Title := 'Materias de la Carrera';
    BeginUpdate;
    With Canvas Do
     Begin
      Fila := 2.00;
      Font.Name := 'Arial';
      Font.Size := 12;
      Font.Style := [FsBold];
      TextOutCenter(10.5,Fila,CarreraLarga, GmCentimeters);
      fila:=fila+0.50;
      TextOutCenter(10.5,Fila,'Listado de Materias al '+ DateToStr(Date), GmCentimeters);
      Font.Size := 10;
      Fila := Fila + 1.00;
      TextOut(4.00,fila,'CUAT.', GmCentimeters);
      TextOut(5.80,fila,'COD. MAT.', GmCentimeters);
      TextOut(9.00,fila,'DESCRIPCION', GmCentimeters);
      fila:=fila+0.60;
      MoveTo(3.80,fila, GmCentimeters);
      LineTo(19.50,fila, GmCentimeters);
      Fila:=Fila+0.25;
      Font.Style := [];
      CustomerData.IBDsVarios.First;
      While NOT CustomerData.IBdsVarios.eof do
       Begin
        TextOut(4.50,fila,InttoStr(CustomerData.IBdsVarios.FieldByName('Cuatrim').value), GmCentimeters);
        TextOut(6.20,fila,CustomerData.IBdsVarios.FieldByName('CodMateri').Value, GmCentimeters);
        TextOut(9.00,fila,CustomerData.IBdsVarios.FieldByName('Descripci').Value, GmCentimeters);
        Fila:=fila+0.50;
        MoveTo(3.80,fila, GmCentimeters);
        LineTo(19.50,fila, GmCentimeters);
        fila:=fila+0.25;
        CustomerData.IBdsVarios.Next;
       End;
       Caja(3.80,3.25,19.50,fila-0.25,FormPreview.VistaPrevia1);
     end;
    EndUpdate;
  end;
  FormPreview.ShowModal;
  FormPreview.Free;
 end;
 Bitbtn3.SetFocus
end;

