procedure TAlMoMaterias.CmbEquivaleExit(Sender: TObject);
Var b:variant;
begin
  if (CmbEquivale.Text<>'') Then Begin
      CmbEquivale.Text:=Lpad(CmbEquivale.Text,2,'0');
      FuncionesDB.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='''+CarreraActiva+''' AND CODMATERI='''+CmbEquivale.Text+'''',['Codigo','Nombre'],b,False);
      If (VarToStr(b[0])='') then begin
         MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
         CmbEquivale.SetFocus;
      end
      else begin
         CmbEquivale.Text:=b[0];
         NombreEqui.Caption:=b[1];
      end
  end;
end;
  
