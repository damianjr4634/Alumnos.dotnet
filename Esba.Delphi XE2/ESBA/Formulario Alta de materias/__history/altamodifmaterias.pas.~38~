begin
  FuncionesDB.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='''+CarreraActiva+''' ORDER BY CODMATERI',['Codigo','Nombre'],b,True);
  CmbEquivale.Text:=b[0];
