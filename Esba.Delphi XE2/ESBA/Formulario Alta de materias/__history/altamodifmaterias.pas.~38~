Procedure TAlMoMaterias.CargaLstMaterias(codmat:String);
Var Mt:TKbmMemTable;
begin
   Mt := TkbmMemTable.Create(Self);
   try
     // para cursar
     if codmat='' then
         FuncionesDB.Carga_MemTable('SELECT M.CODMATERI, M.SIGLA FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' ORDER BY M.CUATRIM',Mt, true)
     else begin
         FuncionesDB.Carga_MemTable('SELECT M.CODMATERI, M.SIGLA FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' AND  NOT EXISTS(SELECT 1 FROM MATERIAS M2 WHERE M2.CODCARRE=M.CODCARRE AND M2.CORRELATIV CONTAINING M.CODMATERI AND M2.CODMATERI='+#39+codmat+#39+') ORDER BY M.CUATRIM',mt, true);
     end;
     mt.First;
     LstMateriasCursar.Items.clear;
     while Not Mt.Eof do begin
         LstMateriasCursar.Items.Append(Mt.FieldByName('SIGLA').AsString);
         Mt.Next;
     end;
     Mt.Close;
     if codmat<>'' then begin
         FuncionesDB.Carga_MemTable('SELECT M.CODMATERI, M.SIGLA FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' AND  EXISTS(SELECT 1 FROM MATERIAS M2 WHERE M2.CODCARRE=M.CODCARRE AND M2.CORRELATIV CONTAINING M.CODMATERI AND M2.CODMATERI='+#39+codmat+#39+') ORDER BY M.CUATRIM',mt, true);
         mt.First;
         LstCorrelaCursar.Items.clear;
         while Not Mt.Eof do begin
             LstCorrelaCursar.Items.Append(Mt.FieldByName('SIGLA').AsString);
             Mt.Next;
         end;
         Mt.Close;
     end;
     Mt.Active:= false;
     // para rendir
     if codmat='' then
         FuncionesDB.Carga_MemTable('SELECT M.CODMATERI, M.SIGLA FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' ORDER BY M.CUATRIM',Mt, true)
     else begin
         FuncionesDB.Carga_MemTable('SELECT M.CODMATERI, M.SIGLA FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' AND  NOT EXISTS(SELECT 1 FROM MATERIAS M2 WHERE M2.CODCARRE=M.CODCARRE AND M2.CORREFINAL CONTAINING M.CODMATERI AND M2.CODMATERI='+#39+codmat+#39+') ORDER BY M.CUATRIM',mt, true);
     end;
     mt.First;
     LstMateriasRendir.Items.clear;
     while Not Mt.Eof do begin
         LstMateriasRendir.Items.Append(Mt.FieldByName('SIGLA').AsString);
         Mt.Next;
     end;
     Mt.Close;
     if codmat<>'' then begin
         FuncionesDB.Carga_MemTable('SELECT M.CODMATERI, M.SIGLA FROM MATERIAS M WHERE M.CODCARRE='+#39+CarreraActiva+#39+' AND  EXISTS(SELECT 1 FROM MATERIAS M2 WHERE M2.CODCARRE=M.CODCARRE AND M2.CORREFINAL CONTAINING M.CODMATERI AND M2.CODMATERI='+#39+codmat+#39+') ORDER BY M.CUATRIM',mt, true);
         mt.First;
         LstCorrelaRendir.Items.clear;
         while Not Mt.Eof do begin
             LstCorrelaRendir.Items.Append(Mt.FieldByName('SIGLA').AsString);
             Mt.Next;
         end;
         Mt.Close;
     end
   finally
     Mt.Free;
   end;
end;

