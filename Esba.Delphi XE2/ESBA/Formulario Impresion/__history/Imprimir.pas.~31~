  public
    FAlumno: string;
    Fcarre: string;
    Ftitle: string;
    { Public declarations }
  end;

var
  FormPreview: TFormPreview;

implementation

uses
    funcionesSystem,funcionesConfiguracion,funcionesDB, EnvioCorreo;
{$R *.DFM}

procedure TFormPreview.SavePdf(const filename:string; const dlg:boolean = true);
var
  gtGmSuiteInterface :TgtGmSuiteInterface;
begin
  gtGmSuiteInterface:= TgtGmSuiteInterface.Create(self);
  try
    gtGmSuiteInterface.Engine:= gtPDFEngine1;
    gtPDFEngine1.FileName:=filename;
    gtPDFEngine1.Preferences.ShowSetupDialog :=dlg;
    gtPDFEngine1.Preferences.OpenAfterCreate :=dlg;
    gtGmSuiteInterface.RenderDocument(VistaPrevia1);
  finally
    gtGmSuiteInterface.Free
  end;
end;

Procedure TFormPreview.ImpImtervalos(paginas : String);
Var
 x : Integer;
 Anterior, Principio : String;
 Intervalo : Boolean;
Begin
  Anterior := '';
  Intervalo := False;
  Paginas := Paginas + ',';
  For x:= 1 to Length(Paginas) Do
    Begin
      If Paginas[x] In ['0'..'9'] Then
         Anterior := Anterior + Paginas[x];
      If Paginas[x] = '-' Then
        Begin
          Intervalo := True;
          Principio := Anterior;
          Anterior := '';
        End;
      If Paginas[x] = ',' Then
         Begin
           If Intervalo Then
             Begin
               If (Principio <> '') And (Anterior <> '') Then
                 Begin
                   VistaPrevia1.PrintRange(StrToInt(Principio),StrToint(Anterior));
                   Principio := '';
                   Anterior := '';
                   Intervalo := False;
                 End;
             End
           Else
             Begin
                If (Anterior <> '') Then
                   Begin
                     VistaPrevia1.CurrentPage := StrToInt(Anterior);
                     VistaPrevia1.PrintCurrentPage;
                     Anterior := '';
                   End;
            End;
         End;
    End;
End;


Procedure TFormPreview.ImpParesImpares(ParOImpar:Integer);
Var
   x: Integer;
Begin
  For x:=1 to VistaPrevia1.NumPages Do
   Begin
     If  (x Mod 2) = ParOImpar Then
       Begin
         VistaPrevia1.CurrentPage := x;
         VistaPrevia1.PrintCurrentPage;
        End;
   End;
End;


procedure TFormPreview.BitBtn2Click(Sender: TObject);
Var
   x : Integer;
begin

//VistaPrevia1.GmPrinter.PrinterPaperSize:=gmPrinter.AsPrinterPaperSize(legal);
VistaPrevia1.GmPrinter.PrinterPaperSize;
 For x:=1 to StrToInt(Copias.Text) Do
  Begin
    If Todo.Checked Then
      VistaPrevia1.Print;
    If Actual.Checked Then
      VistaPrevia1.PrintCurrentPage;
    If Pares.Checked Then
      ImpParesImpares(0);
    If Impares.Checked Then
      ImpParesImpares(1);
    If (Paginas.Checked) And (NumPaginas.Text <> '')Then
      ImpImtervalos(NumPaginas.Text);
  End;
end;


procedure TFormPreview.BtnPdfClick(Sender: TObject);
begin
  if savedialog1.Execute then
    savepdf(savedialog1.FileName);
end;

procedure TFormPreview.UpDown1Changing(Sender: TObject;
  var AllowChange: Boolean);
begin
  VistaPrevia1.Zoom := StrToInt(edit1.text);
end;

procedure TFormPreview.Edit1KeyPress(Sender: TObject; var Key: Char);
begin
 If Key = #13 Then
   VistaPrevia1.Zoom := StrToInt(edit1.text);
end;

procedure TFormPreview.VistaPrevia1MouseUp(Sender: TObject;
  Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
begin
  If Button = MbLeft Then
    UpDown1.Position := UpDown1.Position + 10;
  If Button = MbRight Then
    UpDown1.Position := UpDown1.Position - 10;
end;

procedure TFormPreview.FormCanResize(Sender: TObject; var NewWidth,
  NewHeight: Integer; var Resize: Boolean);
begin
  Barra.Panels.Items[0].Width := FormPreview.ClientWidth - 100;
  Barra.Panels.Items[1].Text := 'Paginas ' + IntToStr(VistaPrevia1.CurrentPage)+'/'+IntToStr(VistaPrevia1.NumPages);
end;

procedure TFormPreview.FormCreate(Sender: TObject);
begin
  FAlumno:='';
  Fcarre:='';
  Ftitle:='documento';
end;

procedure TFormPreview.VistaPrevia1PageChange(Sender: TObject;
  PageNum: Integer);
begin
  Barra.Panels.Items[1].Text := 'Paginas ' + IntToStr(VistaPrevia1.CurrentPage)+'/'+IntToStr(VistaPrevia1.NumPages);
end;

procedure TFormPreview.BitBtn10Click(Sender: TObject);
var
  envmail:TFrmenviomail;
  datos: variant;
  filename: string;
begin
  envmail:= TFrmenviomail.Create(self);
  try
    filename:=funcionesSystem.GetTempDirectory+Ftitle+'.pdf';
    savepdf(filename,false);
    envmail.ArchAdj.Items.Add(filename);
    with envmail do begin
      groupbox4.Enabled:=false;
      groupbox1.Enabled:=false;
      groupbox2.Enabled:=false;
      groupbox3.Enabled:=false;
      groupbox5.Enabled:=false;
      groupbox6.Enabled:=false;
    end;
    EnvioCorreo.VUnidad := funcionesConfiguracion.Path;
    EnvioCorreo.VUsuario:= funcionesConfiguracion.nomusu;
    if Falumno<>'' then begin
      datos:=null;
      FuncionesDB.Consulta('SELECT MAIL FROM ALUMNOS WHERE COD_ALU='''+Falumno+''' AND CARRE='''+FCarre+'''',datos);
      if not varisnull(datos) then
        envmail.DEPara.Text:=vartostr(datos[0]);
    end;
    envmail.Asunto.text := 'Envio de '+FTitle;
    envmail.ShowModal;
    //if enviocorreo.LogEnvio then

  finally
    envmail.free;
  end;
end;

procedure TFormPreview.BitBtn1Click(Sender: TObject);
begin
 Close;
end;

procedure TFormPreview.numpaginasKeyPress(Sender: TObject; var Key: Char);
begin
 If Not (charinset(key,['0'..'9',Chr(8), Chr(7), Chr(13), chr(9),'-',','])) Then
    Key := #0;
end;

procedure TFormPreview.copiasKeyPress(Sender: TObject; var Key: Char);
begin
  If Not (charinset(key,['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)])) Then
    Key := #0;
end;

procedure TFormPreview.paginasClick(Sender: TObject);
begin
  NumPaginas.Enabled := Paginas.Checked;
  If Paginas.Checked Then
     NumPaginas.SetFocus;
end;

procedure TFormPreview.FormActivate(Sender: TObject);
begin
  Todo.Checked := True;
end;

end.
