  GmThumbnails, Printers, GmClasses, GmCanvas, GmPageNavigator, SynPdf,
  gtClasses3, gtCstDocEng, gtCstPlnEng, gtCstPDFEng, gtExPDFEng, gtPDFEng, gtGmSuiteIntf,
  Variants;

type
  TFormPreview = class(TForm)
