    GmThumbnails1: TGmThumbnails;
    RadioGroup1: TRadioGroup;
    todo: TRadioButton;
    Pares: TRadioButton;
    Impares: TRadioButton;
    paginas: TRadioButton;
    numpaginas: TEdit;
    StaticText1: TStaticText;
    Actual: TRadioButton;
    GroupBox2: TGroupBox;
    Edit1: TEdit;
    UpDown1: TUpDown;
    copias: TEdit;
    UpDown2: TUpDown;
    Label1: TLabel;
    Label2: TLabel;
    gtPDFEngine1: TgtPDFEngine;
    GroupBox1: TGroupBox;
    GmPageNavigator1: TGmPageNavigator;
    BitBtn2: TBitBtn;
    BitBtn1: TBitBtn;
    Panel3: TPanel;
    BtnPdf: TBitBtn;
    SaveDialog1: TSaveDialog;
    BitBtn10: TBitBtn;
    gtPDFEngine2: TgtPDFEngine;
    procedure BitBtn2Click(Sender: TObject);
    procedure UpDown1Changing(Sender: TObject; var AllowChange: Boolean);
    procedure Edit1KeyPress(Sender: TObject; var Key: Char);
    procedure VistaPrevia1MouseUp(Sender: TObject; Button: TMouseButton;
