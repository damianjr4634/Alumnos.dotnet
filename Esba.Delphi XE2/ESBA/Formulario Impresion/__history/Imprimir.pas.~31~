    procedure VistaPrevia1PageChange(Sender: TObject; PageNum: Integer);
    procedure BitBtn1Click(Sender: TObject);
    procedure numpaginasKeyPress(Sender: TObject; var Key: Char);
    procedure copiasKeyPress(Sender: TObject; var Key: Char);
