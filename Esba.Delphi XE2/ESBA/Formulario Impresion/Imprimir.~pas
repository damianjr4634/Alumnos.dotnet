unit Imprimir;

interface

uses
  Windows, Messages, SysUtils, Classes, Graphics, Controls, Forms, Dialogs,
  StdCtrls, Buttons, GmTypes, GmPreview, gmprinter,ComCtrls, ExtCtrls, GmRtfPreview,
  GmThumbnails, Printers;

type
  TFormPreview = class(TForm)
    Panel1: TPanel;
    BitBtn1: TBitBtn;
    BitBtn2: TBitBtn;
    Barra: TStatusBar;
    Panel2: TPanel;
    VistaPrevia1: TGmPreview;
    GmThumbnails1: TGmThumbnails;
    RadioGroup1: TRadioGroup;
    todo: TRadioButton;
    Pares: TRadioButton;
    Impares: TRadioButton;
    paginas: TRadioButton;
    numpaginas: TEdit;
    StaticText1: TStaticText;
    GroupBox1: TGroupBox;
    copias: TEdit;
    UpDown2: TUpDown;
    Actual: TRadioButton;
    GroupBox2: TGroupBox;
    Edit1: TEdit;
    UpDown1: TUpDown;
    procedure BitBtn2Click(Sender: TObject);
    procedure UpDown1Changing(Sender: TObject; var AllowChange: Boolean);
    procedure Edit1KeyPress(Sender: TObject; var Key: Char);
    procedure VistaPrevia1MouseUp(Sender: TObject; Button: TMouseButton;
      Shift: TShiftState; X, Y: Integer);
    procedure FormCanResize(Sender: TObject; var NewWidth,
      NewHeight: Integer; var Resize: Boolean);
    procedure VistaPrevia1PageChange(Sender: TObject; PageNum: Integer);
    procedure BitBtn1Click(Sender: TObject);
    procedure numpaginasKeyPress(Sender: TObject; var Key: Char);
    procedure copiasKeyPress(Sender: TObject; var Key: Char);
    procedure paginasClick(Sender: TObject);
    procedure FormActivate(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  FormPreview: TFormPreview;
  Procedure ImpParesImpares(VistaPrevia1:TGmPreview;ParOImpar:Integer);
  Procedure ImpImtervalos(VistaPrevia1:TGmPreview; Paginas : String);
implementation

{$R *.DFM}

Procedure ImpImtervalos(VistaPrevia1:TGmPreview; paginas : String);
Var
 x : Integer;
 Anterior, Principio : String;
 Intervalo : Boolean;
Begin
  Anterior := '';
  Intervalo := False;
  Paginas := Paginas + ',';
  For x:= 1 to Length(Paginas) Do
    Begin
      If Paginas[x] In ['0'..'9'] Then
         Anterior := Anterior + Paginas[x];
      If Paginas[x] = '-' Then
        Begin
          Intervalo := True;
          Principio := Anterior;
          Anterior := '';
        End;
      If Paginas[x] = ',' Then
         Begin
           If Intervalo Then
             Begin
               If (Principio <> '') And (Anterior <> '') Then
                 Begin
                   VistaPrevia1.PrintRange(StrToInt(Principio),StrToint(Anterior));
                   Principio := '';
                   Anterior := '';
                   Intervalo := False;
                 End;
             End
           Else
             Begin
                If (Anterior <> '') Then
                   Begin
                     VistaPrevia1.CurrentPage := StrToInt(Anterior);
                     VistaPrevia1.PrintCurrentPage;
                     Anterior := '';
                   End;
            End;
         End;
    End;
End;


Procedure ImpParesImpares(VistaPrevia1:TGmPreview;ParOImpar:Integer);
Var
   x: Integer;
Begin
  For x:=1 to VistaPrevia1.NumPages Do
   Begin
     If  (x Mod 2) = ParOImpar Then
       Begin
         VistaPrevia1.CurrentPage := x;
         VistaPrevia1.PrintCurrentPage;
        End;
   End;
End;


procedure TFormPreview.BitBtn2Click(Sender: TObject);
Var
   x : Integer;
begin
//VistaPrevia1.GmPrinter.PrinterPaperSize:=gmPrinter.AsPrinterPaperSize(legal);
VistaPrevia1.GmPrinter.PrinterPaperSize;
 For x:=1 to StrToInt(Copias.Text) Do
  Begin
    If Todo.Checked Then
      VistaPrevia1.Print;
    If Actual.Checked Then
      VistaPrevia1.PrintCurrentPage;
    If Pares.Checked Then
      ImpParesImpares(VistaPrevia1,0);
    If Impares.Checked Then
      ImpParesImpares(VistaPrevia1,1);
    If (Paginas.Checked) And (NumPaginas.Text <> '')Then
      ImpImtervalos(VistaPrevia1,NumPaginas.Text);
  End;
end;

procedure TFormPreview.UpDown1Changing(Sender: TObject;
  var AllowChange: Boolean);
begin
  VistaPrevia1.Zoom := StrToInt(edit1.text);
end;

procedure TFormPreview.Edit1KeyPress(Sender: TObject; var Key: Char);
begin
 If Key = #13 Then
   VistaPrevia1.Zoom := StrToInt(edit1.text);
end;

procedure TFormPreview.VistaPrevia1MouseUp(Sender: TObject;
  Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
begin
  If Button = MbLeft Then
    UpDown1.Position := UpDown1.Position + 10;
  If Button = MbRight Then
    UpDown1.Position := UpDown1.Position - 10;
end;

procedure TFormPreview.FormCanResize(Sender: TObject; var NewWidth,
  NewHeight: Integer; var Resize: Boolean);
begin
  Barra.Panels.Items[0].Width := FormPreview.ClientWidth - 100;
  Barra.Panels.Items[1].Text := 'Paginas ' + IntToStr(VistaPrevia1.CurrentPage)+'/'+IntToStr(VistaPrevia1.NumPages);
end;

procedure TFormPreview.VistaPrevia1PageChange(Sender: TObject;
  PageNum: Integer);
begin
  Barra.Panels.Items[1].Text := 'Paginas ' + IntToStr(VistaPrevia1.CurrentPage)+'/'+IntToStr(VistaPrevia1.NumPages);
end;

procedure TFormPreview.BitBtn1Click(Sender: TObject);
begin
 Close;
end;

procedure TFormPreview.numpaginasKeyPress(Sender: TObject; var Key: Char);
begin
 If Not (Key In ['0'..'9',Chr(8), Chr(7), Chr(13), chr(9),'-',',']) Then
    Key := #0;
end;

procedure TFormPreview.copiasKeyPress(Sender: TObject; var Key: Char);
begin
  If Not (Key In ['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)]) Then
    Key := #0;
end;

procedure TFormPreview.paginasClick(Sender: TObject);
begin
  NumPaginas.Enabled := Paginas.Checked;
  If Paginas.Checked Then
     NumPaginas.SetFocus;
end;

procedure TFormPreview.FormActivate(Sender: TObject);
begin
  Todo.Checked := True;
end;

end.
