  StdCtrls,Grids, DBGrids, Buttons, FuncionesText, FuncionesConfiguracion, FuncionesDB, DataModuleZeosLib,
  Mask, RXToolEdit, DB, Variants, kbmMemTable;
type
  TInscripcionMaterias = class(TForm)
    GroupBox1: TGroupBox;
    GroupBox2: TGroupBox;
    DataSource1: TDataSource;
    MateriasCursando: TDBGrid;
    Label1: TLabel;
    MateriasCodigoAlumno: TEdit;
    Label2: TLabel;
    MateriasCarreraCursa: TEdit;
    Label3: TLabel;
    MateriasApellidoyNombre: TEdit;
    Label4: TLabel;
    MateriasLibroMatriz: TEdit;
    GroupBox3: TGroupBox;
    Label5: TLabel;
    Label7: TLabel;
    Label8: TLabel;
    Label9: TLabel;
    Label10: TLabel;
    ComboCondicionAlumno: TComboBox;
    GrabaMateria: TBitBtn;
    Comision: TEdit;
    modificacursada: TBitBtn;
    eliminacursada: TBitBtn;
    salir: TBitBtn;
    CancelaGrabacion: TBitBtn;
    turno: TEdit;
    CursadaNueva: TBitBtn;
    Label11: TLabel;
    Conjunto: TBitBtn;
