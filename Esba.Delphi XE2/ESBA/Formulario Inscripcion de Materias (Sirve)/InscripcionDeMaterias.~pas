  VUnidad : String[1]; //sirve para saber la unidad en la cual se corre el sistema
  VCODALU : String[11]; //pasa el codigo de alumno con el cual se esta trabajando
  VCondicion : String[15]; // nose
  VApellido : String[25]; //Pasa el apellido del alumno activo
  VNombre : String[25];  //Pasa el nombre del alumno activo
  VLibroMatriz : String[5]; //Pasa el libro matriz del alumno
  VInstituto  : String[30]; //Pasa el nomnbre del instituto
  VCaracteristica : String[5]; //Pasa la caracteristica del colegio
  VCuatrimestreAnio : String[4]; //guarda el a隳 cuatrimestre actual
  VNombreUsuario : String; //Trae el usuario que esta trabajando
