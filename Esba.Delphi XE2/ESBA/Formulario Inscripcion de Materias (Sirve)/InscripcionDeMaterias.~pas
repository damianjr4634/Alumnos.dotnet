    Label3: TLabel;
    MateriasApellidoyNombre: TEdit;
    Label4: TLabel;
    MateriasLibroMatriz: TEdit;
    GroupBox3: TGroupBox;
    Label5: TLabel;
    Label7: TLabel;
    Label8: TLabel;
    Label9: TLabel;
    Label10: TLabel;
