  if (CodigoMateria.Text<>'') Then Begin
      CodigoMateria.Text:=Lpad(CodigoMateria.Text,2,'0');
      FuncionesDB.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='+#39+vcarrera+#39+' AND CODMATERI='+#39+CodigoMateria.text+#39+' AND ESTADO<>'+#39+'B'+#39+' ORDER BY CODMATERI',['Codigo','Nombre'],b,False);
      If (vartostr(b[0])='') then begin
         MessageDlg('Código incorrecto',mtError,[mbok],0,mbok);
         CodigoMateria.SetFocus;
      end
      else begin
         CodigoMateria.Text:=b[0];
         NombreMat.Caption:=b[1];
      end
  end
end;

