procedure TFrmlstARegular.CodigoMateriaButtonClick(Sender: TObject);
Var Text1,Text2:String;
begin
  Funciones.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='#39+vcarrera+#39+' AND ESTADO<>'+#39+'B'+#39+' ORDER BY CODMATERI',['Codigo','Nombre'],Text1,Text2,0,1,True);
  CodigoMateria.Text:=Text1;
  NombreMat.Caption:=Text2;
end;

procedure TFrmlstARegular.CodigoMateriaExit(Sender: TObject);
Var Text1,Text2:String;
begin
  Text1:='';
  if (CodigoMateria.Text<>'') Then Begin
      CodigoMateria.Text:=Lpad(CodigoMateria.Text,2,'0');
      Funciones.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='+#39+vcarrera+#39+' AND CODMATERI='+#39+CodigoMateria.text+#39+' AND ESTADO<>'+#39+'B'+#39+' ORDER BY CODMATERI',['Codigo','Nombre'],Text1,Text2,0,1,False);
      If (Text1='') then begin
         MessageBox(FrmlstARegular.Handle,'Codigo Incorrecto','Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
         CodigoMateria.SetFocus;
      end
      else begin
         CodigoMateria.Text:=Text1;
         NombreMat.Caption:=Text2;
      end
  end
end;

end.