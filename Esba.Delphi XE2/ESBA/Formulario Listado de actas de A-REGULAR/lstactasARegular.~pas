  VInstituto  : String[50]; //Pasa el nomnbre del instituto
  VCaracteristica : String[5]; //Pasa la caracteristica del colegio
  VCuatrimestreAnio : String[4]; //guarda el a cuatrimestre actual
  VNombreUsuario : String; //Trae el usuario que esta trabajando
  VCarreraLarga : String; //Trae el nombre completo de la carrera
implementation


{$R *.dfm}
procedure TFrmlstARegular.FormActivate(Sender: TObject);
begin
 Comision.SetFocus;
end;

procedure TFrmlstARegular.ImprimirClick(Sender: TObject);
var
  largopagina:real;
  contareg:integer;
  sw : integer;
  Cutuco_Aux : Integer;
  CodigoMateria_Aux : Integer;
  verti:real;
  x:integer;
  Imagen : TMetaFile;
begin
 sw := 0;
 contareg:=1;
 If (ibtr.Active) then begin
    ibtr.Rollback;
    sqlcomi.Active:=false;
    sqldatos.Active:=False;
 end;
 SqlComi.SQLs.SelectSql.Text:='';
 If (CodigoMateria.Text = '') and (Comision.Text<>'') then
  Begin
     SqlComi.SQLs.SelectSql.Text:= 'SELECT TRIM(D.DOCENTE) AS DOCENTE, TRIM(M.DESCRIPCI) AS DESCRIPCI, C.CUTUCO, C.COD_MAT '+
                        'FROM COMARM C '+
                        'LEFT OUTER JOIN DOCENTES D  ON C.CODPROFES = D.CODPROFES '+
                        'LEFT OUTER JOIN MATERIAS M  ON C.COD_MAT = M.CODMATERI AND C.CARRE = M.CODCARRE '+
                        'WHERE C.CARRE = '+#39+VCarrera+#39+' AND C.CUTUCO = :CUTUCO  AND  C.CUA_ANIO = '+#39+AnsiReplaceText(Cuatrimestre.Text,'/','')+#39+
                        ' AND EXISTS(SELECT 1 FROM CURSADA CU WHERE CU.CARRE=C.CARRE AND CU.COD_MAT=C.COD_MAT AND CU.CUTUCO=C.CUTUCO AND CU.CUA_ANIO=C.CUA_ANIO AND CU.CONDICION='+#39+'A/REGULAR'+#39+')'+
                        '  ORDER BY 3,4';
     SqlComi.ParamByName('CUTUCO').AsInteger := StrToint(Comision.Text);
  end;
 If (CodigoMateria.Text = '') and (Comision.Text='') then
   SqlComi.SQLs.SelectSql.Text:= 'SELECT TRIM(D.DOCENTE) AS DOCENTE, TRIM(M.DESCRIPCI) AS DESCRIPCI, C.CUTUCO, C.COD_MAT '+
                        'FROM COMARM C '+
                        'LEFT OUTER JOIN DOCENTES D  ON C.CODPROFES = D.CODPROFES '+
                        'LEFT OUTER JOIN MATERIAS M  ON C.COD_MAT = M.CODMATERI AND C.CARRE = M.CODCARRE '+
                        'WHERE C.CARRE = '+#39+VCarrera+#39+' AND C.CUA_ANIO = '+#39+AnsiReplaceText(Cuatrimestre.Text,'/','')+#39+
                        ' AND EXISTS(SELECT 1 FROM CURSADA CU WHERE CU.CARRE=C.CARRE AND CU.COD_MAT=C.COD_MAT AND CU.CUTUCO=C.CUTUCO AND CU.CUA_ANIO=C.CUA_ANIO AND CU.CONDICION='+#39+'A/REGULAR'+#39+')'+
                        ' ORDER BY 3,4';
 If (CodigoMateria.Text <> '') and (Comision.Text<>'') then
   Begin
     SqlComi.SQLs.SelectSql.Text:= 'SELECT TRIM(D.DOCENTE) AS DOCENTE, TRIM(M.DESCRIPCI) AS DESCRIPCI, C.CUTUCO, C.COD_MAT '+
                        'FROM COMARM C '+
                        'LEFT OUTER JOIN DOCENTES D  ON C.CODPROFES = D.CODPROFES '+
                        'LEFT OUTER JOIN MATERIAS M  ON C.COD_MAT = M.CODMATERI AND C.CARRE = M.CODCARRE '+
                        'WHERE C.CARRE = '+#39+VCarrera+#39+' AND C.CUTUCO = :CUTUCO  AND  C.CUA_ANIO = '+#39+AnsiReplaceText(Cuatrimestre.Text,'/','')+#39+' AND '+
                        'C.COD_MAT = :MATERIA  AND EXISTS(SELECT 1 FROM CURSADA CU WHERE CU.CARRE=C.CARRE AND CU.COD_MAT=C.COD_MAT AND CU.CUTUCO=C.CUTUCO AND CU.CUA_ANIO=C.CUA_ANIO AND CU.CONDICION='+#39+'A/REGULAR'+#39+')'+
                        '  ORDER BY 3,4';
     SqlComi.ParamByName('MATERIA').AsString := Codigomateria.Text;
     SqlComi.ParamByName('CUTUCO').AsInteger := StrToint(Comision.Text);
   End;
 If (CodigoMateria.Text <> '') and (Comision.Text='') then
   Begin
     SqlComi.SQLs.SelectSQL.Text:= 'SELECT TRIM(D.DOCENTE) AS DOCENTE, TRIM(M.DESCRIPCI) AS DESCRIPCI, C.CUTUCO, C.COD_MAT '+
                        'FROM COMARM C '+
                        'LEFT OUTER JOIN DOCENTES D  ON C.CODPROFES = D.CODPROFES '+
                        'LEFT OUTER JOIN MATERIAS M  ON C.COD_MAT = M.CODMATERI AND C.CARRE = M.CODCARRE '+
                        'WHERE C.CARRE = '+#39+VCarrera+#39+' AND C.CUA_ANIO = '+#39+AnsiReplaceText(Cuatrimestre.Text,'/','')+#39' AND C.COD_MAT = :MATERIA '+
                        ' AND EXISTS(SELECT 1 FROM CURSADA CU WHERE CU.CARRE=C.CARRE AND CU.COD_MAT=C.COD_MAT AND CU.CUTUCO=C.CUTUCO AND CU.CUA_ANIO=C.CUA_ANIO AND CU.CONDICION='+#39+'A/REGULAR'+#39+')'+
                        '  ORDER BY 3,4';
     SqlComi.ParamByName('MATERIA').AsString := codigomateria.Text;
   End;
 SqlComi.Active := True;
 SqlComi.FetchAll;
 IbTr.Active:=True;
 If SqlComi.RecordCount = 0 Then
   Begin
    MessageBox(FrmlstARegular.Handle,Pchar(VNombreUsuario+', no hay datos para mostrar'),'Aviso',MB_OK+MB_APPLMODAL+MB_ICONINFORMATION);
    Comision.SetFocus;
    SqlComi.Active := False;
    IbTr.RollBack;
    IbTr.Active:=False;
   End
 Else
  If PrintDialog1.execute then
   Begin
    FormPreview:=tFormPreview.create(self);
    largopagina:= 1.5;
    Imagen := TMetaFile.Create;
    Imagen.LoadFromFile(vUnidad+'\actas_volantes.wmf');
    FormPreview.VistaPrevia1.PaperSize:=Legal;
    FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21.54,35.56,Imagen,GmCentimeters);
    While not SqlComi.eof do
     begin
      if not sqldatos.active then
        begin
         SqlDatos.SQLs.SelectSQL.Text:='SELECT DISTINCT A.COD_ALU, TRIM(A.APELLIDO) AS APELLIDO, TRIM(A.NOM_APE) AS NOM_APE, TRIM(C.CONDICION) AS CONDICION, C.CUTUCO, A.COD_ALU '+
                                       'FROM  CURSADA C '+
                                       'LEFT OUTER JOIN ALUMNOS A  ON C.COD_ALU = A.COD_ALU AND C.CARRE=A.CARRE '+
                                       'WHERE C.CUTUCO = '+IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger)+' AND C.CUA_ANIO = '+#39+Cuatrimestre.Text+#39+
                                       '      AND TRIM(C.CONDICION) IN  ('+#39+'A/REGULAR'+#39+')  AND C.COD_MAT = '+#39+SqlComi.FieldByName('COD_MAT').AsString+#39+' AND C.CARRE='+#39+vCARRERA +#39+' AND A.BAJA='+#39+'N'+#39+
                                       ' ORDER BY C.CUTUCO, A.APELLIDO, A.NOM_APE ';
         SqlDatos.Active:=True;
         SqlDatos.FetchAll;
        end;
      FormPreview.VistaPrevia1.BeginUpdate;
      // **** INICIO DEL ENCABEZADO ***//
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 9;
      FormPreview.VistaPrevia1.Canvas.Font.Style := [FsBold];
      LargoPagina:=LargoPagina+0.7;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,VCarreraLarga,GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'ACTA DE EXAMENES DE ALUMNOS A/REGULAR',GmCentimeters);
      LargoPagina:=LargoPagina+0.4;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Asignatura: '+SqlComi.FieldByName('DESCRIPCI').AsString,GmCentimeters);
      LargoPagina:=LargoPagina+0.5;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Cuat.: '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'    Turno: '+Turnos(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),2,1)))+'     Divisi: '+Division(StrtoInt(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),3,1))),GmCentimeters);
      LargoPagina:=LargoPagina+0.5;
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 7;
      FormPreview.VistaPrevia1.Canvas.TextOutCenter(10.5,LargoPagina,'Correspondiente al '+(Copy(IntToStr(SqlComi.FieldByName('CUTUCO').AsInteger),1,1))+'ｺ CUATRIMESTRE de estudios',GmCentimeters);
      LargoPagina:=LargoPagina+1.3;
      FormPreview.VistaPrevia1.Canvas.TextOut(1,LargoPagina,Funciones.LPad('',300,'.'),GmCentimeters);
      // **** FIN DEL ENCABEZADO ***//
      // **** INICIO DEL DETALLE ***//
      FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
      FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
      FormPreview.VistaPrevia1.Canvas.Font.Style := [];
      LargoPagina := 7.8;
      //llenar los parametro de sqlcursada y ejecutarlo
      While (not SqlDatos.eof) and  (largopagina<=28)  do
       begin
           contareg:=contareg+1;
           //TOMA DATOS DE LA BD
           FormPreview.VistaPrevia1.Canvas.Font.Name := 'Arial';
           FormPreview.VistaPrevia1.Canvas.Font.Size := 8;
           FormPreview.VistaPrevia1.Canvas.Font.Style := [];
           FormPreview.VistaPrevia1.Canvas.TextOut(3.4,largopagina,SqlDatos.FieldByName('COD_ALU').AsString,gmcentimeters);
           FormPreview.VistaPrevia1.Canvas.TextOut(5.9,largopagina,SqlDatos.FieldByName('APELLIDO').AsString + ', ' + SqlDatos.FieldByName('NOM_APE').AsString ,gmcentimeters);
           LargoPagina := LargoPagina + 0.9;
           SqlDatos.next;
       end;
        FormPreview.VistaPrevia1.EndUpdate;
        if SqlDatos.eof then
         Begin
           SqlDatos.Active:=False;
           SqlComi.Next;
           sw:=0;
           contareg:=1;
         end;
        if (not sqlcomi.Eof) or (largopagina>28) then begin
          FormPreview.VistaPrevia1.Newpage;
          FormPreview.VistaPrevia1.Canvas.StretchDraw(0,0,21.54,35.56,Imagen,GmCentimeters);
        end;
        LargoPagina := 1.5;
     end; //end del while sqlcomi
     FormPreview.VistaPrevia1.CurrentPage := 1;
     FormPreview.ShowModal;
     FormPreview.Free;
     Comision.SetFocus;
  end;
  SqlDatos.Active:=False;
  SqlComi.Active:=False;
  If IbTr.Active then
      IbTr.RollBack;
  IbTr.Active:=False;
end;

