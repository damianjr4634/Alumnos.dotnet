procedure TPermisosExamen.NumeroPermisoKeyPress(Sender: TObject;
  var Key: Char);
begin
 If Not (Key In ['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)]) Then
     Key := #0;
 If Key = #13 Then
   Begin
       Permisos.Active := False;
       Permisos.DatabaseName := Vunidad + ':\New pailot\Archivos\' + Vcarrera;
       Permisos.TableName := 'Permexa.dbf';
       Permisos.IndexFieldNames := 'PERM_EXA';
       Permisos.Active := True;
       If (Permisos.FindKey([NumeroPermiso.Text])) And (Not Modificacion) Then
           MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', el número de permiso pertenece al alumno con documento, '+ Permisos.FieldByName('Cod_Alu').AsString ),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL)
       Else
         Begin
           NumeroPermiso.Enabled := False;
           CodigoMateria.Enabled := True;
           CodigoMateria.SetFocus;
         End;
       Permisos.Active := False;
   End;
End;

procedure TPermisosExamen.codigomateriaKeyPress(Sender: TObject;
  var Key: Char);
begin
  If Not (Key In ['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)]) Then
     Key := #0;
  If Key = #13 Then
    Begin
      If CodigoMateria.Text = '' Then
        Begin
           CodigoMateria.Enabled := False;
           ComboMaterias.Enabled := True;
           ComboMaterias.SetFocus;
        End
      Else
        Begin
          If Length(CodigoMateria.Text) = 1 Then
            CodigoMateria.Text := '0' + CodigoMateria.Text;
          If VerificoSiEsta(ComboMaterias,CodigoMateria.Text,2) Then
            Begin
              If ValidoMateria(SQLMaterias,SQLAnalitico,CodigoMateria.Text) Then
                Begin
                  If CuentoLlamados(SQLCursada,CodigoMateria.Text) Then
                    Begin
                      CodigoMateria.Enabled := False;
                      ComboMaterias.Enabled := False;
                      Comision.Enabled := True;
                      CargoMesasCombo(SQLMesas,ComboMesa,CodigoMateria.Text);
                      Comision.Text := BuscoCutuco(SQLCursada,CodigoMateria.Text);
                      Comision.SetFocus;
                    End
                  Else
                    MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', el alumno no puede rendir la materia ' +Copy(ComboMaterias.Text,4,Length(comboMaterias.Text)) +' porque exedió la cantidad de llamados'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                End
              Else
               MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', el alumno no puede rendir la materia ' +Copy(ComboMaterias.Text,4,Length(comboMaterias.Text)) +' porque adeuda correlatividades.'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
            End
          Else
             MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', el codigo de materia que ingresaste no esta en la lista de materias posibles.'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
        End;
    End;
end;

procedure TPermisosExamen.ComboMateriasClick(Sender: TObject);
Var
 Key : Char;
begin
  CodigoMateria.Text := Copy(ComboMaterias.Text,1,2);
  Key := #13;
  codigomateriaKeyPress(Sender,Key);
end;

procedure TPermisosExamen.ComisionKeyPress(Sender: TObject; var Key: Char);
begin
 If Not (Key In ['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)]) Then
     Key := #0;
 If Key = #13 Then
   Begin
    Mesa.Enabled := True;
    Comision.Enabled := False;
    Mesa.SetFocus;
   End;
end;

procedure TPermisosExamen.MesaKeyPress(Sender: TObject; var Key: Char);
begin
 If Not (Key In ['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)]) Then
     Key := #0;
 If Key = #13 Then
   Begin
    If Mesa.Text = '' Then
      Begin
        Mesa.Enabled := False;
        ComboMesa.Enabled := True;
        ComboMesa.SetFocus;
      End
    Else
      Begin
        If VerificoSiEsta(ComboMesa,Mesa.Text,3) Then
          Begin
            GrabaPermiso.Enabled := True;
            GrabaPermiso.SetFocus;
          End
        Else
          MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', la mesa que ingresaste no existe.'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
      End;
   End;
end;

procedure TPermisosExamen.ComboMesaClick(Sender: TObject);
Var
 Key : Char;
begin
  Mesa.Text := Copy(ComboMesa.Text,1,3);
  Key := #13;
  MesaKeyPress(Sender,Key);
end;

procedure TPermisosExamen.GrabaPermisoClick(Sender: TObject);
begin
  If MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', grabas el permiso de examen?'),'Aviso',MB_OKCANCEL+MB_ICONQUESTION+MB_APPLMODAL)
     = IDOK Then
    Begin
      If Modificacion Then
         Begin
           Permisos.Active := True;
           Permisos.FindKey([StrToInt(NumeroPermiso.Text)]);
           Permisos.Edit;
         End
      Else
         Begin
           Permisos.Active := True;
           Permisos.Append;
         End;
       Permisos.FieldByName('PERM_EXA').AsInteger  := StrToInt(NumeroPermiso.Text);
       Permisos.FieldByName('MESA').AsInteger      := StrToInt(Mesa.Text);
       Permisos.FieldByName('LLAMADO').AsInteger   := StrToInt(Copy(ComboMesa.Text,5,1));
       Permisos.FieldByName('COD_ALU').AsString    := VCodAlu;
       Permisos.FieldByName('APELLIDO').AsString   := VApellido;
       Permisos.FieldByName('CUTUCO').AsInteger    := StrToInt(Comision.Text);
       Permisos.FieldByName('CARRE').AsString      := VCarrera;
       Permisos.FieldByName('COD_MAT').AsString    := CodigoMateria.Text;
       Permisos.FieldByName('FECH_EXA').AsDateTime := StrToDate(Copy(ComboMesa.Text,7,10));
       Permisos.FieldByName('FECH_EMI').AsDateTime := Date();
       Permisos.Post;
       Permisos.Active:=False;
       SQLPermisos.Active := False;
       SQLPermisos.Active := True;
       CancelaGrabacionClick(Sender);
    End;
end;

procedure TPermisosExamen.modificaPermisoClick(Sender: TObject);
Var
  Key : Char;
begin
 NuevoPermisoClick(Sender);
 NumeroPermiso.Text := IntToStr(SQLPermisos.FieldByName('PERM_EXA').AsInteger);
 CodigoMateria.Text := SQLPermisos.FieldByName('COD_Mat').AsString;
 Mesa.Text := IntToStr(SQLPermisos.FieldByName('MESA').AsInteger);
 Modificacion := True;
 Key := #13;
 CodigoMateriaKeyPress(Sender,Key);
 MesaKeyPress(Sender,Key);
 Comision.Enabled := False;
end;

procedure TPermisosExamen.eliminaPermisoClick(Sender: TObject);
begin
 If MessageBox(PermisosExamen.Handle, Pchar(VNombreUsuario + ', esta segura/o de borrar el permiso Nş ' + IntToStr(SQLPermisos.FieldByName('PERM_EXA').AsInteger)+'.'),'Aviso',MB_OKCANCEL+MB_ICONQUESTION+MB_APPLMODAL)
     = IDOK Then
    Begin
      Permisos.Active := True;
      Permisos.FindKey([SQLPermisos.FieldByName('PERM_EXA').AsInteger]);
      Permisos.Delete;
      Permisos.Active:=False;
      SQLPermisos.Active := False;
      SQLPermisos.Active := True;
    End;
end;

end.
