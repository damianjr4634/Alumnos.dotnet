Procedure TNotasExamenes.GraboNotaBAC;
Begin
     If MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', grabas la nota de examen final?'),'Aviso',MB_OKCANCEL+MB_ICONQUESTION+MB_APPLMODAL)
     = IDOK Then
       Begin
         If Nota1.Text = '' Then
            Nota1.text := '0';
        DataModule.CustomerData.TrUpVarios.Rollback;
        DataModule.CustomerData.TrUpVarios.Active:=False;
        DataModule.CustomerData.IBUpVarios.SQL.Clear;
        DataModule.CustomerData.IBUpVarios.SQL.Text:='UPDATE "$$$PERMEXA" SET FINAL1=:FINAL1, FECHA1=:FECHA1, CONDICION=:CONDICION WHERE USUARIO=:USUARIO AND COD_ALU=:COD_ALU;';
        DataModule.CustomerData.IBUpVarios.ParamByName('USUARIO').value:=funciones.codusu;
        DataModule.CustomerData.IBUpVarios.ParamByName('COD_ALU').AsString:=DataModule.CustomerData.IBQrVarios.FieldByName('COD_ALU').AsString;
         Try
           DataModule.CustomerData.IBUpVarios.ParamByName('FINAL1').AsFloat := Nota1.value;
         Except
           DataModule.CustomerData.IBUpVarios.ParamByName('FINAL1').AsFloat := 0;
           MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', la nota esta mal escrita!'),'Aviso',MB_OK+MB_ICONERROR+MB_APPLMODAL)
         End;
         DataModule.CustomerData.IBUpVarios.ParamByName('FECHA1').AsDate := Fecha1.Date;
         If (Nota1.value >= 6) And (Nota1.value <= 10)Then
           Begin
            If DataModule.CustomerData.IBQrVarios.FieldByName('CONDICION').AsString = 'PREVIO' Then
             Begin
                MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno quedo en condicion de Regular'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := 'REGULAR'
             End;
            If DataModule.CustomerData.IBQrVarios.FieldByName('CONDICION').AsString = 'LIBRES' Then
             Begin
                MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno quedo en condicion de Libre'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := 'LIBRE'
             End;
           End
         Else
           Begin
            MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno quedo en condicion de '+DataModule.CustomerData.IBQrVarios.FieldByName('CONDIANT').AsString),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
            DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := DataModule.CustomerData.IBQrVarios.FieldByName('CONDIANT').AsString;
           End;
         DataModule.CustomerData.TrUpVarios.Active:=True;
         DataModule.CustomerData.IBUPVarios.ExecQuery;
         Datamodule.CustomerData.TRUpVarios.Commit;
         DataModule.CustomerData.TrUpVarios.Active:=False;

         Datamodule.CustomerData.TrdsVarios.Rollback;
         Datamodule.CustomerData.TrdsVarios.Active:=False;
         Datamodule.CustomerData.IBdsVarios.Active:=False;
         Datamodule.CustomerData.IBdsVarios.ParamByName('USUARIO').value:=funciones.codusu;
         Datamodule.CustomerData.TrdsVarios.Active:=True;
         Datamodule.CustomerData.IBdsVarios.Active:=True;
       End;
End;

Procedure TNotasExamenes.GraboNotaASC;
begin
    If MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', grabas la nota de examen final?'),'Aviso',MB_OKCANCEL+MB_ICONQUESTION+MB_APPLMODAL)
     = IDOK Then
    Begin
         If Nota1.Text = '' Then
            Nota1.text := '0';
         If Nota2.Text = '' Then
            Nota2.text := '0';
         If Nota3.Text = '' Then
            Nota3.text := '0';
        DataModule.CustomerData.TrUpVarios.Rollback;
        DataModule.CustomerData.TrUpVarios.Active:=False;
        DataModule.CustomerData.IBUpVarios.SQL.Clear;
        DataModule.CustomerData.IBUpVarios.SQL.Text:='UPDATE "$$$PERMEXA" SET FINAL1=:FINAL1, FINAL2=:FINAL2, FINAL3=:FINAL3,FECHA1=:FECHA1, FECHA2=:FECHA2, FECHA3=:FECHA3, CONDICION=:CONDICION WHERE USUARIO=:USUARIO AND COD_ALU=:COD_ALU;';
        DataModule.CustomerData.IBUpVarios.ParamByName('FINAL1').AsFloat := Nota1.value;
        DataModule.CustomerData.IBUpVarios.ParamByName('FINAL2').AsFloat := Nota2.value;
        DataModule.CustomerData.IBUpVarios.ParamByName('FINAL3').AsFloat := Nota3.value;
        DataModule.CustomerData.IBUpVarios.ParamByName('USUARIO').value:=funciones.codusu;
        DataModule.CustomerData.IBUpVarios.ParamByName('COD_ALU').AsString:=DataModule.CustomerData.IBQrVarios.FieldByName('COD_ALU').AsString;
        If Nota1.value <> 0 Then
            DataModule.CustomerData.IBUpVarios.ParamByName('FECHA1').AsDate := Fecha1.Date;
        If Nota2.value <> 0 Then
            DataModule.CustomerData.IBUpVarios.ParamByName('FECHA2').AsDate := Fecha2.Date;
        If Nota3.value <> 0 Then
                DataModule.CustomerData.IBUpVarios.ParamByName('FECHA3').AsDate := Fecha3.Date;
        If (Nota1.value > 0 ) And (nota1.value < 4) Then
           If (Nota2.value > 0 ) And (nota2.value < 4) Then
             If (Nota3.value > 0 ) And (nota3.value < 4) Then
                Begin
                  MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno ha superado el limete de 3 intentos fallidos. Cambia su condicion a RECURSA'),Pchar(VNombreUsuario + ', Decile que se dedique a otra cosa!!!!!!'),MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                  DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := 'RECURSA';
                End;
         If ((Nota1.value >= 4 ) And (nota1.value <= 10)) Then
            Begin
              MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno quedo en condicion de Final'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
              DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := 'FINAL';
            End
         Else
            If ((Nota2.value >= 4 ) And (nota2.value <= 10)) Then
               Begin
                 MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno quedo en condicion de Final'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                 DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := 'FINAL';
               End
            Else
              If ((Nota3.value >= 4 ) And (nota3.value <= 10)) Then
                Begin
                  MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', el alumno quedo en condicion de Final'),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                  DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := 'FINAL';
                End
              Else
                Begin
                  MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + PCHAR(', el alumno quedo en condicion de '+DataModule.CustomerData.IBQrVarios.FieldByName('CONDIANT').AsString)),'Aviso',MB_OK+MB_ICONINFORMATION+MB_APPLMODAL);
                  DataModule.CustomerData.IBUpVarios.ParamByName('CONDICION').AsString := DataModule.CustomerData.IBQrVarios.FieldByName('CONDIANT').AsString;
                End;
       DataModule.CustomerData.TrUpVarios.Active:=True;
       DataModule.CustomerData.IBUPVarios.ExecQuery;
       Datamodule.CustomerData.TRUpVarios.Commit;
       DataModule.CustomerData.TrUpVarios.Active:=False;

       Datamodule.CustomerData.TrdsVarios.Rollback;
       Datamodule.CustomerData.TrdsVarios.Active:=False;
       Datamodule.CustomerData.IBdsVarios.Active:=False;
       Datamodule.CustomerData.IBdsVarios.ParamByName('USUARIO').value:=funciones.codusu;
       Datamodule.CustomerData.TrdsVarios.Active:=True;
       Datamodule.CustomerData.IBdsVarios.Active:=True;
    End;
End;

