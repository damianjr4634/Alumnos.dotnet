         Nota3.Visible  := False;
         Fecha2.Visible := False;
         Fecha1.Enabled := False;
         Fecha3.Visible := False;
         TxtLibroActa2.Visible := False;
         TxtLibroActa3.Visible := False;
         label6.visible:=False;
         label7.visible:=False;
