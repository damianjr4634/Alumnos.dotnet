    Key := #0;
if TcurrencyEdit(Sender).Name='nota1' then begin
 If (Key = #13) and (TcurrencyEdit(Sender).Value>0) Then Begin
     Fecha1.Enabled := True;
     Fecha1.Date := Date();
     Fecha1.SetFocus;
     GrabaNotaFinal.Enabled := True;
 End
 else If (Key = #13) and (TcurrencyEdit(Sender).Value=0) Then begin
