procedure TNotasExamenes.FormCreate(Sender: TObject);
begin
With Datamodule.CustomerData Do
       Begin
         IBDlVarios.Sql.Clear;
         IBDlVarios.Sql.Text := 'DELETE FROM "$$$PERMEXA" WHERE USUARIO = :USUARIO;';
         IBDlVarios.ParamByName('USUARIO').Value := funciones.codusu;
         TRDlVarios.Active := True;
         IBDlVarios.ExecQuery;
         TRDlVarios.Commit;
         TRDlVarios.Active := False;

         TRQrVarios.Active:=False;
         IBQRVarios.SQL.Clear;
         IBQrVarios.SQL.Text:=' INSERT INTO "$$$PERMEXA" (PERM_EXA,FINAL1,FECHA1,FINAL2,FECHA2,FINAL3,FECHA3,MATRIZ, '+
                              '                            COD_ALU, MESA, CARRE, USUARIO, APELLIDO, NOM_APE, CONDICION, COD_MAT,CUA_ANIO,CUTUCO,CONDIANT, NUMFIN, FACTFIN1, FACTFIN2, FACTFIN3) '+
                              ' SELECT P.PERM_EXA, C.FINAL1, C.FECHA1, C.FINAL2, C.FECHA2, C.FINAL3, C.FECHA3, A.MATRIZ, '+
                              '        P.COD_ALU, P.MESA, P.CARRE,:USUARIO,A.APELLIDO, A.NOM_APE,C.CONDICION, P.COD_MAT, C.CUA_ANIO,C.CUTUCO,C.CONDICION, '+
                              '        CASE WHEN COALESCE(C.FINAL1,0)=0 THEN 1 '+
                              '             WHEN COALESCE(C.FINAL1,0)<>0 AND COALESCE(C.FINAL2,0)=0 THEN 2 '+
                              '             WHEN COALESCE(C.FINAL1,0)<>0 AND COALESCE(C.FINAL2,0)<>0 AND COALESCE(C.FINAL3,0)=0 THEN 3 '+
                              '             WHEN COALESCE(C.FINAL1,0)<>0 AND COALESCE(C.FINAL2,0)<>0 AND COALESCE(C.FINAL3,0)<>0 THEN 4 END, '+
                              '        C.FACTFIN1, C.FACTFIN2, C.FACTFIN3 '+
                              ' FROM PERMEXA P '+
                              ' INNER JOIN CURSADA C ON C.COD_ALU = P.COD_ALU AND C.COD_MAT = P.COD_MAT AND P.CARRE=C.CARRE '+
                              ' LEFT OUTER JOIN ALUMNOS A ON A.COD_ALU = P.COD_ALU AND P.CARRE=A.CARRE '+
                              ' WHERE P.CARRE=:CARRE AND P.COD_ALU=:CODALU '+
                              ' ORDER BY A.APELLIDO, A.NOM_APE';
          IBQrVarios.ParamByName('CARRE').AsString:=VCarrera;
          IBQrVarios.ParamByName('CODALU').AsString:=VCODALU;
          IBQrVarios.ParamByName('USUARIO').value:=funciones.codusu;
          TRQrVarios.Active:=True;
          IBQrVarios.ExecQuery;
          TRQrVarios.Commit;
          TRQrVarios.Active:=False;

          if TrDsVarios.Active Then
               TRdsVarios.Rollback;
              
          TRdsVarios.Active:=False;
          IBdsVarios.SQLs.SelectSQL.Clear;
          IBdsVarios.SQLs.SelectSQL.Text:='SELECT P.PERM_EXA,P.CUTUCO,P.CUA_ANIO,P.FINAL1,P.FECHA1,P.FINAL2,P.FECHA2,P.FINAL3,P.FECHA3,P.MATRIZ, '+
                               '       P.COD_ALU, P.MESA, P.CARRE, P.USUARIO, P.APELLIDO, P.NOM_APE, P.CONDICION,P.CONDIANT, P.NUMFIN, M.SIGLA, P.COD_MAT, P.FACTFIN1, P.FACTFIN2, P.FACTFIN3 '+
                               'FROM "$$$PERMEXA" P '+
                               'LEFT OUTER JOIN MATERIAS M ON M.CODMATERI=P.COD_MAT AND P.CARRE=M.CODCARRE '+
                               'WHERE P.USUARIO=:USUARIO';
          IBdsVarios.ParamByName('USUARIO').value:=codusu;
          TRdsVarios.Active:=True;
          IBdsVarios.Active:=True;
          if (IbDsVarios.RecordCount=0) then
             CargaNota.Enabled:=False;
       End
end;

procedure TNotasExamenes.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
  if (Datamodule.customerdata.IbDsVarios.RecordCount=0) then
      Exit;
  If MessageBox(NotasExamenes.Handle, Pchar(VNombreUsuario + ', pasa todas notas introducidas a los archivos correspondiantes?'),'Aviso', MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)
     = IDYES Then
  Begin
   WITH DataModule.CustomerData do
    begin
      TRQrVarios.Active:=False;
      IBQrVarios.SQL.Clear;
      IBQrVarios.SQL.Text:='SELECT FERRCOD, FERRMSG FROM XXX_CARGA_FINAL(:USUARIO,:CODALU) ';
      IBQrVarios.ParamByName('USUARIO').value:=codusu;
      IBQrVarios.ParamByName('CODALU').AsString:=VCodalu;
      TRQrVarios.Active:=True;
      IBQrVarios.ExecQuery;
      IF IBQrVarios.FieldByName('FERRCOD').AsInteger=1 Then
        Begin
          If MessageBox(NotasExamenes.Handle, Pchar(IBQrVarios.FieldByName('FERRMSG').AsString),'Aviso', MB_YESNO+MB_ICONQUESTION+MB_APPLMODAL)
                = IDYES Then
            TRQrVarios.Commit
          else
            TRQrVarios.Rollback;
        End;
      IF IBQrVarios.FieldByName('FERRCOD').AsInteger=2 Then
        Begin
         MessageBox(NotasExamenes.Handle, Pchar(IBQrVarios.FieldByName('FERRMSG').AsString),'Aviso', MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
         TRQrVarios.Rollback;
        End;
      IF IBQrVarios.FieldByName('FERRCOD').AsInteger=0 Then
        Begin
         TRQrVarios.Commit;
        End;
      TRQrVarios.Active:=False;
      IBQrVarios.SQL.Clear;
    end
  End;
end;

procedure TNotasExamenes.GrabaNotaFinalClick(Sender: TObject);
begin
 If (VCarrera = 'ASC') Or (VCarrera = 'RRP') Or (VCarrera = 'RRH') Or (VCarrera = 'ADM') Or (VCarrera = 'TAE') Or (VCarrera = 'TRH')  or (VCarrera = 'DAE') or (VCarrera = 'DRH') or (VCarrera = 'DAS') Then
   GraboNotaASC;
 If (VCarrera = 'BAC') Or (Vcarrera = 'CNA') Or (Vcarrera = '333') Then
   GraboNotaBAC;
 CancelaGrabacionClick(Sender);
end;

end.
