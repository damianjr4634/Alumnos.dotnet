    firma.Checked:=False;
    firma.enabled:=False;
  end;
  ConMail.Enabled := False;
  SinMail.Enabled := False;
  LbPara.Enabled := False;
  LbCC.Enabled := False;
  LbCCO.Enabled := False;
  if groupbox4.Enabled then
     Comision.Setfocus;
  TxtCuat.Text := Cuatrimestre(vcarrera);
  //Label2.Caption := 'Cuatrimestre actual ' + Cuatrimestre();
  SetButtons;
end;

