Function TFrmenviomail.Pos1(Str1, Str2 :String):Integer;
var x,i:integer;
    sw:boolean;
    str3:string;
begin
   Sw:=False;
   Pos1:=0;
   str3:='';
   For i:=1 to Length(str1)-Length(str2) do
    begin
     for x:=0 to Length(str2)-1 do
        str3:=str3+str1[i+x];
     if (str3=str2) then
       begin
         Pos1:=i;
         Break;
       end
     else
         str3:='';
    end;
end;

