procedure TFRMEquivalencias.GrabaMateriaClick(Sender: TObject);
begin
  with CustomerData Do
   Begin
       TrUpVarios.Active:=False;
       IbUpVarios.SQL.Clear;
       if pormateria.Checked then begin
            IbUpVarios.SQL.Text:='INSERT INTO ANALITIC (COD_ALU, APELLIDO, COD_MAT, CUA_ANIO, NOTA_MAT, FEC_FINAL, MATRIZ, CONDICION, INSTITUT, '+
                                 'CARAC, ACTINT, ACTDGE, ACTSNE, CARRE, COLEGIO, "PLAN", A_C, NREG, USUARIO) '+
                                 'VALUES (:CODALU, :APELLIDO, :CODMAT, :CUAANIO, :NOTAMAT, :FECFINAL, :MATRIZ, :CONDICION, :INSTITUT, '+
                                 ':CARAC, :ACTINT, :ACTDGE, :ACTSNE, :CARRE, :COLEGIO, :PLAN1, :A_C, :NREG, :USUARIO);';
       end else if porcuatriano.Checked then begin
            IbUpVarios.SQL.Text:='INSERT INTO ANALITIC (COD_ALU, APELLIDO, COD_MAT, CUA_ANIO, NOTA_MAT, FEC_FINAL, MATRIZ, CONDICION, INSTITUT, '+
                                 'CARAC, ACTINT, ACTDGE, ACTSNE, CARRE, COLEGIO, "PLAN", A_C, NREG, USUARIO) '+
                                 'SELECT :CODALU, :APELLIDO,M.CODMATERI, :CUAANIO, :NOTAMAT, :FECFINAL, :MATRIZ, :CONDICION, :INSTITUT, '+
                                 ':CARAC, :ACTINT, :ACTDGE, :ACTSNE, :CARRE, :COLEGIO, :PLAN1, :A_C, :NREG, :USUARIO '+
                                 'FROM MATERIAS M '+
                                 'WHERE M.CODCARRE=:MCARRE AND M.CUATRIM=:CUATRI';
       end
   end;
  If Pagecontrol.ActivePageIndex = 0 Then //equivalencia
   Begin
     If VLibroMatriz = '' Then
       Begin
         IngresoLibroMatriz := True;
       End;
       With CustomerData Do
         Begin
           if porcuatriano.Checked then begin
              IbUpVarios.ParamByName('MCARRE').Value:=VCarrera;
              IbUpVarios.ParamByName('CUATRI').Value:=CmbCuatAno.Text;
           end else
              IbUpVarios.ParamByName('CODMAT').Value:=combomaterias.text;

           IbUpVarios.ParamByName('CODALU').Value:=VcodAlu;
           IbUpVarios.ParamByName('APELLIDO').Value:=VApellido;
           IbUpVarios.ParamByName('MATRIZ').Value:=VlibroMatriz;
           IbUpVarios.ParamByName('CONDICION').Value:='EQUIVALENCIA';
           IbUpVarios.ParamByName('INSTITUT').Value:=InstitutoEquivalencia.Text;
           IbUpVarios.ParamByName('CARAC').Value:=CaracteristicaEquivalencia.Text;
           If Interna.Checked Then
                IbUpVarios.ParamByName('ACTINT').Value := Copy(Actuacion.Text,1,Length(Actuacion.Text)-3) + Copy(Actuacion.Text,Length(Actuacion.Text)-1,2);
           If Dgegp.Checked Then
                IbUpVarios.ParamByName('ACTDGE').Value:= Copy(Actuacion.Text,1,Length(Actuacion.Text)-3) + Copy(Actuacion.Text,Length(Actuacion.Text)-1,2);
           IbUpVarios.ParamByName('CARRE').Value:=VCarrera;
           IbUpVarios.ParamByName('COLEGIO').Value:=Colegio.Text;
           IbUpVarios.ParamByName('PLAN1').Value:=CmbPlanes.Text;
           if Constanciacheck.Checked Then
                 IbUpVarios.ParamByName('A_C').Value:='C';
           if analiticocheck.Checked Then
                 IbUpVarios.ParamByName('A_C').Value:='A';
           IbUpVarios.ParamByName('USUARIO').Value:=Funciones.CodUsu;
           TrUpVarios.Active:=True;
           IBUPVarios.ExecQuery;
           TrUpVarios.Commit;
           TrUpVarios.Active:=False;
           CancelaGrabacionClick(Sender);
           IF (numeronuevo) and not (dgegp.Checked) then begin
              if (TrqrVarios.Active) then
                  TrqrVarios.Rollback;
              TrqrVarios.Active:=False;
              ibqrVarios.SQL.Clear;
              IbqrVarios.SQL.Text:='EXECUTE PROCEDURE XXX_GRABA_NUMEQUI('+Copy(Actuacion.Text,1,Length(Actuacion.Text)-3)+','+#39+vCARRERA+#39+')';
              TrqrVarios.Active:=True;
              IBqrVarios.ExecQuery;
              TrqrVarios.Commit;
              TrqrVarios.Active:=False;
           end;
       End;
   End;
  If Pagecontrol.ActivePageIndex = 1 Then //pase/regular
   Begin
    With CustomerData Do
      Begin
         if (Vcarrera='BAC') or (Vcarrera='333') or (Vcarrera='CNA') then
           Begin
             IbUpVarios.ParamByName('CODALU').Value:=VcodAlu;
             IbUpVarios.ParamByName('APELLIDO').Value:=VApellido;
             IbUpVarios.ParamByName('CODMAT').Value:=combomaterias.text;
             IbUpVarios.ParamByName('NOTAMAT').Value:=NotaPaseRegular.Text;
             IbUpVarios.ParamByName('MATRIZ').Value:=VlibroMatriz;
             IbUpVarios.ParamByName('CONDICION').Value:='REGULAR';
             IbUpVarios.ParamByName('FECFINAL').Value:=PRFecha.Date;
             IbUpVarios.ParamByName('INSTITUT').Value:=PRInstituto.Text;
             IbUpVarios.ParamByName('CARAC').Value:=PRCaracteristica.Text;
             ibUpvarios.ParamByName('CUAANIO').AsString  := Copy(CuatrimestreAnio.Text,1,1) + Copy(CuatrimestreAnio.Text,3,2);
             IbUpVarios.ParamByName('CARRE').Value:=VCarrera;
             if PrConstancia.Checked Then
                   IbUpVarios.ParamByName('A_C').Value:='C';
             if PrAnalitico.Checked Then
                   IbUpVarios.ParamByName('A_C').Value:='A';
             IbUpVarios.ParamByName('USUARIO').Value:=VnombreUsuario;
             TrUpVarios.Active:=True;
             IBUPVarios.ExecQuery;
             TrUpVarios.Commit;
             TrUpVarios.Active:=False;
             CancelaGrabacionClick(Sender);
          end
        Else
          begin
               with CustomerData Do
                Begin
                  TrUpVarios.Rollback;
                  TrUpVarios.Active:=False;
                  IbUpVarios.SQL.Clear;
                  IbUpVarios.SQL.Text:='INSERT INTO CURSADA(COD_ALU,APELLIDO,CARRE,CUTUCO,'+
                                       ' CUA_ANIO,MATRIZ,INSTITUT,CARAC,CONDICION,COD_MAT,NREG, TP_EVA,FECHA1,USUARIO) ' +
                                       'VALUES(:COD_ALU,:APELLIDO,:CARRE,:CUTUCO, '+
                                       ' :CUA_ANIO,:MATRIZ,:INSTITUT,:CARAC,:CONDICION,:COD_MAT,0,:TPEVA,:FECHA1,:USUARIO)';
                  IbUpVarios.ParamByName('COD_ALU').Value:=VcodAlu;
                  IbUpVarios.ParamByName('APELLIDO').Value:=VApellido;
                  IbUpVarios.ParamByName('COD_MAT').Value:=combomaterias.text;
                  IbUpVarios.ParamByName('TPEVA').Value:=NotaPaseRegular.Text;
                  IbUpVarios.ParamByName('MATRIZ').Value:=VlibroMatriz;
                  IbUpVarios.ParamByName('CONDICION').Value:='REGULAR';
                  IbUpVarios.ParamByName('INSTITUT').Value:=PRInstituto.Text;
                  IbUpVarios.ParamByName('CARAC').Value:=PRCaracteristica.Text;
                  IbUpVarios.ParamByName('CUTUCO').Value:=((ComBoCuatrimestre.ItemIndex + 1)*100) + (StrToInt(Turno.Text)*10) + StrToInt(Comision.Text);
                  ibUpvarios.ParamByName('CUA_ANIO').AsString  := Copy(CuatrimestreAnio.Text,1,1) + Copy(CuatrimestreAnio.Text,3,2);
                  IbUpVarios.ParamByName('CARRE').Value:=VCarrera;
                  IbUpVarios.ParamByName('FECHA1').Value:=PRFecha.Date;
                  IbUpVarios.ParamByName('USUARIO').Value:=VnombreUsuario;
                  TrUpVarios.Active:=True;
                  IBUPVarios.ExecQuery;
                  TrUpVarios.Commit;
                  TrUpVarios.Active:=False;
                  CancelaGrabacionClick(Sender);
                end;
          end
      END
   End;
  If Pagecontrol.ActivePageIndex = 2 Then //Pase/final
   Begin
     If VLibroMatriz = '' Then
         IngresoLibroMatriz := True;
     With CustomerData do
       begin
         IbUpVarios.ParamByName('CODALU').Value:=VcodAlu;
         IbUpVarios.ParamByName('APELLIDO').Value:=VApellido;
         IbUpVarios.ParamByName('CODMAT').Value:=combomaterias.text;
         IbUpVarios.ParamByName('NOTAMAT').Value:=Nota.Text;
         IbUpVarios.ParamByName('MATRIZ').Value:=VlibroMatriz;
         IbUpVarios.ParamByName('CONDICION').Value:='PASE/FINAL';
         IbUpVarios.ParamByName('INSTITUT').Value:=InstitutoPase.Text;
         IbUpVarios.ParamByName('CARAC').Value:=CaracteristicaPase.Text;
         IbUpVarios.ParamByName('CARRE').Value:=VCarrera;
         IbUpVarios.ParamByName('FECFINAL').AsDateTime := FechaNota.Date;
         IbUpVarios.ParamByName('USUARIO').Value:=VnombreUsuario;
         TrUpVarios.Active:=True;
         IBUPVarios.ExecQuery;
         TrUpVarios.Commit;
         CancelaGrabacionClick(Sender);
      end
   End;
  TrCursada.Rollback;
  IbCursada.Active:=False;
  TrCursada.Active:=False;
  IbCursada.Active:=True;
  TrCursada.Active:=True;
end;

