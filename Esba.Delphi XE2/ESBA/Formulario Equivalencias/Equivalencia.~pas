procedure TFRMEquivalencias.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
   TrCursada.Rollback;
   TrCursada.Active:=False;
   IBCursada.Active:=False;
end;

procedure TFRMEquivalencias.PorMateriaClick(Sender: TObject);
begin
  If Pormateria.checked then begin
      CmbCuatAno.Enabled:=False;
      comboMaterias.Enabled:=True;
      CmbCuatAno.ItemIndex:=-1;
      PaseRegular.Enabled:=True;
      PaseFinal.Enabled:=True;
  end else begin
      CmbCuatAno.Enabled:=True;
      comboMaterias.Enabled:=False;
      combomaterias.Text:='';
      Nombremat.Caption:='';
      PaseRegular.Enabled:=False;
      PaseFinal.Enabled:=False;
  end
end;

procedure TFRMEquivalencias.PorCuatriAnoClick(Sender: TObject);
begin
  If PorCuatriAno.checked then begin
      CmbCuatAno.Enabled:=True;
      comboMaterias.Enabled:=False;
      combomaterias.Text:='';
      Nombremat.Caption:='';
      PaseRegular.Enabled:=False;
      PaseFinal.Enabled:=False;
  end else begin
      CmbCuatAno.Enabled:=False;
      comboMaterias.Enabled:=True;
      CmbCuatAno.ItemIndex:=-1;
      PaseRegular.Enabled:=True;
      PaseFinal.Enabled:=True;
  end
end;

end.
