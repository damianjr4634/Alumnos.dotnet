procedure TFRMEquivalencias.ComboMateriasButtonClick(Sender: TObject);
Var Text1,Text2:String;
begin
  Funciones.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='#39+VCARRERA+#39+' AND ESTADO<>'+#39+'B'+#39+' ORDER BY CODMATERI',['Codigo','Nombre'],Text1,Text2,0,1,True);
  ComboMaterias.Text:=Text1;
  NombreMat.Caption:=Text2;
end;

procedure TFRMEquivalencias.ComboMateriasExit(Sender: TObject);
Var Text1,Text2:String;
begin
  Text1:='';
  if (ComboMaterias.Text<>'') Then Begin
      ComBoMaterias.Text:=Lpad(ComboMaterias.Text,2,'0');
      Funciones.combobusqueda('SELECT CODMATERI, DESCRIPCI FROM MATERIAS WHERE CODCARRE='#39+VCARRERA+#39+' AND CODMATERI='#39+ComBoMaterias.Text+#39+' AND ESTADO<>'+#39+'B'+#39+' ORDER BY CODMATERI',['Codigo','Nombre'],Text1,Text2,0,1,false);
      If (Text1='') then begin
         MessageBox(FRMEquivalencias.Handle, Pchar(VNombreUsuario + ', código incorrecto'),'Aviso',MB_OK+MB_ICONQUESTION+MB_APPLMODAL);
         ComboMaterias.SetFocus;
      end
      else begin
          ComboMaterias.Text:=Text1;
          NombreMat.Caption:=Text2;
          If not ValidoMateria(FRMEquivalencias) Then
             ComboMaterias.SetFocus;
      end
  end
  else
     NombreMat.Caption:='';
end;

