Function VerificoActuacion(NumActuacion:String):Boolean;
Var
  Prueba : Integer;
Begin
  VerificoActuacion := True;
  If Length(NumActuacion) <> 8 Then
    VerificoActuacion := False;
  Try
    Prueba := StrToInt(Copy(NumActuacion,Length(NumActuacion)-1,2));
    Prueba := StrToInt(Copy(NumActuacion,1,Length(NumActuacion)-3));
  Except
    VerificoActuacion := False;
  End;
End;

Function ValidoMateria(Formulario:TFRMEquivalencias):Boolean;
Var
  Cont : Integer;
  NombreMateria : String;
  CodMatVerificar : String[2];
  PuedeCursar,VerificoMateria : Boolean;
begin
{
    PASAR ZLIB
  ValidoMateria:=True;
  With DataModule.CustomerData do
    Begin
              If TrQrVarios.Active Then
                 TRQrVarios.Rollback;
              TrQrVarios.Active:=False;
              IbQrVarios.SQL.Clear;
              IBQrVarios.SQL.Text:='SELECT FERRCOD, FERRMSG FROM XXX_INSC_VALMAT(:CODALU,:CARRE,:CODMAT,''A'');';
              IBQrVarios.ParamByName('CODALU').AsString:=VCODALU;
              IBQrVarios.ParamByName('CARRE').AsString:=VCarrera;
              IBQrVarios.ParamByName('CODMAT').AsString:=Formulario.combomaterias.Text;
              TrQrVarios.Active:=True;
              IBQrVarios.ExecQuery;
              If (IBQrVarios.FieldByName('FERRCOD').AsInteger=2) Then
                Begin
                 MessageDlg(PChar(VNombreUsuario + ', '+IBQrVarios.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
                 ValidoMateria:=False;
                End;
              TRQrVarios.Rollback;
    end
    }
end;

procedure TFRMEquivalencias.FormActivate(Sender: TObject);
begin
  LblPlanes.Caption:='';
  IngresoLibroMatriz := False;
  FRMEquivalencias.Height := 356;
  MateriasCodigoAlumno.Text    := VCODALU;
  MateriasCarreraCursa.Text    := VCarrera;
  MateriasApellidoyNombre.Text := VApellido + ', ' + VNombre;
  MateriasLibroMatriz.Text     := Copy(VlibroMatriz,1,2) + '/' + copy(VlibroMatriz,3,3);
  ibcursada.SQLs.SelectSQL.Text:='SELECT C.MATRIZ, C.CUTUCO,  C.COD_MAT, M.SIGLA, C.CONDICION, C.CUA_ANIO '+
                                 'FROM CURSADA C '+
                                 'LEFT OUTER JOIN MATERIAS M ON C.COD_MAT=M.CODMATERI AND  C.CARRE=M.CODCARRE '+
                                 'WHERE C.COD_ALU='+#39+VCODALU+#39+' AND C.CARRE='+#39+Vcarrera+#39;
  IbCursada.Active:=True;
  TrCursada.Active:=True;
  If VCarrera = 'BAC' Then
    ComboCuatrimestre.Items.Delete(5);
end;


procedure TFRMEquivalencias.turnoKeyPress(Sender: TObject;
  var Key: Char);
begin
 If Not (charinset(key,['0'..'9',Chr(8), Chr(7), Chr(13), chr(9)])) Then
   Key := #0;
 If (Key = #13) And (Turno.Text <> '') Then
   Comision.SetFocus;
end;

