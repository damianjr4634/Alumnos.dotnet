procedure TFRMEquivalencias.CursadaNuevaClick(Sender: TObject);
begin
 {
    PASAR ZLIB
 Nombremat.Caption:='';
 ComboMaterias.Text:='';

 FRMEquivalencias.Height := 634;
 CursadaNueva.Enabled := False;
 MateriasCursando.Enabled := False;
 Salir.Enabled := False;
 combomaterias.SetFocus;
 PorMateria.Checked:=True;
 PorMateriaClick(nil);

 With CustomerData do
    Begin
      if (TrDSVarios.Active) then
          TrDSVarios.Rollback;
      TrDSVarios.Active:=False;
      IbDSVarios.SQLs.SelectSQL.Clear;
      IbDSVarios.SQLs.SelectSQL.Text:='SELECT NUM_ENTERO, NUM_FORMA, FERRMSG, FNUMNUE FROM XXX_NUMERO_EQUIVALENCIA('+#39+VCODALU+#39+','+#39+Vcarrera+#39+')';
      trdsvarios.StartTransaction;
      TrDSVarios.Active:=True;
      IBDSVarios.Active:=True;
      if (IbDSVarios.FieldByName('FERRMSG').AsString<>'') then
         MessageDlg(Pchar(IbDSVarios.FieldByName('FERRMSG').AsString),mtInformation,[mbok],0,mbok);
      NumeroNuevo:=False;
      if (IbDSVarios.FieldByName('FNUMNUE').AsString='S') then
         numeronuevo:=True;
      Label16.Caption :=  'Ult. n𤦤. de Act. Int.:'+ IbDSVarios.FieldByName('NUM_FORMA').Value;
      InternaClick(self);
      TrDSVarios.Commit;
      TrDSVarios.Active:=False;
      ibdsvarios.Close;
    End;
 If (Carreras.CarreIndexOf(VCarrera).tipo='TER') Then
   begin
     dgegp.Enabled := False;
     interna.Checked := True;
     colegio.enabled := false;
     cmbplanes.enabled := True;
     documentacion.Enabled := True;
     Actuacion.Enabled:=True;
     NotaPaseRegular.Enabled:=False;
     PrFecha.Enabled:=False;
     groupbox4.Enabled:=False;
   end;
 If (Carreras.CarreIndexOf(VCarrera).tipo='BAC') or (Carreras.CarreIndexOf(VCarrera).tipo='BAD') Then
   Begin
     pasefinal.Enabled := False;
     Paseregular.Enabled := True;
     ComboCuatrimestre.enabled:=False;
     Turno.Enabled:=False;
     Comision.Enabled:=False;
   End;
   }
end;

