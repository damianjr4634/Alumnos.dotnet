procedure TregularizacionMaterias_nuevo.NotaTercertriKeyPress(Sender: TObject;
  var Key: Char);
Var
  Prom :Real;
begin
  Valid(Key,NotaTercerTri.Text);
  If Key = #13 Then
   Begin
     If NotaTercerTri.Text = '' Then
        NotaTercerTri.Text :='0';
     If ((NotaPrimerTri.Text = '99') and (NotaSegundoTri.Text = '99') and (NotaTercerTri.Text = '99')) then
        Prom := 0;
     If ((NotaPrimerTri.Text = '99') and (NotaSegundoTri.Text<>'99') and (NotaSegundoTri.Text<>'0') and (NotaTercerTri.Text<>'99') and (NotaTercerTri.Text<>'0')) then
        Prom := (StrtoFloat(NotaSegundoTri.Text)+StrtoFloat(NotaTercerTri.Text))/2;
     If ((NotaPrimerTri.Text<>'99') and (NotaPrimerTri.Text<>'0') and (NotaSegundoTri.Text='99') and (NotaTercerTri.Text<>'99') and (NotaTercerTri.Text<>'0')) then
        Prom := (StrtoFloat(NotaTercerTri.Text)+StrtoFloat(NotaPrimerTri.Text))/2;
     If ((NotaPrimerTri.Text<>'99') and (NotaPrimerTri.Text<>'0') and (NotaSegundoTri.Text<>'99') and (NotaSegundoTri.Text<>'0') and (NotaTercerTri.Text<>'99') and (NotaTercerTri.Text<>'0')) then
        Prom := (StrtoFloat(NotaSegundoTri.Text)+StrtoFloat(NotaPrimerTri.Text))/2;
     If ((NotaPrimerTri.Text='99') and (NotaSegundoTri.Text<>'99') and (NotaSegundoTri.Text<>'0') and (NotaTercerTri.Text='99')) then
        Prom := StrToFloat(NotaSegundoTri.Text);
     If ((NotaPrimerTri.Text='99') and (NotaTercerTri.Text<>'99') and (NotaTercerTri.Text<>'0') and (NotaSegundoTri.Text='99')) then
        Prom := StrToFloat(NotaTercerTri.Text);
     If ((NotaPrimerTri.Text<>'99') and (NotaPrimerTri.Text<>'0') and (NotaSegundoTri.Text='99') and (NotaTercerTri.Text='99')) then
        Prom := StrToFloat(NotaPrimerTri.Text);
     If ((NotaPrimerTri.Text <> '99') and (NotaPrimerTri.Text <> '0') and (NotaSegundoTri.Text <> '99') and (NotaSegundoTri.Text <> '0') and (NotaTercerTri.Text <> '99') and (NotaTercerTri.Text <> '0')) then
        Prom := (StrtoFloat(NotaPrimerTri.Text)+StrtoFloat(NotaSegundoTri.Text)+StrtoFloat(NotaTercerTri.Text))/3;
     If Prom = 0 Then Begin
//       NotaDic.Enabled := False;
//       NotaMar.Enabled := True;
       NotaMar.SetFocus;
     End
     Else Begin
          If ((Prom >= 4) and (Prom < 6)) Then Begin
//            NotaDic.Enabled := True;
//            NotaMar.Enabled := False;
            NotaDic.SetFocus;
          End;
          If (Prom < 4) Then Begin
//            NotaMar.Enabled := True;
//            NotaDic.Enabled := False;
            NotaMar.SetFocus;
          End;
          If (Prom >= 6) Then Begin
              If ((NotaPrimerTri.Text = '99') or (NotaSegundoTri.Text = '99') or (NotaTercerTri.Text = '99')) then Begin
//                  NotaMar.Enabled := True;
//                  NotaDic.Enabled := False;
                  NotaMar.SetFocus;
              End
              Else
                Graba333Click(Sender);
          End;
      End;
      Promedio.Text := FloatTostr(RoundTo(Prom,-2));
   End;
end;

