procedure TregularizacionMaterias_nuevo.Graba333Click(Sender: TObject);
Var
  Nota1, Nota2, Nota3, Dic, Mar, Prom: Real;
begin
  If (NotaPrimerTri.Text = '') Then
       NotaPrimerTri.Text := '0';
  If (NotaSegundoTri.Text = '') Then
       NotaSegundoTri.Text := '0';
  If (NotaTercerTri.Text = '') Then
       NotaTercerTri.Text := '0';
  If (NotaDic.Text = '') Then
       NotaDic.Text := '0';
  If (NotaMar.Text = '') Then
       NotaMar.Text := '0';
  Prom := RoundTo(CalculaPromedio,-2);
  Promedio.Text := FloatTostr(RoundTo(Prom,-2));
  Nota1 := RoundTo(NotaPrimerTri.value,-2);
  Nota2 := RoundTo(NotaSegundoTri.value,-2);
  Nota3 := RoundTo(NotaTercerTri.value,-2);
  Dic   := RoundTo(NotaDic.value,-2);
  Mar   := RoundTo(NotaMar.value,-2);
  CustomerData.IBUpVarios.SQL.Clear;
  CustomerData.IBUpVarios.SQL.Text := 'UPDATE "$$$CURSADA" SET TP_EVA=:TP_EVA, TP_EVA2=:TP_EVA2, TP_EVA3=:TP_EVA3, CONDICION=:CONDICION, '+
                                      'FINAL1=:FINAL1, FINAL2=:FINAL2, PROM=:PROM, FEC_EVA1=:FEC_EVA1, FEC_EVA2=:FEC_EVA2, FEC_EVA3=:FEC_EVA3, '+
                                      'FAL_EVA1=:FAL_EVA1,FAL_EVA2=:FAL_EVA2,FAL_EVA3=:FAL_EVA3, NOTAMAR=:NOTAMAR, NOTADIC=:NOTADIC, FECHMAR=:FECHMAR, FECHDIC=:FECHDIC ' +
                                      'WHERE COD_ALU = :COD_ALU AND USUARIO = :USUARIO AND COD_MAT=:CODMAT; ';
  CustomerData.IBUpVarios.ParamByName('TP_EVA').Value := Nota1;
  CustomerData.IBUpVarios.ParamByName('FAL_EVA1').Value := FaltasPrimerTri.Value;
  if (FechaPrimerTri.date<>0) then
     CustomerData.IBUpVarios.ParamByName('FEC_EVA1').Value := FechaPrimerTri.Date
  else
     CustomerData.IBUpVarios.ParamByName('FEC_EVA1').Clear;

