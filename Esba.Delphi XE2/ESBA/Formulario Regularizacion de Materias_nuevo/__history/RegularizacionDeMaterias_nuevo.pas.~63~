procedure TregularizacionMaterias_nuevo.GrabaMateriaCNAClick(Sender: TObject);
Var
  Nota : Real;
  Cod_mat, Condicion : String;
begin
  Condicion := DataModule.CustomerData.IBdsVarios.FieldByName('Condicion').Value;
  Nota := NotaDefinitivaCNA.Value;
  if FechaCNA.Date=0 then
    raise Exception.Create('Debe cargar una fecha');
  If Nota >= 7 Then
    Condicion := 'REGULAR'
  else If Nota >= 1 Then
    Condicion := 'RECURSA'
  else
    Condicion := 'CURSANDO';

  MessageDlg(Pchar(VnombreUsuario+', la materia quedó en condición de: ' + condicion),mtInformation, [mbok],0,mbok);
  //** GRABACION **//
  CustomerData.IBUpVarios.SQL.Clear;
  CustomerData.IBUpVarios.SQL.Text := 'UPDATE "$$$CURSADA" SET FINAL1=:FINAL1, FECHA1=:FECHA1, CONDICION=:CONDICION '+
                                      'WHERE COD_ALU = :COD_ALU AND USUARIO = :USUARIO AND COD_MAT=:CODMAT; ';
  CustomerData.IBUpVarios.ParamByName('FINAL1').Value := Nota;
  CustomerData.IBUpVarios.ParamByName('FECHA1').Value := FechaCNA.Date;
  CustomerData.IBUpVarios.ParamByName('CONDICION').Value := Condicion;
  CustomerData.IBUpVarios.ParamByName('CODMAT').Value := CustomerData.IBdsVarios.FieldByName('COD_MAT').Value;

  CustomerData.IBUpVarios.ParamByName('COD_ALU').Value := CustomerData.IBdsVarios.FieldByName('COD_ALU').Value;
  CustomerData.IBUpVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
  CustomerData.TRUpVarios.Active := True;
  CustomerData.IBUpVarios.ExecQuery;
  CustomerData.TRUpVarios.Commit;
  CustomerData.TRUpVarios.Active := False;

  CustomerData.TRdsVarios.RollBack;
  CustomerData.TRdsVarios.Active := False;
  CustomerData.IBdsVarios.Active := False;
  CustomerData.IBdsVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
  CustomerData.TRdsVarios.Active := True;
  CustomerData.IBdsVarios.Active := True;
  CancelaGrabacionBACClick(Sender);
end;

