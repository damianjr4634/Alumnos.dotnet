procedure TregularizacionMaterias_nuevo.RecuperatorioBACKeyPress(Sender: TObject;
  var Key: Char);
Var
  Prom : Real;
begin
 Prom := 0;
 Valid(Key,RecuperatorioBAC.Text);
 If (Key =#13) Then
  Begin
    If RecuperatorioBAC.Text = '' Then
       RecuperatorioBAC.Text := '0';
    If ((StrToInt(RecuperatorioBAC.Text) >= 6) And (StrToInt(RecuperatorioBAC.Text) <= 10)) Or (StrToInt(RecuperatorioBAC.Text) = 0) Then
     Begin
      TotalHorasBAC.SetFocus ;
//      SinJustificarBAC.Enabled :=True;
      //*** NUEVA NOTA DEFINITIVA ***//
      If StrToInt(RecuperatorioBAC.Text) <> 0 Then
       Begin
         If  Bimestre1.Text = '99' Then
            Prom := (1+StrToInt(Bimestre2.Text)) / 2;
         If  Bimestre2.Text = '99' Then
            Prom := (StrToInt(Bimestre1.Text)+1) / 2;
         If  (Bimestre1.Text <> '99') And  (Bimestre1.Text <> '99') Then
            Prom := (StrToInt(Bimestre1.Text)+StrToInt(Bimestre2.Text)) / 2;
         NotadefinitivaBAC.Text := FloatToStr((Prom + StrToInt(RecuperatorioBAC.Text)) / 2);
       End;
     End;
    If ((StrToInt(RecuperatorioBAC.Text) >= 1) And (StrToInt(RecuperatorioBAC.Text) < 6)) Or (StrToInt(RecuperatorioBAC.Text) = 99) Then
     Begin
       If (StrToInt(RecuperatorioBAC.Text) <> 99) Then
         Begin
           If  Bimestre1.Text = '99' Then
              Prom := (1+StrToInt(Bimestre2.Text)) / 2;
           If  Bimestre2.Text = '99' Then
              Prom := (StrToInt(Bimestre1.Text)+1) / 2;
           If  (Bimestre1.Text <> '99') And  (Bimestre1.Text <> '99') Then
              Prom := (StrToInt(Bimestre1.Text)+StrToInt(Bimestre2.Text)) / 2;
          NotadefinitivaBAC.Text := FloatToStr((Prom + StrToInt(RecuperatorioBAC.Text)) / 2);
         End
       Else
          NotadefinitivaBAC.Text := FloatToStr(Prom);
//       NotaRegularBAC.Enabled := True;
//       SinJustificarBAC.Enabled := True;
       NotaRegularBAC.SetFocus;
//       TotalHorasBAC.Enabled := True ;
       //** LOS QUE RINDEN COMO A/REGULAR, ESA NOTA SI ES >= 6 NO SE PROMEDIA CON NADA Y QUEDA ESA NOTA
       //** LO ANTERIOR NO EXISTE.**//
     End;
  End;
end;

