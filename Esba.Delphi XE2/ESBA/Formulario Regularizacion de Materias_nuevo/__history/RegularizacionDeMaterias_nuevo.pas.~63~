procedure TregularizacionMaterias_nuevo.Bimestre2Exit(Sender: TObject);
var nota1,nota2,prom:real;
begin
 prom:=0;
 if Bimestre1.text = '' Then
    Nota1:= 0
 Else
    Nota1:=StrToFloat(Bimestre1.text);
 If Bimestre2.Text = '' Then
    Nota2 := 0
 Else
    Nota2:=StrToFloat(Bimestre2.text);
 If (Nota1=99) or (Nota2=99) then Begin
     If Nota1 = 99 Then
         Nota1 := 1;
     If Nota2 = 99 Then
         Nota2 := 1;
 end Else
     Prom:=(Nota1 + Nota2)/2;
 Promediocuatrimestre.Text:=floattoStr(prom);
end;

procedure TregularizacionMaterias_nuevo.RecuperatorioBACExit(Sender: TObject);
var
   prom:real;
begin
   If StrToInt(RecuperatorioBAC.Text) <> 0 Then  Begin
       If  Bimestre1.Text = '99' Then
            Prom := (1+StrToInt(Bimestre2.Text)) / 2;
       If  Bimestre2.Text = '99' Then
            Prom := (StrToInt(Bimestre1.Text)+1) / 2;
       If  (Bimestre1.Text <> '99') And  (Bimestre1.Text <> '99') Then
            Prom := (StrToInt(Bimestre1.Text)+StrToInt(Bimestre2.Text)) / 2;
       NotadefinitivaBAC.Text := FloatToStr((Prom + StrToInt(RecuperatorioBAC.Text)) / 2);
   End;
   If ((StrToInt(RecuperatorioBAC.Text) >= 1) And (StrToInt(RecuperatorioBAC.Text) < 6)) Or (StrToInt(RecuperatorioBAC.Text) = 99) Then  Begin
       If (StrToInt(RecuperatorioBAC.Text) <> 99) Then  Begin
           If  Bimestre1.Text = '99' Then
              Prom := (1+StrToInt(Bimestre2.Text)) / 2;
           If  Bimestre2.Text = '99' Then
              Prom := (StrToInt(Bimestre1.Text)+1) / 2;
           If  (Bimestre1.Text <> '99') And  (Bimestre1.Text <> '99') Then
              Prom := (StrToInt(Bimestre1.Text)+StrToInt(Bimestre2.Text)) / 2;
           NotadefinitivaBAC.Text := FloatToStr((Prom + StrToInt(RecuperatorioBAC.Text)) / 2);
       End
       Else
          NotadefinitivaBAC.Text := FloatToStr(Prom);
   end;
end;

