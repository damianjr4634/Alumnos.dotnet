procedure TregularizacionMaterias_nuevo.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
  if not modificacion then
    exit;
  if MessageDlg(Pchar(VNombreUsuario + ', pasa todas notas introducidas a los archivos correspondiantes?'),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
  Begin
    CustomerData.TRUpVarios.Active := False;
    CustomerData.IBUpVarios.SQL.Clear;
    CustomerData.IBUpVarios.SQL.Text := 'SELECT FERRCOD, FERRMSG FROM XXX_REGULARIZACION(:CARRE,:USUARIO)';
    CustomerData.IBUpVarios.ParamByName('CARRE').Value := Vcarrera;
    CustomerData.IBUpVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
    CustomerData.TRUpVarios.Active := True;
    CustomerData.IBUpVarios.ExecQuery;
    If (CustomerData.IBUpVarios.FieldByName('FERRCOD').Value=0) then
         CustomerData.TRUpVarios.Commit
    Else If (CustomerData.IBUpVarios.FieldByName('FERRCOD').Value=1) then
           begin
              if MessageDlg(Pchar(VNombreUsuario + CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString),mtConfirmation,[mbyes,mbno],0,mbyes)=mryes  Then
                CustomerData.TRUpVarios.Commit
              Else
                CustomerData.TRUpVarios.Rollback;
           end
    Else If (CustomerData.IBUpVarios.FieldByName('FERRCOD').Value=2) then
           begin
              MessageDlg(Pchar(VNombreUsuario + CustomerData.IBUpVarios.FieldByName('FERRMSG').AsString),mtError,[mbok],0,mbok);
              CustomerData.TRUpVarios.Rollback;
           end;
    CustomerData.TRUpVarios.Active := False;
  End;
  CustomerData.TRDlVarios.Active := False;
  CustomerData.IBDlVarios.Sql.Clear;
  CustomerData.IBDlVarios.Sql.Text := 'DELETE FROM "$$$CURSADA" WHERE USUARIO = :USUARIO;';
  CustomerData.IBDlVarios.ParamByName('USUARIO').Value := FuncionesConfiguracion.CodUsu;
  CustomerData.TRDlVarios.Active := True;
  CustomerData.IBDlVarios.ExecQuery;
  CustomerData.TRDlVarios.Commit;
  If (CustomerData.TrdsVarios.Active) Then
     CustomerData.TRdsVarios.Rollback;
  CustomerData.TRdsVarios.Active:=False;
  CustomerData.IBdsVarios.SQLs.SelectSQL.Clear;
end;

