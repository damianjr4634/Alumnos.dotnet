  ConstanciaAlumno.ColWidths[2]:=45;
  ConstanciaAlumno.ColWidths[3]:=230;
  ConstanciaAlumno.ColWidths[4]:=130;
  ConstanciaAlumno.ColWidths[5]:=70;
  ConstanciaAlumno.ColWidths[6]:=50;
  ConstanciaAlumno.ColWidths[7]:=80;
  ConstanciaAlumno.ColWidths[8]:=85;
  ConstanciaAlumno.ColWidths[9]:=160;
  ConstanciaAlumno.ColWidths[10]:=90;
  ConstanciaAlumno.ColWidths[11]:=90;
  ConstanciaAlumno.ColWidths[12]:=90;
  ConstanciaAlumno.ColWidths[13]:=0;

  ConstanciaAlumno.Cells[1,0]:='Cuat.';
  ConstanciaAlumno.Cells[2,0]:='Cod.';
  ConstanciaAlumno.Cells[3,0]:='Materia';
  ConstanciaAlumno.Cells[4,0]:='Condición';
  ConstanciaAlumno.Cells[5,0]:='Cuat./Año';
  ConstanciaAlumno.Cells[6,0]:='Comi.';
  ConstanciaAlumno.Cells[7,0]:='Nota Final';
  ConstanciaAlumno.Cells[8,0]:='Fecha Final';
  ConstanciaAlumno.Cells[9,0]:='Instituto';
  ConstanciaAlumno.Cells[10,0]:='Caract.';
  ConstanciaAlumno.Cells[11,0]:='Act. Int.';
  ConstanciaAlumno.Cells[12,0]:='Act. DGEGP';
  ConstanciaAlumno.Cells[13,0]:='Act. SNEP';
  ConstanciaAlumno.Cells[14,0]:='Nombre Largo';


  DataModule.CustomerData.IBConstancia.ParamByName('CODALU').AsString:=CodigoAlumno;
  DataModule.CustomerData.IBConstancia.ParamByName('CARRE').AsString:=CarreraActiva;
  Constancia(ConstanciadelAlumno);
  if Datamodule.CustomerData.TrDsVarios.Active then
     Datamodule.CustomerData.TrDsVarios.Rollback;
  DataModule.CustomerData.IbDsVarios.Active:=False;
  DataModule.CustomerData.IbDsVarios.SQLs.SelectSQL.Text:='SELECT PROMGRAL FROM XXX_PROMEDIO_GRAL('+#39+CodigoAlumno+#39+','+#39+carreraActiva+#39+')';
  DataModule.CustomerData.TrQrVarios.Active:=true;
  DataModule.CustomerData.IbDsVarios.Active:=True;
  PromGral.Value:=DataModule.CustomerData.IbDsVarios.FieldByname('PROMGRAL').Value;
  Datamodule.CustomerData.TrDsVarios.Commit;
  DataModule.CustomerData.IbDsVarios.Active:=False;
  try
     ConstanciaAlumno.FixedRows := 1;
  except
     MessageDlg('Error al mostrar materias, puede que no haya materias cargadas o el alumno tenga problemas',mtError,[mbok],0,mbok);
  end;

  ConstanciaAlumno.SetFocus;
end;

