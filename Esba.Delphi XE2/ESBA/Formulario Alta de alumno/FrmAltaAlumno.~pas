procedure TAltaAlumno.documentoKeyPress(Sender: TObject; var Key: Char);
begin
  if key in ['A'..'Z','a'..'z'] then
     key:=#0;
  If (Key = Chr(13)) And (Documento.Text <> '') And (Not Modificacion) Then
    Begin
      if DataModule.CustomerData.TrQrVarios.Active then
         DataModule.CustomerData.TrQrVarios.Rollback;
      DataModule.CustomerData.IbQrVarios.SQL.Text:='SELECT COD_ALU, RTRIM(CAST(APELLIDO AS VARCHAR(30)))||'+ #39+','+#39+'||RTRIM(CAST(NOM_APE AS VARCHAR(30))) AS NOMBRE, BAJA FROM ALUMNOS WHERE COD_ALU = :CODALU AND CARRE=:CARRERA';
      DataModule.CustomerData.IbQrVarios.ParamByName('CODALU').AsString := TipoDoc.Text+Documento.Text;
      DataModule.CustomerData.IbQrVarios.ParamByName('CARRERA').AsString := Carrera;
      DataModule.CustomerData.TrQrVarios.Active:=True;
      DataModule.CustomerData.IbQrVarios.ExecQuery;
      If (DataModule.CustomerData.IbQrVarios.FieldByName('COD_ALU').AsString <> '') And (DataModule.CustomerData.IbQrVarios.FieldByName('BAJA').AsString = 'N') Then
        Begin
          MessageBox(AltaAlumno.Handle,Pchar(VUsuario+', el Alumno ya existe en altas'),'Error',MB_OK+MB_ICONERROR);
        End
      Else
        Begin
          If DataModule.CustomerData.IbQrVarios.FieldByName('BAJA').AsString = 'S' Then
             MessageBox(AltaAlumno.Handle,Pchar(VUsuario+', el Alumno'+DataModule.CustomerData.IbQrVarios.FieldByName('NOMBRE').AsString+ ' ya Existe en bajas'),'Error',MB_OK+MB_ICONERROR)
          Else
            Begin
             DatosPersonales.Enabled := True;
             EstudiosCursados.Enabled := True;
             DatosLaborales.Enabled := True;
             DocuPresentada.Enabled := True;
             Grabar.Enabled := True;
             TipoDoc.Enabled := False;
             Documento.Enabled := False;
             Apellido.SetFocus;
            End;
        End;
      if DataModule.CustomerData.TrQrVarios.Active then
          DataModule.CustomerData.TrQrVarios.Rollback;
    End;
end;

