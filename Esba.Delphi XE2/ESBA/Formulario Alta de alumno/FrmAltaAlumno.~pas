procedure TAltaAlumno.grabarClick(Sender: TObject);
Var
  i : Integer;
  NDocumento : String;
  SentenciaSql :String;
  codalu:string;
begin
 codalu:='';
 With CustomerData Do Begin
   If MessageBox(AltaAlumno.Handle,Pchar(VUsuario+', desea guardar la información?'), 'Aviso',
      MB_OKCANCEL + MB_APPLMODAL + MB_ICONQUESTION) = IDOK  Then
    Begin
     Try
       ibqrvarios.SQL.Clear;
       NDocumento := '';
       For i := 1 to (8-Length(Documento.Text)) do
             NDocumento := NDocumento + '0';
       Documento.Text := NDocumento + Documento.Text;
       If (TipoDoc.Text = 'CI') Or (TipoDoc.Text = 'LE') Then
             codalu   := TipoDoc.Text +' ' + Documento.Text
       Else
             codalu   := TipoDoc.Text + Documento.Text;
       If Not Modificacion Then
        Begin
            SentenciaSql := 'INSERT INTO ALUMNOS (COD_ALU, CARRE, APELLIDO, NOM_APE, NACIONAL, EST_CIV,'+
                            'FEC_NAC, LUG_NAC, PCIA_NAC, DOMI, LOCALI, COD_POS, CAR_TEL, TELE, FEC_ING, CPRIM, APRIM, TPRIM, '+
                            'CSECU, ASECU, TSECU, TERCI, ATERCI, TTERCI,'+
                            'EMPRE, RUBRO, CARGO, ANTI, DOMI_1, TELE_1, INTER,'+
                            'CTT, FECH_CTT, DNI, CA, USUARIO, BAJA, MAIL, SEXO, OBSERV, CELULAR, FFOTO, FAPTFIS, FAPTFEC) '+
                            'VALUES (:COD_ALU, :CARRE, :APELLIDO, :NOM_APE, :NACIONAL,:EST_CIV,'+
                            'CAST(:FEC_NAC AS DATE), :LUG_NAC, :PCIA_NAC, :DOMI, :LOCALI, :COD_POS, :CAR_TEL, :TELE, :FEC_ING, :CPRIM, '+
                            ':APRIM, :TPRIM, :CSECU, :ASECU, :TSECU, :TERCI, :ATERCI, :TTERCI, '+
                            ':EMPRE, :RUBRO, :CARGO, :ANTI, :DOMLAB,'+
                            ':TELLAB, :INTER, :CTT, :FECH_CTT, :DNI, :CA,'+
                            ':USUARIO, :BAJA, :MAIL, :SEXO, :OBSERV, :CELULAR, :FFOTO, :FAPTFIS, :FAPTFEC);';
        End
       Else Begin
          SentenciaSql := 'UPDATE ALUMNOS SET APELLIDO=  :APELLIDO,NOM_APE=   :NOM_APE,EXT_POR=   :EXT_POR,'+
                         'NACIONAL=  :NACIONAL,EST_CIV=   :EST_CIV,FEC_NAC= :FEC_NAC,LUG_NAC=   :LUG_NAC,PCIA_NAC=  :PCIA_NAC,DOMI=      :DOMI,'+
                         'LOCALI=    :LOCALI,COD_POS=   :COD_POS,CAR_TEL=   :CAR_TEL,TELE=      :TELE,FEC_ING=   :FEC_ING,CPRIM=     :CPRIM,'+
                         'APRIM=     :APRIM,TPRIM=     :TPRIM,CSECU=     :CSECU,ASECU=     :ASECU,TSECU=     :TSECU,'+
                         'TERCI=     :TERCI,ATERCI=    :ATERCI,TTERCI=    :TTERCI,'+
                         'EMPRE=     :EMPRE,RUBRO=     :RUBRO,CARGO=     :CARGO,ANTI=      :ANTI,DOMI_1=    :DOMLAB,'+
                         'TELE_1=    :TELLAB,INTER=     :INTER,'+
                         'CTT= :CTT,FECH_CTT=  :FECH_CTT, DNI=       :DNI,CA=        :CA,'+
                         'MAIL =     :MAIL, BAJA= :BAJA, SEXO= :SEXO, OBSERV= :OBSERV, USUARIO= :USUARIO, CELULAR=:CELULAR, FFOTO=:FFOTO, FAPTFIS=:FAPTFIS, FAPTFEC=:FAPTFEC '+
                         'WHERE COD_ALU = :COD_ALU AND CARRE = :CARRE;';
       End;
       ibqrvarios.Sql.Text := SentenciaSql;
       ibqrvarios.ParamByName('COD_ALU').Value := codalu;
       ibqrvarios.ParamByName('CARRE').Value := Carrera;
       ibqrvarios.ParamByName('APELLIDO').Value  := Apellido.Text;
       ibqrvarios.ParamByName('NOM_APE').Value   := Nombre.Text;
       ibqrvarios.ParamByName('NACIONAL').Value  := Nacionalidad.Text;
       ibqrvarios.ParamByName('EST_CIV').Value   := Copy(EstadoCivil.Text,1,1);
       ibqrvarios.ParamByName('FEC_NAC').Value   := FechaNacimiento.Date;
       ibqrvarios.ParamByName('LUG_NAC').Value   := LugarNacimiento.Text;
       ibqrvarios.ParamByName('PCIA_NAC').Value  := ProvinciaNacimiento.Text;
       ibqrvarios.ParamByName('DOMI').Value      := Domicilio.Text;
       ibqrvarios.ParamByName('LOCALI').Value    := Localidad.Text;
       If CodigoPostal.Text <> '' Then
          ibqrvarios.ParamByName('COD_POS').Value   := StrToInt(CodigoPostal.Text);
       ibqrvarios.ParamByName('CAR_TEL').Value   := Caracteristica.Text;
       ibqrvarios.ParamByName('TELE').Value      := Telefono.Text;
       ibqrvarios.ParamByName('FEC_ING').Value   := FechaIngreso.Date;
       ibqrvarios.ParamByName('CPRIM').Value    := ColegioPrimario.Text;
       ibqrvarios.ParamByName('APRIM').Value    := AnosPrimario.Text;
       ibqrvarios.ParamByName('TPRIM').Value     := ModalidadPrimario.Text;
       ibqrvarios.ParamByName('CSECU').Value     := ColegioSecundario.Text;
       ibqrvarios.ParamByName('ASECU').Value     := AnosSecundario.Text;
       ibqrvarios.ParamByName('TSECU').Value     := ModalidadSecundario.Text;
       ibqrvarios.ParamByName('TERCI').Value     := ColegioTerciario.Text;
       ibqrvarios.ParamByName('ATERCI').Value    := AnosTerciario.Text;
       ibqrvarios.ParamByName('TTERCI').Value    := ModalidadTerciario.Text;
       ibqrvarios.ParamByName('EMPRE').Value     := Empresa.Text;
       ibqrvarios.ParamByName('RUBRO').Value     := Rubro.Text;
       ibqrvarios.ParamByName('CARGO').Value     := Cargo.Text;
       ibqrvarios.ParamByName('ANTI').Value      := Antiguedad.Text;
       ibqrvarios.ParamByName('DOMLAB').Value    := Direccion.Text;
       ibqrvarios.ParamByName('TELLAB').Value    := TelefonoLaboral.Text;
       ibqrvarios.ParamByName('INTER').Value    := Interno.Text;
       ibqrvarios.ParamByName('MAIL').Value     := Mail.Text;
       ibqrvarios.ParamByName('USUARIO').Value  := VUsuario;
       ibqrvarios.ParamByName('OBSERV').Value  := Memo.Lines.Text;
       ibqrvarios.ParamByName('USUARIO').Value := Funciones.codusu;
       ibqrvarios.ParamByName('CELULAR').Value := Celular.text;
       If Ctt.Checked Then  Begin
           ibqrvarios.ParamByName('CTT').Value := '*';
           ibqrvarios.ParamByName('FECH_CTT').Value  := Fechactt.Date;
       End;
       if (DNI.ItemIndex<>-1) then
           ibqrvarios.ParamByName('DNI').AsString := IntToStr(DNI.ItemIndex);
       If CA.Checked Then
           ibqrvarios.ParamByName('CA').Value := '*';
       If Not Modificacion Then ibqrvarios.ParamByName('BAJA').Value := 'N';
       If CmbSexo.ItemIndex=0 Then
           ibqrvarios.ParamByName('SEXO').Value := 'F'
       else If CmbSexo.ItemIndex=1 Then
           ibqrvarios.ParamByName('SEXO').Value := 'M';
       If CbxBaja.Checked Then
           ibqrvarios.ParamByName('BAJA').Value := 'S'
       else
           ibqrvarios.ParamByName('BAJA').Value := 'N';
       if foto.Checked then
          ibqrvarios.ParamByName('FFOTO').AsString:='S'
       else
          ibqrvarios.ParamByName('FFOTO').AsString:='N';
       if AptoFisico.Checked then
          ibqrvarios.ParamByName('FAPTFIS').AsString:='S'
       else
          ibqrvarios.ParamByName('FAPTFIS').AsString:='N';
       if FechaAptoFisico.date<>0 then
          ibqrvarios.ParamByName('FAPTFEC').AsDate:= FechaAptoFisico.Date;

       Try
          TrQrVArios.Active := True;
          ibqrvarios.ExecQuery;
          TrQrVArios.Commit;
       Finally
          If TrQrVArios.Active Then TrQrVArios.Rollback;
          TrQrVArios.Active := False;
       End;
       if TrQrVArios.Active then
          TrQrVArios.RollBack;
       TrQrVArios.Active := False;
       //alta de tutores
       if frmtutores<>nil then begin
            SentenciaSql:='DELETE FROM TUTORES WHERE COD_ALU='+#39+codalu+#39+' AND CARRE='+#39+CARRERA+#39;
            ibqrvarios.Sql.Text := SentenciaSql;
            Try
               TrQrVArios.Active := True;
               ibqrvarios.ExecQuery;
               TrQrVArios.Commit;
            Finally
               If TrQrVArios.Active Then TrQrVArios.Rollback;
               TrQrVArios.Active := False;
            End;
            if TrQrVArios.Active then
            TrQrVArios.RollBack;
            SentenciaSql:= 'INSERT INTO TUTORES (COD_ALU, CARRE, FDNI, FNOMBRE, FAPELLIDO, FDIRECC, FTELEFO, FCELULAR, FEMAIL, FPARENT, FRETIRA) '+
                           ' VALUES (:COD_ALU, :CARRE, :FDNI, :FNOMBRE, :FAPELLIDO, :FDIRECC, :FTELEFO, :FCELULAR, :FEMAIL, :FPARENT, :FRETIRA); ';
            ibqrvarios.Sql.Text := SentenciaSql;
            trqrvarios.Active:=True;
            frmtutores.MtTutores.First;
            while not frmtutores.MtTutores.Eof do begin
                 for i:=0 to Frmtutores.MtTutores.FieldCount-1 do
                      ibqrvarios.ParamByName(FrmTutores.MtTutores.Fields.Fields[i].FullName).Value:=FrmTutores.MtTutores.Fields.Fields[i].Value;
                 ibqrvarios.ParamByName('COD_ALU').Value:=CODALU;
                 ibqrvarios.ParamByName('CARRE').Value:=Carrera;
                 Ibqrvarios.ExecQuery;
                 frmtutores.MtTutores.Next;
            end;
            TrqrVarios.Commit;
            TrQrVarios.Active:=False;
       end;
       //alta de actas disciplinarias
       if frmActasDisciplinarias<>nil then begin
            SentenciaSql:='DELETE FROM ACTAS_DISC WHERE COD_ALU='+#39+codalu+#39+' AND CARRE='+#39+CARRERA+#39;
            ibqrvarios.Sql.Text := SentenciaSql;
            Try
               TrQrVArios.Active := True;
               ibqrvarios.ExecQuery;
               TrQrVArios.Commit;
            Finally
               If TrQrVArios.Active Then TrQrVArios.Rollback;
               TrQrVArios.Active := False;
            End;
            if TrQrVArios.Active then
            TrQrVArios.RollBack;
            SentenciaSql:= 'INSERT INTO ACTAS_DISC (COD_ALU, CARRE, FECHA, CARPOR, OBSERV) '+
                           ' VALUES (:COD_ALU, :CARRE, :FECHA, :CARPOR, :OBSERV)';
            ibqrvarios.Sql.Text := SentenciaSql;
            trqrvarios.Active:=True;
            frmActasDisciplinarias.MtActasDisciplinarias.First;
            while not frmActasDisciplinarias.MtActasDisciplinarias.Eof do begin
                 for i:=0 to FrmActasDisciplinarias.MtActasDisciplinarias.FieldCount-1 do
                      ibqrvarios.ParamByName(FrmActasDisciplinarias.MtActasDisciplinarias.Fields.Fields[i].FullName).Value:=FrmActasDisciplinarias.MtActasDisciplinarias.Fields.Fields[i].Value;
                 ibqrvarios.ParamByName('COD_ALU').Value:=CODALU;
                 ibqrvarios.ParamByName('CARRE').Value:=Carrera;
                 Ibqrvarios.ExecQuery;
                 frmActasDisciplinarias.MtActasDisciplinarias.Next;
            end;
            TrqrVarios.Commit;
            TrQrVarios.Active:=False;
       end;
       AltaAlumno.Close;
     Except
       MessageBox(AltaAlumno.Handle,Pchar(VUsuario+', hubo un error al grabar la informacion.'),'Error',MB_OK+MB_ICONERROR+MB_APPLMODAL);
       if TrQrVArios.Active then
           TrQrVArios.Rollback;
       TrQrVArios.Active := False;
     End;
   End;
 End;
End;

