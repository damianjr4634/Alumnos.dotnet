procedure TAltaAlumno.BtnTutoresClick(Sender: TObject);
var x:integer;
begin
//  if not assigned(frmTutores) then begin
  if frmtutores=nil then begin
     FrmTutores:=TFrmTutores.Create(AltaAlumno);
     FrmTutores.Visible:=False;
     FrmTutores.Height:=247;
     with datamodule.customerdata do begin
        if (TrdsVArios.Active) then begin
            TrdsVarios.Rollback;
            TrdsVArios.Active:=False;
        end;
        ibdsvarios.SQLs.SelectSQL.Text := 'SELECT FDNI, FNOMBRE, FAPELLIDO, FDIRECC, FTELEFO, FCELULAR, FEMAIL, FPARENT, FRETIRA, FLOCALI, FCODPOS, FRESPON '+
                                          'FROM TUTORES '+
                                          'WHERE COD_ALU='+#39+tipodoc.text+documento.Text+#39+' AND CARRE='+#39+CARRERA+#39;
        TrdsVArios.Active:=True;
        ibdsvarios.Active:=True;
        ibdsvarios.First;
        while not ibdsvarios.Eof do begin
            FrmTutores.MtTutores.Append;
            for x:=0 to ibdsvarios.FieldCount-1 do
               FrmTutores.MtTutores.FieldByName(ibdsvarios.Fields.Fields[x].FullName).Value:=ibdsvarios.Fields.Fields[x].Value;
            FrmTutores.MtTutores.Post;
            ibdsvarios.Next;
        end;
        TrdsVArios.Commit;
        TrdsVArios.Active:=false;
        ibdsvarios.Active:=False;
        ibdsvarios.SQLs.SelectSQL.Clear;
      end;
  end;
  FrmTutores.ShowModal;
end;

