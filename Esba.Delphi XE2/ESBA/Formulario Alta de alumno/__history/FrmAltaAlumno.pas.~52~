procedure TAltaAlumno.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  if assigned(frmTutores) then begin
      FrmTutores.Close;
      FrmTutores.Free;
      FrmTutores:=Nil;
  end;
  if assigned(frmActasDisciplinarias) then begin
      FrmActasDisciplinarias.Close;
      FrmActasDisciplinarias.Free;
      FrmActasDisciplinarias:=Nil;
  end;
end;

