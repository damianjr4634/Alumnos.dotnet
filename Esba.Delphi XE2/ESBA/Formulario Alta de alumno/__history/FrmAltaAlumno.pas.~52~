procedure TAltaAlumno.FormActivate(Sender: TObject);
begin
  If Modificacion Then
    Begin
      with datamodule.customerdata do begin
        if (TrQrVArios.Active) then begin
            TrqrVarios.Rollback;
            TrQrVArios.Active:=False;
        end;
        ibqrvarios.SQL.Text:= 'SELECT OBSERV FROM ALUMNOS WHERE COD_ALU=:CODALU AND CARRE=:CARRE';
        ibqrvarios.parambyname('CODALU').value:= tipodoc.text+documento.Text;
        ibqrvarios.parambyname('CARRE').value:= CARRERA;
        TrQrVArios.Active:=True;
        ibqrvarios.ExecQuery;
        memo.lines.Text:=ibqrvarios.fieldbyname('OBSERV').AsString;
        TrQrVArios.Commit;
        TrQrVArios.Active:=false;
        ibqrvarios.SQL.Clear;
        ibqrvarios.SQL.Text:= 'SELECT SEXO, NACIONAL, EST_CIV, FEC_NAC, LUG_NAC, PCIA_NAC, DOMI, LOCALI, '+
                              '       COD_POS, CAR_TEL, TELE, MAIL, CELULAR, CAMBIO'+
                              ' FROM WEB_ALUMNOS '+
                              ' WHERE COD_ALU=:CODALU AND CARRE=:CARRE';
        ibqrvarios.parambyname('CODALU').value:= tipodoc.text+documento.Text;
        ibqrvarios.parambyname('CARRE').value:= CARRERA;
        TrQrVArios.Active:=True;
        ibqrvarios.ExecQuery;
        WNacionalidad.Text          := ibqrvarios.FieldByName('NACIONAL').AsString;
        If ibqrvarios.FieldByName('Est_Civ').AsString = 'S' Then
           WEstadoCivil.ItemIndex  := 0
        Else
         If ibqrvarios.FieldByName('Est_Civ').AsString = 'C' Then
            WEstadoCivil.ItemIndex  := 1
         Else
           If ibqrvarios.FieldByName('Est_Civ').AsString = 'V' Then
             WEstadoCivil.ItemIndex  := 3
           Else
              If ibqrvarios.FieldByName('Est_Civ').AsString = 'D' Then
                WEstadoCivil.ItemIndex  := 2
              Else
                WEstadoCivil.ItemIndex  := -1;
        If (ibqrvarios.FieldByname('Sexo').AsString='M') Then
          WCmbSexo.ItemIndex:=1
        else
          If (ibqrvarios.FieldByname('Sexo').AsString='F') Then
             WCmbSexo.ItemIndex:=0;
        if not ((ibqrvarios.FieldByName('CAMBIO').IsNull) or (ibqrvarios.FieldByName('CAMBIO').AsString='N')) then begin
           MessageDlg('El alumno modifico sus datos en la web',mtInformation,[mbok],0,mbok);
        end;
        WFechaNacimiento.Date       := ibqrvarios.FieldByName('Fec_Nac').AsDateTime;
        WLugarNacimiento.Text       := ibqrvarios.FieldByName('Lug_Nac').AsString;
        WProvinciaNacimiento.Text   := ibqrvarios.FieldByName('Pcia_Nac').AsString;
        WDomicilio.Text             := ibqrvarios.FieldByName('DOMI').AsString;
        WLocalidad.Text             := ibqrvarios.FieldByName('LOCALI').AsString;
        WCodigoPostal.Text          := IntToStr(ibqrvarios.FieldByName('COD_POS').AsInteger);
        WCaracteristica.Text        := ibqrvarios.FieldByName('Car_Tel').AsString;
        WTelefono.Text              := ibqrvarios.FieldByName('Tele').AsString;
        WMail.Text                  := ibqrvarios.FieldByName('Mail').AsString;
        Wcelular.text := ibqrvarios.FieldByName('CELULAR').AsString;
        TrQrVArios.Commit;
        TrQrVArios.Active:=false;
        ibqrvarios.SQL.Clear;
      end;
      DatosPersonales.Enabled := True;
      EstudiosCursados.Enabled := True;
      DatosLaborales.Enabled := True;
      DocuPresentada.Enabled := True;
      Grabar.Enabled := True;
      TipoDoc.Enabled := False;
      Documento.Enabled := False;
      FECHACTTChange(Sender);
      FechaAptoFisicoChange(sender);
      AptoFisicoClick(sender);
      If (ctt.Checked) And (Ca.Checked) Then
       Begin
        ca.Enabled := True;
        ctt.Enabled := true;
       End;
      Apellido.SetFocus;
    End
  Else
   Begin
     Tipodoc.SetFocus;
     FECHACTT.Date := DATE;
     FECHANACIMIENTO.DATE:=DATE;
     FechaIngreso.Date := Date;
     fechactt.Enabled :=ctt.Checked;
   End;
end;

